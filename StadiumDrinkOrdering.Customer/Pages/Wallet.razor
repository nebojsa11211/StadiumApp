@page "/wallet"
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Customer.Components
@inject IApiService ApiService
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["Wallet_PageTitle"]</PageTitle>

<AuthenticationGuard>
    <div class="container" id="customer-wallet-container">
        <h1 class="mb-4" id="customer-wallet-title">💳 @Localizer["Wallet_PageTitle"]</h1>

        @if (summary == null)
        {
            <div class="text-center" id="customer-wallet-loading">
                <div class="spinner-border" role="status"><span class="visually-hidden">@Localizer["Loading"]</span></div>
            </div>
        }
        else if (!summary.Exists && !summary.IsEligible)
        {
            <div class="text-center py-5" id="customer-wallet-not-eligible">
                <div class="mb-3"><span style="font-size: 4rem;">🎟️</span></div>
                <h3 id="customer-wallet-not-eligible-title">@Localizer["Wallet_NotEligibleTitle"]</h3>
                <p class="text-muted" id="customer-wallet-not-eligible-message">@Localizer["Wallet_NotEligibleMessage"]</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                <div class="col-lg-5">
                    <div class="card shadow-sm" id="customer-wallet-balance-card">
                        <div class="card-body text-center">
                            <div class="text-muted text-uppercase small" id="customer-wallet-balance-label">@Localizer["Wallet_Balance"]</div>
                            <div class="display-5 fw-bold text-primary my-2" id="customer-wallet-balance-amount">
                                @FormatMoney(summary.Balance)
                            </div>
                            @if (summary.Status == WalletStatus.Frozen)
                            {
                                <span class="badge bg-danger" id="customer-wallet-frozen-badge">@Localizer["Wallet_Frozen"]</span>
                            }
                        </div>
                    </div>

                    <div class="card shadow-sm mt-4" id="customer-wallet-deposit-card">
                        <div class="card-header" id="customer-wallet-deposit-header">@Localizer["Wallet_AddFunds"]</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label" for="customer-wallet-deposit-amount">@Localizer["Wallet_Amount"] (@summary.Currency)</label>
                                <input type="number" min="0.01" step="0.01" class="form-control"
                                       id="customer-wallet-deposit-amount" @bind="depositAmount" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="customer-wallet-deposit-method">@Localizer["Wallet_Method"]</label>
                                <select class="form-select" id="customer-wallet-deposit-method" @bind="depositMethod">
                                    <option value="CreditCard">Credit Card</option>
                                    <option value="PayPal">PayPal</option>
                                </select>
                            </div>
                            <button class="btn btn-primary w-100" id="customer-wallet-deposit-btn"
                                    @onclick="Deposit" disabled="@(isDepositing || depositAmount <= 0)">
                                @if (isDepositing)
                                {
                                    <span class="spinner-border spinner-border-sm" id="customer-wallet-deposit-spinner"></span>
                                }
                                @Localizer["Wallet_Deposit"]
                            </button>
                        </div>
                    </div>
                </div>

                <div class="col-lg-7">
                    <div class="card shadow-sm" id="customer-wallet-transactions-card">
                        <div class="card-header" id="customer-wallet-transactions-header">@Localizer["Wallet_Transactions"]</div>
                        <div class="card-body p-0">
                            @if (transactions == null || transactions.Transactions.Count == 0)
                            {
                                <p class="text-muted text-center py-4 m-0" id="customer-wallet-transactions-empty">
                                    @Localizer["Wallet_NoTransactions"]
                                </p>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm mb-0" id="customer-wallet-transactions-table">
                                        <thead>
                                            <tr>
                                                <th>@Localizer["Wallet_Date"]</th>
                                                <th>@Localizer["Wallet_Type"]</th>
                                                <th class="text-end">@Localizer["Wallet_Amount"]</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var t in transactions.Transactions)
                                            {
                                                <tr id="customer-wallet-txn-@t.Id">
                                                    <td id="customer-wallet-txn-date-@t.Id">@t.CreatedAt.ToLocalTime().ToString("MMM dd, HH:mm")</td>
                                                    <td id="customer-wallet-txn-type-@t.Id">@t.Type</td>
                                                    <td class="text-end fw-bold @(t.Amount < 0 ? "text-danger" : "text-success")" id="customer-wallet-txn-amount-@t.Id">
                                                        @(t.Amount < 0 ? "" : "+")@FormatMoney(t.Amount)
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(alertMessage))
        {
            <div class="position-fixed top-0 end-0 p-3" style="z-index: 1055;" id="customer-wallet-alert-container">
                <div class="alert @(alertType == "success" ? "alert-success" : alertType == "info" ? "alert-info" : "alert-danger") alert-dismissible fade show" id="customer-wallet-alert">
                    @alertMessage
                    <button type="button" class="btn-close" @onclick="() => alertMessage = string.Empty" id="customer-wallet-alert-close"></button>
                </div>
            </div>
        }
    </div>
</AuthenticationGuard>

@code {
    private WalletSummaryDto? summary;
    private WalletTransactionListDto? transactions;
    private decimal depositAmount = 20m;
    private string depositMethod = "CreditCard";
    private bool isDepositing;
    private string alertMessage = string.Empty;
    private string alertType = string.Empty;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        summary = await ApiService.GetWalletSummaryAsync();
        if (summary is { Exists: true })
        {
            transactions = await ApiService.GetWalletTransactionsAsync(1, 25);
        }
    }

    private async Task Deposit()
    {
        if (isDepositing || depositAmount <= 0) return;
        isDepositing = true;
        try
        {
            var dto = new InitiateDepositDto
            {
                Amount = depositAmount,
                Method = depositMethod,
                IdempotencyKey = Guid.NewGuid().ToString("N")
            };
            var result = await ApiService.DepositToWalletAsync(dto);
            if (result is { RequiresAction: true })
            {
                // Async gateway (Stripe): the browser must confirm the card with result.ClientSecret via
                // Stripe Elements before the webhook credits the wallet. Elements wiring is pending live keys;
                // the mock gateway (default) credits synchronously and hits the success branch below.
                ShowAlert(Localizer["Wallet_ConfirmationRequired"], "info");
            }
            else if (result is { Success: true })
            {
                ShowAlert(Localizer["Wallet_DepositSuccess"], "success");
                await Load();
            }
            else
            {
                ShowAlert(Localizer["Wallet_DepositFailed"], "danger");
            }
        }
        catch (Exception ex)
        {
            ShowAlert(ex.Message, "danger");
        }
        finally
        {
            isDepositing = false;
        }
    }

    private string FormatMoney(decimal amount)
    {
        var currency = summary?.Currency ?? "EUR";
        var symbol = currency == "EUR" ? "€" : currency + " ";
        return $"{symbol}{Math.Abs(amount).ToString("N2")}";
    }

    private void ShowAlert(string message, string type)
    {
        alertMessage = message;
        alertType = type;
        StateHasChanged();
        _ = Task.Delay(5000).ContinueWith(_ =>
        {
            alertMessage = string.Empty;
            InvokeAsync(StateHasChanged);
        });
    }
}
