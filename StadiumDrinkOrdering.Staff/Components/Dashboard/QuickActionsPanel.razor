@using StadiumDrinkOrdering.Staff.Models

<div class="card quick-actions-card" id="staff-quick-actions-card">
    <div class="card-header" id="staff-quick-actions-header">
        <h5 class="mb-0" id="staff-quick-actions-title">@Title</h5>
    </div>
    <div class="card-body" id="staff-quick-actions-body">
        @if (IsLoading)
        {
            <div class="d-grid gap-2" id="staff-quick-actions-loading-grid">
                @for (int i = 0; i < 3; i++)
                {
                    <div class="skeleton-button" id="staff-quick-actions-skeleton-@i"></div>
                }
            </div>
        }
        else if (Actions != null && Actions.Any())
        {
            <div class="d-grid gap-2" id="staff-quick-actions-grid">
                @foreach (var action in Actions)
                {
                    @if (!string.IsNullOrEmpty(action.Url))
                    {
                        <a href="@action.Url" class="btn @action.ButtonClass @(action.IsDisabled ? "disabled" : "")" id="staff-quick-actions-link-@action.Title.Replace(" ", "-").ToLower()">
                            @if (!string.IsNullOrEmpty(action.IconClass))
                            {
                                <span class="@action.IconClass me-2" id="staff-quick-actions-icon-@action.Title.Replace(" ", "-").ToLower()"></span>
                            }
                            @action.Title
                            @if (action.BadgeCount > 0)
                            {
                                <span class="badge bg-light text-dark ms-2" id="staff-quick-actions-badge-@action.Title.Replace(" ", "-").ToLower()">@action.BadgeCount</span>
                            }
                        </a>
                    }
                    else if (action.OnClick.HasDelegate)
                    {
                        <button class="btn @action.ButtonClass @(action.IsDisabled ? "disabled" : "")" id="staff-quick-actions-btn-@action.Title.Replace(" ", "-").ToLower()"
                                @onclick="action.OnClick"
                                disabled="@action.IsDisabled">
                            @if (!string.IsNullOrEmpty(action.IconClass))
                            {
                                <span class="@action.IconClass me-2" id="staff-quick-actions-btn-icon-@action.Title.Replace(" ", "-").ToLower()"></span>
                            }
                            @action.Title
                            @if (action.BadgeCount > 0)
                            {
                                <span class="badge bg-light text-dark ms-2" id="staff-quick-actions-btn-badge-@action.Title.Replace(" ", "-").ToLower()">@action.BadgeCount</span>
                            }
                        </button>
                    }

                    @if (!string.IsNullOrEmpty(action.Description))
                    {
                        <small class="text-muted mt-1 d-block" id="staff-quick-actions-desc-@action.Title.Replace(" ", "-").ToLower()">@action.Description</small>
                    }
                }
            </div>
        }
        else
        {
            <div class="empty-state text-center text-muted py-3" id="staff-quick-actions-empty">
                <span class="oi oi-warning" id="staff-quick-actions-empty-icon" style="font-size: 2rem;"></span>
                <p class="mt-2 mb-0" id="staff-quick-actions-empty-text">No actions available</p>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Quick Actions";
    [Parameter] public IEnumerable<QuickAction>? Actions { get; set; }
    [Parameter] public bool IsLoading { get; set; }
}