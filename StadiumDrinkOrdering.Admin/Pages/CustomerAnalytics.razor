@page "/customer-analytics"
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Admin.Services
@attribute [Authorize(Roles = "Admin")]

@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["CustAnalytics_PageTitle"]</PageTitle>

<div class="console" id="admin-customer-analytics-main-container">
    <!-- Page Header -->
    <PageHeader Id="admin-customer-analytics-header"
                Eyebrow='@L["CustAnalytics_Eyebrow"]'
                Title='@L["CustAnalytics_Title"]'
                Subtitle='@L["CustAnalytics_Subtitle"]'>
        <Actions>
            <button class="pill-btn pill-btn--success" @onclick="ExportData" disabled="@(isLoading || customers?.Any() != true)" id="admin-customer-analytics-export-btn">
                <i class="bi bi-download"></i><span>@L["CustAnalytics_ExportCSV"]</span>
            </button>
        </Actions>
    </PageHeader>

    @if (isLoading && customers?.Any() != true)
    {
        <div class="loading-state" id="admin-customer-analytics-loading">
            <span class="loading-spinner"></span>
            <p>@L["CustAnalytics_Loading"]</p>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="console-alert console-alert--danger" role="alert" id="admin-customer-analytics-error-alert">
            <i class="bi bi-exclamation-triangle"></i>
            <span>@errorMessage</span>
            <button type="button" class="pill-btn pill-btn--danger" @onclick="LoadCustomerAnalytics" id="admin-customer-analytics-retry-btn">
                <i class="bi bi-arrow-clockwise"></i><span>@L["CustAnalytics_Retry"]</span>
            </button>
        </div>
    }
    else
    {
        <!-- Summary Cards -->
        @if (summary != null)
        {
            <section class="metrics" id="admin-customer-analytics-metrics">
                <article class="metric" id="admin-customer-analytics-metric-total">
                    <div class="metric__head">
                        <span class="metric__label">@L["CustAnalytics_TotalCustomers"]</span>
                        <i class="bi bi-people metric__icon"></i>
                    </div>
                    <div class="metric__value mono">@summary.TotalCustomers</div>
                    <div class="metric__foot">
                        <span class="metric__hint">@L["CustAnalytics_AllTimeRegistered"]</span>
                    </div>
                </article>

                <article class="metric metric--accent" id="admin-customer-analytics-metric-revenue">
                    <div class="metric__head">
                        <span class="metric__label">@L["CustAnalytics_TotalRevenue"]</span>
                        <i class="bi bi-currency-euro metric__icon"></i>
                    </div>
                    <div class="metric__value mono"><span class="metric__unit">€</span>@summary.TotalRevenue.ToString("N0")</div>
                    <div class="metric__foot">
                        <span class="metric__hint">@L["CustAnalytics_TicketsDrinksCombined"]</span>
                    </div>
                </article>

                <article class="metric" id="admin-customer-analytics-metric-avg">
                    <div class="metric__head">
                        <span class="metric__label">@L["CustAnalytics_AvgCustomerValue"]</span>
                        <i class="bi bi-graph-up metric__icon"></i>
                    </div>
                    <div class="metric__value mono"><span class="metric__unit">€</span>@summary.AverageCustomerValue.ToString("N0")</div>
                    <div class="metric__foot">
                        <span class="metric__hint">@L["CustAnalytics_RevenuePerCustomer"]</span>
                    </div>
                </article>

                <article class="metric" id="admin-customer-analytics-metric-active">
                    <div class="metric__head">
                        <span class="metric__label">@L["CustAnalytics_ActiveLast30"]</span>
                        <i class="bi bi-fire metric__icon"></i>
                    </div>
                    <div class="metric__value mono">@summary.ActiveCustomersLast30Days</div>
                    <div class="metric__foot">
                        <span class="metric__hint">@L["CustAnalytics_RecentlyEngaged"]</span>
                    </div>
                </article>
            </section>
        }

        <!-- Filters and Search -->
        <div class="panel filters-panel" id="admin-customer-analytics-filters-panel">
            <div class="panel__head" id="admin-customer-analytics-filters-panel-head">
                <h2 class="panel__title" id="admin-customer-analytics-filters-title"><i class="bi bi-funnel"></i> @L["CustAnalytics_FiltersSearch"]</h2>
                <button class="icon-btn" type="button" data-bs-toggle="collapse" data-bs-target="#filtersCollapse" id="admin-customer-analytics-filters-toggle-btn" title="@L["CustAnalytics_ToggleFilters"]">
                    <i class="bi bi-chevron-down"></i>
                </button>
            </div>
            <div class="collapse show" id="filtersCollapse">
                <div class="filters" id="admin-customer-analytics-filters-container">
                    <div class="field field--grow" id="admin-customer-analytics-filter-search-field">
                        <label class="field__label">@L["CustAnalytics_SearchCustomer"]</label>
                        <input type="text" class="field__input" id="admin-customer-analytics-filter-search-input" placeholder="@L["CustAnalytics_SearchPlaceholder"]"
                               @bind="currentFilter.SearchTerm" @onkeypress="OnSearchKeyPress" />
                    </div>
                    <div class="field" id="admin-customer-analytics-filter-min-spent-field">
                        <label class="field__label">@L["CustAnalytics_MinSpent"]</label>
                        <input type="number" class="field__input" id="admin-customer-analytics-filter-min-spent-input" placeholder="0" @bind="currentFilter.MinSpent" />
                    </div>
                    <div class="field" id="admin-customer-analytics-filter-max-spent-field">
                        <label class="field__label">@L["CustAnalytics_MaxSpent"]</label>
                        <input type="number" class="field__input" id="admin-customer-analytics-filter-max-spent-input" placeholder="10000" @bind="currentFilter.MaxSpent" />
                    </div>
                    <div class="field" id="admin-customer-analytics-filter-sort-by-field">
                        <label class="field__label">@L["CustAnalytics_SortBy"]</label>
                        <select class="field__input" id="admin-customer-analytics-filter-sort-by-select" @bind="currentFilter.SortBy">
                            <option value="@CustomerSortBy.TotalSpent">@L["CustAnalytics_Sort_TotalSpent"]</option>
                            <option value="@CustomerSortBy.CustomerName">@L["CustAnalytics_Sort_CustomerName"]</option>
                            <option value="@CustomerSortBy.TicketsPurchased">@L["CustAnalytics_Sort_TicketsPurchased"]</option>
                            <option value="@CustomerSortBy.LastPurchaseDate">@L["CustAnalytics_Sort_LastPurchase"]</option>
                        </select>
                    </div>
                    <div class="field" id="admin-customer-analytics-filter-order-field">
                        <label class="field__label">@L["CustAnalytics_Order"]</label>
                        <select class="field__input" id="admin-customer-analytics-filter-order-select" @bind="currentFilter.SortDescending">
                            <option value="true">@L["CustAnalytics_Descending"]</option>
                            <option value="false">@L["CustAnalytics_Ascending"]</option>
                        </select>
                    </div>
                </div>
                <div class="table-foot" id="admin-customer-analytics-filters-footer">
                    <span class="metric__hint">@L["CustAnalytics_RefineList"]</span>
                    <div class="bulk-actions" id="admin-customer-analytics-filters-actions">
                        <button class="pill-btn pill-btn--primary" @onclick="ApplyFilters" disabled="@isLoading" id="admin-customer-analytics-apply-filters-btn">
                            <i class="bi bi-search"></i><span>@L["CustAnalytics_ApplyFilters"]</span>
                        </button>
                        <button class="pill-btn" @onclick="ClearFilters" disabled="@isLoading" id="admin-customer-analytics-clear-filters-btn">
                            <i class="bi bi-x-lg"></i><span>@L["CustAnalytics_Clear"]</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Customer List -->
        <div class="panel" id="admin-customer-analytics-list-panel">
            <div class="panel__head" id="admin-customer-analytics-list-panel-head">
                <h2 class="panel__title" id="admin-customer-analytics-list-title">
                    @L["CustAnalytics_CustomerList"]
                    @if (pagedResult != null)
                    {
                        <span class="panel__count mono">@pagedResult.TotalCount @L["CustAnalytics_Total"]</span>
                    }
                </h2>
                <div class="field" id="admin-customer-analytics-pagesize-selector" style="flex-direction: row; align-items: center; gap: 0.5rem; min-width: auto;">
                    <label class="field__label" style="margin: 0;">@L["CustAnalytics_Show"]</label>
                    <select class="field__input" id="admin-customer-analytics-pagesize-select" style="width: auto; height: 32px;" @onchange="OnPageSizeChanged">
                        <option value="10">10</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>
            </div>

            @if (customers?.Any() == true)
            {
                <table class="console-table" id="admin-customer-analytics-table">
                    <thead id="admin-customer-analytics-table-head">
                        <tr id="admin-customer-analytics-table-header-row">
                            <th class="sortable @(sortState.IsSorted("customer") ? "is-sorted" : "")" @onclick='() => SortBy("customer")' id="admin-customer-analytics-table-header-customer">@L["CustAnalytics_HeaderCustomer"]<span class="sort-ind">@sortState.Indicator("customer")</span></th>
                            <th class="num sortable @(sortState.IsSorted("spent") ? "is-sorted" : "")" @onclick='() => SortBy("spent")' id="admin-customer-analytics-table-header-spent">@L["CustAnalytics_HeaderTotalSpent"]<span class="sort-ind">@sortState.Indicator("spent")</span></th>
                            <th class="num sortable @(sortState.IsSorted("tickets") ? "is-sorted" : "")" @onclick='() => SortBy("tickets")' id="admin-customer-analytics-table-header-tickets">@L["CustAnalytics_HeaderTickets"]<span class="sort-ind">@sortState.Indicator("tickets")</span></th>
                            <th class="num sortable @(sortState.IsSorted("events") ? "is-sorted" : "")" @onclick='() => SortBy("events")' id="admin-customer-analytics-table-header-events">@L["CustAnalytics_HeaderEvents"]<span class="sort-ind">@sortState.Indicator("events")</span></th>
                            <th class="num sortable @(sortState.IsSorted("avg") ? "is-sorted" : "")" @onclick='() => SortBy("avg")' id="admin-customer-analytics-table-header-avg">@L["CustAnalytics_HeaderAvgTransaction"]<span class="sort-ind">@sortState.Indicator("avg")</span></th>
                            <th class="sortable @(sortState.IsSorted("lastpurchase") ? "is-sorted" : "")" @onclick='() => SortBy("lastpurchase")' id="admin-customer-analytics-table-header-lastpurchase">@L["CustAnalytics_HeaderLastPurchase"]<span class="sort-ind">@sortState.Indicator("lastpurchase")</span></th>
                            <th class="actions-col" id="admin-customer-analytics-table-header-actions">@L["CustAnalytics_HeaderActions"]</th>
                        </tr>
                    </thead>
                    <tbody id="admin-customer-analytics-table-body">
                        @foreach (var customer in customers)
                        {
                            <tr id="@($"admin-customer-analytics-customer-row-{customer.CustomerEmail.Replace("@", "_").Replace(".", "_")}")">
                                <td>
                                    <div class="console-table__id">@customer.CustomerName</div>
                                    <div class="console-table__muted">@customer.CustomerEmail</div>
                                    @if (!string.IsNullOrEmpty(customer.CustomerPhone))
                                    {
                                        <div class="console-table__muted">@customer.CustomerPhone</div>
                                    }
                                </td>
                                <td class="num">
                                    <div class="mono" style="font-weight: 600; color: var(--pitch-dark);">€@customer.TotalSpent.ToString("N2")</div>
                                    <div class="console-table__muted">
                                        Tickets: €@customer.TicketSpending.ToString("N0") |
                                        Drinks: €@customer.DrinkSpending.ToString("N0")
                                    </div>
                                </td>
                                <td class="num mono">@customer.TotalTicketsPurchased</td>
                                <td class="num mono">@customer.TotalEventsAttended</td>
                                <td class="num mono">€@customer.AverageSpendPerTransaction.ToString("N2")</td>
                                <td class="console-table__time">@customer.LastPurchaseDate.ToString("MMM dd, yyyy")</td>
                                <td class="actions-col">
                                    <div class="row-actions">
                                        <button class="row-btn" title="@L["CustAnalytics_ViewDetails"]" @onclick="() => ViewCustomerDetails(customer.CustomerEmail)" id="admin-customer-analytics-view-details-btn-@customer.CustomerEmail.Replace("@", "_").Replace(".", "_")">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <!-- Pagination -->
                @if (pagedResult != null && pagedResult.TotalPages > 1)
                {
                    <div class="table-foot" id="admin-customer-analytics-pagination-footer">
                        <p id="admin-customer-analytics-pagination-info">
                            @L["CustAnalytics_ShowingResults", (pagedResult.Page - 1) * pagedResult.PageSize + 1, Math.Min(pagedResult.Page * pagedResult.PageSize, pagedResult.TotalCount), pagedResult.TotalCount]
                        </p>
                        <div class="bulk-actions" id="admin-customer-analytics-pagination-buttons">
                            <button class="icon-btn" @onclick="() => GoToPage(pagedResult.Page - 1)" disabled="@(pagedResult.Page == 1 || isLoading)" id="admin-customer-analytics-prev-page-btn" title="@L["CustAnalytics_PreviousPage"]">
                                <i class="bi bi-chevron-left"></i>
                            </button>

                            @for (int i = Math.Max(1, pagedResult.Page - 2); i <= Math.Min(pagedResult.TotalPages, pagedResult.Page + 2); i++)
                            {
                                <button class="pill-btn @(i == pagedResult.Page ? "pill-btn--primary" : "")" @onclick="() => GoToPage(i)" disabled="@isLoading" id="admin-customer-analytics-page-@i-btn">@i</button>
                            }

                            <button class="icon-btn" @onclick="() => GoToPage(pagedResult.Page + 1)" disabled="@(pagedResult.Page == pagedResult.TotalPages || isLoading)" id="admin-customer-analytics-next-page-btn" title="@L["CustAnalytics_NextPage"]">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty" id="admin-customer-analytics-empty-state">
                    <i class="bi bi-people"></i>
                    <p id="admin-customer-analytics-empty-title">@L["CustAnalytics_NoCustomersFound"]</p>
                    <span id="admin-customer-analytics-empty-subtitle">@L["CustAnalytics_AdjustFilters"]</span>
                    <div style="margin-top: 1rem;" id="admin-customer-analytics-empty-actions">
                        <button class="pill-btn" @onclick="ClearFilters" id="admin-customer-analytics-clear-filters-empty-btn">
                            <i class="bi bi-x-lg"></i><span>@L["CustAnalytics_ClearFilters"]</span>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Customer Detail Modal -->
@if (detailEmail != null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" style="background-color: rgba(0,0,0,0.5);" id="admin-customer-analytics-detail-modal">
        <div class="modal-dialog modal-xl modal-dialog-scrollable" id="admin-customer-analytics-detail-dialog">
            <div class="modal-content" id="admin-customer-analytics-detail-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="admin-customer-analytics-detail-title">
                        @(detail?.CustomerName is { Length: > 0 } n ? n : detailEmail)
                        <span class="text-muted small ms-2">@detailEmail</span>
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseCustomerDetails" id="admin-customer-analytics-detail-close-btn"></button>
                </div>

                <div class="modal-body" id="admin-customer-analytics-detail-body">
                    @if (isDetailLoading)
                    {
                        <div class="loading-state" id="admin-customer-analytics-detail-loading">
                            <span class="loading-spinner"></span>
                            <p>@L["CustAnalytics_Loading"]</p>
                        </div>
                    }
                    else if (detailError != null)
                    {
                        <div class="console-alert console-alert--danger" role="alert" id="admin-customer-analytics-detail-error">
                            <i class="bi bi-exclamation-triangle"></i>
                            <span>@detailError</span>
                        </div>
                    }
                    else if (detail != null)
                    {
                        <!-- Spending Summary -->
                        <section class="metrics" id="admin-customer-analytics-detail-metrics">
                            <article class="metric" id="admin-customer-analytics-detail-metric-total">
                                <div class="metric__head"><span class="metric__label">@L["CustAnalytics_DetailTotalSpent"]</span></div>
                                <div class="metric__value mono">€@detail.Summary.TotalSpent.ToString("N2")</div>
                                <div class="metric__foot">
                                    <span class="metric__hint">
                                        @L["CustAnalytics_DetailTickets"]: €@detail.Summary.TicketSpending.ToString("N2") |
                                        @L["CustAnalytics_DetailDrinks"]: €@detail.Summary.DrinkSpending.ToString("N2")
                                    </span>
                                </div>
                            </article>

                            <article class="metric" id="admin-customer-analytics-detail-metric-tickets">
                                <div class="metric__head"><span class="metric__label">@L["CustAnalytics_DetailTickets"]</span></div>
                                <div class="metric__value mono">@detail.Summary.TotalTickets</div>
                                <div class="metric__foot">
                                    <span class="metric__hint">@L["CustAnalytics_DetailAvgTicket"]: €@detail.Summary.AverageTicketPrice.ToString("N2")</span>
                                </div>
                            </article>

                            <article class="metric" id="admin-customer-analytics-detail-metric-orders">
                                <div class="metric__head"><span class="metric__label">@L["CustAnalytics_DetailDrinkOrders"]</span></div>
                                <div class="metric__value mono">@detail.Summary.TotalDrinkOrders</div>
                                <div class="metric__foot">
                                    <span class="metric__hint">@L["CustAnalytics_DetailAvgOrder"]: €@detail.Summary.AverageDrinkOrderValue.ToString("N2")</span>
                                </div>
                            </article>

                            <article class="metric" id="admin-customer-analytics-detail-metric-events">
                                <div class="metric__head"><span class="metric__label">@L["CustAnalytics_DetailEvents"]</span></div>
                                <div class="metric__value mono">@detail.Summary.TotalEvents</div>
                                <div class="metric__foot">
                                    <span class="metric__hint">
                                        @detail.Summary.FirstPurchase.ToLocalTime().ToString("MMM dd, yyyy") &ndash;
                                        @detail.Summary.LastPurchase.ToLocalTime().ToString("MMM dd, yyyy")
                                    </span>
                                </div>
                            </article>
                        </section>

                        <!-- Ticket Purchases -->
                        <h6 class="mt-4" id="admin-customer-analytics-detail-tickets-heading">@L["CustAnalytics_DetailTicketPurchases"]</h6>
                        @if (detail.TicketPurchases.Any())
                        {
                            <div class="table-wrap">
                                <table class="console-table" id="admin-customer-analytics-detail-tickets-table">
                                    <thead>
                                        <tr>
                                            <th>@L["CustAnalytics_DetailDate"]</th>
                                            <th>@L["CustAnalytics_DetailEvent"]</th>
                                            <th>@L["CustAnalytics_DetailSeat"]</th>
                                            <th class="num">@L["CustAnalytics_DetailPrice"]</th>
                                            <th>@L["CustAnalytics_DetailStatus"]</th>
                                        </tr>
                                    </thead>
                                    <tbody id="admin-customer-analytics-detail-tickets-tbody">
                                        @foreach (var p in detail.TicketPurchases.OrderByDescending(x => x.PurchaseDate))
                                        {
                                            <tr id="admin-customer-analytics-detail-ticket-row-@p.TicketNumber">
                                                <td class="console-table__time">@p.PurchaseDate.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                                                <td>
                                                    <div>@p.EventName</div>
                                                    <div class="text-muted small">@p.EventDate.ToLocalTime().ToString("MMM dd, yyyy")</div>
                                                </td>
                                                <td class="mono">@p.SectionName @p.SeatCode</td>
                                                <td class="num mono">€@p.Price.ToString("N2")</td>
                                                <td>@p.Status</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted" id="admin-customer-analytics-detail-no-tickets">@L["CustAnalytics_DetailNoTickets"]</p>
                        }

                        <!-- Drink Orders -->
                        <h6 class="mt-4" id="admin-customer-analytics-detail-orders-heading">@L["CustAnalytics_DetailDrinkOrders"]</h6>
                        @if (detail.DrinkOrders.Any())
                        {
                            <div class="table-wrap">
                                <table class="console-table" id="admin-customer-analytics-detail-orders-table">
                                    <thead>
                                        <tr>
                                            <th>@L["CustAnalytics_DetailDate"]</th>
                                            <th>@L["CustAnalytics_DetailSeat"]</th>
                                            <th>@L["CustAnalytics_DetailItems"]</th>
                                            <th class="num">@L["CustAnalytics_DetailTotal"]</th>
                                            <th>@L["CustAnalytics_DetailStatus"]</th>
                                        </tr>
                                    </thead>
                                    <tbody id="admin-customer-analytics-detail-orders-tbody">
                                        @foreach (var o in detail.DrinkOrders.OrderByDescending(x => x.OrderDate))
                                        {
                                            <tr>
                                                <td class="console-table__time">@o.OrderDate.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                                                <td class="mono">@o.SeatNumber</td>
                                                <td>
                                                    @foreach (var item in o.Items)
                                                    {
                                                        <div class="text-muted small">
                                                            @item.Quantity &times; @item.DrinkName &mdash; €@item.TotalPrice.ToString("N2")
                                                        </div>
                                                    }
                                                </td>
                                                <td class="num mono">€@o.TotalAmount.ToString("N2")</td>
                                                <td>@o.Status</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted" id="admin-customer-analytics-detail-no-orders">@L["CustAnalytics_DetailNoOrders"]</p>
                        }
                    }
                </div>

                <div class="modal-footer">
                    <button type="button" class="pill-btn" @onclick="CloseCustomerDetails" id="admin-customer-analytics-detail-footer-close-btn">
                        <i class="bi bi-x-lg"></i><span>@L["CustAnalytics_DetailClose"]</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
}
