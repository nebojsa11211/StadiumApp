@page "/admin/email-templates"
@using System.Net.Http
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Shared.Authentication.Interfaces
@inject IHttpClientFactory HttpClientFactory
@inject ITokenStorageService TokenStorage
@inject ILogger<EmailTemplates> Logger
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["EmailTemplates_PageTitle"]</PageTitle>

<div id="admin-email-templates-main-container" class="container-fluid">
    <PageHeader Id="admin-email-templates-header"
                Eyebrow='@L["EmailTemplates_Eyebrow"]'
                Title='@L["EmailTemplates_Heading"]'
                Subtitle='@L["EmailTemplates_Subtitle"]' />

    <a id="admin-email-templates-back-link" class="btn btn-link ps-0 mb-2" href="/admin/settings">
        <i class="bi bi-arrow-left me-1"></i>@L["EmailTemplates_BackToSettings"]
    </a>

    @if (!string.IsNullOrEmpty(alertMessage))
    {
        <div id="admin-email-templates-alert" class="alert @alertClass alert-dismissible d-flex justify-content-between align-items-center" role="alert">
            <span id="admin-email-templates-alert-text">@alertMessage</span>
            <button type="button" id="admin-email-templates-alert-close" class="btn-close" @onclick="() => alertMessage = null"></button>
        </div>
    }

    @if (isLoading)
    {
        <div id="admin-email-templates-loading" class="d-flex align-items-center text-muted">
            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
            <span>@L["EmailTemplates_Loading"]</span>
        </div>
    }
    else if (loadError || templates is null)
    {
        <div id="admin-email-templates-error" class="alert alert-danger d-flex justify-content-between align-items-center" role="alert">
            <span>@L["EmailTemplates_Error"]</span>
            <button id="admin-email-templates-retry-btn" class="btn btn-sm btn-outline-danger" @onclick="LoadAsync">@L["EmailTemplates_Retry"]</button>
        </div>
    }
    else if (templates.Count == 0)
    {
        <div id="admin-email-templates-empty" class="alert alert-info">@L["EmailTemplates_Empty"]</div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-4" id="admin-email-templates-list-col">
                <div class="list-group" id="admin-email-templates-list">
                    @for (var i = 0; i < templates.Count; i++)
                    {
                        var index = i;
                        var t = templates[index];
                        <button type="button"
                                id="@($"admin-email-template-item-{t.Key}")"
                                class="list-group-item list-group-item-action @(index == selectedIndex ? "active" : "")"
                                @onclick="() => Select(index)">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-semibold">@t.Name</span>
                                @if (t.IsCustomized)
                                {
                                    <span class="badge bg-info" id="@($"admin-email-template-badge-{t.Key}")">@L["EmailTemplates_Customized"]</span>
                                }
                            </div>
                            <div class="small @(index == selectedIndex ? "" : "text-muted")">@t.Description</div>
                        </button>
                    }
                </div>
            </div>

            <div class="col-lg-8" id="admin-email-templates-editor-col">
                @if (Selected is not null)
                {
                    <div class="card" id="admin-email-template-editor-card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0" id="admin-email-template-editor-title">@Selected.Name</h5>
                            @if (Selected.UpdatedAt is not null)
                            {
                                <span class="small text-muted" id="admin-email-template-updated">
                                    @L["EmailTemplates_UpdatedAt"] @Selected.UpdatedAt?.ToLocalTime().ToString("g")
                                    @(string.IsNullOrEmpty(Selected.UpdatedBy) ? "" : $" · {Selected.UpdatedBy}")
                                </span>
                            }
                        </div>
                        <div class="card-body">
                            <div class="mb-3" id="admin-email-template-placeholders">
                                <label class="form-label mb-1">@L["EmailTemplates_Placeholders"]</label>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var p in Selected.Placeholders)
                                    {
                                        <span class="font-monospace border rounded px-2 py-1"
                                              style="background-color:#eef1f5;color:#334155;font-size:.8125rem;line-height:1.2;">@($"{{{{{p}}}}}")</span>
                                    }
                                </div>
                                <div class="form-text">@L["EmailTemplates_PlaceholdersHint"]</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="admin-email-template-subject-input">@L["EmailTemplates_Subject"]</label>
                                <input type="text" class="form-control" id="admin-email-template-subject-input"
                                       @bind="Selected.Subject" maxlength="300" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="admin-email-template-html-input">@L["EmailTemplates_HtmlBody"]</label>
                                <textarea class="form-control font-monospace" id="admin-email-template-html-input"
                                          rows="10" @bind="Selected.HtmlBody"></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="admin-email-template-text-input">@L["EmailTemplates_TextBody"]</label>
                                <textarea class="form-control font-monospace" id="admin-email-template-text-input"
                                          rows="5" @bind="Selected.TextBody"></textarea>
                                <div class="form-text">@L["EmailTemplates_TextBodyHint"]</div>
                            </div>

                            <div class="d-flex flex-wrap gap-2">
                                <button type="button" id="admin-email-template-save-btn" class="btn btn-primary"
                                        @onclick="SaveAsync" disabled="@isBusy">
                                    @if (isSaving)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    }
                                    @L["EmailTemplates_Save"]
                                </button>
                                <button type="button" id="admin-email-template-preview-btn" class="btn btn-outline-secondary"
                                        @onclick="PreviewAsync" disabled="@isBusy">
                                    <i class="bi bi-eye me-1"></i>@L["EmailTemplates_Preview"]
                                </button>
                                <button type="button" id="admin-email-template-reset-btn" class="btn btn-outline-danger ms-auto"
                                        @onclick="ResetAsync" disabled="@(isBusy || !Selected.IsCustomized)">
                                    @if (isResetting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    }
                                    <i class="bi bi-arrow-counterclockwise me-1"></i>@L["EmailTemplates_Reset"]
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@if (preview is not null)
{
    <div class="modal fade show d-block" id="admin-email-template-preview-modal" tabindex="-1"
         style="background-color: rgba(0,0,0,0.5);" role="dialog">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable" role="document">
            <div class="modal-content" id="admin-email-template-preview-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="admin-email-template-preview-title">@L["EmailTemplates_PreviewTitle"]</h5>
                    <button type="button" id="admin-email-template-preview-close" class="btn-close"
                            @onclick="() => preview = null"></button>
                </div>
                <div class="modal-body" id="admin-email-template-preview-body">
                    <div class="mb-2"><strong>@L["EmailTemplates_Subject"]:</strong> @preview.Subject</div>
                    <div class="border rounded p-3 mb-3 bg-white text-dark" id="admin-email-template-preview-html">
                        @((MarkupString)preview.HtmlBody)
                    </div>
                    @if (!string.IsNullOrWhiteSpace(preview.TextBody))
                    {
                        <label class="form-label">@L["EmailTemplates_TextBody"]</label>
                        <pre class="border rounded p-2 small mb-0" id="admin-email-template-preview-text">@preview.TextBody</pre>
                    }
                    <div class="form-text mt-2">@L["EmailTemplates_PreviewSampleHint"]</div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="admin-email-template-preview-ok" class="btn btn-secondary"
                            @onclick="() => preview = null">@L["EmailTemplates_Close"]</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool loadError;
    private bool isSaving;
    private bool isResetting;
    private bool isBusy => isSaving || isResetting;

    private List<EmailTemplateDto>? templates;
    private int selectedIndex;
    private EmailTemplateDto? Selected =>
        templates is not null && selectedIndex >= 0 && selectedIndex < templates.Count ? templates[selectedIndex] : null;

    private EmailTemplatePreviewResultDto? preview;

    private string? alertMessage;
    private string alertClass = "alert-success";

    // Same reason as the Settings page: attach the circuit-scoped token ourselves because the shared
    // AuthenticationHandler runs in a different DI scope with an empty token store.
    private HttpClient Api
    {
        get
        {
            var client = HttpClientFactory.CreateClient("AuthenticatedClient");
            var token = TokenStorage.Token;
            if (!string.IsNullOrEmpty(token))
                client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            return client;
        }
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();
        try
        {
            templates = await Api.GetFromJsonAsync<List<EmailTemplateDto>>("api/email-templates");
            if (selectedIndex >= (templates?.Count ?? 0)) selectedIndex = 0;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load email templates");
            loadError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void Select(int index)
    {
        selectedIndex = index;
        preview = null;
    }

    private async Task SaveAsync()
    {
        if (Selected is null) return;
        isSaving = true;
        try
        {
            var body = new UpdateEmailTemplateDto
            {
                Subject = Selected.Subject,
                HtmlBody = Selected.HtmlBody,
                TextBody = Selected.TextBody
            };
            var resp = await Api.PutAsJsonAsync($"api/email-templates/{Selected.Key}", body);
            if (resp.IsSuccessStatusCode)
            {
                var updated = await resp.Content.ReadFromJsonAsync<EmailTemplateDto>();
                if (updated is not null && templates is not null)
                    templates[selectedIndex] = updated;
                ShowAlert(L["EmailTemplates_Saved"], true);
            }
            else
            {
                ShowAlert(L["EmailTemplates_SaveFailed"], false);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save email template");
            ShowAlert(L["EmailTemplates_SaveFailed"], false);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ResetAsync()
    {
        if (Selected is null) return;
        isResetting = true;
        try
        {
            var resp = await Api.PostAsync($"api/email-templates/{Selected.Key}/reset", content: null);
            if (resp.IsSuccessStatusCode)
            {
                var reset = await resp.Content.ReadFromJsonAsync<EmailTemplateDto>();
                if (reset is not null && templates is not null)
                    templates[selectedIndex] = reset;
                ShowAlert(L["EmailTemplates_ResetDone"], true);
            }
            else
            {
                ShowAlert(L["EmailTemplates_ResetFailed"], false);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to reset email template");
            ShowAlert(L["EmailTemplates_ResetFailed"], false);
        }
        finally
        {
            isResetting = false;
        }
    }

    private async Task PreviewAsync()
    {
        if (Selected is null) return;
        try
        {
            var body = new UpdateEmailTemplateDto
            {
                Subject = Selected.Subject,
                HtmlBody = Selected.HtmlBody,
                TextBody = Selected.TextBody
            };
            var resp = await Api.PostAsJsonAsync($"api/email-templates/{Selected.Key}/preview", body);
            if (resp.IsSuccessStatusCode)
                preview = await resp.Content.ReadFromJsonAsync<EmailTemplatePreviewResultDto>();
            else
                ShowAlert(L["EmailTemplates_PreviewFailed"], false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to preview email template");
            ShowAlert(L["EmailTemplates_PreviewFailed"], false);
        }
    }

    private void ShowAlert(string message, bool success)
    {
        alertMessage = message;
        alertClass = success ? "alert-success" : "alert-danger";
    }
}
