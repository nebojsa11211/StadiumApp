@page "/"
@layout DashboardLayout
@using StadiumDrinkOrdering.Admin.Components.Stadium
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Shared.Models

@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Index_PageTitle"]</PageTitle>

@* The sidebar + dash-main shell is provided by DashboardLayout. *@

        @* ---------- EVENT SELECTOR (scopes the whole dashboard) ---------- *@
        @if (_loading)
        {
            <div class="dash-event-bar dash-event-bar--loading" id="admin-dashboard-event-bar">
                <i class="bi bi-arrow-repeat dash-spin"></i>
                <span>@L["Index_LoadingEvents"]</span>
            </div>
        }
        else if (_selectedEvent != null)
        {
            <div class="dash-event-bar" id="admin-dashboard-event-bar">
                <button class="dash-event-nav" @onclick="SelectPrevEvent" disabled="@(!CanGoPrev)" id="admin-dashboard-event-prev-btn" title="@L["Index_PreviousEvent"]">
                    <i class="bi bi-chevron-left"></i>
                </button>

                <div class="dash-event-info">
                    <div class="dash-event-meta">
                        <span class="dash-event-pos">@L["Index_EventPosition", SelectedIndex + 1, _events.Count]</span>
                        <span class="dash-event-phase phase-@GetPhaseModifier(_selectedEvent.Phase)">
                            <i class="dot"></i>@_selectedEvent.StatusName
                        </span>
                    </div>
                    <div class="dash-event-name-row">
                        <i class="bi bi-calendar-event"></i>
                        <h2 class="dash-event-name" id="admin-dashboard-event-name">@_selectedEvent.Name</h2>
                        @if (_selectedEvent.Date.HasValue)
                        {
                            <span class="dash-event-date">@_selectedEvent.Date.Value.ToString("ddd, dd. MMM yyyy. · HH:mm")</span>
                        }
                    </div>
                </div>

                <div class="dash-event-controls">
                    @if (!IsOnDefaultEvent)
                    {
                        <button class="dash-event-current" @onclick="GoToCurrentEvent" id="admin-dashboard-event-current-btn" title="@L["Index_ReturnToCurrent"]">
                            <i class="bi bi-broadcast"></i> @L["Index_Current"]
                        </button>
                    }
                    <select class="dash-event-select" @onchange="OnSelectEvent" id="admin-dashboard-event-select" title="@L["Index_SelectEvent"]">
                        @foreach (var ev in _events)
                        {
                            <option value="@ev.Id" selected="@(ev.Id == _selectedEvent.Id)">@ev.Name</option>
                        }
                    </select>
                    <button class="dash-event-nav" @onclick="SelectNextEvent" disabled="@(!CanGoNext)" id="admin-dashboard-event-next-btn" title="@L["Index_NextEvent"]">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="dash-event-bar dash-event-bar--empty" id="admin-dashboard-event-bar-empty">
                <i class="bi bi-calendar-x"></i>
                <span>@L["Index_NoEvents"]</span>
                <a href="events" class="dash-btn-outline" id="admin-dashboard-event-create-btn">@L["Index_CreateEvent"]</a>
            </div>
        }

        @* ---------- KPI CARDS (scoped to selected event) ---------- *@
        <section class="dash-kpis" id="admin-dashboard-kpis">
            <div class="dash-kpi-card" id="admin-dashboard-kpi-tickets">
                <div class="dash-kpi-head">
                    <div class="dash-kpi-label">
                        <span class="dash-kpi-title">@L["Index_TicketsSold"]</span>
                        <span class="dash-kpi-context">@(_selectedEvent != null ? L["Index_OfSeats", _selectedEvent.Capacity] : "—")</span>
                    </div>
                    <div class="dash-kpi-icon"><i class="bi bi-ticket-perforated"></i></div>
                </div>
                <div class="dash-kpi-value">@_ticketsSold.ToString("N0")</div>
            </div>

            <div class="dash-kpi-card" id="admin-dashboard-kpi-revenue">
                <div class="dash-kpi-head">
                    <div class="dash-kpi-label">
                        <span class="dash-kpi-title">@L["Index_TotalRevenue"]</span>
                        <span class="dash-kpi-context">@L["Index_ForThisEvent"]</span>
                    </div>
                    <div class="dash-kpi-icon"><i class="bi bi-cash-stack"></i></div>
                </div>
                <div class="dash-kpi-value">@_eventRevenue.ToString("N0")€</div>
            </div>

            <div class="dash-kpi-card" id="admin-dashboard-kpi-orders">
                <div class="dash-kpi-head">
                    <div class="dash-kpi-label">
                        <span class="dash-kpi-title">@L["Index_ActiveOrders"]</span>
                        <span class="dash-kpi-context">@L["Index_DrinksInProgress"]</span>
                    </div>
                    <div class="dash-kpi-icon"><i class="bi bi-cup-straw"></i></div>
                </div>
                <div class="dash-kpi-value">@_activeDrinkOrders</div>
            </div>

            <div class="dash-kpi-card" id="admin-dashboard-kpi-nps">
                <div class="dash-kpi-head">
                    <div class="dash-kpi-label">
                        <span class="dash-kpi-title">@L["Index_UserSatisfaction"]</span>
                        <span class="dash-kpi-context">@L["Index_NPSComingSoon"]</span>
                    </div>
                    <div class="dash-kpi-icon"><i class="bi bi-hand-thumbs-up"></i></div>
                </div>
                <div class="dash-kpi-value dash-kpi-value--muted">—</div>
            </div>
        </section>

        @* ---------- MIDDLE ROW: STADIUM + ORDERS ---------- *@
        <section class="dash-mid">
            @* Stadium overview *@
            <div class="dash-card dash-stadium-card" id="admin-dashboard-stadium-card">
                <div class="dash-card-head">
                    <h2 class="dash-card-title">@L["Index_StadiumOverview"]</h2>
                </div>

                <div class="dash-stadium-body">
                    @* Read-only canvas only (background image + DB sector overlays), no drawing toolbar. *@
                    <StadiumCanvasView />
                </div>
            </div>

            @* Recent orders (scoped to selected event) *@
            <div class="dash-card dash-orders-card" id="admin-dashboard-orders-card">
                <div class="dash-card-head">
                    <h2 class="dash-card-title">@L["Index_RecentOrders"]</h2>
                </div>
                <table class="dash-orders-table">
                    <thead>
                        <tr><th>@L["Index_HeaderID"]</th><th>@L["Index_HeaderSeat"]</th><th>@L["Index_HeaderAmount"]</th><th>@L["Index_HeaderStatus"]</th></tr>
                    </thead>
                    <tbody>
                        @if (_recentOrders.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="dash-muted" style="text-align:center; padding:22px 8px;">
                                    @(_selectedEvent == null ? @L["Index_SelectEventPrompt"] : @L["Index_NoOrdersThisEvent"])
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var o in _recentOrders)
                            {
                                <tr id="@($"admin-dashboard-order-{o.Id}")">
                                    <td class="dash-order-id">#@o.Id</td>
                                    <td>@(string.IsNullOrWhiteSpace(o.SeatNumber) ? "—" : o.SeatNumber)</td>
                                    <td class="dash-muted">@o.TotalAmount.ToString("N2")€</td>
                                    <td><span class="dash-status @StatusClass(o.Status)"><i class="dot"></i>@StatusLabel(o.Status)</span></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
                <a href="orders" class="dash-btn-ghost" id="admin-dashboard-orders-viewall-btn">@L["Index_ViewAllOrders"]</a>
            </div>
        </section>

        @* ---------- BOTTOM ROW: LOGS + HEALTH/ACTIONS ---------- *@
        <section class="dash-bottom">
            @* Centralized logs *@
            <div class="dash-card dash-logs-card" id="admin-dashboard-logs-card">
                <div class="dash-card-head">
                    <h2 class="dash-card-title">@L["Index_CentralizedLogs"]</h2>
                    <a href="logs" class="dash-btn-outline" id="admin-dashboard-logs-viewall-btn">@L["Index_ViewAllLogs"]</a>
                </div>
                <ul class="dash-log-list">
                    <li class="dash-log-row">
                        <i class="bi bi-exclamation-triangle dash-log-ico log-warn"></i>
                        <span><b class="log-warn-txt">[Upozorenje]</b> ConnectionPool iscrpljen (referencing <a href="#" class="dash-log-link">CLAUDE.md</a>)</span>
                    </li>
                    <li class="dash-log-row">
                        <i class="bi bi-person-circle dash-log-ico log-user"></i>
                        <span><b class="log-user-txt">[Korisnik]</b> @@Bartender1 je preuzeo narudžbu #123</span>
                    </li>
                    <li class="dash-log-row">
                        <i class="bi bi-ticket-detailed dash-log-ico log-ok"></i>
                        <span><b class="log-ok-txt">[Karta]</b> Karta validirana (A, RS 512)</span>
                    </li>
                    <li class="dash-log-row">
                        <i class="bi bi-x-octagon dash-log-ico log-err"></i>
                        <span><b class="log-err-txt">[Greška]</b> API greška (Npgea), retry 1</span>
                    </li>
                </ul>
            </div>

            @* Health + quick actions *@
            <div class="dash-card dash-health-card" id="admin-dashboard-health-card">
                <div class="dash-card-head">
                    <h2 class="dash-card-title">@L["Index_SystemHealthQuickActions"]</h2>
                </div>

                <div class="dash-health-grid">
                    <div class="dash-health-box">
                        <div class="dash-health-status"><i class="dot dot-pulse"></i> @L["Index_Connected"]</div>
                        <div class="dash-health-label">@L["Index_Database"]</div>
                    </div>
                    <div class="dash-health-box">
                        <div class="dash-health-status"><i class="dot dot-pulse"></i> @L["Index_Healthy"]</div>
                        <div class="dash-health-label">@L["Index_APIHealth"]</div>
                    </div>
                    <div class="dash-health-box">
                        <div class="dash-health-status"><i class="dot dot-pulse"></i> @L["Index_Active"]</div>
                        <div class="dash-health-label">@L["Index_Cache"]</div>
                    </div>
                    <div class="dash-health-box">
                        <div class="dash-health-status"><i class="dot dot-pulse"></i> @L["Index_Running"]</div>
                        <div class="dash-health-label">@L["Index_BackgroundServices"]</div>
                    </div>
                </div>

                <div class="dash-actions-grid">
                    <a href="orders" class="dash-action" id="admin-dashboard-action-new-order">
                        <i class="bi bi-plus-circle"></i> @L["Index_NewOrder"]
                    </a>
                    <a href="users" class="dash-action" id="admin-dashboard-action-add-user">
                        <i class="bi bi-person-plus"></i> @L["Index_AddUser"]
                    </a>
                    <a href="analytics" class="dash-action" id="admin-dashboard-action-export">
                        <i class="bi bi-file-earmark-arrow-down"></i> @L["Index_ExportReport"]
                    </a>
                    <a href="logs" class="dash-action" id="admin-dashboard-action-logs">
                        <i class="bi bi-journal-text"></i> @L["Index_ViewLogs"]
                    </a>
                </div>
            </div>
        </section>
