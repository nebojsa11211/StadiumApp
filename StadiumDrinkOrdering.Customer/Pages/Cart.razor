@page "/cart"
@layout MobileShell
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Shared.DTOs
@inject OrderSessionState State
@inject IApiService Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> Localizer
@implements IDisposable

<PageTitle>@Localizer["Cart_PageTitle"]</PageTitle>

<div id="customer-cart-atmos" class="crowd-atmos" aria-hidden="true"></div>

<ScreenHeader Title="@Localizer["Cart_ScreenHeaderTitle"]" Subtitle="@SubtitleText" BackHref="/order" />

<div id="customer-cart-body" class="body">
    @if (State.Count == 0)
    {
        <div id="customer-cart-empty" class="empty">
            <div id="customer-cart-emoji" class="e-emoji" aria-hidden="true">🛒</div>
            <p>@Localizer["Cart_EmptyMessage"]</p>
            <button id="customer-cart-back-btn" class="btn btn-ghost btn-sm" @onclick="@(() => Nav.NavigateTo("/order"))">@Localizer["Cart_BackMenuButton"]</button>
        </div>
    }
    else
    {
        <div id="customer-cart-deliver-banner" class="deliver-banner">
            <span class="ic" aria-hidden="true">📍</span>
            <div id="customer-cart-delivery-info">
                <div id="customer-cart-delivery-title" class="t">@Localizer["Cart_DeliveryTitle"]</div>
                <div id="customer-cart-delivery-seat" class="s tnum">@State.SeatText</div>
            </div>
        </div>

        <div id="customer-cart-pad" class="pad">
            <div id="customer-cart-items" class="items">
                @foreach (var item in State.Items)
                {
                    <div id="customer-cart-item-@item.DrinkId" class="cart-item">
                        <div id="customer-cart-item-icon-@item.DrinkId" class="th" aria-hidden="true">🥤</div>
                        <div id="customer-cart-item-info-@item.DrinkId" class="ci">
                            <div id="customer-cart-item-name-@item.DrinkId" class="n">@item.DrinkName</div>
                            <div id="customer-cart-item-price-@item.DrinkId" class="p tnum">@Localizer["Cart_UnitPriceLabel", item.UnitPrice.ToString("F2")]</div>
                        </div>
                        <div id="customer-cart-item-step-@item.DrinkId" class="mini-step">
                            <button id="customer-cart-item-qty-dec-@item.DrinkId" @onclick="() => Change(item.DrinkId, item.Quantity - 1)" aria-label="@Localizer["Cart_DecreaseButton_Aria"]">−</button>
                            <span id="customer-cart-item-qty-@item.DrinkId" class="q tnum">@item.Quantity</span>
                            <button id="customer-cart-item-qty-inc-@item.DrinkId" @onclick="() => Change(item.DrinkId, item.Quantity + 1)" aria-label="@Localizer["Cart_IncreaseButton_Aria"]">+</button>
                        </div>
                    </div>
                }
            </div>

            <div id="customer-cart-payment-label" class="label" style="margin:22px 0 12px">@Localizer["Cart_PaymentLabel"]</div>
            @* Which methods appear is an operator setting (Admin → Settings → Payments). *@
            @if (_settings.WalletPaymentEnabled)
            {
            <div id="customer-cart-pay-wallet" class="pay-opt @(_pay == "wallet" ? "sel" : "")" @onclick="@(() => _pay = "wallet")">
                <div id="customer-cart-wallet-icon" class="pic" aria-hidden="true">@(_wallet is { IsTicketWallet: true } ? "🎟️" : "👛")</div>
                <div id="customer-cart-wallet-info" class="pb">
                    <div id="customer-cart-wallet-title" class="t">@WalletTitle</div>
                    @* Whose money this is — the one place identity is decision-relevant, and why it no
                       longer occupies the order header. *@
                    <div id="customer-cart-wallet-holder" class="s">@FanName</div>
                    <div id="customer-cart-wallet-balance" class="s tnum">@WalletText</div>
                </div>
                <div class="radio"></div>
            </div>
            }
            @if (_settings.CardPaymentEnabled)
            {
            <div id="customer-cart-pay-card" class="pay-opt @(_pay == "card" ? "sel" : "")" @onclick="@(() => _pay = "card")">
                <div id="customer-cart-card-icon" class="pic" aria-hidden="true">💳</div>
                <div id="customer-cart-card-info" class="pb">
                    <div id="customer-cart-card-title" class="t">@Localizer["Cart_CardTitle"]</div>
                    <div id="customer-cart-card-subtitle" class="s">@Localizer["Cart_CardSubtitle"]</div>
                </div>
                <div class="radio"></div>
            </div>
            }
            @if (_settings.CashPaymentEnabled)
            {
            <div id="customer-cart-pay-cash" class="pay-opt @(_pay == "cash" ? "sel" : "")" @onclick="@(() => _pay = "cash")">
                <div id="customer-cart-cash-icon" class="pic" aria-hidden="true">💵</div>
                <div id="customer-cart-cash-info" class="pb">
                    <div id="customer-cart-cash-title" class="t">@Localizer["Cart_CashTitle"]</div>
                    <div id="customer-cart-cash-subtitle" class="s">@Localizer["Cart_CashSubtitle"]</div>
                </div>
                <div class="radio"></div>
            </div>
            }

            <div id="customer-cart-summary" class="summary">
                <div id="customer-cart-summary-subtotal" class="sr"><span>@Localizer["Cart_SubtotalLabel"]</span><b class="tnum">€@State.Subtotal.ToString("F2")</b></div>
                <div id="customer-cart-summary-fee" class="sr"><span>@Localizer["Cart_FeeLabel"]</span><b class="tnum">€@ServiceFee.ToString("F2")</b></div>
                <div id="customer-cart-summary-total" class="sr total"><span>@Localizer["Cart_TotalLabel"]</span><b class="tnum">€@Total.ToString("F2")</b></div>
            </div>

            @if (State.HasSession && !State.CanOrderDrinks)
            {
                <div id="customer-cart-error-closed" class="err">@Localizer["Cart_OrderingClosed"]</div>
            }
            @if (!string.IsNullOrEmpty(_error))
            {
                <div id="customer-cart-error-message" class="err">@_error</div>
            }
        </div>
    }
</div>

@if (State.Count > 0)
{
    <div id="customer-cart-checkout-footer" class="checkout-foot">
        <button id="customer-cart-checkout-btn" class="btn btn-primary" @onclick="PlaceOrder" disabled="@(_placing || !State.CanOrderDrinks)">
            @if (_placing)
            {
                <span class="spinner"></span> <span>@Localizer["Cart_Placing"]</span>
            }
            else if (!State.CanOrderDrinks)
            {
                <span>@Localizer["Cart_OrderingUnavailable"]</span>
            }
            else
            {
                <span>@Localizer["Cart_PlaceOrderButton", Total.ToString("F2")]</span>
            }
        </button>
    </div>
}

@code {
    private const decimal ServiceFee = 0.50m;
    private string _pay = "wallet";
    private bool _placing;
    private string? _error;
    private WalletSummaryDto? _wallet;
    // Accepted payment methods for this installation. Defaults to all-enabled so a settings
    // fetch failure never blocks checkout — the order API re-checks and is authoritative.
    private AppSettingsDto _settings = new();

    private decimal Total => State.Subtotal + (State.Count > 0 ? ServiceFee : 0m);
    private string SubtitleText => State.Count > 0 ? Localizer["Cart_ItemCountSubtitle", State.Count, State.Count == 1 ? Localizer["Cart_Item"] : Localizer["Cart_Items"]] : Localizer["Cart_EmptySubtitle"];
    private string WalletText => _wallet is { Exists: true } ? $"Stanje €{_wallet.Balance:F2}" : Localizer["Cart_WalletPlaceholder"];
    // Ticket holder paying from this wallet; anonymous bearer tickets carry no name.
    private string FanName => string.IsNullOrWhiteSpace(State.CustomerName) ? Localizer["Order_GuestName"] : State.CustomerName;
    // Anonymous bearer balance loaded on the scanned ticket vs a registered fan's personal wallet.
    private string WalletTitle => _wallet is { IsTicketWallet: true } ? Localizer["Cart_TicketWalletTitle"] : Localizer["Cart_PersonalWalletTitle"];

    protected override void OnInitialized() => State.OnChange += StateChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!State.HasSession)
        {
            var token = await JS.InvokeAsync<string?>("sessionStorage.getItem", "htSessionToken");
            if (!string.IsNullOrEmpty(token))
                await State.InitFromTokenAsync(token);
        }

        // Wallet balance is best-effort; failure just falls back to a generic label. Resolved from the ticket
        // session (this walk-up flow has no JWT login) — the API maps the scanned ticket to its owner's wallet.
        if (State.HasSession)
            _wallet = await Api.GetSessionWalletSummaryAsync(State.SessionToken!);

        _settings = await Api.GetAppSettingsAsync();

        // Preselect wallet only when it's offered AND there's actually a wallet to charge; otherwise
        // fall back to the first method the operator still accepts.
        _pay = SelectDefaultMethod();
        StateHasChanged();
    }

    /// <summary>Best enabled method to preselect: a funded wallet first, then card, then cash.</summary>
    private string SelectDefaultMethod()
    {
        if (_settings.WalletPaymentEnabled && _wallet is { Exists: true }) return "wallet";
        if (_settings.CardPaymentEnabled) return "card";
        if (_settings.CashPaymentEnabled) return "cash";
        return "wallet"; // wallet is the only one left enabled (the API forbids disabling all three)
    }

    private void Change(int drinkId, int qty) => State.SetQty(drinkId, qty);

    private async Task PlaceOrder()
    {
        if (_placing) return;
        if (!State.CanOrderDrinks)
        {
            _error = Localizer["Cart_OrderingClosed"];
            return;
        }
        _placing = true;
        _error = null;

        // Wallet pays from the ticket owner's HALFTIME wallet (charged server-side); "card" and "cash" move
        // no money at checkout — the order is created unpaid and settled at the bar / on delivery — but the
        // chosen method is recorded so staff know cash vs card. The ticket session is intentionally kept so
        // the fan can track and order again.
        var method = _pay switch
        {
            "cash" => PaymentMethod.Cash,
            "card" => PaymentMethod.CreditCard,
            _ => (PaymentMethod?)null
        };
        var result = await State.CheckoutAsync(payWithWallet: _pay == "wallet", paymentMethod: method);

        if (result is { Success: true })
        {
            // Remember the in-flight order so the fan can jump back to /track after leaving to order more.
            // sessionStorage survives a hard reload; OrderSessionState already mirrors it in-circuit.
            try { await JS.InvokeVoidAsync("sessionStorage.setItem", "htActiveOrderId", result.OrderId); }
            catch { /* no JS — the in-circuit mirror still carries it */ }
            Nav.NavigateTo($"/track/{result.OrderId}");
        }
        else if (result is { InsufficientFunds: true })
        {
            _error = _wallet is { IsTicketWallet: true }
                ? Localizer["Cart_InsufficientTicketBalance"]
                : Localizer["Cart_InsufficientWalletBalance"];
            _placing = false;
        }
        else
        {
            _error = result?.Error ?? Localizer["Cart_OrderFailed"];
            _placing = false;
        }
    }

    private void StateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => State.OnChange -= StateChanged;
}
