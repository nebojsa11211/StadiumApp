@{
    string containerClass = Type switch
    {
        SkeletonType.Card => "skeleton-card-container",
        SkeletonType.Table => "skeleton-table-container",
        SkeletonType.Button => "skeleton-button-container",
        SkeletonType.List => "skeleton-list-container",
        _ => "skeleton-container"
    };
}

<div class="@containerClass" id="staff-loading-skeleton-@Type">
    @if (Type == SkeletonType.Card)
    {
        <div class="skeleton-card @AdditionalClass" id="staff-loading-skeleton-card">
            <div class="skeleton-header" id="staff-loading-skeleton-card-header">
                <div class="skeleton-text skeleton-title" id="staff-loading-skeleton-card-title"></div>
                <div class="skeleton-text skeleton-subtitle" id="staff-loading-skeleton-card-subtitle"></div>
            </div>
            <div class="skeleton-icon" id="staff-loading-skeleton-card-icon"></div>
        </div>
    }
    else if (Type == SkeletonType.Table)
    {
        <div class="skeleton-table @AdditionalClass" id="staff-loading-skeleton-table">
            <div class="skeleton-table-header" id="staff-loading-skeleton-table-header">
                @for (int i = 0; i < Columns; i++)
                {
                    <div class="skeleton-text skeleton-header-cell" id="staff-loading-skeleton-table-col-@i"></div>
                }
            </div>
            @for (int row = 0; row < Rows; row++)
            {
                <div class="skeleton-table-row" id="staff-loading-skeleton-table-row-@row">
                    @for (int col = 0; col < Columns; col++)
                    {
                        <div class="skeleton-text skeleton-cell" id="staff-loading-skeleton-table-cell-@row-@col"></div>
                    }
                </div>
            }
        </div>
    }
    else if (Type == SkeletonType.Button)
    {
        @for (int i = 0; i < Count; i++)
        {
            <div class="skeleton-button @AdditionalClass mb-2" id="staff-loading-skeleton-button-@i"></div>
        }
    }
    else if (Type == SkeletonType.List)
    {
        @for (int i = 0; i < Count; i++)
        {
            <div class="skeleton-list-item @AdditionalClass mb-3" id="staff-loading-skeleton-list-item-@i">
                <div class="skeleton-text skeleton-primary" id="staff-loading-skeleton-list-primary-@i"></div>
                <div class="skeleton-text skeleton-secondary" id="staff-loading-skeleton-list-secondary-@i"></div>
            </div>
        }
    }
    else if (Type == SkeletonType.Text)
    {
        @for (int i = 0; i < Count; i++)
        {
            <div class="skeleton-text @AdditionalClass mb-2" id="staff-loading-skeleton-text-@i" style="width: @(Width ?? "100%");"></div>
        }
    }
    else if (Type == SkeletonType.Circle)
    {
        <div class="skeleton-circle @AdditionalClass" id="staff-loading-skeleton-circle" style="width: @(Width ?? "40px"); height: @(Width ?? "40px");"></div>
    }
    else
    {
        <div class="skeleton-placeholder @AdditionalClass" id="staff-loading-skeleton-placeholder" style="height: @(Height ?? "20px"); width: @(Width ?? "100%");"></div>
    }
</div>

@code {
    [Parameter] public SkeletonType Type { get; set; } = SkeletonType.Text;
    [Parameter] public int Count { get; set; } = 1;
    [Parameter] public int Rows { get; set; } = 3;
    [Parameter] public int Columns { get; set; } = 4;
    [Parameter] public string? Width { get; set; }
    [Parameter] public string? Height { get; set; }
    [Parameter] public string AdditionalClass { get; set; } = "";

    public enum SkeletonType
    {
        Card,
        Table,
        Button,
        List,
        Text,
        Circle,
        Custom
    }
}