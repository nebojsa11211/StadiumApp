@page "/admin/teams"
@using System.Net.Http
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Forms
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Shared.Authentication.Interfaces
@using StadiumDrinkOrdering.Admin.Common
@inject IHttpClientFactory HttpClientFactory
@inject IConfiguration Configuration
@inject ITokenStorageService TokenStorage
@inject ILogger<Teams> Logger
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Teams_PageTitle"]</PageTitle>

<div id="admin-teams-main-container" class="container-fluid">
    <PageHeader Id="admin-teams-header"
                Eyebrow='@L["Teams_Eyebrow"]'
                Title='@L["Teams_Heading"]'
                Subtitle='@L["Teams_Subtitle"]' />

    @if (!string.IsNullOrEmpty(alertMessage))
    {
        <div id="admin-teams-alert" class="alert @alertClass alert-dismissible d-flex justify-content-between align-items-center" role="alert">
            <span id="admin-teams-alert-text">@alertMessage</span>
            <button type="button" id="admin-teams-alert-close" class="btn-close" @onclick="() => alertMessage = null"></button>
        </div>
    }

    @if (isLoading)
    {
        <div id="admin-teams-loading" class="d-flex align-items-center text-muted">
            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
            <span>@L["Teams_Loading"]</span>
        </div>
    }
    else if (loadError)
    {
        <div id="admin-teams-error" class="alert alert-danger d-flex justify-content-between align-items-center">
            <span id="admin-teams-error-text">@L["Teams_LoadFailed"]</span>
            <button type="button" id="admin-teams-retry-btn" class="btn btn-sm btn-outline-danger" @onclick="LoadAsync">@L["Teams_Retry"]</button>
        </div>
    }
    else
    {
        <div class="card" id="admin-teams-card">
            <div class="card-header d-flex justify-content-between align-items-center gap-2">
                <h5 class="mb-0" id="admin-teams-title">@L["Teams_ListSection"]</h5>
                <div class="d-flex gap-2 align-items-center">
                    <input id="admin-teams-search-input"
                           class="form-control form-control-sm"
                           style="max-width:220px;"
                           placeholder="@L["Teams_SearchPlaceholder"]"
                           value="@searchTerm"
                           @oninput="OnSearchInput" />
                    <button type="button" id="admin-teams-add-btn" class="btn btn-sm btn-primary" @onclick="StartAdd" disabled="@(editingTeam is not null)">
                        <i class="bi bi-plus-lg me-1"></i>@L["Teams_AddTeam"]
                    </button>
                </div>
            </div>
            <div class="card-body" id="admin-teams-body">

                @if (editingTeam is not null)
                {
                    <div class="border rounded p-3 mb-3" id="admin-teams-editor">
                        <h6 id="admin-teams-editor-title">@(editingTeamId is null ? L["Teams_NewTeam"] : L["Teams_EditTeam"])</h6>
                        <EditForm Model="editingTeam" OnValidSubmit="SaveAsync" id="admin-teams-form">
                            <DataAnnotationsValidator />
                            <div class="row g-3">
                                <div class="col-md-5" id="admin-teams-name-group">
                                    <label class="form-label" for="admin-teams-name-input">@L["Teams_Name"]</label>
                                    <InputText id="admin-teams-name-input" class="form-control" @bind-Value="editingTeam.Name" />
                                    <ValidationMessage For="() => editingTeam.Name" />
                                </div>
                                <div class="col-md-3" id="admin-teams-short-group">
                                    <label class="form-label" for="admin-teams-short-input">@L["Teams_ShortName"]</label>
                                    <InputText id="admin-teams-short-input" class="form-control" @bind-Value="editingTeam.ShortName" />
                                </div>
                                <div class="col-md-2" id="admin-teams-founded-group">
                                    <label class="form-label" for="admin-teams-founded-input">@L["Teams_Founded"]</label>
                                    <InputNumber id="admin-teams-founded-input" class="form-control" @bind-Value="editingTeam.FoundedYear" />
                                    <ValidationMessage For="() => editingTeam.FoundedYear" />
                                </div>
                                <div class="col-md-2" id="admin-teams-city-group">
                                    <label class="form-label" for="admin-teams-city-input">@L["Teams_City"]</label>
                                    <InputText id="admin-teams-city-input" class="form-control" @bind-Value="editingTeam.City" />
                                </div>

                                <div class="col-md-3" id="admin-teams-primarycolor-group">
                                    <label class="form-label" for="admin-teams-primarycolor-input">@L["Teams_PrimaryColor"]</label>
                                    <InputText id="admin-teams-primarycolor-input" type="color" class="form-control form-control-color" @bind-Value="editingTeam.PrimaryColor" />
                                </div>
                                <div class="col-md-3" id="admin-teams-secondarycolor-group">
                                    <label class="form-label" for="admin-teams-secondarycolor-input">@L["Teams_SecondaryColor"]</label>
                                    <InputText id="admin-teams-secondarycolor-input" type="color" class="form-control form-control-color" @bind-Value="editingTeam.SecondaryColor" />
                                </div>
                                <div class="col-md-6" id="admin-teams-website-group">
                                    <label class="form-label" for="admin-teams-website-input">@L["Teams_Website"]</label>
                                    <InputText id="admin-teams-website-input" class="form-control" @bind-Value="editingTeam.Website" />
                                </div>
                            </div>
                            <div class="d-flex gap-2 mt-3">
                                <button type="submit" id="admin-teams-save-btn" class="btn btn-primary btn-sm" disabled="@isSaving">@L["Teams_Save"]</button>
                                <button type="button" id="admin-teams-cancel-btn" class="btn btn-outline-secondary btn-sm" @onclick="CancelEdit">@L["Teams_Cancel"]</button>
                            </div>
                            @if (editingTeamId is null)
                            {
                                <div class="form-text mt-2" id="admin-teams-crest-hint">@L["Teams_CrestAfterSaveHint"]</div>
                            }
                        </EditForm>
                    </div>
                }

                @if (teams.Count == 0)
                {
                    <div class="text-muted" id="admin-teams-empty">
                        @(string.IsNullOrWhiteSpace(searchTerm) ? L["Teams_NoTeams"] : L["Teams_NoMatches"])
                    </div>
                }
                else
                {
                    <div class="table-responsive" id="admin-teams-responsive">
                        <table class="table align-middle mb-0" id="admin-teams-table">
                            <thead id="admin-teams-thead">
                                <tr id="admin-teams-header-row">
                                    <th style="width:64px;" id="admin-teams-col-crest"></th>
                                    <th class="sortable @(sortState.IsSorted("name") ? "is-sorted" : "")" @onclick='() => SortBy("name")' id="admin-teams-col-name">@L["Teams_Name"]<span class="sort-ind">@sortState.Indicator("name")</span></th>
                                    <th class="sortable @(sortState.IsSorted("city") ? "is-sorted" : "")" @onclick='() => SortBy("city")' id="admin-teams-col-city">@L["Teams_City"]<span class="sort-ind">@sortState.Indicator("city")</span></th>
                                    <th class="text-end" id="admin-teams-col-actions"></th>
                                </tr>
                            </thead>
                            <tbody id="admin-teams-tbody">
                                @foreach (var team in DisplayedTeams)
                                {
                                    <tr id="admin-teams-row-@team.Id">
                                        <td style="width:64px;">
                                            <div id="admin-teams-crest-@team.Id" style="width:48px;height:48px;border-radius:8px;background:#f1f3f5;display:flex;align-items:center;justify-content:center;overflow:hidden;">
                                                @if (team.HasLogo)
                                                {
                                                    <img id="admin-teams-crest-img-@team.Id" src="@ImageUrl($"{team.Id}/logo")" alt="@team.Name" style="max-width:100%;max-height:100%;" />
                                                }
                                                else
                                                {
                                                    <i class="bi bi-shield" style="color:#adb5bd;"></i>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <div class="fw-semibold" id="admin-teams-name-@team.Id">@team.Name</div>
                                            <div class="text-muted small" id="admin-teams-meta-@team.Id">
                                                @team.ShortName@(team.FoundedYear.HasValue ? $" · {team.FoundedYear}" : "")
                                            </div>
                                        </td>
                                        <td id="admin-teams-city-@team.Id">@team.City</td>
                                        <td class="text-end">
                                            <label class="btn btn-outline-secondary btn-sm mb-0 me-1" id="admin-teams-crest-label-@team.Id">
                                                <InputFile id="@($"admin-teams-crest-input-{team.Id}")" OnChange="@(e => UploadCrestAsync(e, team.Id))" accept="image/*" class="d-none" />
                                                @(team.HasLogo ? L["Teams_ReplaceCrest"] : L["Teams_UploadCrest"])
                                            </label>
                                            @if (team.HasLogo)
                                            {
                                                <button type="button" id="admin-teams-crest-remove-@team.Id" class="btn btn-outline-secondary btn-sm me-1" @onclick="@(() => DeleteCrestAsync(team.Id))">@L["Teams_RemoveCrest"]</button>
                                            }
                                            <button type="button" id="admin-teams-edit-btn-@team.Id" class="btn btn-outline-primary btn-sm me-1" @onclick="@(() => StartEdit(team))">@L["Teams_Edit"]</button>
                                            <button type="button" id="admin-teams-delete-btn-@team.Id" class="btn btn-outline-danger btn-sm" @onclick="@(() => DeleteAsync(team))">@L["Teams_Delete"]</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private bool loadError;
    private bool isSaving;

    private List<TeamDto> teams = new();
    private TeamUpsertDto? editingTeam;
    private int? editingTeamId;
    private string searchTerm = string.Empty;

    private string? alertMessage;
    private string alertClass = "alert-success";

    // Bumped after each crest upload/delete so <img> URLs change and the browser re-fetches
    // (the logo endpoint sets a short cache lifetime).
    private int imgVersion;

    private readonly TableSortState sortState = new();
    private static readonly Dictionary<string, Func<TeamDto, object?>> SortSelectors = new()
    {
        ["name"] = t => t.Name,
        ["city"] = t => t.City,
    };

    // The API already returns teams alphabetically, so leave that order alone until the admin
    // picks a column explicitly.
    private IEnumerable<TeamDto> DisplayedTeams =>
        sortState.Column is null ? teams : sortState.Apply(teams, SortSelectors);

    private void SortBy(string column)
    {
        sortState.Toggle(column);
        StateHasChanged();
    }

    // See VenueSettings: the shared AuthenticationHandler runs in a different DI scope than the
    // Blazor circuit, so its token store is empty and writes come back 401. Attach the
    // circuit-scoped token ourselves.
    private HttpClient Api
    {
        get
        {
            var client = HttpClientFactory.CreateClient("AuthenticatedClient");
            var token = TokenStorage.Token;
            if (!string.IsNullOrEmpty(token))
                client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            return client;
        }
    }

    private string ApiBaseUrl =>
        Configuration.GetValue<string>("ApiSettings:BaseUrl")?.TrimEnd('/') ?? "https://localhost:7010";

    /// <summary>Crest endpoints are anonymous, so the browser fetches them directly.</summary>
    private string ImageUrl(string path) => $"{ApiBaseUrl}/api/teams/{path}?v={imgVersion}";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();
        try
        {
            var url = string.IsNullOrWhiteSpace(searchTerm)
                ? "api/teams"
                : $"api/teams?search={Uri.EscapeDataString(searchTerm)}";
            teams = await Api.GetFromJsonAsync<List<TeamDto>>(url) ?? new();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load teams");
            loadError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    /// <summary>Reloads without the full-page spinner, so the table does not flash on every save.</summary>
    private async Task ReloadAsync()
    {
        try
        {
            var url = string.IsNullOrWhiteSpace(searchTerm)
                ? "api/teams"
                : $"api/teams?search={Uri.EscapeDataString(searchTerm)}";
            teams = await Api.GetFromJsonAsync<List<TeamDto>>(url) ?? new();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to reload teams");
        }
        finally
        {
            StateHasChanged();
        }
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
        await ReloadAsync();
    }

    private void StartAdd()
    {
        editingTeamId = null;
        editingTeam = new TeamUpsertDto { PrimaryColor = "#1d4ed8", SecondaryColor = "#0f172a" };
    }

    private void StartEdit(TeamDto team)
    {
        editingTeamId = team.Id;
        editingTeam = new TeamUpsertDto
        {
            Name = team.Name,
            ShortName = team.ShortName,
            PrimaryColor = team.PrimaryColor ?? "#1d4ed8",
            SecondaryColor = team.SecondaryColor ?? "#0f172a",
            FoundedYear = team.FoundedYear,
            City = team.City,
            Website = team.Website
        };
    }

    private void CancelEdit()
    {
        editingTeam = null;
        editingTeamId = null;
    }

    private async Task SaveAsync()
    {
        if (editingTeam is null) return;
        isSaving = true;
        try
        {
            var resp = editingTeamId is null
                ? await Api.PostAsJsonAsync("api/teams", editingTeam)
                : await Api.PutAsJsonAsync($"api/teams/{editingTeamId}", editingTeam);

            if (resp.IsSuccessStatusCode)
            {
                CancelEdit();
                await ReloadAsync();
                ShowAlert(L["Teams_Saved"], true);
            }
            else if (resp.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                // A duplicate name is an ordinary mistake, not a failure — say which one.
                ShowAlert(L["Teams_DuplicateName"], false);
            }
            else
            {
                ShowAlert(L["Teams_SaveFailed"], false);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save team");
            ShowAlert(L["Teams_SaveFailed"], false);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteAsync(TeamDto team)
    {
        try
        {
            var resp = await Api.DeleteAsync($"api/teams/{team.Id}");
            if (resp.IsSuccessStatusCode)
            {
                await ReloadAsync();
                ShowAlert(L["Teams_Deleted"], true);
            }
            else
            {
                ShowAlert(L["Teams_SaveFailed"], false);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete team {TeamId}", team.Id);
            ShowAlert(L["Teams_SaveFailed"], false);
        }
    }

    private async Task UploadCrestAsync(InputFileChangeEventArgs e, int teamId)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            using var content = new MultipartFormDataContent();
            // Matches the API's 2 MB cap; OpenReadStream throws above this rather than sending a
            // request that would be rejected anyway.
            var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
            var streamContent = new StreamContent(stream);
            streamContent.Headers.ContentType = new MediaTypeHeaderValue(
                string.IsNullOrEmpty(file.ContentType) ? "application/octet-stream" : file.ContentType);
            content.Add(streamContent, "file", file.Name);

            var resp = await Api.PostAsync($"api/teams/{teamId}/logo", content);
            if (resp.IsSuccessStatusCode)
            {
                imgVersion++;
                await ReloadAsync();
                ShowAlert(L["Teams_CrestSaved"], true);
            }
            else
            {
                ShowAlert(L["Teams_CrestFailed"], false);
            }
        }
        catch (IOException ex)
        {
            Logger.LogWarning(ex, "Crest for team {TeamId} exceeded the size limit", teamId);
            ShowAlert(L["Teams_CrestTooLarge"], false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to upload crest for team {TeamId}", teamId);
            ShowAlert(L["Teams_CrestFailed"], false);
        }
    }

    private async Task DeleteCrestAsync(int teamId)
    {
        try
        {
            var resp = await Api.DeleteAsync($"api/teams/{teamId}/logo");
            if (resp.IsSuccessStatusCode)
            {
                imgVersion++;
                await ReloadAsync();
                ShowAlert(L["Teams_CrestRemoved"], true);
            }
            else
            {
                ShowAlert(L["Teams_CrestFailed"], false);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to remove crest for team {TeamId}", teamId);
            ShowAlert(L["Teams_CrestFailed"], false);
        }
    }

    private void ShowAlert(string message, bool success)
    {
        alertMessage = message;
        alertClass = success ? "alert-success" : "alert-danger";
        StateHasChanged();
    }
}
