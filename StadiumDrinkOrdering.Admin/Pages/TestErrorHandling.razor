@page "/test-error-handling"
@using Microsoft.Extensions.Localization
@using StadiumDrinkOrdering.Admin
@inject IStringLocalizer<SharedResources> L

<div class="container-fluid" id="admin-testerror-main-container">
    <div class="row" id="admin-testerror-row">
        <div class="col-12" id="admin-testerror-col">
            <div class="card" id="admin-testerror-card">
                <div class="card-header" id="admin-testerror-header">
                    <h3 id="admin-testerror-title">🧪 @L["TestError_Title"]</h3>
                    <p class="mb-0" id="admin-testerror-subtitle">@L["TestError_Subtitle"]</p>
                </div>
                <div class="card-body" id="admin-testerror-body">
                    <div class="row" id="admin-testerror-content-row">
                        <div class="col-md-6" id="admin-testerror-manual-col">
                            <h4 id="admin-testerror-manual-title">@L["TestError_ManualTests"]</h4>
                            <div class="d-grid gap-2" id="admin-testerror-manual-buttons">
                                <button class="btn btn-danger" @onclick="TestErrorNotification" id="admin-test-error-btn">
                                    🔴 @L["TestError_TestErrorMsg"]
                                </button>
                                <button class="btn btn-warning" @onclick="TestWarningNotification" id="admin-test-warning-btn">
                                    🟡 @L["TestError_TestWarningMsg"]
                                </button>
                                <button class="btn btn-success" @onclick="TestSuccessNotification" id="admin-test-success-btn">
                                    🟢 @L["TestError_TestSuccessMsg"]
                                </button>
                                <button class="btn btn-info" @onclick="TestInfoNotification" id="admin-test-info-btn">
                                    🔵 @L["TestError_TestInfoMsg"]
                                </button>
                                <button class="btn btn-secondary" @onclick="TestAuthError" id="admin-test-auth-error-btn">
                                    🔐 @L["TestError_TestAuthError"]
                                </button>
                            </div>
                        </div>
                        <div class="col-md-6" id="admin-testerror-api-col">
                            <h4 id="admin-testerror-api-title">@L["TestError_ApiTests"]</h4>
                            <div class="d-grid gap-2" id="admin-testerror-api-buttons">
                                <button class="btn btn-outline-danger" @onclick="TestApiConnection" id="admin-test-api-connection-btn">
                                    🌐 @L["TestError_TestApiConnection"]
                                </button>
                                <button class="btn btn-outline-warning" @onclick="TestDrinksFetch" id="admin-test-drinks-fetch-btn">
                                    🥤 @L["TestError_TestDrinksFetch"]
                                </button>
                                <button class="btn btn-outline-info" @onclick="TestOrdersFetch" id="admin-test-orders-fetch-btn">
                                    📦 @L["TestError_TestOrdersFetch"]
                                </button>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" id="admin-testerror-divider" />

                    <div class="alert alert-info" id="admin-testerror-results-alert">
                        <h5 id="admin-testerror-results-title">📋 @L["TestError_Results"]</h5>
                        <p id="admin-testerror-results-note">@L["TestError_ResultsNote"]</p>
                        <ul id="admin-testerror-results-list">
                            <li id="admin-testerror-result-success">✅ <strong>@L["Success"]</strong>: @L["TestError_SuccessDesc"]</li>
                            <li id="admin-testerror-result-warning">⚠️ <strong>@L["TestError_Warning"]</strong>: @L["TestError_WarningDesc"]</li>
                            <li id="admin-testerror-result-error">❌ <strong>@L["ErrorOccurred"]</strong>: @L["TestError_ErrorDesc"]</li>
                            <li id="admin-testerror-result-info">ℹ️ <strong>@L["TestError_Info"]</strong>: @L["TestError_InfoDesc"]</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

