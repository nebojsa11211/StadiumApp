@using StadiumDrinkOrdering.Customer.Services
@using Microsoft.Extensions.Localization
@inject ICustomerAuthStateService AuthStateService
@inject IStringLocalizer<SharedResources> Localizer
@implements IDisposable

<nav class="stadium-nav" role="navigation" aria-label="Main navigation">
    <div class="container-fluid">
        <ul class="nav-links" role="list">
            <li role="listitem"><a href="/" class="nav-link" aria-label="Navigate to home page">🏠 @Localizer["Home"]</a></li>
            <li role="listitem"><a href="/events" class="nav-link" aria-label="View available events">🎟️ @Localizer["Events"]</a></li>
            <li role="listitem"><a href="/menu" class="nav-link" aria-label="Browse drinks menu">🍺 @Localizer["Menu"]</a></li>
            @if (AuthStateService.IsAuthenticated)
            {
                <li role="listitem"><a href="/orders" class="nav-link" aria-label="View your orders">📋 @Localizer["MyOrders"]</a></li>
                <li role="listitem"><a href="/wallet" class="nav-link" id="customer-nav-wallet-link" aria-label="View your wallet">💳 @Localizer["Wallet"]</a></li>
            }
        </ul>
    </div>
</nav>

@code {
    protected override void OnInitialized()
    {
        AuthStateService.OnAuthenticationStateChanged += OnAuthenticationStateChanged;
    }

    private void OnAuthenticationStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AuthStateService.OnAuthenticationStateChanged -= OnAuthenticationStateChanged;
    }
}
