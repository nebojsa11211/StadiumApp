@page "/logs"
@layout MobileShell
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Customer.Components
@inject IApiService ApiService

<PageTitle>Moja aktivnost — HALFTIME</PageTitle>

<ScreenHeader Title="Moja aktivnost" Subtitle="Zapisi & privatnost" ShowBack="false" />

<AuthenticationGuard>
    <div id="customer-logs-container" class="act-body no-scrollbar">

        <div id="customer-logs-info-alert" class="act-note">
            ℹ️ Ova stranica prikazuje tvoju aktivnost u sustavu naručivanja. Radnje se bilježe kako bismo poboljšali iskustvo i pružili podršku.
        </div>

        <div id="customer-logs-cards" class="act-cards">
            <div id="customer-logs-order-card" class="act-card">
                <div class="act-card-icon">🍺</div>
                <div class="act-card-body">
                    <span class="act-card-title">Narudžbe</span>
                    <span class="act-card-desc">Sve narudžbe pića, izmjene i plaćanja bilježe se u tvojoj evidenciji.</span>
                </div>
                <button id="customer-log-order-activity-btn" class="btn btn-ghost btn-sm" @onclick="@(() => LogSampleActivity("PlaceOrder", "UserAction", "Viewed order activity information"))">Zabilježi primjer</button>
            </div>

            <div id="customer-logs-qr-card" class="act-card">
                <div class="act-card-icon">🎫</div>
                <div class="act-card-body">
                    <span class="act-card-title">Provjera ulaznice</span>
                    <span class="act-card-desc">Skeniranja QR koda i provjere ulaznica bilježe se radi sigurnosti.</span>
                </div>
                <button id="customer-log-qr-activity-btn" class="btn btn-ghost btn-sm" @onclick="@(() => LogSampleActivity("ScanQRCode", "UserAction", "Viewed QR code activity information"))">Zabilježi primjer</button>
            </div>

            <div id="customer-logs-auth-card" class="act-card">
                <div class="act-card-icon">🔐</div>
                <div class="act-card-body">
                    <span class="act-card-title">Prijava</span>
                    <span class="act-card-desc">Pokušaji prijave i sigurnosne radnje prate se radi zaštite računa.</span>
                </div>
                <button id="customer-log-auth-activity-btn" class="btn btn-ghost btn-sm" @onclick="@(() => LogSampleActivity("Login", "Authentication", "Viewed authentication activity information"))">Zabilježi primjer</button>
            </div>
        </div>

        <div id="customer-logs-info-section-card" class="act-info">
            <span class="act-info-title">Zašto bilježimo aktivnost?</span>
            <ul class="act-list">
                <li><strong>Povijest narudžbi</strong> — potpuna evidencija svih narudžbi i kupnji.</li>
                <li><strong>Podrška</strong> — detaljni zapisi pomažu našem timu da ti brže pomogne.</li>
                <li><strong>Sigurnost</strong> — praćenje prijava i autentifikacije radi zaštite računa.</li>
                <li><strong>Poboljšanja</strong> — obrasci korištenja pomažu nam unaprijediti iskustvo.</li>
            </ul>

            <div id="customer-logs-privacy-alert" class="act-privacy">
                🛡️ <strong>Privatnost:</strong> tvoji su zapisi povjerljivi i koriste se samo za poboljšanje usluge i podršku. Pristup imaju samo administratori i ovlašteno osoblje.
            </div>

            <span class="act-info-title">Nedavne aktivnosti uključuju</span>
            <ul class="act-checks">
                <li>Navigaciju stranicama (Meni, Narudžbe…)</li>
                <li>Skeniranje i provjeru QR koda</li>
                <li>Dodavanje pića u košaricu</li>
                <li>Slanje i izmjene narudžbi</li>
                <li>Plaćanja</li>
                <li>Prijave i autentifikaciju</li>
            </ul>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div id="customer-logs-status-alert" class="act-toast @(isSuccessMessage ? "ok" : "bad")">
            <span>@statusMessage</span>
            <button id="customer-log-alert-close-btn" class="act-toast-x" @onclick="() => statusMessage = null" aria-label="Zatvori">✕</button>
        </div>
    }
</AuthenticationGuard>

@code {
    private string? statusMessage;
    private bool isSuccessMessage = false;

    protected override async Task OnInitializedAsync()
    {
        await ApiService.LogUserActionAsync("ViewActivityPage", "UserAction", "Customer viewed their activity page");
    }

    private async Task LogSampleActivity(string action, string category, string details)
    {
        try
        {
            var success = await ApiService.LogUserActionAsync(action, category, details);
            if (success)
            {
                statusMessage = $"Aktivnost „{action}\" je zabilježena. Ovako pratimo tvoje radnje.";
                isSuccessMessage = true;
            }
            else
            {
                statusMessage = "Bilježenje nije uspjelo. Pokušaj ponovno.";
                isSuccessMessage = false;
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Pogreška pri bilježenju: {ex.Message}";
            isSuccessMessage = false;
        }

        StateHasChanged();
        await Task.Delay(5000);
        statusMessage = null;
        StateHasChanged();
    }
}
