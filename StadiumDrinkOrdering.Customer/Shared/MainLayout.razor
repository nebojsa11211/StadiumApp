@code {
    private bool isUserMenuOpen = false;
    private bool isMobileMenuOpen = false;

    protected override void OnInitialized()
    {
        AuthStateService.OnAuthenticationStateChanged += OnAuthenticationStateChanged;
    }

    private void OnAuthenticationStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void ToggleUserMenu()
    {
        isUserMenuOpen = !isUserMenuOpen;
        if (isUserMenuOpen) isMobileMenuOpen = false;
    }

    private void ToggleMobileMenu()
    {
        isMobileMenuOpen = !isMobileMenuOpen;
        if (isMobileMenuOpen) isUserMenuOpen = false;
    }

    private void HandleOrderStatusChanged(string statusUpdate)
    {
        // Handle real-time order status updates
        StateHasChanged();
    }

    private void HandleNotification(string notification)
    {
        // Handle real-time notifications
        StateHasChanged();
    }

    private async Task HandleLogout()
    {
        isUserMenuOpen = false;
        isMobileMenuOpen = false;
        await AuthStateService.LogoutAsync();
        NavigationManager.NavigateTo("/");
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "U";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            var firstInitial = parts[0].Length > 0 ? parts[0][0].ToString() : "";
            var secondInitial = parts[1].Length > 0 ? parts[1][0].ToString() : "";
            return (firstInitial + secondInitial).ToUpper();
        }
        return name.Length > 0 ? name.Substring(0, Math.Min(2, name.Length)).ToUpper() : "U";
    }

    public void Dispose()
    {
        AuthStateService.OnAuthenticationStateChanged -= OnAuthenticationStateChanged;
    }
}
