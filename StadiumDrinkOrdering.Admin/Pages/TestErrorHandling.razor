@page "/test-error-handling"
@using Microsoft.Extensions.Localization
@using StadiumDrinkOrdering.Admin
@inject IStringLocalizer<SharedResources> L

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3>🧪 @L["TestError_Title"]</h3>
                    <p class="mb-0">@L["TestError_Subtitle"]</p>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h4>@L["TestError_ManualTests"]</h4>
                            <div class="d-grid gap-2">
                                <button class="btn btn-danger" @onclick="TestErrorNotification" id="admin-test-error-btn">
                                    🔴 @L["TestError_TestErrorMsg"]
                                </button>
                                <button class="btn btn-warning" @onclick="TestWarningNotification" id="admin-test-warning-btn">
                                    🟡 @L["TestError_TestWarningMsg"]
                                </button>
                                <button class="btn btn-success" @onclick="TestSuccessNotification" id="admin-test-success-btn">
                                    🟢 @L["TestError_TestSuccessMsg"]
                                </button>
                                <button class="btn btn-info" @onclick="TestInfoNotification" id="admin-test-info-btn">
                                    🔵 @L["TestError_TestInfoMsg"]
                                </button>
                                <button class="btn btn-secondary" @onclick="TestAuthError" id="admin-test-auth-error-btn">
                                    🔐 @L["TestError_TestAuthError"]
                                </button>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <h4>@L["TestError_ApiTests"]</h4>
                            <div class="d-grid gap-2">
                                <button class="btn btn-outline-danger" @onclick="TestApiConnection" id="admin-test-api-connection-btn">
                                    🌐 @L["TestError_TestApiConnection"]
                                </button>
                                <button class="btn btn-outline-warning" @onclick="TestDrinksFetch" id="admin-test-drinks-fetch-btn">
                                    🥤 @L["TestError_TestDrinksFetch"]
                                </button>
                                <button class="btn btn-outline-info" @onclick="TestOrdersFetch" id="admin-test-orders-fetch-btn">
                                    📦 @L["TestError_TestOrdersFetch"]
                                </button>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="alert alert-info">
                        <h5>📋 @L["TestError_Results"]</h5>
                        <p>@L["TestError_ResultsNote"]</p>
                        <ul>
                            <li>✅ <strong>@L["Success"]</strong>: @L["TestError_SuccessDesc"]</li>
                            <li>⚠️ <strong>@L["TestError_Warning"]</strong>: @L["TestError_WarningDesc"]</li>
                            <li>❌ <strong>@L["ErrorOccurred"]</strong>: @L["TestError_ErrorDesc"]</li>
                            <li>ℹ️ <strong>@L["TestError_Info"]</strong>: @L["TestError_InfoDesc"]</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

