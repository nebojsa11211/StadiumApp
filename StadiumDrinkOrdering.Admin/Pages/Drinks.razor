@page "/drinks"
@using StadiumDrinkOrdering.Shared.Models
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Drinks_PageTitle"]</PageTitle>

<div class="console" id="admin-drinks-container">
    <!-- Page Header -->
    <PageHeader Id="admin-drinks-header"
                Eyebrow='@L["Drinks_EyebrowLabel"]'
                Title='@L["Drinks_MainTitle"]'
                Subtitle='@L["Drinks_Subtitle"]'>
        <Actions>
            <button class="pill-btn pill-btn--primary" @onclick="ShowCreateDrinkModal" id="admin-add-drink-btn">
                <i class="bi bi-plus-lg"></i><span>@L["Drinks_AddNewDrinkButton"]</span>
            </button>
        </Actions>
    </PageHeader>

    @if (drinks == null)
    {
        <div class="loading-state" id="admin-drinks-loading">
            <span class="loading-spinner"></span>
            <p>@L["Drinks_LoadingMessage"]</p>
        </div>
    }
    else if (loadingFailed)
    {
        <div class="console-alert console-alert--danger" role="alert" id="admin-drinks-error">
            <i class="bi bi-exclamation-triangle"></i>
            <div>
                <strong>@L["Drinks_ErrorLoadingTitle"]</strong>
                <div>@loadingError</div>
            </div>
            <button class="pill-btn" style="margin-left:auto;" @onclick="async () => await LoadDrinks()" id="admin-drinks-retry-btn">
                <i class="bi bi-arrow-clockwise"></i><span>@L["Drinks_RetryButton"]</span>
            </button>
        </div>
    }
    else if (!drinks.Any())
    {
        <div class="empty" id="admin-drinks-empty">
            <i class="bi bi-cup-straw"></i>
            <p id="admin-drinks-empty-title">@L["Drinks_NoDrinksFound"]</p>
            <span id="admin-drinks-empty-message">@L["Drinks_StartByAddingMessage"]</span>
            <div style="margin-top:1rem;" id="admin-drinks-empty-button-container">
                <button class="pill-btn pill-btn--primary" @onclick="ShowCreateDrinkModal" id="admin-add-first-drink-btn">
                    <i class="bi bi-plus"></i><span>@L["Drinks_AddFirstDrinkButton"]</span>
                </button>
            </div>
        </div>
    }
    else
    {
        <!-- Key Metrics -->
        <section class="metrics" id="admin-drinks-metrics">
            <article class="metric" id="admin-drinks-metric-total">
                <div class="metric__head" id="admin-drinks-metric-total-head">
                    <span class="metric__label">@L["Drinks_TotalDrinksLabel"]</span>
                    <i class="bi bi-cup-straw metric__icon"></i>
                </div>
                <div class="metric__value mono" id="admin-drinks-metric-total-value">@drinks.Count</div>
                <div class="metric__foot" id="admin-drinks-metric-total-foot">
                    <span class="metric__hint">@L["Drinks_InCatalogHint"]</span>
                </div>
            </article>

            <article class="metric metric--accent" id="admin-drinks-metric-available">
                <div class="metric__head" id="admin-drinks-metric-available-head">
                    <span class="metric__label">@L["Drinks_AvailableLabel"]</span>
                    <i class="bi bi-check-circle metric__icon is-ok"></i>
                </div>
                <div class="metric__value mono" id="admin-drinks-metric-available-value">@drinks.Count(d => d.IsAvailable)</div>
                <div class="metric__foot" id="admin-drinks-metric-available-foot">
                    <span class="metric__hint">@L["Drinks_OrderableNowHint"]</span>
                </div>
            </article>

            <article class="metric" id="admin-drinks-metric-lowstock">
                <div class="metric__head" id="admin-drinks-metric-lowstock-head">
                    <span class="metric__label">@L["Drinks_LowStockLabel"]</span>
                    <i class="bi bi-exclamation-triangle metric__icon"></i>
                </div>
                <div class="metric__value mono" id="admin-drinks-metric-lowstock-value">@drinks.Count(d => d.StockQuantity < LowStockThreshold)</div>
                <div class="metric__foot" id="admin-drinks-metric-lowstock-foot">
                    <span class="metric__hint">@L["Drinks_BelowUnitsHint"]</span>
                </div>
            </article>

            <article class="metric" id="admin-drinks-metric-categories">
                <div class="metric__head" id="admin-drinks-metric-categories-head">
                    <span class="metric__label">@L["Drinks_CategoriesLabel"]</span>
                    <i class="bi bi-tags metric__icon"></i>
                </div>
                <div class="metric__value mono" id="admin-drinks-metric-categories-value">@drinks.Select(d => d.CategoryId).Distinct().Count()</div>
                <div class="metric__foot" id="admin-drinks-metric-categories-foot">
                    <span class="metric__hint">@L["Drinks_DistinctTypesHint"]</span>
                </div>
            </article>
        </section>

        <!-- Filter Controls -->
        <div class="panel" id="admin-drinks-filter-card">
            <div class="panel__head" id="admin-drinks-filter-header">
                <h2 class="panel__title" id="admin-drinks-filter-title">@L["Drinks_FilterDrinksTitle"]</h2>
            </div>
            <div class="filters" id="admin-drinks-filter-body">
                <div class="field" id="admin-drinks-filter-category-field">
                    <label class="field__label" for="admin-category-filter">@L["Drinks_CategoryLabel"]</label>
                    <select class="field__input" @bind="selectedCategory" @bind:after="StateHasChanged" id="admin-category-filter">
                        <option value="">@L["Drinks_AllCategoriesOption"]</option>
                        @foreach (var category in categories)
                        {
                            <option value="@category.Id">@category.Icon @category.Name</option>
                        }
                    </select>
                </div>
                <div class="field" id="admin-drinks-filter-availability-field">
                    <label class="field__label" for="admin-availability-filter">@L["Drinks_AvailabilityLabel"]</label>
                    <select class="field__input" @bind="availabilityFilter" @bind:after="StateHasChanged" id="admin-availability-filter">
                        <option value="">@L["Drinks_AllDrinksOption"]</option>
                        <option value="available">@L["Drinks_AvailableOnlyOption"]</option>
                        <option value="unavailable">@L["Drinks_UnavailableOnlyOption"]</option>
                        <option value="lowstock">@L["Drinks_LowStockOption"]</option>
                    </select>
                </div>
                <div class="field field--grow" id="admin-drinks-filter-search-field">
                    <label class="field__label" for="admin-search-filter">@L["Drinks_SearchLabel"]</label>
                    <input type="text" class="field__input" placeholder="@L["Drinks_SearchPlaceholder"]"
                           @bind="searchTerm" @bind:after="StateHasChanged" id="admin-search-filter" />
                </div>
            </div>
        </div>

        <!-- Drinks Table -->
        <div class="panel" id="admin-drinks-table-panel">
            <div class="panel__head" id="admin-drinks-table-header">
                <h2 class="panel__title" id="admin-drinks-table-title">@L["Drinks_DrinksTableTitle"] <span class="panel__count mono">@FilteredDrinks.Count()</span></h2>
            </div>

            @{ pager.Source = FilteredDrinks.ToList(); }
            <table class="console-table" id="admin-drinks-grid">
                <thead id="admin-drinks-table-head">
                    <tr id="admin-drinks-table-header-row">
                        <th class="sortable @(sortState.IsSorted("name") ? "is-sorted" : "")" @onclick='() => SortBy("name")' id="admin-drinks-th-drink">@L["Drinks_DrinkColumnHeader"]<span class="sort-ind">@sortState.Indicator("name")</span></th>
                        <th class="sortable @(sortState.IsSorted("category") ? "is-sorted" : "")" @onclick='() => SortBy("category")' id="admin-drinks-th-category">@L["Drinks_CategoryColumnHeader"]<span class="sort-ind">@sortState.Indicator("category")</span></th>
                        <th class="sortable @(sortState.IsSorted("description") ? "is-sorted" : "")" @onclick='() => SortBy("description")' id="admin-drinks-th-description">@L["Drinks_DescriptionColumnHeader"]<span class="sort-ind">@sortState.Indicator("description")</span></th>
                        <th class="num sortable @(sortState.IsSorted("price") ? "is-sorted" : "")" @onclick='() => SortBy("price")' id="admin-drinks-th-price">@L["Drinks_PriceColumnHeader"]<span class="sort-ind">@sortState.Indicator("price")</span></th>
                        <th class="num sortable @(sortState.IsSorted("stock") ? "is-sorted" : "")" @onclick='() => SortBy("stock")' id="admin-drinks-th-stock">@L["Drinks_StockColumnHeader"]<span class="sort-ind">@sortState.Indicator("stock")</span></th>
                        <th class="sortable @(sortState.IsSorted("status") ? "is-sorted" : "")" @onclick='() => SortBy("status")' id="admin-drinks-th-status">@L["Drinks_StatusColumnHeader"]<span class="sort-ind">@sortState.Indicator("status")</span></th>
                        <th class="actions-col" id="admin-drinks-th-actions">@L["Drinks_ActionsColumnHeader"]</th>
                    </tr>
                </thead>
                <tbody id="admin-drinks-table-body">
                    @foreach (var drink in pager.PageItems)
                    {
                        <tr id="admin-drink-card-@drink.Id">
                            <td>
                                <div class="drink-cell" id="admin-drink-@drink.Id">
                                    @if (!string.IsNullOrEmpty(drink.ImageUrl))
                                    {
                                        <img src="@drink.ImageUrl" class="drink-thumb" alt="@drink.Name" id="admin-drink-image-@drink.Id" />
                                    }
                                    else
                                    {
                                        <span class="drink-thumb drink-thumb--ph" id="admin-drink-placeholder-@drink.Id">🥤</span>
                                    }
                                    <span class="drink-name" id="admin-drink-name-@drink.Id">@drink.Name</span>
                                </div>
                            </td>
                            <td class="console-table__muted" id="admin-drink-category-@drink.Id">@drink.CategoryIcon @drink.CategoryName</td>
                            <td class="drink-desc" id="admin-drink-description-@drink.Id">@drink.Description</td>
                            <td class="num mono" id="admin-drink-price-@drink.Id">€@drink.Price.ToString("F2")</td>
                            <td class="num mono" id="admin-drink-stock-@drink.Id">@drink.StockQuantity</td>
                            <td id="admin-drink-status-cell-@drink.Id">
                                @if (!drink.IsAvailable)
                                {
                                    <span class="status is-cancelled" id="admin-drink-status-unavailable-@drink.Id">
                                        <span class="status__dot"></span>@L["Drinks_UnavailableStatus"]
                                    </span>
                                }
                                else if (drink.StockQuantity < LowStockThreshold)
                                {
                                    <span class="status is-pending" id="admin-drink-status-lowstock-@drink.Id">
                                        <span class="status__dot"></span>@L["Drinks_LowStockStatus"]
                                    </span>
                                }
                                else
                                {
                                    <span class="status is-active" id="admin-drink-status-available-@drink.Id">
                                        <span class="status__dot"></span>@L["Drinks_AvailableStatus"]
                                    </span>
                                }
                            </td>
                            <td class="actions-col" id="admin-drink-actions-cell-@drink.Id">
                                <div class="row-actions" id="admin-drink-row-actions-@drink.Id">
                                    <button class="row-btn row-btn--label row-btn--ok"
                                            @onclick="() => ShowRestockModal(drink)"
                                            id="admin-restock-drink-@drink.Id">
                                        <i class="bi bi-plus-circle"></i> @L["Drinks_AddStockButton"]
                                    </button>
                                    <button class="row-btn row-btn--label"
                                            @onclick="() => ShowHistoryModal(drink)"
                                            id="admin-drink-history-@drink.Id">
                                        <i class="bi bi-clock-history"></i> @L["Drinks_HistoryButton"]
                                    </button>
                                    <button class="row-btn row-btn--label"
                                            @onclick="() => ShowEditDrinkModal(drink)"
                                            id="admin-edit-drink-@drink.Id">
                                        <i class="bi bi-pencil"></i> @L["Drinks_EditButton"]
                                    </button>
                                    <button class="row-btn row-btn--label @(drink.IsAvailable ? "" : "row-btn--ok")"
                                            @onclick="() => ToggleAvailability(drink)"
                                            id="admin-toggle-availability-@drink.Id">
                                        @if (drink.IsAvailable)
                                        {
                                            <i class="bi bi-eye-slash"></i> <span id="admin-disable-text-@drink.Id">@L["Drinks_DisableButton"]</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-eye"></i> <span id="admin-enable-text-@drink.Id">@L["Drinks_EnableButton"]</span>
                                        }
                                    </button>
                                    <button class="row-btn row-btn--label row-btn--danger"
                                            @onclick="() => DeleteDrink(drink)"
                                            id="admin-delete-drink-@drink.Id">
                                        <i class="bi bi-trash"></i> @L["Drinks_DeleteButton"]
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <TablePager TItem="DrinkDto" View="pager" IdPrefix="admin-drinks-table" OnChanged="StateHasChanged" />
        </div>
    }
</div>

<!-- Create/Edit Drink Modal -->
@if (showDrinkModal)
{
    <div class="drink-modal-overlay" id="admin-drink-modal" @onclick="HideDrinkModal">
        <div class="drink-modal" @onclick:stopPropagation="true">
            <div class="drink-modal__content" id="admin-drink-modal-content">
                <header class="drink-modal__head" id="admin-drink-modal-header">
                    <div class="drink-modal__head-left">
                        <span class="drink-modal__icon"><i class="bi bi-cup-straw"></i></span>
                        <div class="drink-modal__head-text">
                            <span class="eyebrow">@L["Drinks_EyebrowLabel"]</span>
                            <h5 class="drink-modal__title" id="admin-drink-modal-title">@(editingDrink == null ? L["Drinks_AddNewDrinkModalTitle"] : L["Drinks_EditDrinkModalTitle"])</h5>
                        </div>
                    </div>
                    <button type="button" class="drink-modal__close" @onclick="HideDrinkModal" id="admin-drink-modal-close-btn" aria-label="Close">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </header>
                <div class="drink-modal__body" id="admin-drink-modal-body">
                    <div class="field" id="admin-drink-modal-name-field">
                        <label class="field__label" for="admin-drink-name">@L["Drinks_NameLabel"] *</label>
                        <input type="text" class="field__input" @bind="drinkForm.Name" required id="admin-drink-name">
                    </div>

                    <div class="field" id="admin-drink-modal-description-field">
                        <label class="field__label" for="admin-drink-description">@L["Drinks_DescriptionLabel"]</label>
                        <textarea class="field__input" rows="3" @bind="drinkForm.Description" id="admin-drink-description"></textarea>
                    </div>

                    <div class="drink-modal__row" id="admin-drink-modal-number-fields">
                        <div class="field field--grow" id="admin-drink-modal-price-field">
                            <label class="field__label" for="admin-drink-price">@L["Drinks_PriceLabel"] *</label>
                            <input type="number" class="field__input" @bind="drinkForm.Price"
                                   step="0.01" min="0" required id="admin-drink-price">
                        </div>
                        <div class="field field--grow" id="admin-drink-modal-stock-field">
                            <label class="field__label" for="admin-drink-stock">@L["Drinks_StockQuantityLabel"] *</label>
                            <input type="number" class="field__input" @bind="drinkForm.StockQuantity"
                                   min="0" required id="admin-drink-stock">
                        </div>
                    </div>

                    <div class="field" id="admin-drink-modal-category-field">
                        <label class="field__label" for="admin-drink-category">@L["Drinks_CategoryModalLabel"] *</label>
                        <select class="field__input" @bind="drinkForm.CategoryId" required id="admin-drink-category">
                            @foreach (var category in SelectableCategories)
                            {
                                <option value="@category.Id">@category.Icon @category.Name</option>
                            }
                        </select>
                    </div>

                    <div class="field" id="admin-drink-modal-image-field">
                        <label class="field__label" for="admin-drink-image">@L["Drinks_ImageUrlLabel"]</label>
                        <div class="drink-image-upload" id="admin-drink-image-upload">
                            <div class="drink-image-preview" id="admin-drink-image-preview">
                                @if (!string.IsNullOrWhiteSpace(drinkForm.ImageUrl))
                                {
                                    <img src="@drinkForm.ImageUrl" alt="@drinkForm.Name" id="admin-drink-image-preview-img" />
                                }
                                else
                                {
                                    <span class="drink-image-preview__ph" id="admin-drink-image-preview-ph">🥤</span>
                                }
                            </div>
                            <div class="drink-image-upload__controls" id="admin-drink-image-controls">
                                <input type="url" class="field__input" @bind="drinkForm.ImageUrl"
                                       placeholder="@L["Drinks_ImageUrlPlaceholder"]" id="admin-drink-image">
                                <div class="drink-image-upload__actions" id="admin-drink-image-actions">
                                    <label class="pill-btn @(isUploadingImage ? "disabled" : "")" id="admin-drink-image-upload-label">
                                        @if (isUploadingImage)
                                        {
                                            <span class="spinner-border spinner-border-sm" id="admin-drink-image-spinner"></span>
                                            <span>@L["Drinks_UploadingImage"]</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-upload"></i>
                                            <span>@L["Drinks_UploadImageButton"]</span>
                                        }
                                        <InputFile OnChange="OnImageSelected" accept="image/*" class="d-none"
                                                   disabled="@isUploadingImage" id="admin-drink-image-input" />
                                    </label>
                                    @if (!string.IsNullOrWhiteSpace(drinkForm.ImageUrl))
                                    {
                                        <button type="button" class="pill-btn pill-btn--danger" @onclick="ClearImage" id="admin-drink-image-remove-btn">
                                            <i class="bi bi-trash"></i><span>@L["Drinks_RemoveImageButton"]</span>
                                        </button>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(imageError))
                                {
                                    <span class="drink-image-upload__error" id="admin-drink-image-error">@imageError</span>
                                }
                            </div>
                        </div>
                    </div>

                    <label class="drink-check" id="admin-drink-available-label">
                        <input type="checkbox" class="check-box" @bind="drinkForm.IsAvailable" id="admin-drink-available">
                        <span>@L["Drinks_AvailableForOrderingLabel"]</span>
                    </label>
                </div>
                <footer class="drink-modal__foot" id="admin-drink-modal-footer">
                    <button type="button" class="pill-btn" @onclick="HideDrinkModal" id="admin-drink-modal-cancel-btn">
                        @L["Drinks_CancelButton"]
                    </button>
                    <button type="button" class="pill-btn pill-btn--primary" @onclick="SaveDrink" disabled="@isSaving" id="admin-drink-modal-save-btn">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2" id="admin-drink-saving-spinner"></span>
                        }
                        @(editingDrink == null ? L["Drinks_CreateDrinkButton"] : L["Drinks_SaveChangesButton"])
                    </button>
                </footer>
            </div>
        </div>
    </div>
}

<!-- Add Stock (Restock) Modal -->
@if (showRestockModal && restockDrink != null)
{
    <div class="drink-modal-overlay" id="admin-restock-modal" @onclick="HideRestockModal">
        <div class="drink-modal drink-modal--sm" @onclick:stopPropagation="true">
            <div class="drink-modal__content" id="admin-restock-modal-content">
                <header class="drink-modal__head" id="admin-restock-modal-header">
                    <div class="drink-modal__head-left">
                        <span class="drink-modal__icon"><i class="bi bi-plus-circle"></i></span>
                        <div class="drink-modal__head-text">
                            <span class="eyebrow">@L["Drinks_AddStockEyebrow"]</span>
                            <h5 class="drink-modal__title" id="admin-restock-modal-title">@restockDrink.Name</h5>
                        </div>
                    </div>
                    <button type="button" class="drink-modal__close" @onclick="HideRestockModal" id="admin-restock-modal-close-btn" aria-label="Close">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </header>
                <div class="drink-modal__body" id="admin-restock-modal-body">
                    <p class="text-muted" id="admin-restock-current-stock">
                        @L["Drinks_RestockCurrentStock"]: <strong class="mono">@restockDrink.StockQuantity</strong>
                    </p>
                    <div class="field" id="admin-restock-quantity-field">
                        <label class="field__label" for="admin-restock-quantity">@L["Drinks_RestockQuantityLabel"] *</label>
                        <input type="number" class="field__input" @bind="restockQuantity"
                               min="1" step="1" required id="admin-restock-quantity">
                    </div>
                    <div class="field" id="admin-restock-note-field">
                        <label class="field__label" for="admin-restock-note">@L["Drinks_RestockNoteLabel"]</label>
                        <input type="text" class="field__input" @bind="restockNote"
                               maxlength="500" placeholder="@L["Drinks_RestockNotePlaceholder"]" id="admin-restock-note">
                    </div>
                    @if (restockQuantity > 0)
                    {
                        <p class="text-muted" id="admin-restock-new-stock">
                            @L["Drinks_RestockNewStock"]: <strong class="mono">@(restockDrink.StockQuantity + restockQuantity)</strong>
                        </p>
                    }
                </div>
                <footer class="drink-modal__foot" id="admin-restock-modal-footer">
                    <button type="button" class="pill-btn" @onclick="HideRestockModal" id="admin-restock-modal-cancel-btn">
                        @L["Drinks_CancelButton"]
                    </button>
                    <button type="button" class="pill-btn pill-btn--primary" @onclick="SubmitRestock" disabled="@isRestocking" id="admin-restock-modal-save-btn">
                        @if (isRestocking)
                        {
                            <span class="spinner-border spinner-border-sm me-2" id="admin-restock-saving-spinner"></span>
                        }
                        @L["Drinks_AddStockButton"]
                    </button>
                </footer>
            </div>
        </div>
    </div>
}

<!-- Stock History Modal -->
@if (showHistoryModal && historyDrink != null)
{
    <div class="drink-modal-overlay" id="admin-history-modal" @onclick="HideHistoryModal">
        <div class="drink-modal" @onclick:stopPropagation="true">
            <div class="drink-modal__content" id="admin-history-modal-content">
                <header class="drink-modal__head" id="admin-history-modal-header">
                    <div class="drink-modal__head-left">
                        <span class="drink-modal__icon"><i class="bi bi-clock-history"></i></span>
                        <div class="drink-modal__head-text">
                            <span class="eyebrow">@L["Drinks_HistoryEyebrow"]</span>
                            <h5 class="drink-modal__title" id="admin-history-modal-title">@historyDrink.Name</h5>
                        </div>
                    </div>
                    <button type="button" class="drink-modal__close" @onclick="HideHistoryModal" id="admin-history-modal-close-btn" aria-label="Close">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </header>
                <div class="drink-modal__body" id="admin-history-modal-body">
                    @if (loadingHistory)
                    {
                        <div class="loading-state" id="admin-history-loading">
                            <span class="loading-spinner"></span>
                            <p>@L["Drinks_HistoryLoading"]</p>
                        </div>
                    }
                    else if (stockMovements == null || !stockMovements.Any())
                    {
                        <div class="empty" id="admin-history-empty">
                            <i class="bi bi-clock-history"></i>
                            <p>@L["Drinks_HistoryEmpty"]</p>
                        </div>
                    }
                    else
                    {
                        <table class="console-table" id="admin-history-table">
                            <thead>
                                <tr>
                                    <th id="admin-history-th-date">@L["Drinks_HistoryDateColumn"]</th>
                                    <th id="admin-history-th-type">@L["Drinks_HistoryTypeColumn"]</th>
                                    <th class="num" id="admin-history-th-change">@L["Drinks_HistoryChangeColumn"]</th>
                                    <th class="num" id="admin-history-th-balance">@L["Drinks_HistoryBalanceColumn"]</th>
                                    <th id="admin-history-th-by">@L["Drinks_HistoryByColumn"]</th>
                                    <th id="admin-history-th-note">@L["Drinks_HistoryNoteColumn"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var m in stockMovements)
                                {
                                    <tr id="admin-history-row-@m.Id">
                                        <td class="console-table__muted mono">@m.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>
                                            <span class="status @MovementBadgeClass(m.Type)">
                                                <span class="status__dot"></span>@MovementTypeLabel(m.Type)
                                            </span>
                                        </td>
                                        <td class="num mono @(m.Delta >= 0 ? "text-success" : "text-danger")">@(m.Delta > 0 ? "+" : "")@m.Delta</td>
                                        <td class="num mono">@m.QuantityAfter</td>
                                        <td class="console-table__muted">@(string.IsNullOrEmpty(m.UserEmail) ? L["Drinks_HistorySystemActor"] : m.UserEmail)</td>
                                        <td class="console-table__muted">
                                            @if (m.OrderId.HasValue)
                                            {
                                                <span>#@m.OrderId </span>
                                            }
                                            @m.Note
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
                <footer class="drink-modal__foot" id="admin-history-modal-footer">
                    <button type="button" class="pill-btn" @onclick="HideHistoryModal" id="admin-history-modal-close-footer-btn">
                        @L["Drinks_CloseButton"]
                    </button>
                </footer>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(alertMessage))
{
    <div class="position-fixed top-0 end-0 p-3" style="z-index: 1055;" id="admin-alert-container">
        <div class="console-alert @(alertType == "success" ? "console-alert--success" : "console-alert--danger")" id="admin-alert-message">
            <span>@alertMessage</span>
            <button type="button" class="btn-close" style="margin-left:auto;" @onclick="ClearAlert" id="admin-drinks-alert-close-btn"></button>
        </div>
    </div>
}
