@page "/set-password"
@layout MobileShell
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Customer.Services
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.Localization
@inject IApiService Api
@inject ICustomerAuthStateService AuthState
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["SetPassword_PageTitle"]</PageTitle>

<ScreenHeader Title="@Localizer["SetPassword_ScreenHeader_Title"]" Subtitle="@Localizer["SetPassword_ScreenHeader_Subtitle"]" BackHref="/login" />

<div id="customer-setpassword-container" class="setpw-body">
    @if (_loading)
    {
        <div id="customer-setpassword-loading" class="setpw-loading">
            <span class="spinner" id="customer-setpassword-loading-spinner"></span>
            <span>@Localizer["SetPassword_CheckingLink"]</span>
        </div>
    }
    else if (!_valid)
    {
        <div id="customer-setpassword-invalid" class="setpw-hero">
            <div class="badge">@Localizer["SetPassword_LinkInvalid_Badge"]</div>
            <h1 class="display">@Localizer["SetPassword_LinkInvalid_Title"]</h1>
            <div id="customer-setpassword-invalid-message" class="err">@_invalidMessage</div>
            <p class="alt"><a id="customer-setpassword-login-link" href="/login">@Localizer["SetPassword_LoginLink"]</a></p>
        </div>
    }
    else
    {
        <div id="customer-setpassword-hero" class="setpw-hero">
            <div id="customer-setpassword-badge" class="badge">@Localizer["SetPassword_Welcome_Badge"]</div>
            <h1 id="customer-setpassword-title" class="display">@Localizer["SetPassword_SetPassword_Title"]</h1>
            <p id="customer-setpassword-greeting">
                @if (!string.IsNullOrWhiteSpace(_fullName))
                {
                    @Localizer["SetPassword_GreetingHi", _fullName]
                }
                @Localizer["SetPassword_GreetingMain", string.IsNullOrWhiteSpace(_email) ? "" : $" ({_email})"]
            </p>
        </div>

        <EditForm Model="@_model" OnValidSubmit="@HandleSubmit" class="setpw-form" id="customer-setpassword-form">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(_error))
            {
                <div id="customer-setpassword-error" class="err">@_error</div>
            }

            <div id="customer-setpassword-password-group" class="field">
                <label for="customer-setpassword-password-input">@Localizer["SetPassword_NewPasswordLabel"]</label>
                <InputText id="customer-setpassword-password-input" type="password" @bind-Value="_model.NewPassword" placeholder="••••••••" autocomplete="new-password" />
                <ValidationMessage For="@(() => _model.NewPassword)" class="verr" />
                <span class="setpw-hint">@Localizer["SetPassword_PasswordHint"]</span>
            </div>

            <div id="customer-setpassword-confirm-group" class="field">
                <label for="customer-setpassword-confirm-input">@Localizer["SetPassword_ConfirmPasswordLabel"]</label>
                <InputText id="customer-setpassword-confirm-input" type="password" @bind-Value="_model.ConfirmPassword" placeholder="••••••••" autocomplete="new-password" />
                <ValidationMessage For="@(() => _model.ConfirmPassword)" class="verr" />
            </div>

            <button type="submit" class="btn btn-primary" disabled="@_busy" id="customer-setpassword-submit-btn">
                @if (_busy)
                {
                    <span class="spinner" id="customer-setpassword-spinner"></span> <span id="customer-setpassword-loading-text">@Localizer["SetPassword_ActivatingButton"]</span>
                }
                else
                {
                    <span id="customer-setpassword-button-text">@Localizer["SetPassword_ActivateButton"]</span>
                }
            </button>
        </EditForm>
    }
</div>

@code {
    private readonly SetPasswordModel _model = new();
    private string? _token;
    private bool _loading = true;
    private bool _valid;
    private bool _busy;
    private string? _error;
    private string? _invalidMessage;
    private string? _email;
    private string? _fullName;

    public class SetPasswordModel
    {
        [Required(ErrorMessage = "Lozinka je obavezna")]
        [StringLength(100, MinimumLength = 6, ErrorMessage = "Lozinka mora imati najmanje 6 znakova")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "Potvrdi lozinku")]
        [Compare(nameof(NewPassword), ErrorMessage = "Lozinke se ne podudaraju")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        var query = QueryHelpers.ParseQuery(new Uri(Nav.Uri).Query);
        _token = query.TryGetValue("token", out var t) ? t.ToString() : null;

        if (string.IsNullOrWhiteSpace(_token))
        {
            _valid = false;
            _invalidMessage = Localizer["SetPassword_LinkNotFound"];
            _loading = false;
            return;
        }

        try
        {
            var info = await Api.GetActivationInfoAsync(_token);
            if (info is { Valid: true })
            {
                _valid = true;
                _email = info.Email;
                _fullName = info.FullName;
            }
            else
            {
                _valid = false;
                _invalidMessage = MapReason(info?.Reason);
            }
        }
        catch (Exception)
        {
            _valid = false;
            _invalidMessage = Localizer["SetPassword_CheckError"];
        }
        finally
        {
            _loading = false;
        }
    }

    private string MapReason(string? reason) => reason switch
    {
        "NotFound" => Localizer["SetPassword_LinkNotFound"],
        "Expired" => Localizer["SetPassword_LinkExpired"],
        "AlreadyUsed" => Localizer["SetPassword_LinkAlreadyUsed"],
        "AlreadyActive" => Localizer["SetPassword_AccountAlreadyActive"],
        _ => Localizer["SetPassword_LinkInvalid"]
    };

    private async Task HandleSubmit()
    {
        if (_busy || string.IsNullOrWhiteSpace(_token)) return;
        _busy = true;
        _error = null;

        try
        {
            var dto = new ActivateAccountDto
            {
                Token = _token,
                NewPassword = _model.NewPassword,
                ConfirmPassword = _model.ConfirmPassword
            };

            var (ok, error, result) = await Api.ActivateAccountAsync(dto);

            if (ok && result?.Token != null && result.User != null)
            {
                // Log the fan in exactly like Login.razor does: persist token + user via the shared auth-state service.
                await AuthState.LoginAsync(result.Token, result.User);
                Nav.NavigateTo("/home", forceLoad: false);
            }
            else
            {
                _error = error ?? Localizer["SetPassword_ActivationFailed"];
            }
        }
        catch (Exception)
        {
            _error = Localizer["SetPassword_GeneralError"];
        }
        finally
        {
            _busy = false;
        }
    }
}

