@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["AuthLayout_Title"]</PageTitle>

<div class="auth-page">
    <main class="auth-main">
        @Body
    </main>
</div>

<style>
    .auth-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }
    
    .auth-main {
        width: 100%;
        max-width: 500px;
    }
</style>