@page "/t/{Token}"
@layout MobileShell
@using StadiumDrinkOrdering.Customer.Services
@using Microsoft.Extensions.Localization
@inject OrderSessionState State
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> Localizer
@implements IDisposable

<PageTitle>HALFTIME</PageTitle>

<div id="customer-resolve-container" class="resolve">
    @if (_phase == Phase.Validating)
    {
        <div id="customer-resolve-validating" class="center">
            <span class="spinner big"></span>
            <p>@Localizer["Resolve_ValidatingTicket"]</p>
        </div>
    }
    else if (_phase == Phase.Ready)
    {
        <div id="customer-resolve-ready" class="center">
            <div id="customer-resolve-tick" class="tick">✓</div>
            <h2>@Localizer["Resolve_Ready_Title"]</h2>
            <div id="customer-resolve-seatcard" class="seatcard">
                <div id="customer-resolve-match" class="match">@State.EventName</div>
                <div id="customer-resolve-row" class="row"><span>@Localizer["Resolve_Seat_Label"]</span><b>@State.SeatText</b></div>
            </div>
            <div id="customer-resolve-redirecting" class="redirecting"><span class="spinner"></span> @Localizer["Resolve_Redirecting"]</div>
            <button id="customer-resolve-start-order-btn" class="btn btn-primary" @onclick="Go">@Localizer["Resolve_StartOrdering_Button"]</button>
        </div>
    }
    else
    {
        <div id="customer-resolve-error" class="center">
            <div id="customer-resolve-cross" class="cross">✕</div>
            <h2>@Localizer["Resolve_Error_Title"]</h2>
            <p class="err">@_error</p>
            <button id="customer-resolve-retry-scan-btn" class="btn btn-primary" @onclick="@(() => Nav.NavigateTo("/scan"))">@Localizer["Resolve_RescanButton"]</button>
            <button id="customer-resolve-home-btn" class="btn btn-ghost" @onclick="@(() => Nav.NavigateTo("/welcome"))">@Localizer["Resolve_Home_Button"]</button>
        </div>
    }
</div>

@code {
    [Parameter] public string Token { get; set; } = "";

    private enum Phase { Validating, Ready, Failed }
    private Phase _phase = Phase.Validating;
    private string? _error;
    private Timer? _forward;
    private bool _started;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Resolve the ticket exactly once, and ONLY on the interactive client.
        // OnAfterRenderAsync never runs during ServerPrerendered prerendering, so doing the
        // resolve here (instead of OnInitializedAsync) avoids the double-execution that would
        // consume a single-use ticket during prerender and then fail the interactive render
        // with "already used". The page shows the "Validating" spinner until this completes.
        if (!firstRender || _started) return;
        _started = true;

        // Device binding: the ordering session's id is a per-device secret. We persist it in localStorage
        // keyed by this ticket's QR, so re-scanning/reloading on the SAME device presents it and resumes
        // the live session. A different phone has no stored token → the API turns it away as a second
        // device. Reading may throw on a locked/unavailable store; treat that as "no stored token".
        var deviceKey = $"ht.session.{Token}";
        string? deviceToken = null;
        try { deviceToken = await JS.InvokeAsync<string?>("localStorage.getItem", deviceKey); }
        catch { /* localStorage unavailable — proceed as a fresh device */ }

        var (ok, error) = await State.InitFromQrAsync(Token, deviceToken);
        _phase = ok ? Phase.Ready : Phase.Failed;
        _error = error;
        StateHasChanged();

        if (_phase != Phase.Ready) return;

        // Remember this device's claim (persistent) so a later re-scan resumes instead of being blocked.
        try { await JS.InvokeVoidAsync("localStorage.setItem", deviceKey, State.SessionToken); }
        catch { /* localStorage unavailable — same-device resume just won't be possible */ }

        // Persist the session token so a hard reload on /order or /track can recover it.
        await JS.InvokeVoidAsync("sessionStorage.setItem", "htSessionToken", State.SessionToken);

        // "Immediately redirected": auto-forward into ordering after a brief confirmation beat.
        _forward = new Timer(_ => InvokeAsync(Go), null, 1300, Timeout.Infinite);
    }

    private void Go()
    {
        _forward?.Dispose();
        Nav.NavigateTo("/order");
    }

    public void Dispose() => _forward?.Dispose();
}
