@page "/orders"
@using StadiumDrinkOrdering.Shared.Models
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Orders_PageTitle"]</PageTitle>

<div class="console" id="admin-orders-main-container">
    <!-- Page Header -->
    <header class="console-head" id="admin-orders-header">
        <div class="console-head__title" id="admin-orders-title-section">
            <span class="eyebrow">@L["Orders_Eyebrow"]</span>
            <h1>@L["Orders_Title"]</h1>
            <p>@L["Orders_Subtitle"]</p>
        </div>
        <div class="console-head__actions" id="admin-orders-action-buttons">
            <button class="pill-btn pill-btn--primary" @onclick="CreateNewOrder" id="admin-orders-create-btn">
                <i class="oi oi-plus"></i><span>@L["Orders_NewButton"]</span>
            </button>
            <button class="icon-btn" @onclick="RefreshData" disabled="@isLoading" id="admin-orders-refresh-btn" title="@L["Orders_RefreshTitle"]">
                <i class="oi oi-reload @(isLoading ? "spin" : "")"></i>
            </button>
        </div>
    </header>

    <!-- Key Metrics Cards -->
    <section class="metrics">
        <!-- Total Orders -->
        <article class="metric" id="admin-orders-total-card">
            <div class="metric__head">
                <span class="metric__label">@L["Orders_TotalLabel"]</span>
                <i class="oi oi-list-rich metric__icon"></i>
            </div>
            <div class="metric__value mono">@totalOrders</div>
            <div class="metric__foot">
                <span class="metric__hint">@L["Orders_TotalHint"]</span>
            </div>
        </article>

        <!-- Pending Orders (accent: needs attention now) -->
        <article class="metric metric--accent" id="admin-orders-pending-card">
            <div class="metric__head">
                <span class="metric__label">@L["Orders_PendingLabel"]</span>
                <i class="oi oi-clock metric__icon"></i>
            </div>
            <div class="metric__value mono">@pendingOrders</div>
            <div class="metric__foot">
                <span class="metric__hint">@L["Orders_PendingHint"]</span>
            </div>
        </article>

        <!-- Completed Today -->
        <article class="metric" id="admin-orders-completed-card">
            <div class="metric__head">
                <span class="metric__label">@L["Orders_CompletedLabel"]</span>
                <i class="oi oi-circle-check metric__icon is-ok"></i>
            </div>
            <div class="metric__value mono">@completedToday</div>
            <div class="metric__foot">
                <span class="metric__hint">@L["Orders_CompletedHint"]</span>
            </div>
        </article>

        <!-- Revenue Today -->
        <article class="metric" id="admin-orders-revenue-card">
            <div class="metric__head">
                <span class="metric__label">@L["Orders_RevenueLabel"]</span>
                <i class="oi oi-dollar metric__icon"></i>
            </div>
            <div class="metric__value mono"><span class="metric__unit">$</span>@revenueToday.ToString("N0")</div>
            <div class="metric__foot">
                <span class="metric__hint">@L["Orders_RevenueHint"]</span>
            </div>
        </article>
    </section>

    <!-- Filters -->
    <div class="panel filters-panel">
        <div class="panel__head">
            <h2 class="panel__title">@L["Orders_FiltersTitle"]</h2>
            <button class="link-btn" @onclick="ClearFilters" id="admin-orders-clear-filters-btn">
                <i class="oi oi-x"></i> @L["Orders_ClearButton"]
            </button>
        </div>
        <div class="filters">
            <div class="field">
                <label class="field__label">@L["Orders_StatusLabel"]</label>
                <select class="field__input" @bind="selectedStatus" @bind:after="FilterOrders">
                    <option value="">@L["Orders_AllStatusesOption"]</option>
                    <option value="Pending">@L["Orders_PendingOption"]</option>
                    <option value="Accepted">@L["Orders_AcceptedOption"]</option>
                    <option value="InPreparation">@L["Orders_InPreparationOption"]</option>
                    <option value="Ready">@L["Orders_ReadyOption"]</option>
                    <option value="OutForDelivery">@L["Orders_OutForDeliveryOption"]</option>
                    <option value="Delivered">@L["Orders_DeliveredOption"]</option>
                    <option value="Cancelled">@L["Orders_CancelledOption"]</option>
                </select>
            </div>
            <div class="field field--grow">
                <label class="field__label">@L["Orders_CustomerSearchLabel"]</label>
                <input type="text" class="field__input" placeholder="@L["Orders_SearchPlaceholder"]"
                       @bind="customerSearch" @oninput="FilterOrders" />
            </div>
            <div class="field">
                <label class="field__label">@L["Orders_FromDateLabel"]</label>
                <input type="date" class="field__input" @bind="fromDate" @bind:after="FilterOrders" />
            </div>
            <div class="field">
                <label class="field__label">@L["Orders_ToDateLabel"]</label>
                <input type="date" class="field__input" @bind="toDate" @bind:after="FilterOrders" />
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <span class="loading-spinner"></span>
            <p>@L["Orders_Loading"]</p>
        </div>
    }
    else
    {
        <!-- Orders Table -->
        <div class="panel">
            <div class="panel__head">
                <h2 class="panel__title">@L["Orders_PanelTitle"] <span class="panel__count mono">@filteredOrders.Count</span></h2>
                @if (selectedOrderIds.Any())
                {
                    <div class="bulk-actions">
                        <button class="pill-btn pill-btn--success" @onclick="BulkAccept" id="admin-orders-bulk-accept-btn">
                            <i class="oi oi-check"></i><span>@L["Orders_AcceptButtonText", selectedOrderIds.Count]</span>
                        </button>
                        <button class="pill-btn pill-btn--danger" @onclick="BulkCancel" id="admin-orders-bulk-cancel-btn">
                            <i class="oi oi-x"></i><span>@L["Orders_CancelBulkButton"]</span>
                        </button>
                    </div>
                }
            </div>

            @if (filteredOrders?.Any() == true)
            {
                <table class="order-table">
                    <thead>
                        <tr>
                            <th class="check">
                                <input type="checkbox" class="check-box" @onchange="ToggleSelectAll" />
                            </th>
                            <th>@L["Orders_OrderHeader"]</th>
                            <th>@L["Orders_CustomerHeader"]</th>
                            <th>@L["Orders_ItemsHeader"]</th>
                            <th class="num">@L["Orders_TotalHeader"]</th>
                            <th>@L["Orders_StatusHeader"]</th>
                            <th class="num">@L["Orders_CreatedHeader"]</th>
                            <th class="actions-col">@L["Orders_ActionsHeader"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in filteredOrders.Take(50))
                        {
                            <tr class="@(selectedOrderIds.Contains(order.Id) ? "is-selected" : "")">
                                <td class="check">
                                    <input type="checkbox" class="check-box"
                                           checked="@selectedOrderIds.Contains(order.Id)"
                                           @onchange="@((e) => ToggleOrderSelection(order.Id, (bool)e.Value!))" />
                                </td>
                                <td class="mono order-table__id">#@order.Id</td>
                                <td>@order.CustomerName</td>
                                <td class="order-table__muted">@order.OrderItems.Count @L["Orders_ItemsSuffix"]</td>
                                <td class="num mono">$@order.TotalAmount.ToString("N2")</td>
                                <td>
                                    <span class="status @GetStatusModifier(order.Status)">
                                        <span class="status__dot"></span>@order.Status
                                    </span>
                                </td>
                                <td class="num mono order-table__time">@order.CreatedAt.ToString("MMM dd, HH:mm")</td>
                                <td class="actions-col">
                                    <div class="row-actions">
                                        <button class="row-btn" title="@L["Orders_ViewTitle"]" @onclick="@(() => ViewOrder(order.Id))" id="admin-orders-view-btn-@order.Id">
                                            <i class="oi oi-eye"></i>
                                        </button>
                                        @if (order.Status == OrderStatus.Pending)
                                        {
                                            <button class="row-btn row-btn--ok" title="@L["Orders_AcceptTitle"]" @onclick="@(() => AcceptOrder(order.Id))" id="admin-orders-accept-btn-@order.Id">
                                                <i class="oi oi-check"></i>
                                            </button>
                                        }
                                        @if (order.Status != OrderStatus.Delivered && order.Status != OrderStatus.Cancelled)
                                        {
                                            <button class="row-btn" title="@L["Orders_AdvanceTitle"]" @onclick="@(() => AdvanceOrderStatus(order.Id))" id="admin-orders-advance-btn-@order.Id">
                                                <i class="oi oi-arrow-right"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (filteredOrders.Count > 50)
                {
                    <div class="table-foot">
                        <p>@L["Orders_ShowingMessage", filteredOrders.Count]</p>
                        <button class="pill-btn" @onclick="LoadMoreOrders" id="admin-orders-load-more-btn">@L["Orders_LoadMoreButton"]</button>
                    </div>
                }
            }
            else
            {
                <div class="empty">
                    <i class="oi oi-inbox"></i>
                    <p>@L["Orders_NoOrdersFound"]</p>
                    <span>@L["Orders_NoOrdersMessage"]</span>
                </div>
            }
        </div>
    }
</div>
