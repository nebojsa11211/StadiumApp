@page "/t/{Token}"
@layout MobileShell
@using StadiumDrinkOrdering.Customer.Services
@inject OrderSessionState State
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>HALFTIME</PageTitle>

<div class="resolve">
    @if (_phase == Phase.Validating)
    {
        <div class="center">
            <span class="spinner big"></span>
            <p>Provjeravam tvoju ulaznicu…</p>
        </div>
    }
    else if (_phase == Phase.Ready)
    {
        <div class="center">
            <div class="tick">✓</div>
            <h2>Spreman si!</h2>
            <div class="seatcard">
                <div class="match">@State.EventName</div>
                <div class="row"><span>Mjesto</span><b>@State.SeatText</b></div>
            </div>
            <div class="redirecting"><span class="spinner"></span> Vodim te na meni…</div>
            <button class="btn btn-primary" @onclick="Go">Započni naručivanje</button>
        </div>
    }
    else
    {
        <div class="center">
            <div class="cross">✕</div>
            <h2>Ups…</h2>
            <p class="err">@_error</p>
            <button class="btn btn-primary" @onclick="@(() => Nav.NavigateTo("/scan"))">Skeniraj ponovno</button>
            <button class="btn btn-ghost" @onclick="@(() => Nav.NavigateTo("/welcome"))">Početna</button>
        </div>
    }
</div>

@code {
    [Parameter] public string Token { get; set; } = "";

    private enum Phase { Validating, Ready, Failed }
    private Phase _phase = Phase.Validating;
    private string? _error;
    private Timer? _forward;

    protected override async Task OnInitializedAsync()
    {
        var (ok, error) = await State.InitFromQrAsync(Token);
        _phase = ok ? Phase.Ready : Phase.Failed;
        _error = error;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _phase != Phase.Ready) return;

        // Persist the session token so a hard reload on /order or /track can recover it.
        await JS.InvokeVoidAsync("sessionStorage.setItem", "htSessionToken", State.SessionToken);

        // "Immediately redirected": auto-forward into ordering after a brief confirmation beat.
        _forward = new Timer(_ => InvokeAsync(Go), null, 1300, Timeout.Infinite);
    }

    private void Go()
    {
        _forward?.Dispose();
        Nav.NavigateTo("/order");
    }

    public void Dispose() => _forward?.Dispose();
}
