                <div class="form-check" id="admin-settings-reset-area-catalog-group">
                    <input class="form-check-input" type="checkbox" id="admin-settings-reset-area-catalog"
                           checked="@resetCatalog"
                           @onchange="e => resetCatalog = e.Value is bool b && b" />
                    <label class="form-check-label" for="admin-settings-reset-area-catalog">@L["Settings_ResetArea_Catalog"]</label>
                </div>

                <div class="form-check" id="admin-settings-reset-area-directories-group">
                    <input class="form-check-input" type="checkbox" id="admin-settings-reset-area-directories"
                           checked="@resetDirectories"
                           @onchange="e => resetDirectories = e.Value is bool b && b" />
                    <label class="form-check-label" for="admin-settings-reset-area-directories">@L["Settings_ResetArea_Directories"]</label>
                </div>

                <div class="form-check mb-3" id="admin-settings-reset-area-firstrun-group">
                    <input class="form-check-input" type="checkbox" id="admin-settings-reset-area-firstrun"
                           checked="@resetFirstRun"
                           @onchange="e => resetFirstRun = e.Value is bool b && b" />
                    <label class="form-check-label" for="admin-settings-reset-area-firstrun">@L["Settings_ResetArea_FirstRun"]</label>
                </div>

                <button type="button" id="admin-settings-reset-btn" class="btn btn-danger"
                        @onclick="OpenResetModal" disabled="@(isResetting || !AnyResetAreaSelected)">
                    <i class="bi bi-exclamation-octagon me-1"></i>@L["Settings_ResetButton"]
                </button>
            </div>
        </div>
        }
    }
</div>

