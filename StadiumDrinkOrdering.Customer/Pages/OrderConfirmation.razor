@page "/order-confirmation/{orderId}"
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Shared.DTOs
@inject IApiService ApiService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["OrderConfirmation_PageTitle"]</PageTitle>

@if (isLoading)
{
    <div id="customer-order-confirmation-loading-container" class="container-fluid py-5">
        <div id="customer-order-confirmation-loading-center" class="text-center">
            <div id="customer-order-confirmation-spinner" class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">@Localizer["Loading"]</span>
            </div>
            <p class="mt-3">@Localizer["OrderConfirmation_LoadingConfirmation"]</p>
        </div>
    </div>
}
else if (orderConfirmation == null)
{
    <div id="customer-order-confirmation-error-container" class="container-fluid py-5">
        <div id="customer-order-confirmation-error-alert" class="alert alert-danger text-center">
            <i class="fas fa-exclamation-triangle fa-3x mb-3"></i>
            <h4>@Localizer["OrderConfirmation_OrderNotFound"]</h4>
            <p>@Localizer["OrderConfirmation_OrderNotFoundMessage"]</p>
            <a href="/events" class="btn btn-primary">@Localizer["Events_BackToHome"]</a>
        </div>
    </div>
}
else
{
    <div id="customer-order-confirmation-container" class="container-fluid py-4">
        <!-- Success Header -->
        <div id="customer-order-confirmation-header-row" class="row mb-4">
            <div id="customer-order-confirmation-header-col" class="col-12 text-center">
                <div id="customer-order-confirmation-success-alert" class="alert alert-success shadow-sm">
                    <i class="fas fa-check-circle fa-3x text-success mb-3"></i>
                    <h2 class="text-success mb-2">@Localizer["OrderConfirmation_PaymentSuccessful"]</h2>
                    <p class="lead mb-0">@Localizer["OrderConfirmation_ConfirmedReady"]</p>
                </div>
            </div>
        </div>

        <div id="customer-order-confirmation-content-row" class="row">
            <!-- Order Details -->
            <div id="customer-order-confirmation-details-col" class="col-lg-8 mb-4">
                <div id="customer-order-confirmation-details-card" class="card shadow-sm">
                    <div id="customer-order-confirmation-details-header" class="card-header bg-primary text-white">
                        <h4 class="mb-0"><i class="fas fa-receipt me-2"></i>@Localizer["OrderConfirmation_OrderDetails"]</h4>
                    </div>
                    <div id="customer-order-confirmation-details-body" class="card-body">
                        <div id="customer-order-confirmation-details-row-1" class="row mb-3">
                            <div id="customer-order-confirmation-details-col-1-1" class="col-sm-6">
                                <strong>@Localizer["OrderConfirmation_OrderID"]</strong> #@orderConfirmation.OrderId
                            </div>
                            <div id="customer-order-confirmation-details-col-1-2" class="col-sm-6">
                                <strong>@Localizer["OrderConfirmation_OrderDate"]</strong> @orderConfirmation.OrderDate.ToString("MMM dd, yyyy - HH:mm")
                            </div>
                        </div>
                        <div id="customer-order-confirmation-details-row-2" class="row mb-3">
                            <div id="customer-order-confirmation-details-col-2-1" class="col-sm-6">
                                <strong>@Localizer["OrderConfirmation_Customer"]</strong> @orderConfirmation.CustomerName
                            </div>
                            <div id="customer-order-confirmation-details-col-2-2" class="col-sm-6">
                                <strong>@Localizer["OrderConfirmation_PaymentStatus"]</strong>
                                <span class="badge bg-success ms-2">@orderConfirmation.PaymentStatus</span>
                            </div>
                        </div>
                        <div id="customer-order-confirmation-details-row-3" class="row">
                            <div id="customer-order-confirmation-details-col-3-1" class="col-sm-6">
                                <strong>@Localizer["Checkout_Event"]</strong> @orderConfirmation.EventName
                            </div>
                            <div id="customer-order-confirmation-details-col-3-2" class="col-sm-6">
                                <strong>@Localizer["OrderConfirmation_EventDate"]</strong> @orderConfirmation.EventDate.ToString("MMM dd, yyyy - HH:mm")
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tickets -->
                <div id="customer-order-confirmation-tickets-card" class="card shadow-sm mt-4">
                    <div id="customer-order-confirmation-tickets-header" class="card-header bg-success text-white">
                        <h4 class="mb-0"><i class="fas fa-ticket-alt me-2"></i>@string.Format(Localizer["OrderConfirmation_Tickets"], orderConfirmation.Tickets.Count)</h4>
                    </div>
                    <div id="customer-order-confirmation-tickets-body" class="card-body">
                        <div id="customer-order-confirmation-tickets-row" class="row">
                            @foreach (var ticket in orderConfirmation.Tickets)
                            {
                                <div id="customer-order-confirmation-ticket-col-@ticket.SeatCode.GetHashCode()" class="col-md-6 mb-3">
                                    <div id="customer-order-confirmation-ticket-@ticket.SeatCode.GetHashCode()" class="ticket-card border rounded p-3 bg-light">
                                        <div id="customer-order-confirmation-ticket-header-@ticket.SeatCode.GetHashCode()" class="d-flex justify-content-between align-items-center mb-2">
                                            <h6 class="mb-0"><strong>@ticket.SeatCode</strong></h6>
                                            <span class="badge bg-primary">$@ticket.Price.ToString("F2")</span>
                                        </div>
                                        <div id="customer-order-confirmation-ticket-sector-@ticket.SeatCode.GetHashCode()" class="mb-2">
                                            <small class="text-muted">@Localizer["Checkout_Sector"]: @ticket.SectionName</small>
                                        </div>
                                        <div id="customer-order-confirmation-ticket-number-@ticket.SeatCode.GetHashCode()" class="mb-2">
                                            <small class="text-muted">@Localizer["Tickets"]: @ticket.TicketNumber</small>
                                        </div>
                                        <div id="customer-order-confirmation-ticket-qr-@ticket.SeatCode.GetHashCode()" class="qr-code-placeholder bg-white border rounded p-2 text-center">
                                            <i class="fas fa-qrcode fa-2x text-muted"></i>
                                            <div><small>@Localizer["Tickets"]</small></div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Order Summary & Actions -->
            <div id="customer-order-confirmation-summary-col" class="col-lg-4">
                <div id="customer-order-confirmation-summary-card" class="card shadow-sm sticky-top" style="top: 20px;">
                    <div id="customer-order-confirmation-summary-header" class="card-header bg-dark text-white">
                        <h5 class="mb-0"><i class="fas fa-calculator me-2"></i>@Localizer["Checkout_OrderSummary"]</h5>
                    </div>
                    <div id="customer-order-confirmation-summary-body" class="card-body">
                        <div id="customer-order-confirmation-summary-tickets-row" class="d-flex justify-content-between mb-2">
                            <span>@Localizer["Tickets"] (@orderConfirmation.Tickets.Count)</span>
                            <span>$@orderConfirmation.Tickets.Sum(t => t.Price).ToString("F2")</span>
                        </div>
                        <div id="customer-order-confirmation-summary-service-row" class="d-flex justify-content-between mb-2">
                            <span>@Localizer["OrderConfirmation_ServiceFee"]</span>
                            <span>$@(orderConfirmation.Tickets.Sum(t => t.Price) * 0.10m).ToString("F2")</span>
                        </div>
                        <div id="customer-order-confirmation-summary-processing-row" class="d-flex justify-content-between mb-3">
                            <span>@Localizer["OrderConfirmation_ProcessingFee"]</span>
                            <span>$2.50</span>
                        </div>
                        <hr>
                        <div id="customer-order-confirmation-summary-total-row" class="d-flex justify-content-between fw-bold h5">
                            <span>@Localizer["Events_From"]</span>
                            <span class="text-success">$@orderConfirmation.TotalAmount.ToString("F2")</span>
                        </div>

                        <!-- Action Buttons -->
                        <div id="customer-order-confirmation-actions" class="d-grid gap-2 mt-4">
                            <button class="btn btn-primary" @onclick="PrintTickets">
                                <i class="fas fa-print me-2"></i>@Localizer["OrderConfirmation_PrintTickets"]
                            </button>
                            <button class="btn btn-outline-secondary" @onclick="DownloadTickets">
                                <i class="fas fa-download me-2"></i>@Localizer["OrderConfirmation_DownloadPDF"]
                            </button>
                            <button class="btn btn-outline-info" @onclick="EmailTickets">
                                <i class="fas fa-envelope me-2"></i>@Localizer["OrderConfirmation_EmailTickets"]
                            </button>
                        </div>

                        <hr>
                        <div id="customer-order-confirmation-browse" class="text-center">
                            <a href="/events" class="btn btn-success">
                                <i class="fas fa-calendar me-2"></i>@Localizer["OrderConfirmation_BrowseMoreEvents"]
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Important Information -->
        <div id="customer-order-confirmation-info-row" class="row mt-4">
            <div id="customer-order-confirmation-info-col" class="col-12">
                <div id="customer-order-confirmation-info-alert" class="alert alert-info">
                    <h6><i class="fas fa-info-circle me-2"></i>@Localizer["OrderConfirmation_ImportantInformation"]</h6>
                    <ul class="mb-0">
                        <li>@Localizer["OrderConfirmation_ArriveInfo"]</li>
                        <li>@Localizer["OrderConfirmation_QRCodeInfo"]</li>
                        <li>@Localizer["OrderConfirmation_KeepSafeInfo"]</li>
                        <li>@Localizer["OrderConfirmation_SupportInfo"]</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string OrderId { get; set; } = string.Empty;
    
    private OrderConfirmationDto? orderConfirmation;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrderConfirmation();
    }

    private async Task LoadOrderConfirmation()
    {
        try
        {
            orderConfirmation = await ApiService.GetOrderConfirmationAsync(OrderId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading order confirmation: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task PrintTickets()
    {
        await JSRuntime.InvokeVoidAsync("window.print");
    }

    private async Task DownloadTickets()
    {
        await JSRuntime.InvokeVoidAsync("alert", "PDF download functionality will be implemented soon!");
    }

    private async Task EmailTickets()
    {
        await JSRuntime.InvokeVoidAsync("alert", "Tickets have been sent to your email address!");
    }
}

<style>
    .ticket-card {
        transition: transform 0.2s;
    }

    .ticket-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

    .qr-code-placeholder {
        min-height: 80px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    .sticky-top {
        position: -webkit-sticky;
        position: sticky;
    }

    @@media print {
        .btn, .alert-info {
            display: none !important;
        }
        
        .ticket-card {
            page-break-inside: avoid;
            margin-bottom: 20px;
        }
    }

    @@media (max-width: 991.98px) {
        .sticky-top {
            position: static;
        }
    }
</style>