@page "/counter"
@using Microsoft.Extensions.Localization
@using StadiumDrinkOrdering.Admin
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Counter_PageTitle"]</PageTitle>

<h1>@L["Counter_Title"]</h1>

<p role="status">@L["Counter_CurrentCount"] @currentCount</p>

<button class="btn btn-primary" @onclick="IncrementCount" id="admin-counter-increment-btn">@L["Counter_ClickMe"]</button>

