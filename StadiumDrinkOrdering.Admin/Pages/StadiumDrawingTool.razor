    private async Task HandleSectorSave()
    {
        if (currentSectorData == null) return;

        try
        {
            var apiBaseUrl = Configuration.GetValue<string>("ApiSettings:BaseUrl")?.TrimEnd('/') ?? "https://localhost:7010";

            if (isNewSector)
            {
                // Create new sector via API
                var newDbSector = new StadiumDrinkOrdering.Shared.Models.StadiumSectorOverlay
                {
                    SectorCode = currentSectorData.SectorCode,
                    Name = currentSectorData.Name,
                    TopPercent = currentSectorData.TopPercent,
                    LeftPercent = currentSectorData.LeftPercent,
                    WidthPercent = currentSectorData.WidthPercent,
                    HeightPercent = currentSectorData.HeightPercent,
                    ShapeType = currentSectorData.ShapeType,
                    ShapeData = currentSectorData.ShapeData,
                    Rows = currentSectorData.Rows,
                    SeatsPerRow = currentSectorData.SeatsPerRow,
                    UseVariableSeating = currentSectorData.UseVariableSeating,
                    VariableSeatingData = currentSectorData.VariableSeatingData,
                    Type = currentSectorData.Type,
                    Color = currentSectorData.Color
                };

                var response = await HttpClient.PostAsJsonAsync($"{apiBaseUrl}/api/StadiumSectorOverlay", newDbSector);

                if (response.IsSuccessStatusCode)
                {
                    var createdSector = await response.Content.ReadFromJsonAsync<StadiumDrinkOrdering.Shared.Models.StadiumSectorOverlay>();
                    if (createdSector != null)
                    {
                        // Add to local list
                        var localSector = ConvertFromModalData(currentSectorData);
                        localSector.Id = createdSector.Id.ToString();
                        sectorOverlays.Add(localSector);

                        ShowAlert($"Sector '{createdSector.SectorCode}' created successfully!", "success");
                    }
                }
                else
                {
                    var errorContent = await response.Content.ReadAsStringAsync();
                    ShowAlert($"Error creating sector: {errorContent}", "danger");
                    return;
                }
            }
            else
            {
                // Update existing sector via API
                var existing = sectorOverlays.FirstOrDefault(s => s.Id == currentSectorData.Id);
                if (existing != null && int.TryParse(existing.Id, out int sectorId))
                {
                    var updatedDbSector = new StadiumDrinkOrdering.Shared.Models.StadiumSectorOverlay
                    {
                        Id = sectorId,
                        SectorCode = currentSectorData.SectorCode,
                        Name = currentSectorData.Name,
                        TopPercent = currentSectorData.TopPercent,
                        LeftPercent = currentSectorData.LeftPercent,
                        WidthPercent = currentSectorData.WidthPercent,
                        HeightPercent = currentSectorData.HeightPercent,
                        ShapeType = currentSectorData.ShapeType,
                        ShapeData = currentSectorData.ShapeData,
                        Rows = currentSectorData.Rows,
                        SeatsPerRow = currentSectorData.SeatsPerRow,
                        UseVariableSeating = currentSectorData.UseVariableSeating,
                        VariableSeatingData = currentSectorData.VariableSeatingData,
                        Type = currentSectorData.Type,
                        Color = currentSectorData.Color
                    };

                    var response = await HttpClient.PutAsJsonAsync($"{apiBaseUrl}/api/StadiumSectorOverlay/{sectorId}", updatedDbSector);

                    if (response.IsSuccessStatusCode)
                    {
                        // Update local sector
                        UpdateSectorFromModalData(existing, currentSectorData);
                        ShowAlert($"Sector '{existing.SectorCode}' updated successfully!", "success");
                    }
                    else
                    {
                        var errorContent = await response.Content.ReadAsStringAsync();
                        ShowAlert($"Error updating sector: {errorContent}", "danger");
                        return;
                    }
                }
            }

            // Redraw canvas with updated sectors
            await DrawSectorOverlays();

            // Close modal
            showSectorModal = false;
            currentSectorData = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving sector to database");
            ShowAlert($"Error saving sector: {ex.Message}", "danger");
        }
    }

    private async Task HandleSectorDelete()
    {
        if (currentSectorData == null) return;

        try
        {
            var sectorToDelete = sectorOverlays.FirstOrDefault(s => s.Id == currentSectorData.Id);
            if (sectorToDelete != null && int.TryParse(sectorToDelete.Id, out int sectorId))
            {
                var apiBaseUrl = Configuration.GetValue<string>("ApiSettings:BaseUrl")?.TrimEnd('/') ?? "https://localhost:7010";
                var response = await HttpClient.DeleteAsync($"{apiBaseUrl}/api/StadiumSectorOverlay/{sectorId}");

                if (response.IsSuccessStatusCode)
                {
                    // Remove from local list
                    sectorOverlays.Remove(sectorToDelete);
                    ShowAlert($"Sector '{sectorToDelete.SectorCode}' deleted successfully!", "success");

                    // Redraw canvas without deleted sector
                    await DrawSectorOverlays();
                }
                else
                {
                    var errorContent = await response.Content.ReadAsStringAsync();
                    ShowAlert($"Error deleting sector: {errorContent}", "danger");
                    return;
                }
            }

            // Close modal
            showSectorModal = false;
            currentSectorData = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting sector from database");
            ShowAlert($"Error deleting sector: {ex.Message}", "danger");
        }
    }

    private void HandleSectorCancel()
    {
        showSectorModal = false;
        currentSectorData = null;
        StateHasChanged();
    }

    private bool ValidateSectorCode(string currentId, string sectorCode)
    {
        // Check if sector code already exists (excluding current sector)
        return !sectorOverlays.Any(s => s.Id != currentId &&
                                        s.SectorCode.Equals(sectorCode, StringComparison.OrdinalIgnoreCase));
    }

    // Handle sector position/size changes from JavaScript
    [JSInvokable]
    public void OnSectorModified(string sectorId, double topPercent, double leftPercent, double widthPercent, double heightPercent)
    {
        var sector = sectorOverlays.FirstOrDefault(s => s.Id == sectorId);
        if (sector != null)
        {
            // Store the modified sector data temporarily
            modifiedSectorId = sectorId;
            modifiedSectorData = new SectorOverlay
            {
                Id = sector.Id,
                SectorCode = sector.SectorCode,
                Name = sector.Name,
                TopPercent = topPercent,
                LeftPercent = leftPercent,
                WidthPercent = widthPercent,
                HeightPercent = heightPercent,
                ShapeType = sector.ShapeType,
                ShapeData = sector.ShapeData,
                Rows = sector.Rows,
                SeatsPerRow = sector.SeatsPerRow,
                UseVariableSeating = sector.UseVariableSeating,
                VariableSeatingData = sector.VariableSeatingData,
                Type = sector.Type,
                Color = sector.Color,
                CreatedDate = sector.CreatedDate,
                ModifiedDate = DateTime.UtcNow
            };

            hasUnsavedSectorChanges = true;
            StateHasChanged(); // Update UI to show save button
        }
    }

    private async Task SaveSectorPositionChanges()
    {
        if (modifiedSectorData == null || modifiedSectorId == null) return;

        try
        {
            // Update via API
            var apiBaseUrl = Configuration.GetValue<string>("ApiSettings:BaseUrl")?.TrimEnd('/') ?? "https://localhost:7010";

            if (int.TryParse(modifiedSectorId, out int sectorId))
            {
                var updatedDbSector = new StadiumDrinkOrdering.Shared.Models.StadiumSectorOverlay
                {
                    Id = sectorId,
                    SectorCode = modifiedSectorData.SectorCode,
                    Name = modifiedSectorData.Name,
                    TopPercent = modifiedSectorData.TopPercent,
                    LeftPercent = modifiedSectorData.LeftPercent,
                    WidthPercent = modifiedSectorData.WidthPercent,
                    HeightPercent = modifiedSectorData.HeightPercent,
                    ShapeType = modifiedSectorData.ShapeType,
                    ShapeData = modifiedSectorData.ShapeData,
                    Rows = modifiedSectorData.Rows,
                    SeatsPerRow = modifiedSectorData.SeatsPerRow,
                    Type = modifiedSectorData.Type,
                    Color = modifiedSectorData.Color
                };

                var response = await HttpClient.PutAsJsonAsync($"{apiBaseUrl}/api/StadiumSectorOverlay/{sectorId}", updatedDbSector);

                if (response.IsSuccessStatusCode)
                {
                    // Update local sector
                    var localSector = sectorOverlays.FirstOrDefault(s => s.Id == modifiedSectorId);
                    if (localSector != null)
                    {
                        localSector.TopPercent = modifiedSectorData.TopPercent;
                        localSector.LeftPercent = modifiedSectorData.LeftPercent;
                        localSector.WidthPercent = modifiedSectorData.WidthPercent;
                        localSector.HeightPercent = modifiedSectorData.HeightPercent;
                        localSector.ModifiedDate = DateTime.UtcNow;
                    }

                    // Clear unsaved changes flag
                    hasUnsavedSectorChanges = false;
                    modifiedSectorId = null;
                    modifiedSectorData = null;

                    ShowAlert($"Sector position/size saved successfully!", "success");
                }
                else
                {
                    var errorContent = await response.Content.ReadAsStringAsync();
                    ShowAlert($"Error saving sector: {errorContent}", "danger");
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving sector position changes");
            ShowAlert($"Error saving changes: {ex.Message}", "danger");
        }
    }

    private async Task DiscardSectorChanges()
    {
        // Reset unsaved changes
        hasUnsavedSectorChanges = false;
        modifiedSectorId = null;
        modifiedSectorData = null;

        // Reload sectors from database to revert visual changes
        await LoadSectorOverlays();

        ShowAlert("Changes discarded", "info");
    }

