@page "/order"
@layout MobileShell
@using Microsoft.AspNetCore.WebUtilities
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Shared.DTOs
@inject OrderSessionState State
@inject IApiService Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Naruči piće — HALFTIME</PageTitle>

@if (!State.HasSession && !_loading)
{
    <div id="customer-order-no-session-1" class="gate">
        <div id="customer-order-no-session-emoji-1" class="gate-icon">🎟️</div>
        <h2 id="customer-order-no-session-heading-1">Nema aktivne narudžbe</h2>
        <p id="customer-order-no-session-message-1">Skeniraj QR kod s ulaznice pa ti piće stigne točno na tvoje mjesto — bez čekanja u redu.</p>
        <div class="gate-actions">
            <button id="customer-order-scan-btn-1" class="btn btn-primary" @onclick="@(() => Nav.NavigateTo("/scan"))">Skeniraj ulaznicu</button>
        </div>
    </div>
}
else if (State.HasSession && !State.CanOrderDrinks && !_loading)
{
    <div id="customer-order-no-session-2" class="gate">
        <div id="customer-order-no-session-emoji-2" class="gate-icon paused">⏸️</div>
        <h2 id="customer-order-no-session-heading-2">Naručivanje je na pauzi</h2>
        <p id="customer-order-no-session-message-2">Piće možeš naručiti samo dok utakmica traje. Tvoje mjesto te čeka — vrati se kad sudac svira početak.</p>
        <div id="customer-order-no-session-slots-2" class="seat-line seat-line--center">
            <span id="customer-order-no-session-slot-4" class="seat-cell"><span class="k">Sektor</span><span class="v tnum">@Coord(State.SeatSection)</span></span>
            <span class="seat-dot"></span>
            <span id="customer-order-no-session-slot-5" class="seat-cell"><span class="k">Red</span><span class="v tnum">@Coord(State.SeatRow)</span></span>
            <span class="seat-dot"></span>
            <span id="customer-order-no-session-slot-6" class="seat-cell seat"><span class="k">Sjedalo</span><span class="v tnum">@Coord(State.SeatNumber)</span></span>
        </div>
        <div class="gate-actions">
            <button id="customer-order-home-btn" class="btn btn-primary" @onclick="@(() => Nav.NavigateTo("/"))">Početna</button>
        </div>
    </div>
}
else
{
    <div id="customer-order-atmos" class="crowd-atmos" aria-hidden="true"></div>
    <div id="customer-order-head" class="order-head">
        <div id="customer-order-top" class="head-bar">
            <button id="customer-order-back-btn" class="iconbtn" @onclick="@(() => Nav.NavigateTo("/"))" aria-label="Natrag">‹</button>
            <div id="customer-order-match-info" class="head-titles">
                <div id="customer-order-pass-match" class="head-title">@(string.IsNullOrWhiteSpace(State.EventName) ? "Utakmica" : State.EventName)</div>
                <div id="customer-order-pass-eyebrow" class="head-sub">Piće stiže na tvoje mjesto</div>
            </div>
            <span id="customer-order-pass-live" class="live-badge"><span class="pulse"></span>Uživo</span>
        </div>
        <div id="customer-order-seat-coords" class="seat-line">
            <span id="customer-order-coord-sector" class="seat-cell"><span class="k">Sektor</span><span class="v tnum">@Coord(State.SeatSection)</span></span>
            <span id="customer-order-cdiv-1" class="seat-dot"></span>
            <span id="customer-order-coord-row" class="seat-cell"><span class="k">Red</span><span class="v tnum">@Coord(State.SeatRow)</span></span>
            <span id="customer-order-cdiv-2" class="seat-dot"></span>
            <span id="customer-order-coord-seat" class="seat-cell seat"><span class="k">Sjedalo</span><span class="v tnum">@Coord(State.SeatNumber)</span></span>
        </div>
        <div id="customer-order-tabs" class="tabs no-scrollbar">
            @foreach (var cat in _categories)
            {
                var n = CatCount(cat.Id);
                <button id="customer-order-tab-@cat.Id" class="tab @(cat.Id == _selected ? "on" : "")" @onclick="() => _selected = cat.Id">
                    <span class="tab-emoji">@cat.Icon</span> @cat.Label
                    @if (n > 0)
                    {
                        <span id="customer-order-tab-count-@cat.Id" class="cnt tnum">@n</span>
                    }
                </button>
            }
        </div>
    </div>

    <div id="customer-order-body" class="body no-scrollbar" style="padding-bottom:120px">
        @if (_loading)
        {
            <div id="customer-order-loading" class="loading"><span class="spinner"></span> Učitavam ponudu…</div>
        }
        else
        {
            <div id="customer-order-menu-grid" class="menu-grid">
                @foreach (var drink in Filtered())
                {
                    <DrinkCard Drink="drink"
                               Qty="State.QtyOf(drink.Id)"
                               OnAdd="() => QuickAdd(drink)"
                               OnInc="() => State.AddDrink(drink, 1)"
                               OnDec="() => State.SetQty(drink.Id, State.QtyOf(drink.Id) - 1)"
                               OnOpen="() => _sheetDrink = drink" />
                }
            </div>
        }
    </div>

    <CartBar Count="State.Count" Total="State.Subtotal" OnView="@(() => Nav.NavigateTo("/cart"))" />

    <DrinkSheet Drink="_sheetDrink" OnClose="() => _sheetDrink = null" OnAdd="SheetAdd" />
}

@code {
    private bool _loading = true;
    private List<DrinkDto> _drinks = new();
    private List<CatTab> _categories = new();
    private int _selected;
    private DrinkDto? _sheetDrink;

    // Lightweight category descriptor for the tab strip, built from the loaded drinks.
    private record CatTab(int Id, string Icon, string Label);

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateChanged;

        if (!State.HasSession)
        {
            // Direct-entry / testing bootstrap: /order?qr={token} or /order?s={sessionToken}.
            var q = QueryHelpers.ParseQuery(new Uri(Nav.Uri).Query);
            if (q.TryGetValue("qr", out var qr) && !string.IsNullOrEmpty(qr))
                await State.InitFromQrAsync(qr!);
            else if (q.TryGetValue("s", out var st) && !string.IsNullOrEmpty(st))
                await State.InitFromTokenAsync(st!);
        }

        await LoadDrinks();
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Persist the session token so a hard reload can recover it; or restore if we arrived cold.
        if (State.HasSession)
        {
            await JS.InvokeVoidAsync("sessionStorage.setItem", "htSessionToken", State.SessionToken);
        }
        else
        {
            var token = await JS.InvokeAsync<string?>("sessionStorage.getItem", "htSessionToken");
            if (!string.IsNullOrEmpty(token) && await State.InitFromTokenAsync(token))
            {
                await LoadDrinks();
                _loading = false;
                StateHasChanged();
            }
        }
    }

    private async Task LoadDrinks()
    {
        _drinks = await Api.GetDrinksAsync() ?? new();
        _categories = _drinks.Where(d => d.IsAvailable)
            .GroupBy(d => d.CategoryId)
            .Select(g => new CatTab(
                g.Key,
                DrinkVisuals.Emoji(g.First().CategoryIcon),
                DrinkVisuals.Label(g.First().CategoryDisplayName, g.First().CategoryName)))
            .ToList();
        if (_categories.Any() && _categories.All(c => c.Id != _selected))
            _selected = _categories.First().Id;
    }

    private IEnumerable<DrinkDto> Filtered() =>
        _drinks.Where(d => d.CategoryId == _selected).OrderByDescending(d => d.IsAvailable && d.StockQuantity > 0).ThenBy(d => d.Name);

    private void QuickAdd(DrinkDto drink) => State.AddDrink(drink, 1);

    // Total cart quantity for a category — powers the count badge on each tab.
    private int CatCount(int categoryId) => _drinks.Where(d => d.CategoryId == categoryId).Sum(d => State.QtyOf(d.Id));

    // A seat coordinate for the pass; falls back to an em dash so the ticket layout never collapses.
    private static string Coord(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value.Trim();

    private void SheetAdd(DrinkOrderRequest req)
    {
        var drink = _drinks.FirstOrDefault(d => d.Id == req.DrinkId);
        if (drink != null) State.AddDrink(drink, req.Quantity, req.Note);
        _sheetDrink = null;
    }

    private void StateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => State.OnChange -= StateChanged;
}
