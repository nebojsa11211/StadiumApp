@page "/order-confirmation/{orderId}"
@layout MobileShell
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Shared.DTOs
@inject IApiService ApiService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Potvrda narudžbe — HALFTIME</PageTitle>

<ScreenHeader Title="Potvrda narudžbe" Subtitle="Ulaznice" OnBack="GoBack" />

@if (isLoading)
{
    <div id="customer-order-confirmation-loading" class="oc-state">
        <span class="spinner"></span> Učitavam potvrdu…
    </div>
}
else if (orderConfirmation == null)
{
    <div id="customer-order-confirmation-notfound" class="oc-state oc-notfound">
        <div id="customer-order-confirmation-emoji" class="oc-emoji">🚫</div>
        <h2>Narudžba nije pronađena</h2>
        <p>Ne možemo pronaći ovu narudžbu. Provjeri poveznicu ili pokušaj ponovno.</p>
        <button id="customer-order-confirmation-notfound-btn" class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/events"))">Pregledaj utakmice</button>
    </div>
}
else
{
    <div id="customer-order-confirmation-body" class="oc-body no-scrollbar">

        <!-- Success hero -->
        <div id="customer-order-confirmation-hero" class="oc-hero">
            <div id="customer-order-confirmation-check" class="oc-check">✓</div>
            <h2 id="customer-order-confirmation-hero-title">Plaćanje uspješno!</h2>
            <p id="customer-order-confirmation-hero-sub">Tvoje ulaznice su potvrđene i spremne.</p>
        </div>

        <!-- Order meta -->
        <div id="customer-order-confirmation-details-card" class="oc-card">
            <span class="label">Detalji narudžbe</span>
            <div id="customer-order-confirmation-meta" class="oc-meta">
                <div class="oc-meta-row"><span>Narudžba</span><span id="customer-order-confirmation-order-id" class="v tnum">#@orderConfirmation.OrderId</span></div>
                <div class="oc-meta-row"><span>Datum</span><span id="customer-order-confirmation-order-date" class="v">@orderConfirmation.OrderDate.ToString("dd.MM.yyyy · HH:mm")</span></div>
                <div class="oc-meta-row"><span>Kupac</span><span id="customer-order-confirmation-customer" class="v">@orderConfirmation.CustomerName</span></div>
                <div class="oc-meta-row"><span>Plaćanje</span><span id="customer-order-confirmation-payment-badge" class="oc-badge">@orderConfirmation.PaymentStatus</span></div>
                <div class="oc-meta-row"><span>Utakmica</span><span id="customer-order-confirmation-event" class="v">@orderConfirmation.EventName</span></div>
                <div class="oc-meta-row"><span>Termin</span><span id="customer-order-confirmation-event-date" class="v">@orderConfirmation.EventDate.ToString("dd.MM.yyyy · HH:mm")</span></div>
            </div>
        </div>

        <!-- Tickets -->
        <div id="customer-order-confirmation-tickets" class="oc-section">
            <span class="label">Ulaznice (@orderConfirmation.Tickets.Count)</span>
            <div id="customer-order-confirmation-tickets-list" class="oc-tickets">
                @foreach (var ticket in orderConfirmation.Tickets)
                {
                    var _k = ticket.SeatCode.GetHashCode();
                    <div id="customer-order-confirmation-ticket-@_k" class="oc-ticket">
                        <div id="customer-order-confirmation-ticket-info-@_k" class="oc-ticket-info">
                            <div class="oc-ticket-top">
                                <span id="customer-order-confirmation-ticket-code-@_k" class="oc-ticket-code">@ticket.SeatCode</span>
                                <span id="customer-order-confirmation-ticket-price-@_k" class="oc-ticket-price tnum">€@ticket.Price.ToString("F2")</span>
                            </div>
                            <span id="customer-order-confirmation-ticket-sector-@_k" class="oc-ticket-sub">Sektor · @ticket.SectionName</span>
                            <span id="customer-order-confirmation-ticket-number-@_k" class="oc-ticket-sub tnum">@ticket.TicketNumber</span>
                        </div>
                        <div id="customer-order-confirmation-ticket-qr-@_k" class="oc-qr" title="QR kod ulaznice" aria-label="QR kod ulaznice"></div>
                    </div>
                }
            </div>
        </div>

        <!-- Summary -->
        <div id="customer-order-confirmation-summary-card" class="oc-card">
            <span class="label">Sažetak</span>
            <div class="oc-lines">
                <div class="oc-line"><span>Ulaznice (@orderConfirmation.Tickets.Count)</span><span class="tnum">€@ticketsSubtotal.ToString("F2")</span></div>
                <div class="oc-line"><span>Naknada za uslugu</span><span class="tnum">€@serviceFee.ToString("F2")</span></div>
                <div class="oc-line"><span>Naknada za obradu</span><span class="tnum">€@processingFee.ToString("F2")</span></div>
                <div class="oc-line oc-line-total"><span>Ukupno</span><span id="customer-order-confirmation-total" class="tnum">€@orderConfirmation.TotalAmount.ToString("F2")</span></div>
            </div>
        </div>

        <!-- Ticket actions -->
        <div id="customer-order-confirmation-actions" class="oc-actions">
            <button id="customer-order-confirmation-print-btn" class="btn btn-ghost" @onclick="PrintTickets">🖨️ Ispiši</button>
            <button id="customer-order-confirmation-download-btn" class="btn btn-ghost" @onclick="DownloadTickets">⬇️ PDF</button>
            <button id="customer-order-confirmation-email-btn" class="btn btn-ghost" @onclick="EmailTickets">✉️ Email</button>
        </div>

        <!-- Important info -->
        <div id="customer-order-confirmation-info" class="oc-info">
            <span class="oc-info-title">ℹ️ Važne informacije</span>
            <ul id="customer-order-confirmation-info-list">
                <li>Dođi barem 30 minuta prije početka utakmice.</li>
                <li>Pokaži QR kod ulaznice na ulazu.</li>
                <li>Čuvaj ulaznice — svaki QR kod vrijedi samo jednom.</li>
                <li>Za pomoć se javi našoj podršci.</li>
            </ul>
        </div>
    </div>

    <div id="customer-order-confirmation-cta" class="oc-cta">
        <button id="customer-order-confirmation-browse-btn" class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/events"))">Pregledaj još utakmica</button>
    </div>
}

@code {
    [Parameter] public string OrderId { get; set; } = string.Empty;

    private OrderConfirmationDto? orderConfirmation;
    private bool isLoading = true;

    private decimal ticketsSubtotal => orderConfirmation?.Tickets.Sum(t => t.Price) ?? 0;
    private decimal serviceFee => ticketsSubtotal * 0.10m;
    private decimal processingFee => 2.50m;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrderConfirmation();
    }

    private async Task LoadOrderConfirmation()
    {
        try
        {
            orderConfirmation = await ApiService.GetOrderConfirmationAsync(OrderId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading order confirmation: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task PrintTickets() => await JSRuntime.InvokeVoidAsync("window.print");

    private async Task DownloadTickets() =>
        await JSRuntime.InvokeVoidAsync("alert", "Preuzimanje PDF-a bit će uskoro dostupno.");

    private async Task EmailTickets() =>
        await JSRuntime.InvokeVoidAsync("alert", "Ulaznice su poslane na tvoju email adresu.");

    private void GoBack() => Navigation.NavigateTo("/events");
}
