@page "/my-orders"
@using StadiumDrinkOrdering.Shared.Authentication.Interfaces
@inject IStaffApiService ApiService
@inject IAuthenticationStateService AuthService
@inject ISignalRService SignalRService
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> Localizer
@implements IDisposable

<PageTitle>@Localizer["MyOrders_Title"]</PageTitle>

@if (!AuthService.IsAuthenticated)
{
    <div class="container mt-5" id="staff-myorders-auth-container">
        <div class="alert alert-warning" role="alert" id="staff-myorders-auth-alert">
            @Localizer["MyOrders_AuthRequired"]
            <a href="/login" class="btn btn-primary ms-2" id="staff-myorders-login-link">@Localizer["Login"]</a>
        </div>
    </div>
}
else
{
    <div class="container-fluid" id="staff-myorders-main">
        <div class="row mb-4" id="staff-myorders-header-row">
            <div class="col" id="staff-myorders-header-col">
                <h1 id="staff-myorders-heading">@Localizer["MyOrders_Heading"]</h1>
                <p class="text-muted" id="staff-myorders-subtitle">@Localizer["MyOrders_Subtitle"]</p>
            </div>
            <div class="col-auto" id="staff-myorders-header-actions">
                <button class="btn btn-outline-primary" @onclick="RefreshOrders" id="staff-myorders-refresh-btn">
                    <span class="oi oi-reload me-2"></span>@Localizer["Refresh"]
                </button>
            </div>
        </div>

        <!-- Summary Cards -->
        <div class="row mb-4" id="staff-myorders-summary-row">
            <div class="col-md-3" id="staff-myorders-assigned-col">
                <div class="card bg-primary text-white" id="staff-myorders-assigned-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4 id="staff-myorders-assigned-count">@assignedOrders.Count</h4>
                                <small>@Localizer["MyOrders_TotalAssigned"]</small>
                            </div>
                            <div>
                                <span class="oi oi-clipboard" style="font-size: 2rem;"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3" id="staff-myorders-ready-col">
                <div class="card bg-info text-white" id="staff-myorders-ready-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4 id="staff-myorders-ready-count">@readyForDelivery.Count</h4>
                                <small>@Localizer["MyOrders_ReadyForDelivery"]</small>
                            </div>
                            <div>
                                <span class="oi oi-box" style="font-size: 2rem;"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3" id="staff-myorders-out-col">
                <div class="card bg-warning text-dark" id="staff-myorders-out-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4 id="staff-myorders-out-count">@outForDelivery.Count</h4>
                                <small>@Localizer["MyOrders_OutForDelivery"]</small>
                            </div>
                            <div>
                                <span class="oi oi-arrow-right" style="font-size: 2rem;"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3" id="staff-myorders-delivered-col">
                <div class="card bg-success text-white" id="staff-myorders-delivered-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4 id="staff-myorders-delivered-count">@deliveredToday.Count</h4>
                                <small>@Localizer["MyOrders_DeliveredToday"]</small>
                            </div>
                            <div>
                                <span class="oi oi-check" style="font-size: 2rem;"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Delivery Route Optimization -->
        @if (readyForDelivery.Any())
        {
            <div class="row mb-4" id="staff-myorders-route-row">
                <div class="col" id="staff-myorders-route-col">
                    <div class="card" id="staff-myorders-route-card">
                        <div class="card-header" id="staff-myorders-route-header">
                            <h5 id="staff-myorders-route-title">@Localizer["MyOrders_SuggestedRoute"]</h5>
                            <small class="text-muted" id="staff-myorders-route-subtitle">@Localizer["MyOrders_OptimizedBySection"]</small>
                        </div>
                        <div class="card-body" id="staff-myorders-route-body">
                            @foreach (var sectionGroup in GetOptimizedRoute())
                            {
                                <div class="mb-3" id="@($"staff-myorders-section-{sectionGroup.Key}")">
                                    <h6 class="text-primary" id="@($"staff-myorders-section-title-{sectionGroup.Key}")">@Localizer["MyOrders_Section"] @sectionGroup.Key (@sectionGroup.Count() @Localizer["MyOrders_Orders"])</h6>
                                    <div class="row" id="@($"staff-myorders-section-row-{sectionGroup.Key}")">
                                        @foreach (var order in sectionGroup.OrderBy(o => o.SeatNumber))
                                        {
                                            <div class="col-md-6 col-lg-4 mb-2" id="@($"staff-myorders-route-item-{order.Id}")">
                                                <div class="card border-info">
                                                    <div class="card-body p-2">
                                                        <small>
                                                            <strong>Order #@order.Id</strong><br>
                                                            @Localizer["MyOrders_Seat"] @order.SeatNumber<br>
                                                            @order.OrderItems.Sum(oi => oi.Quantity) @Localizer["MyOrders_Items"]
                                                        </small>
                                                        <div class="mt-2">
                                                            <button class="btn btn-sm btn-success" @onclick="() => MarkDelivered(order.Id)" id="staff-myorders-delivered-btn-@order.Id">
                                                                @Localizer["MyOrders_Delivered"]
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            @if (readyForDelivery.Any())
                            {
                                <div class="mt-3">
                                    <button class="btn btn-primary" @onclick="StartBatchDelivery" id="staff-myorders-batch-delivery-btn">
                                        <span class="oi oi-arrow-right me-2"></span>@Localizer["MyOrders_StartBatchDelivery"]
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Orders List -->
        <div class="row" id="staff-myorders-list-row">
            @if (assignedOrders.Any())
            {
                @foreach (var order in assignedOrders.OrderByDescending(o => o.OrderDate))
                {
                    <div class="col-lg-6 col-xl-4 mb-4" id="@($"staff-myorders-col-{order.Id}")">
                        <div class="card @GetOrderCardClass(order.Status)" id="@($"staff-myorders-card-{order.Id}")">
                            <div class="card-header d-flex justify-content-between align-items-center" id="@($"staff-myorders-card-header-{order.Id}")">
                                <h6 class="mb-0" id="@($"staff-myorders-card-title-{order.Id}")">Order #@order.Id</h6>
                                <span class="badge @GetStatusBadgeClass(order.Status)" id="@($"staff-myorders-card-status-{order.Id}")">
                                    @order.Status
                                </span>
                            </div>
                            <div class="card-body" id="@($"staff-myorders-card-body-{order.Id}")">
                                <div class="row mb-2" id="@($"staff-myorders-card-info-row-{order.Id}")">
                                    <div class="col-6" id="@($"staff-myorders-card-customer-{order.Id}")">
                                        <strong>@Localizer["MyOrders_Customer"]</strong><br>
                                        <small>@order.CustomerName</small>
                                    </div>
                                    <div class="col-6" id="@($"staff-myorders-card-seat-{order.Id}")">
                                        <strong>@Localizer["MyOrders_Seat"]</strong><br>
                                        <small>@order.SeatNumber</small>
                                    </div>
                                </div>

                                <div class="mb-2" id="@($"staff-myorders-card-items-{order.Id}")">
                                    <strong>@Localizer["MyOrders_Items"]</strong><br>
                                    @foreach (var item in order.OrderItems)
                                    {
                                        <small class="d-block">
                                            @item.Quantity x @item.DrinkName
                                        </small>
                                    }
                                </div>

                                <div class="mb-2" id="@($"staff-myorders-card-total-{order.Id}")">
                                    <strong>@Localizer["MyOrders_Total"]</strong> $@order.TotalAmount.ToString("F2")
                                </div>

                                <div class="mb-3" id="@($"staff-myorders-card-dates-{order.Id}")">
                                    <small class="text-muted">
                                        @Localizer["MyOrders_Ordered"] @order.OrderDate.ToString("HH:mm")
                                        @if (order.AcceptedAt.HasValue)
                                        {
                                            <br />@:@Localizer["MyOrders_Accepted"] @order.AcceptedAt.Value.ToString("HH:mm")
                                        }
                                    </small>
                                </div>

                                <!-- Order Actions -->
                                <div class="d-grid gap-2">
                                    @if (order.Status == OrderStatus.Ready)
                                    {
                                        <button class="btn btn-primary btn-sm" @onclick="() => StartDelivery(order.Id)" id="staff-myorders-start-delivery-btn-@order.Id">
                                            <span class="oi oi-arrow-right me-1"></span>@Localizer["MyOrders_StartDelivery"]
                                        </button>
                                    }
                                    else if (order.Status == OrderStatus.OutForDelivery)
                                    {
                                        <button class="btn btn-success btn-sm" @onclick="() => MarkDelivered(order.Id)" id="staff-myorders-mark-delivered-btn-@order.Id">
                                            <span class="oi oi-check me-1"></span>@Localizer["MyOrders_MarkDelivered"]
                                        </button>
                                    }

                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => ViewOrderDetails(order.Id)" id="staff-myorders-details-btn-@order.Id">
                                        <span class="oi oi-eye me-1"></span>@Localizer["MyOrders_ViewDetails"]
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12" id="staff-myorders-empty-col">
                    <div class="text-center py-5" id="staff-myorders-empty-state">
                        <span class="oi oi-clipboard" style="font-size: 4rem; color: #ccc;"></span>
                        <h4 class="mt-3 text-muted" id="staff-myorders-empty-title">@Localizer["MyOrders_NoOrders"]</h4>
                        <p class="text-muted" id="staff-myorders-empty-text">@Localizer["MyOrders_NoOrdersHelp"]</p>
                        <a href="/order-queue" class="btn btn-primary" id="staff-myorders-queue-link">
                            <span class="oi oi-list me-2"></span>@Localizer["MyOrders_GoToOrderQueue"]
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<OrderDto> assignedOrders = new();
    private List<OrderDto> readyForDelivery = new();
    private List<OrderDto> outForDelivery = new();
    private List<OrderDto> deliveredToday = new();
    private int currentStaffId; // Resolved from the authenticated staff user's JWT claims
    private bool isLoadingOrders = false;
    private CancellationTokenSource? loadOrdersCts;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        // Resolve the staff ID from the authenticated user's JWT claims.
        // If it can't be parsed, currentStaffId stays 0 and no orders are loaded
        // (safer than defaulting to another staffer's assignments).
        if (!int.TryParse(AuthService.UserId, out currentStaffId))
        {
            currentStaffId = 0;
            Console.WriteLine($"MyOrders: Unable to resolve staff ID from UserId claim '{AuthService.UserId}'");
        }

        try
        {
            if (!SignalRService.IsConnected)
            {
                await SignalRService.StartAsync();
                await SignalRService.JoinStaffHub();
            }
            
            SignalRService.OrderUpdated += OnOrderUpdated;
            SignalRService.OrderAssignedToStaff += OnOrderAssigned;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to start SignalR: {ex.Message}");
        }

        await LoadAssignedOrders();
    }

    private async Task LoadAssignedOrders()
    {
        // Prevent concurrent API calls
        if (isLoadingOrders)
        {
            Console.WriteLine("LoadAssignedOrders: Already loading, skipping duplicate call");
            return;
        }

        // Cancel any pending load operation
        loadOrdersCts?.Cancel();
        loadOrdersCts = new CancellationTokenSource();
        var token = loadOrdersCts.Token;

        try
        {
            isLoadingOrders = true;
            Console.WriteLine($"LoadAssignedOrders: Starting API call at {DateTime.Now:HH:mm:ss.fff}");
            
            var orders = await ApiService.GetAssignedOrdersAsync(currentStaffId) ?? new List<OrderDto>();
            
            // Check if this operation was cancelled
            if (token.IsCancellationRequested)
            {
                Console.WriteLine("LoadAssignedOrders: Operation was cancelled");
                return;
            }
            
            assignedOrders = orders;

            readyForDelivery = orders.Where(o => o.Status == OrderStatus.Ready).ToList();
            outForDelivery = orders.Where(o => o.Status == OrderStatus.OutForDelivery).ToList();
            deliveredToday = orders.Where(o => o.Status == OrderStatus.Delivered && 
                                              o.DeliveredAt.HasValue && 
                                              o.DeliveredAt.Value.Date == DateTime.Today).ToList();

            Console.WriteLine($"LoadAssignedOrders: Completed API call at {DateTime.Now:HH:mm:ss.fff}, loaded {orders.Count} orders");
            StateHasChanged();
        }
        catch (OperationCanceledException)
        {
            Console.WriteLine("LoadAssignedOrders: Operation cancelled");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"LoadAssignedOrders: Error - {ex.Message}");
        }
        finally
        {
            isLoadingOrders = false;
        }
    }

    private IEnumerable<IGrouping<string, OrderDto>> GetOptimizedRoute()
    {
        return readyForDelivery
            .GroupBy(o => o.SeatNumber?.Substring(0, 1) ?? "Unknown")
            .OrderBy(g => g.Key);
    }

    private async Task StartDelivery(int orderId)
    {
        var updateDto = new UpdateOrderStatusDto 
        { 
            Status = OrderStatus.OutForDelivery,
            Notes = "Out for delivery"
        };
        
        var success = await ApiService.UpdateOrderStatusAsync(orderId, updateDto);
        if (success)
        {
            await LoadAssignedOrders();
            await SignalRService.SendOrderStatusChanged(orderId, OrderStatus.OutForDelivery, "");
        }
    }

    private async Task MarkDelivered(int orderId)
    {
        var updateDto = new UpdateOrderStatusDto 
        { 
            Status = OrderStatus.Delivered,
            Notes = "Delivered successfully"
        };
        
        var success = await ApiService.UpdateOrderStatusAsync(orderId, updateDto);
        if (success)
        {
            await LoadAssignedOrders();
            await SignalRService.SendOrderStatusChanged(orderId, OrderStatus.Delivered, "");
        }
    }

    private async Task StartBatchDelivery()
    {
        foreach (var order in readyForDelivery)
        {
            await StartDelivery(order.Id);
            await Task.Delay(100); // Small delay to avoid overwhelming the API
        }
    }

    private void ViewOrderDetails(int orderId)
    {
        Navigation.NavigateTo($"/order/{orderId}");
    }

    private async Task RefreshOrders()
    {
        // Don't refresh if already loading
        if (isLoadingOrders)
        {
            Console.WriteLine("RefreshOrders: Already loading, skipping");
            return;
        }

        await LoadAssignedOrders();
    }

    private async void OnOrderUpdated(OrderDto order)
    {
        await InvokeAsync(async () =>
        {
            await LoadAssignedOrders();
        });
    }

    private async void OnOrderAssigned(int orderId, int staffId)
    {
        if (staffId == currentStaffId)
        {
            await InvokeAsync(async () =>
            {
                await LoadAssignedOrders();
            });
        }
    }

    private string GetOrderCardClass(OrderStatus status)
    {
        return status switch
        {
            OrderStatus.Ready => "border-success",
            OrderStatus.OutForDelivery => "border-warning",
            OrderStatus.Delivered => "border-secondary",
            _ => ""
        };
    }

    private string GetStatusBadgeClass(OrderStatus status)
    {
        return status switch
        {
            OrderStatus.Ready => "bg-success",
            OrderStatus.OutForDelivery => "bg-warning text-dark",
            OrderStatus.Delivered => "bg-success",
            _ => "bg-secondary"
        };
    }

    public void Dispose()
    {
        loadOrdersCts?.Cancel();
        loadOrdersCts?.Dispose();
        
        if (SignalRService != null)
        {
            SignalRService.OrderUpdated -= OnOrderUpdated;
            SignalRService.OrderAssignedToStaff -= OnOrderAssigned;
        }
    }
}