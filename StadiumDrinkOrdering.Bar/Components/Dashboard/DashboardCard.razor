@if (IsLoading)
{
    <div id="bar-dashboardcard-loading-col-@TitleSlug()" class="col-md-3 mb-4">
        <div id="bar-dashboardcard-skeleton-card-@TitleSlug()" class="dashboard-card skeleton-card">
            <div id="bar-dashboardcard-skeleton-content-@TitleSlug()" class="skeleton-content">
                <div id="bar-dashboardcard-loading-title-@TitleSlug()" class="skeleton-text skeleton-title"></div>
                <div id="bar-dashboardcard-loading-subtitle-@TitleSlug()" class="skeleton-text skeleton-subtitle"></div>
            </div>
            <div id="bar-dashboardcard-loading-icon-@TitleSlug()" class="skeleton-icon"></div>
        </div>
    </div>
}
else
{
    <div id="bar-dashboardcard-col-@TitleSlug()" class="col-md-3 mb-4">
        <div id="bar-dashboardcard-card-@TitleSlug()" class="dashboard-card @BackgroundClass @(Clickable ? "clickable" : "")" @onclick="HandleClick">
            <div id="bar-dashboardcard-card-body-@TitleSlug()" class="card-body">
                <div id="bar-dashboardcard-content-flex-@TitleSlug()" class="d-flex justify-content-between">
                    <div id="bar-dashboardcard-metric-@TitleSlug()" class="metric-content">
                        <h4 class="metric-value @TextColorClass">@Value</h4>
                        <small class="metric-title @TextColorClass">@Title</small>
                    </div>
                    <div id="bar-dashboardcard-metric-icon-@TitleSlug()" class="metric-icon">
                        <span class="@IconClass @TextColorClass" style="font-size: 2rem;"></span>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Subtitle))
                {
                    <div id="bar-dashboardcard-subtitle-@TitleSlug()" class="mt-2">
                        <small class="@TextColorClass opacity-75">@Subtitle</small>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Value { get; set; } = "0";
    [Parameter] public string IconClass { get; set; } = "oi oi-info";
    [Parameter] public string BackgroundClass { get; set; } = "bg-primary";
    [Parameter] public string TextColorClass { get; set; } = "text-white";
    [Parameter] public string Subtitle { get; set; } = string.Empty;
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public bool Clickable { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }

    // Stable, language-independent slug for element IDs. When set it is used as-is so the
    // automation/test IDs stay constant across cultures; otherwise we fall back to slugifying
    // the (localized) title.
    [Parameter] public string? IdSlug { get; set; }

    private string TitleSlug() => !string.IsNullOrWhiteSpace(IdSlug)
        ? IdSlug
        : System.Text.RegularExpressions.Regex.Replace(Title.ToLower(), "[^a-z0-9-]", "-");

    private async Task HandleClick()
    {
        if (Clickable && OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync();
        }
    }
}