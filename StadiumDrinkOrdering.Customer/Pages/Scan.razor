@page "/scan"
@layout MobileShell
@inject NavigationManager Nav

<PageTitle>Skeniraj ulaznicu — HALFTIME</PageTitle>

<ScreenHeader Title="Skeniraj ulaznicu" BackHref="/welcome" />

<div id="customer-scan-body" class="scan-body">
    <div id="customer-scan-reticle" class="reticle">
        <span class="corner tl"></span><span class="corner tr"></span>
        <span class="corner bl"></span><span class="corner br"></span>
        <div id="customer-scan-qr-emoji" class="qr-emoji">🎟️</div>
        <div id="customer-scan-scanline" class="scanline"></div>
    </div>

    <p class="scan-hint">Uperi kameru svog telefona u QR kôd na ulaznici — aplikacija se otvara automatski.</p>

    <div id="customer-scan-manual" class="manual">
        <div id="customer-scan-manual-label" class="label">Ne možeš skenirati?</div>
        <div id="customer-scan-manual-row" class="manual-row">
            <input id="customer-scan-code-input" @bind="_code" @bind:event="oninput" placeholder="Unesi kôd s ulaznice" @onkeydown="OnKey" />
            <button id="customer-scan-submit-btn" class="btn btn-primary btn-sm" @onclick="Submit" disabled="@string.IsNullOrWhiteSpace(_code)">Nastavi</button>
        </div>
        @if (_error)
        {
            <div id="customer-scan-error" class="err">Unesi važeći kôd s ulaznice.</div>
        }
    </div>
</div>

@code {
    private string _code = "";
    private bool _error;

    private void OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") Submit();
    }

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(_code)) { _error = true; return; }
        Nav.NavigateTo($"/t/{_code.Trim()}");
    }
}
