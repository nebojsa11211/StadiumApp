@page "/order-confirmation/{orderId}"
@layout MobileShell
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Shared.DTOs
@inject IApiService ApiService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["OrderConfirmation_PageTitle"]</PageTitle>

<ScreenHeader Title="@Localizer["OrderConfirmation_ScreenHeader"]" Subtitle="Ulaznice" OnBack="GoBack" />

@if (isLoading)
{
    <div id="customer-order-confirmation-loading" class="oc-state">
        <span class="spinner"></span> @Localizer["OrderConfirmation_Loading"]
    </div>
}
else if (orderConfirmation == null)
{
    <div id="customer-order-confirmation-notfound" class="oc-state oc-notfound">
        <div id="customer-order-confirmation-emoji" class="oc-emoji">🚫</div>
        <h2>@Localizer["OrderConfirmation_NotFound_Title"]</h2>
        <p>@Localizer["OrderConfirmation_NotFound_Message"]</p>
        <button id="customer-order-confirmation-notfound-btn" class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/events"))">@Localizer["OrderConfirmation_BackToEvents"]</button>
    </div>
}
else
{
    <div id="customer-order-confirmation-body" class="oc-body no-scrollbar">

        <!-- Success hero -->
        <div id="customer-order-confirmation-hero" class="oc-hero">
            <div id="customer-order-confirmation-check" class="oc-check">✓</div>
            <h2 id="customer-order-confirmation-hero-title">@Localizer["OrderConfirmation_Success"]</h2>
            <p id="customer-order-confirmation-hero-sub">@Localizer["OrderConfirmation_SuccessMessage"]</p>
        </div>

        <!-- Order meta -->
        <div id="customer-order-confirmation-details-card" class="oc-card">
            <span class="label">@Localizer["OrderConfirmation_OrderDetails"]</span>
            <div id="customer-order-confirmation-meta" class="oc-meta">
                <div class="oc-meta-row"><span>@Localizer["OrderConfirmation_Order_Label"]</span><span id="customer-order-confirmation-order-id" class="v tnum">#@orderConfirmation.OrderId</span></div>
                <div class="oc-meta-row"><span>@Localizer["OrderConfirmation_Date_Label"]</span><span id="customer-order-confirmation-order-date" class="v">@orderConfirmation.OrderDate.ToString("dd.MM.yyyy · HH:mm")</span></div>
                <div class="oc-meta-row"><span>@Localizer["OrderConfirmation_Customer_Label"]</span><span id="customer-order-confirmation-customer" class="v">@orderConfirmation.CustomerName</span></div>
                <div class="oc-meta-row"><span>@Localizer["OrderConfirmation_Payment_Label"]</span><span id="customer-order-confirmation-payment-badge" class="oc-badge">@orderConfirmation.PaymentStatus</span></div>
                <div class="oc-meta-row"><span>@Localizer["OrderConfirmation_Event_Label"]</span><span id="customer-order-confirmation-event" class="v">@orderConfirmation.EventName</span></div>
                <div class="oc-meta-row"><span>@Localizer["OrderConfirmation_EventDate_Label"]</span><span id="customer-order-confirmation-event-date" class="v">@orderConfirmation.EventDate.ToString("dd.MM.yyyy · HH:mm")</span></div>
            </div>
        </div>

        <!-- Tickets -->
        <div id="customer-order-confirmation-tickets" class="oc-section">
            <span class="label">@Localizer["OrderConfirmation_Tickets", orderConfirmation.Tickets.Count]</span>
            <div id="customer-order-confirmation-tickets-list" class="oc-tickets">
                @foreach (var ticket in orderConfirmation.Tickets)
                {
                    var _k = ticket.SeatCode.GetHashCode();
                    <div id="customer-order-confirmation-ticket-@_k" class="oc-ticket">
                        <div id="customer-order-confirmation-ticket-info-@_k" class="oc-ticket-info">
                            <div class="oc-ticket-top">
                                <span id="customer-order-confirmation-ticket-code-@_k" class="oc-ticket-code">@ticket.SeatCode</span>
                                <span id="customer-order-confirmation-ticket-price-@_k" class="oc-ticket-price tnum">€@ticket.Price.ToString("F2")</span>
                            </div>
                            <span id="customer-order-confirmation-ticket-sector-@_k" class="oc-ticket-sub">@Localizer["OrderConfirmation_TicketSector", ticket.SectionName]</span>
                            <span id="customer-order-confirmation-ticket-number-@_k" class="oc-ticket-sub tnum">@ticket.TicketNumber</span>
                        </div>
                        <div id="customer-order-confirmation-ticket-qr-@_k" class="oc-qr" title="QR kod ulaznice" aria-label="QR kod ulaznice"></div>
                    </div>
                }
            </div>
        </div>

        <!-- Summary -->
        <div id="customer-order-confirmation-summary-card" class="oc-card">
            <span class="label">@Localizer["OrderConfirmation_Summary"]</span>
            <div class="oc-lines">
                <div class="oc-line"><span>@Localizer["OrderConfirmation_TicketsLine", orderConfirmation.Tickets.Count]</span><span class="tnum">€@ticketsSubtotal.ToString("F2")</span></div>
                <div class="oc-line"><span>@Localizer["OrderConfirmation_ServiceFee"]</span><span class="tnum">€@serviceFee.ToString("F2")</span></div>
                <div class="oc-line"><span>@Localizer["OrderConfirmation_ProcessingFee"]</span><span class="tnum">€@processingFee.ToString("F2")</span></div>
                <div class="oc-line oc-line-total"><span>@Localizer["OrderConfirmation_Total"]</span><span id="customer-order-confirmation-total" class="tnum">€@orderConfirmation.TotalAmount.ToString("F2")</span></div>
            </div>
        </div>

        <!-- Ticket actions -->
        <div id="customer-order-confirmation-actions" class="oc-actions">
            <button id="customer-order-confirmation-print-btn" class="btn btn-ghost" @onclick="PrintTickets">@Localizer["OrderConfirmation_PrintButton"]</button>
            <button id="customer-order-confirmation-download-btn" class="btn btn-ghost" @onclick="DownloadTickets">@Localizer["OrderConfirmation_DownloadButton"]</button>
            <button id="customer-order-confirmation-email-btn" class="btn btn-ghost" @onclick="EmailTickets">@Localizer["OrderConfirmation_EmailButton"]</button>
        </div>

        <!-- Important info -->
        <div id="customer-order-confirmation-info" class="oc-info">
            <span class="oc-info-title">@Localizer["OrderConfirmation_ImportantInfo"]</span>
            <ul id="customer-order-confirmation-info-list">
                <li>@Localizer["OrderConfirmation_ArriveEarly"]</li>
                <li>@Localizer["OrderConfirmation_ShowQRCode"]</li>
                <li>@Localizer["OrderConfirmation_KeepSafe"]</li>
                <li>@Localizer["OrderConfirmation_SupportContact"]</li>
            </ul>
        </div>
    </div>

    <div id="customer-order-confirmation-cta" class="oc-cta">
        <button id="customer-order-confirmation-browse-btn" class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/events"))">@Localizer["OrderConfirmation_BrowseMore"]</button>
    </div>
}

@code {
    [Parameter] public string OrderId { get; set; } = string.Empty;

    private OrderConfirmationDto? orderConfirmation;
    private bool isLoading = true;

    private decimal ticketsSubtotal => orderConfirmation?.Tickets.Sum(t => t.Price) ?? 0;
    private decimal serviceFee => ticketsSubtotal * 0.10m;
    private decimal processingFee => 2.50m;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrderConfirmation();
    }

    private async Task LoadOrderConfirmation()
    {
        try
        {
            orderConfirmation = await ApiService.GetOrderConfirmationAsync(OrderId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading order confirmation: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task PrintTickets() => await JSRuntime.InvokeVoidAsync("window.print");

    private async Task DownloadTickets() =>
        await JSRuntime.InvokeVoidAsync("alert", Localizer["OrderConfirmation_DownloadNotReady"]);

    private async Task EmailTickets() =>
        await JSRuntime.InvokeVoidAsync("alert", Localizer["OrderConfirmation_EmailSent"]);

    private void GoBack() => Navigation.NavigateTo("/events");
}
