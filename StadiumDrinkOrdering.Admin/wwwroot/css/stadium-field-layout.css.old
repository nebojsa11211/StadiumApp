/* ===============================================
   STADIUM FIELD LAYOUT - Core Grid System
   Optimized for maximum visibility and responsiveness
   =============================================== */

:root {
    /* Stadium Layout Variables - Optimized for Square Field */
    --stadium-container-height: auto;
    --stadium-container-min-height: 700px;
    --stadium-container-max-width: 100%;
    --stadium-padding: 1rem;
    --stadium-gap: 0.75rem;

    /* Stadium Field Dimensions - 105m x 45m proportions */
    --field-width: 100%;
    --field-max-width: 700px; /* Increased for rectangular field */
    --field-aspect-ratio: 2.333; /* 105:45 ratio (7:3) for 105m x 45m rectangular field */

    /* Stand Dimensions */
    --stand-padding: 0.75rem;
    --stand-border-radius: 1rem;
    --stand-min-height: 150px; /* Ensure tribunes are always visible */

    /* Z-index hierarchy */
    --z-field: 1;
    --z-stands: 10;
    --z-sectors: 20;
    --z-modal: 100;
}

/* Main Stadium Container - Optimized for Square Field Visibility */
#admin-stadium-container,
.stadium-container {
    width: 100% !important;
    height: auto !important;
    min-height: var(--stadium-container-min-height) !important;
    max-width: var(--stadium-container-max-width) !important;
    padding: var(--stadium-padding) !important;
    box-sizing: border-box !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    position: relative !important;
    overflow: visible !important;
    background: linear-gradient(135deg,
        rgba(239, 246, 255, 0.5) 0%,
        rgba(219, 234, 254, 0.5) 100%);
    border-radius: 1.5rem;
}

/* Stadium Grid Layout - Optimized for Rectangular Field (105m × 45m) */
.stadium-grid-layout {
    width: 100%;
    max-width: 1400px;
    height: auto;
    display: grid !important;
    grid-template-columns: 180px 700px 180px;
    grid-template-rows: 150px 300px 150px;
    grid-template-areas:
        "corner-nw stand-n corner-ne"
        "stand-w field stand-e"
        "corner-sw stand-s corner-se";
    gap: var(--stadium-gap);
    padding: var(--stadium-padding);
    position: relative;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border-radius: 2rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    /* Prevent overflow */
    overflow: hidden;
    box-sizing: border-box;
    /* Center items in grid cells */
    align-items: center;
    justify-items: center;
}

/* Stadium Field - Rectangular Playing Area (105m × 45m) */
.stadium-field {
    grid-area: field !important;
    width: 700px !important;
    height: 300px !important;
    background: linear-gradient(135deg,
        #4ade80 0%,
        #22c55e 25%,
        #16a34a 50%,
        #22c55e 75%,
        #4ade80 100%);
    background-size: 200% 200%;
    animation: fieldGradient 10s ease infinite;
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: var(--z-field);
    box-shadow:
        inset 0 4px 12px rgba(0, 0, 0, 0.15),
        0 8px 32px rgba(34, 197, 94, 0.25);
    border: 3px solid rgba(255, 255, 255, 0.5);
    overflow: hidden;
}

@keyframes fieldGradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

/* Field Markings - Soccer/football field lines */
.field-markings {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 2px solid rgba(255, 255, 255, 0.6);
    border-radius: 0.5rem;
    pointer-events: none;
    box-sizing: border-box;
}

.field-markings::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    width: 2px;
    height: 100%;
    background: rgba(255, 255, 255, 0.6);
    transform: translateX(-50%);
}

/* Center circle */
.center-circle {
    position: absolute !important;
    top: 50% !important;
    left: 50% !important;
    transform: translate(-50%, -50%) !important;
    width: 80px !important;
    height: 80px !important;
    border: 2px solid rgba(255, 255, 255, 0.9) !important;
    border-radius: 50% !important;
    background: transparent !important;
    z-index: 10 !important;
}

/* Center line */
.center-line {
    position: absolute !important;
    top: 0 !important;
    left: 50% !important;
    width: 2px !important;
    height: 100% !important;
    background: rgba(255, 255, 255, 0.8) !important;
    transform: translateX(-50%) !important;
    z-index: 9 !important;
}

.center-circle::after {
    content: '';
    position: absolute !important;
    top: 50% !important;
    left: 50% !important;
    transform: translate(-50%, -50%) !important;
    width: 8px !important;
    height: 8px !important;
    background: rgba(255, 255, 255, 0.9) !important;
    border-radius: 50% !important;
    z-index: 11 !important;
}

/* Penalty areas */
.penalty-area-left,
.penalty-area-right {
    position: absolute;
    width: 20%;
    height: 50%;
    top: 25%;
    border: 2px solid rgba(255, 255, 255, 0.6);
    background: transparent;
}

.penalty-area-left {
    left: -2px;
    border-left: none;
    border-radius: 0 0.5rem 0.5rem 0;
}

.penalty-area-right {
    right: -2px;
    border-right: none;
    border-radius: 0.5rem 0 0 0.5rem;
}

/* Goals */
.goal-left,
.goal-right {
    position: absolute;
    width: 8%;
    height: 25%;
    top: 37.5%;
    background: rgba(255, 255, 255, 0.3);
    border: 2px solid rgba(255, 255, 255, 0.8);
}

.goal-left {
    left: -2px;
    border-left: none;
    border-radius: 0 0.25rem 0.25rem 0;
}

.goal-right {
    right: -2px;
    border-right: none;
    border-radius: 0.25rem 0 0 0.25rem;
}

/* Field Label */
.field-label {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.95);
    font-size: 1.25rem;
    font-weight: 800;
    text-shadow:
        0 2px 4px rgba(0, 0, 0, 0.3),
        0 0 20px rgba(34, 197, 94, 0.5);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    z-index: 10;
}

/* Stadium Stands - Tribune areas with Minimum Visibility */
.stadium-stand {
    background: linear-gradient(135deg,
        rgba(255, 255, 255, 0.98) 0%,
        rgba(249, 250, 251, 0.98) 100%);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: var(--stand-border-radius);
    padding: var(--stand-padding);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
    z-index: var(--z-stands);
    box-shadow:
        0 4px 6px rgba(0, 0, 0, 0.05),
        0 10px 20px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
    overflow: auto;
    min-height: var(--stand-min-height);
    max-width: 100%;
    max-height: 100%;
    box-sizing: border-box;
}

.stadium-stand:hover {
    transform: translateY(-2px);
    box-shadow:
        0 8px 12px rgba(0, 0, 0, 0.1),
        0 16px 32px rgba(0, 0, 0, 0.12);
    border-color: rgba(59, 130, 246, 0.4);
    z-index: calc(var(--z-stands) + 5);
}

/* Stand positioning - Fixed class names */
.stand-n,
.stand-north,
.stand-position-north {
    grid-area: stand-n !important;
    width: 100% !important;
    height: 100% !important;
    max-width: 700px !important;
    max-height: 150px !important;
    box-sizing: border-box !important;
}

.stand-s,
.stand-south,
.stand-position-south {
    grid-area: stand-s !important;
    width: 100% !important;
    height: 100% !important;
    max-width: 700px !important;
    max-height: 150px !important;
    box-sizing: border-box !important;
}

.stand-e,
.stand-east,
.stand-position-east {
    grid-area: stand-e !important;
    width: 100% !important;
    height: 100% !important;
    max-width: 180px !important;
    max-height: 300px !important;
    box-sizing: border-box !important;
}

.stand-w,
.stand-west,
.stand-position-west {
    grid-area: stand-w !important;
    width: 100% !important;
    height: 100% !important;
    max-width: 180px !important;
    max-height: 300px !important;
    box-sizing: border-box !important;
}

/* Stand Title - Hidden */
.stand-title {
    display: none !important;
}

/* Sectors Grid */
.sectors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
    gap: 0.5rem;
    flex: 1;
    align-content: start;
}

/* Individual Sector */
.sector {
    background: linear-gradient(135deg,
        rgba(255, 255, 255, 0.9) 0%,
        rgba(249, 250, 251, 0.9) 100%);
    border: 2px solid rgba(203, 213, 225, 0.8);
    border-radius: 0.75rem;
    padding: 0.75rem 0.5rem;
    min-height: 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
    z-index: var(--z-sectors);
    overflow: hidden;
}

.sector:hover {
    transform: translateY(-3px) scale(1.05);
    box-shadow:
        0 8px 16px rgba(0, 0, 0, 0.12),
        0 0 0 2px rgba(59, 130, 246, 0.5);
    background: linear-gradient(135deg,
        rgba(255, 255, 255, 1) 0%,
        rgba(239, 246, 255, 1) 100%);
    z-index: calc(var(--z-sectors) + 10);
}

.sector:focus {
    outline: 3px solid rgba(59, 130, 246, 0.5);
    outline-offset: 2px;
}

/* Sector Name */
.sector-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 0.25rem;
    line-height: 1.2;
}

/* Seat Count Display */
.seat-count {
    font-size: 0.75rem;
    color: #475569;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-weight: 600;
}

.seat-count .available {
    color: #10b981;
}

.seat-count .separator {
    color: #94a3b8;
}

.seat-count .total {
    color: #64748b;
}

/* Occupancy Bar */
.occupancy-bar {
    width: 100%;
    height: 4px;
    background: rgba(203, 213, 225, 0.3);
    border-radius: 2px;
    overflow: hidden;
    margin-top: 0.5rem;
}

.occupancy-fill {
    height: 100%;
    background: linear-gradient(90deg, #3b82f6 0%, #2563eb 100%);
    border-radius: 2px;
    transition: width 0.3s ease;
}

/* Sector Status Colors */
.sector.status-available {
    background: linear-gradient(135deg,
        rgba(220, 252, 231, 0.9) 0%,
        rgba(187, 247, 208, 0.9) 100%);
    border-color: rgba(34, 197, 94, 0.5);
}

.sector.status-partial {
    background: linear-gradient(135deg,
        rgba(254, 243, 199, 0.9) 0%,
        rgba(253, 230, 138, 0.9) 100%);
    border-color: rgba(245, 158, 11, 0.5);
}

.sector.status-full {
    background: linear-gradient(135deg,
        rgba(254, 226, 226, 0.9) 0%,
        rgba(254, 202, 202, 0.9) 100%);
    border-color: rgba(239, 68, 68, 0.5);
}

.sector.sector-vip {
    background: linear-gradient(135deg,
        rgba(237, 233, 254, 0.9) 0%,
        rgba(221, 214, 254, 0.9) 100%);
    border-color: rgba(139, 92, 246, 0.5);
}

/* Responsive Breakpoints - Optimized for Rectangular Field (105:45 ratio) */
@media (max-width: 1400px) {
    :root {
        --field-max-width: 630px;
        --stand-min-height: 135px;
    }

    .stadium-grid-layout {
        grid-template-columns: 160px 630px 160px;
        grid-template-rows: 135px 270px 135px;
        max-width: 1250px;
    }

    .stadium-field {
        width: 630px !important;
        height: 270px !important;
    }
}

@media (max-width: 1200px) {
    :root {
        --stadium-container-min-height: 550px;
        --stadium-padding: 0.75rem;
        --stadium-gap: 0.5rem;
        --field-max-width: 560px;
        --stand-min-height: 120px;
        --stand-padding: 0.5rem;
    }

    .stadium-grid-layout {
        grid-template-columns: 140px 560px 140px;
        grid-template-rows: 120px 240px 120px;
        max-width: 1100px;
    }

    .stadium-field {
        width: 560px !important;
        height: 240px !important;
    }

    .sectors-grid {
        grid-template-columns: repeat(auto-fit, minmax(70px, 1fr));
        gap: 0.4rem;
    }
}

@media (max-width: 992px) {
    :root {
        --stadium-container-min-height: 500px;
        --field-max-width: 490px;
        --stand-min-height: 105px;
    }

    .stadium-grid-layout {
        grid-template-columns: 110px 490px 110px;
        grid-template-rows: 105px 210px 105px;
        gap: 0.5rem;
        padding: 0.75rem;
        max-width: 900px;
    }

    .stadium-field {
        width: 490px !important;
        height: 210px !important;
    }

    .sector {
        min-height: 70px;
        padding: 0.5rem 0.25rem;
    }

    .sector-name {
        font-size: 0.75rem;
    }

    .seat-count {
        font-size: 0.625rem;
    }
}

@media (max-width: 768px) {
    :root {
        --stadium-container-min-height: auto;
        --field-max-width: 100%;
    }

    .stadium-grid-layout {
        display: flex !important;
        flex-direction: column;
        gap: 1rem;
        max-width: 100%;
        height: auto;
    }

    .stadium-field {
        order: 2;
        width: 100% !important;
        height: auto !important;
        min-height: 180px;
        max-width: 90vw;
        aspect-ratio: 2.333 !important; /* Force 105:45 ratio (7:3) on mobile */
    }

    .stand-n { order: 1; }
    .stand-s { order: 3; }
    .stand-w { order: 4; }
    .stand-e { order: 5; }

    .stadium-stand {
        width: 100%;
        min-height: 150px;
    }

    .sectors-grid {
        grid-template-columns: repeat(auto-fill, minmax(60px, 1fr));
    }
}

@media (max-width: 480px) {
    .stadium-field {
        width: 100% !important;
        height: auto !important;
        min-height: 150px;
        max-width: 95vw;
        aspect-ratio: 2.333 !important; /* Maintain 105:45 ratio (7:3) on small screens */
    }

    .sector {
        min-height: 60px;
        padding: 0.5rem 0.25rem;
    }

    .field-label {
        font-size: 0.875rem;
    }

    .center-circle {
        width: 50px !important;
        height: 50px !important;
    }
}

/* Loading and Error States */
.loading-state,
.error-state,
.empty-state {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    background: linear-gradient(135deg,
        rgba(249, 250, 251, 0.9) 0%,
        rgba(243, 244, 246, 0.9) 100%);
    border-radius: 1rem;
    text-align: center;
}

.loading-spinner {
    width: 48px;
    height: 48px;
    border: 4px solid rgba(59, 130, 246, 0.2);
    border-top-color: #3b82f6;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* Print Styles */
@media print {
    #admin-stadium-container {
        height: auto !important;
        min-height: auto !important;
        page-break-inside: avoid;
    }

    .stadium-grid-layout {
        height: auto;
        max-height: none;
    }

    .stadium-field {
        background: #e5e7eb !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }
}

/* Accessibility - High Contrast Mode */
@media (prefers-contrast: high) {
    .stadium-field {
        background: #22c55e !important;
        border: 3px solid #000 !important;
    }

    .stadium-stand {
        background: #fff !important;
        border: 2px solid #000 !important;
    }

    .sector {
        border: 2px solid #000 !important;
    }

    .field-markings,
    .center-circle,
    .penalty-area-left,
    .penalty-area-right {
        border-color: #fff !important;
    }
}

/* Reduced Motion */
@media (prefers-reduced-motion: reduce) {
    .stadium-field {
        animation: none !important;
    }

    .stadium-stand,
    .sector {
        transition: none !important;
    }
}