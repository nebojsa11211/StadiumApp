@page "/my-tickets"
@layout MobileShell
@using System.IO
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Customer.Components
@using Microsoft.Extensions.Localization
@inject IApiService ApiService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["MyTickets_PageTitle"]</PageTitle>

<ScreenHeader Title="@Localizer["MyTickets_ScreenHeader_Title"]" Subtitle="@Localizer["MyTickets_ScreenHeader_Subtitle"]" ShowBack="true" BackHref="/home" />

<AuthenticationGuard>
    <div id="customer-tickets-container" class="mt-body no-scrollbar">

        @if (tickets == null)
        {
            <div id="customer-tickets-loading" class="mt-state"><span class="spinner"></span> @Localizer["MyTickets_Loading"]</div>
        }
        else if (!tickets.Any())
        {
            <div id="customer-tickets-empty" class="mt-state mt-empty">
                <div class="mt-emoji">🎟️</div>
                <h2>@Localizer["MyTickets_Empty_Title"]</h2>
                <p>@Localizer["MyTickets_Empty_Message"]</p>
                <a id="customer-tickets-browse-btn" href="/events" class="btn btn-primary">@Localizer["MyTickets_BrowseEvents"]</a>
            </div>
        }
        else
        {
            <div id="customer-tickets-list" class="mt-list">
                @foreach (var ticket in tickets)
                {
                    <button type="button" id="customer-ticket-@ticket.Id" class="mt-card" @onclick="() => OpenDetail(ticket.Id)">
                        <div class="mt-card-head">
                            <span id="customer-ticket-event-@ticket.Id" class="mt-event">@ticket.EventName</span>
                            @if (ticket.Kind == TicketKind.Season)
                            {
                                <span class="mt-badge">@Localizer["MyTickets_SeasonBadge"]</span>
                            }
                        </div>
                        <div class="mt-card-meta">
                            <span id="customer-ticket-date-@ticket.Id">📅 @(ticket.EventDate?.ToLocalTime().ToString("dd.MM.yyyy · HH:mm") ?? "—")</span>
                            <span id="customer-ticket-seat-@ticket.Id">🎫 @SeatText(ticket)</span>
                        </div>
                        <div class="mt-card-foot">
                            <span id="customer-ticket-number-@ticket.Id" class="mt-num tnum">@ticket.TicketNumber</span>
                            <span id="customer-ticket-price-@ticket.Id" class="mt-price tnum">
                                @(ticket.Kind == TicketKind.Season && ticket.Price == 0m ? "Uključeno" : Money(ticket.Price))
                            </span>
                        </div>
                    </button>
                }
            </div>
        }
    </div>

    @if (showDetail)
    {
        <div id="customer-ticket-scrim" class="mt-scrim show" @onclick="CloseDetail"></div>
        <div id="customer-ticket-sheet" class="mt-sheet show">
            <div class="grab"></div>
            <div class="mt-sheet-head">
                <div>
                    <div id="customer-ticket-sheet-title" class="mt-sheet-title">@Localizer["MyTickets_TicketTitle"]</div>
                    <div class="mt-sheet-sub tnum">@(selectedDetail?.TicketNumber ?? "")</div>
                </div>
                <button id="customer-ticket-sheet-close-btn" class="iconbtn" @onclick="CloseDetail" aria-label="@Localizer["MyTickets_CloseButton"]">✕</button>
            </div>

            <div class="mt-sheet-body no-scrollbar">
                @if (detailLoading)
                {
                    <div class="mt-state"><span class="spinner"></span> @Localizer["MyTickets_DetailsLoading"]</div>
                }
                else if (selectedDetail == null)
                {
                    <div class="mt-inline-error">@Localizer["MyTickets_DetailsError"]</div>
                }
                else
                {
                    <!-- Visual ticket card -->
                    <div id="customer-ticket-card" class="tcard">
                        <div class="tcard-head">
                            <div>
                                <span class="tcard-eyebrow">@Localizer["MyTickets_TicketEntry"]</span>
                                <div class="tcard-event">@selectedDetail.EventName</div>
                            </div>
                            @if (selectedDetail.Kind == TicketKind.Season)
                            {
                                <span class="tcard-season">@Localizer["MyTickets_SeasonTicket"]</span>
                            }
                        </div>
                        <div class="tcard-body">
                            <div class="tcard-info">
                                <div class="tcard-field">
                                    <span>@Localizer["MyTickets_DateField"]</span>
                                    <strong>@(selectedDetail.EventDate?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "—")</strong>
                                </div>
                                <div class="tcard-seatrow">
                                    <div class="tcard-field"><span>@Localizer["MyTickets_SectorField"]</span><strong>@Dash(selectedDetail.Section)</strong></div>
                                    <div class="tcard-field"><span>@Localizer["MyTickets_RowField"]</span><strong>@Dash(selectedDetail.Row)</strong></div>
                                    <div class="tcard-field"><span>@Localizer["MyTickets_SeatField"]</span><strong>@Dash(selectedDetail.SeatNumber)</strong></div>
                                </div>
                            </div>
                            <div class="tcard-qr">
                                @if (!string.IsNullOrEmpty(selectedDetail.QrImageDataUri))
                                {
                                    <img src="@selectedDetail.QrImageDataUri" alt="QR" id="customer-ticket-qr" />
                                }
                            </div>
                        </div>
                        <div class="tcard-foot">
                            <div>
                                <span class="tcard-pricelabel">@Localizer["MyTickets_PriceLabel"]</span>
                                <div class="tcard-price tnum">@Money(selectedDetail.TicketPrice)</div>
                            </div>
                            <span class="tcard-purchased tnum">@selectedDetail.PurchaseDate.ToLocalTime().ToString("dd.MM.yyyy")</span>
                        </div>
                    </div>

                    <button id="customer-ticket-download-btn" class="btn btn-primary mt-download"
                            disabled="@pdfDownloading" @onclick="DownloadCardPdf">
                        @if (pdfDownloading)
                        {
                            <span class="spinner"></span> <span>@Localizer["MyTickets_DownloadLoading"]</span>
                        }
                        else
                        {
                            <span>@Localizer["MyTickets_DownloadButton"]</span>
                        }
                    </button>
                    @if (!string.IsNullOrEmpty(pdfError))
                    {
                        <div class="mt-inline-error">@pdfError</div>
                    }

                    <!-- Spending breakdown -->
                    <span class="label">@Localizer["MyTickets_SpendingLabel"]</span>
                    <div class="mt-spend">
                        <div class="mt-spend-row">
                            <span>@Localizer["MyTickets_TicketPrice_Row"]</span>
                            <span class="tnum">@Money(selectedDetail.TicketPrice)</span>
                        </div>

                        <div class="mt-spend-sub">@Localizer["MyTickets_DrinksOrders"]</div>
                        @if (selectedDetail.DrinkOrders.Count == 0)
                        {
                            <p id="customer-ticket-no-orders" class="mt-spend-empty">@Localizer["MyTickets_NoOrders"]</p>
                        }
                        else
                        {
                            @foreach (var order in selectedDetail.DrinkOrders)
                            {
                                <div id="customer-ticket-order-@order.OrderId" class="mt-order">
                                    <div class="mt-order-head">
                                        <span>Narudžba #@order.OrderId · @order.Status</span>
                                        <span class="tnum">@Money(order.OrderTotal)</span>
                                    </div>
                                    @foreach (var item in order.Items)
                                    {
                                        <div class="mt-order-item">
                                            <span>@item.Quantity × @item.DrinkName</span>
                                            <span class="tnum">@Money(item.TotalPrice)</span>
                                        </div>
                                    }
                                    @if (order.Payment != null)
                                    {
                                        <div class="mt-order-pay">💳 @order.Payment.Method · @order.Payment.Status</div>
                                    }
                                </div>
                            }
                            <div class="mt-spend-row">
                                <span>@Localizer["MyTickets_DrinksTotal_Row"]</span>
                                <span class="tnum">@Money(selectedDetail.DrinksTotal)</span>
                            </div>
                        }

                        <div class="mt-spend-row mt-spend-grand">
                            <span>@Localizer["MyTickets_GrandTotal"]</span>
                            <span class="tnum">@Money(selectedDetail.GrandTotal)</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</AuthenticationGuard>

@code {
    private List<TicketDto>? tickets;
    private bool showDetail;
    private bool detailLoading;
    private TicketDetailDto? selectedDetail;
    private int detailTicketId;
    private bool pdfDownloading;
    private string? pdfError;

    protected override async Task OnInitializedAsync() => tickets = await ApiService.GetMyTicketsAsync();

    private async Task OpenDetail(int ticketId)
    {
        detailTicketId = ticketId;
        showDetail = true;
        detailLoading = true;
        pdfError = null;
        selectedDetail = null;
        StateHasChanged();

        selectedDetail = await ApiService.GetMyTicketDetailsAsync(ticketId);
        detailLoading = false;
    }

    private void CloseDetail()
    {
        showDetail = false;
        selectedDetail = null;
        pdfError = null;
    }

    private async Task DownloadCardPdf()
    {
        if (pdfDownloading) return;
        pdfDownloading = true;
        pdfError = null;
        StateHasChanged();

        try
        {
            var bytes = await ApiService.GetMyTicketCardPdfAsync(detailTicketId);
            if (bytes == null || bytes.Length == 0)
            {
                pdfError = Localizer["MyTickets_PDFGenerationError"];
                return;
            }

            var fileName = $"ulaznica-{selectedDetail?.TicketNumber ?? detailTicketId.ToString()}.pdf";
            using var stream = new MemoryStream(bytes);
            using var streamRef = new DotNetStreamReference(stream);
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
        }
        catch (Exception)
        {
            pdfError = Localizer["MyTickets_PDFGenerationError"];
        }
        finally
        {
            pdfDownloading = false;
        }
    }

    private static string Dash(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value!;

    private static string Money(decimal amount) => $"€{amount:0.00}";

    private string SeatText(TicketDto t)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(t.Section)) parts.Add(t.Section!);
        if (!string.IsNullOrWhiteSpace(t.Row)) parts.Add(Localizer["MyTickets_SeatRowText", t.Row]);
        if (!string.IsNullOrWhiteSpace(t.SeatNumber)) parts.Add(Localizer["MyTickets_SeatAbbrText", t.SeatNumber]);
        return parts.Count == 0 ? "—" : string.Join(" · ", parts);
    }
}
