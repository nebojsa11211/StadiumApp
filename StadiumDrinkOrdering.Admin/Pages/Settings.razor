@page "/admin/settings"
@using System.Net.Http
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Shared.Authentication.Interfaces
@inject IHttpClientFactory HttpClientFactory
@inject IConfiguration Configuration
@inject ITokenStorageService TokenStorage
@inject ILogger<Settings> Logger
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Settings_PageTitle"]</PageTitle>

<div id="admin-settings-main-container" class="container-fluid">
    <div class="row mb-3" id="admin-settings-header-row">
        <div class="col-12" id="admin-settings-header-col">
            <h1 id="admin-settings-title" class="mb-1">@L["Settings_Heading"]</h1>
            <p class="text-muted" id="admin-settings-subtitle">@L["Settings_Subtitle"]</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(alertMessage))
    {
        <div id="admin-settings-alert" class="alert @alertClass alert-dismissible d-flex justify-content-between align-items-center" role="alert">
            <span id="admin-settings-alert-text">@alertMessage</span>
            <button type="button" id="admin-settings-alert-close" class="btn-close" @onclick="() => alertMessage = null"></button>
        </div>
    }

    @if (isLoading)
    {
        <div id="admin-settings-loading" class="d-flex align-items-center text-muted">
            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
            <span>@L["Settings_Loading"]</span>
        </div>
    }
    else if (loadError || settings is null)
    {
        <div id="admin-settings-error" class="alert alert-danger d-flex justify-content-between align-items-center" role="alert">
            <span>@L["Settings_Error"]</span>
            <button id="admin-settings-retry-btn" class="btn btn-sm btn-outline-danger" @onclick="LoadAsync">@L["Settings_Retry"]</button>
        </div>
    }
    else
    {
        <div class="card mb-4" id="admin-settings-ticketing-card">
            <div class="card-header">
                <h5 class="mb-0" id="admin-settings-ticketing-title">@L["Settings_TicketingSection"]</h5>
            </div>
            <div class="card-body" id="admin-settings-ticketing-body">
                <div class="form-check form-switch" id="admin-settings-ticket-sales-group">
                    <input class="form-check-input" type="checkbox" role="switch"
                           id="admin-settings-ticket-sales-input"
                           checked="@settings.TicketSalesEnabled"
                           @onchange="OnTicketSalesToggled" />
                    <label class="form-check-label fw-semibold" for="admin-settings-ticket-sales-input">
                        @L["Settings_TicketSalesEnabled"]
                    </label>
                </div>
                <div class="form-text mt-1" id="admin-settings-ticket-sales-hint">@L["Settings_TicketSalesEnabledHint"]</div>

                <div id="admin-settings-ticket-sales-status" class="alert @(settings.TicketSalesEnabled ? "alert-success" : "alert-warning") mt-3 mb-0 py-2">
                    <i class="bi @(settings.TicketSalesEnabled ? "bi-check-circle" : "bi-slash-circle") me-1"></i>
                    @(settings.TicketSalesEnabled ? L["Settings_TicketSalesOn"] : L["Settings_TicketSalesOff"])
                </div>

                <div class="d-flex align-items-center gap-3 mt-4">
                    <button type="button" id="admin-settings-save-btn" class="btn btn-primary" @onclick="SaveAsync" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        @L["Settings_Save"]
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private bool loadError;
    private bool isSaving;
    private AppSettingsDto? settings;

    private string? alertMessage;
    private string alertClass = "alert-success";

    // The shared "AuthenticatedClient" injects the JWT via AuthenticationHandler, but that handler
    // runs in a different DI scope than the Blazor circuit, so its scoped token store is empty and
    // every authorized (write) call comes back 401. Match the VenueSettings pattern: read the
    // circuit-scoped token and attach it ourselves before each request.
    private HttpClient Api
    {
        get
        {
            var client = HttpClientFactory.CreateClient("AuthenticatedClient");
            var token = TokenStorage.Token;
            if (!string.IsNullOrEmpty(token))
                client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            return client;
        }
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();
        try
        {
            settings = await Api.GetFromJsonAsync<AppSettingsDto>("api/venue/settings");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load app settings");
            loadError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void OnTicketSalesToggled(ChangeEventArgs e)
    {
        if (settings is not null)
            settings.TicketSalesEnabled = e.Value is bool b && b;
    }

    private async Task SaveAsync()
    {
        if (settings is null) return;
        isSaving = true;
        try
        {
            var resp = await Api.PutAsJsonAsync("api/venue/settings", settings);
            if (resp.IsSuccessStatusCode)
            {
                settings = await resp.Content.ReadFromJsonAsync<AppSettingsDto>();
                ShowAlert(L["Settings_Saved"], true);
            }
            else
            {
                ShowAlert(L["Settings_SaveFailed"], false);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save app settings");
            ShowAlert(L["Settings_SaveFailed"], false);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ShowAlert(string message, bool success)
    {
        alertMessage = message;
        alertClass = success ? "alert-success" : "alert-danger";
    }
}
