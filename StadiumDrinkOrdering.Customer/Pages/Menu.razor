@page "/menu"
@layout MobileShell
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Customer.Components
@using Microsoft.Extensions.Localization
@inject IApiService ApiService
@inject ICartService CartService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResources> Localizer
@implements IDisposable

<PageTitle>@Localizer["Menu_PageTitle"]</PageTitle>

<ScreenHeader Title="@Localizer["Menu_ScreenTitle"]" Subtitle="@Localizer["Menu_ScreenSubtitle"]" ShowBack="false" />

<TicketProtectedRoute>
    <div id="customer-menu-container" class="menu-body no-scrollbar">

        @if (drinks == null)
        {
            <div id="customer-menu-loading" class="menu-state"><span class="spinner"></span> @Localizer["Menu_Loading"]</div>
        }
        else if (!drinks.Any())
        {
            <div id="customer-menu-empty" class="menu-state menu-emptystate">
                <div class="menu-emoji">🥤</div>
                <h2>@Localizer["Menu_EmptyTitle"]</h2>
                <p>@Localizer["Menu_EmptyDescription"]</p>
            </div>
        }
        else
        {
            <div id="customer-category-filters" class="menu-cats no-scrollbar">
                <button id="customer-category-all" class="menu-chip @(selectedCategory == null ? "on" : "")" @onclick="() => FilterByCategory(null)">@Localizer["Menu_FilterAllButtonText"]</button>
                @foreach (var category in MenuCategories)
                {
                    <button id="customer-category-@category.Id" class="menu-chip @(selectedCategory == category.Id ? "on" : "")" @onclick="() => FilterByCategory(category.Id)">@category.Icon @category.Label</button>
                }
            </div>

            <div id="customer-drinks-grid" class="menu-grid">
                @foreach (var drink in FilteredDrinks)
                {
                    var qty = quantities.GetValueOrDefault(drink.Id, 0);
                    var canOrder = drink.StockQuantity > 0 && drink.IsAvailable;
                    <div id="customer-drink-@drink.Id" class="menu-card">
                        <div id="customer-drink-thumb-@drink.Id" class="menu-thumb">
                            @if (!string.IsNullOrEmpty(drink.ImageUrl))
                            {
                                <img id="customer-drink-image-@drink.Id" src="@drink.ImageUrl" alt="@drink.Name" />
                            }
                            else
                            {
                                <span class="menu-thumb-emoji">🥤</span>
                            }
                        </div>
                        <div id="customer-drink-card-body-@drink.Id" class="menu-info">
                            <div class="menu-info-top">
                                <span id="customer-drink-name-@drink.Id" class="menu-name">@drink.Name</span>
                                <span id="customer-drink-price-@drink.Id" class="menu-price tnum">€@drink.Price.ToString("F2")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(drink.Description))
                            {
                                <span id="customer-drink-description-@drink.Id" class="menu-desc">@drink.Description</span>
                            }
                            <div id="customer-drink-actions-@drink.Id" class="menu-actions">
                                @if (canOrder)
                                {
                                    <div id="customer-quantity-controls-@drink.Id" class="menu-stepper">
                                        <button id="customer-decrease-btn-@drink.Id" class="menu-step" @onclick="() => DecreaseQuantity(drink.Id)" disabled="@(qty <= 0)">−</button>
                                        <span id="customer-quantity-input-@drink.Id" class="menu-qty tnum">@qty</span>
                                        <button id="customer-increase-btn-@drink.Id" class="menu-step" @onclick="() => IncreaseQuantity(drink.Id)" disabled="@(qty >= drink.StockQuantity)">+</button>
                                    </div>
                                    <button id="customer-add-to-cart-btn-@drink.Id" class="btn btn-primary btn-sm menu-add" @onclick="() => AddToCart(drink)" disabled="@(qty <= 0)">@Localizer["Menu_AddButtonText"]</button>
                                }
                                else
                                {
                                    <span id="customer-out-of-stock-btn-@drink.Id" class="menu-oos">@Localizer["Menu_OutOfStockText"]</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <CartBar Count="CartService.GetTotalItems()" Total="CartService.GetTotalPrice()" Label="@Localizer["Menu_YourOrderLabel"]" OnView="() => showCart = true" />

    @if (showCart)
    {
        <div id="customer-cart-scrim" class="menu-scrim show" @onclick="() => showCart = false"></div>
        <div id="customer-cart-card" class="menu-sheet show">
            <div class="grab"></div>
            <div class="menu-sheet-head">
                <div id="customer-cart-title" class="menu-sheet-title">@Localizer["Menu_YourOrderLabel"]</div>
                <button class="iconbtn" @onclick="() => showCart = false" aria-label="@Localizer["Menu_CloseAriaLabel"]">✕</button>
            </div>

            <div class="menu-sheet-body no-scrollbar">
                @if (!CartService.Items.Any())
                {
                    <p id="customer-cart-empty" class="menu-cart-empty">@Localizer["Menu_CartEmptyText"]</p>
                }
                else
                {
                    <div class="menu-cart-items">
                        @foreach (var item in CartService.Items)
                        {
                            <div id="customer-cart-item-@item.Drink.Id" class="menu-cart-item">
                                <div class="menu-ci-l">
                                    <span id="customer-cart-item-name-@item.Drink.Id" class="menu-ci-name">@item.Quantity × @item.Drink.Name</span>
                                    <span id="customer-cart-item-price-@item.Drink.Id" class="menu-ci-sub tnum">€@item.Drink.Price.ToString("F2") @Localizer["Menu_PricePerUnit"]</span>
                                    @if (!string.IsNullOrEmpty(item.SpecialInstructions))
                                    {
                                        <span id="customer-cart-item-notes-@item.Drink.Id" class="menu-ci-note">💬 @item.SpecialInstructions</span>
                                    }
                                </div>
                                <div class="menu-ci-r">
                                    <span id="customer-cart-item-total-@item.Drink.Id" class="tnum">€@item.TotalPrice.ToString("F2")</span>
                                    <button id="customer-cart-remove-btn-@item.Drink.Id" class="menu-ci-del" @onclick="() => CartService.RemoveItem(item.Drink.Id)" aria-label="@Localizer["Menu_RemoveItemAria"]">🗑</button>
                                </div>
                            </div>
                        }
                    </div>

                    <div id="customer-cart-total-row" class="menu-cart-total"><span>@Localizer["Menu_TotalLabel"]</span><span class="tnum">€@CartService.GetTotalPrice().ToString("F2")</span></div>

                    <div id="customer-ticket-input-group" class="field">
                        <label for="customer-ticket-input">@Localizer["Menu_TicketNumberLabel"]</label>
                        <input id="customer-ticket-input" type="text" @bind="ticketNumber" placeholder='@Localizer["Menu_TicketNumberPlaceholder"]' />
                    </div>

                    <div id="customer-notes-input-group" class="field">
                        <label for="customer-notes-input">@Localizer["Menu_NotesLabel"]</label>
                        <textarea id="customer-notes-input" @bind="orderNotes" placeholder='@Localizer["Menu_NotesPlaceholder"]' rows="2"></textarea>
                    </div>

                    @if (walletPaymentEnabled && walletSummary is { Exists: true })
                    {
                        <label id="customer-menu-pay-wallet-group" class="menu-wallet">
                            <input id="customer-menu-pay-wallet-check" type="checkbox" @bind="payWithWallet" />
                            <span>@Localizer["Menu_PayWithWalletText"] <span class="menu-wallet-bal">(@FormatWalletMoney(walletSummary.Balance) @Localizer["Menu_AvailableText"])</span></span>
                        </label>
                    }
                    @if (showTopUpPrompt)
                    {
                        <div id="customer-menu-topup-prompt" class="menu-topup">
                            @Localizer["Menu_InsufficientFundsText"]
                            <a id="customer-menu-topup-link" href="/wallet">@Localizer["Menu_TopUpLinkText"]</a>
                        </div>
                    }

                    <div class="menu-sheet-cta">
                        <button id="customer-place-order-btn" class="btn btn-primary" @onclick="PlaceOrder" disabled="@(string.IsNullOrWhiteSpace(ticketNumber) || isPlacingOrder)">
                            @if (isPlacingOrder)
                            {
                                <span class="spinner"></span> <span>@Localizer["Menu_SendingButtonText"]</span>
                            }
                            else
                            {
                                <span>@Localizer["Menu_OrderButtonText"]</span>
                            }
                        </button>
                        <button id="customer-clear-cart-btn" class="btn btn-ghost" @onclick="CartService.ClearCart">@Localizer["Menu_ClearButtonText"]</button>
                    </div>
                }
            </div>
        </div>
    }
</TicketProtectedRoute>

@if (!string.IsNullOrEmpty(alertMessage))
{
    <div id="customer-alert-container" class="menu-toast @(alertType == "success" ? "ok" : "bad")">
        <span>@alertMessage</span>
        <button id="customer-menu-alert-close-btn" class="menu-toast-x" @onclick="ClearAlert" aria-label="@Localizer["Menu_CloseAriaLabel"]">✕</button>
    </div>
}

@code {
    private List<DrinkDto>? drinks;
    private int? selectedCategory;
    private Dictionary<int, int> quantities = new();
    private string ticketNumber = "";
    private string orderNotes = "";
    private bool isPlacingOrder = false;
    private bool showCart = false;
    private string alertMessage = "";
    private string alertType = "";
    private WalletSummaryDto? walletSummary;
    private bool payWithWallet = false;
    private bool showTopUpPrompt = false;
    // Wallet is only offered when the operator accepts it (Admin → Settings → Payments).
    private bool walletPaymentEnabled = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDrinks();
        walletPaymentEnabled = (await ApiService.GetAppSettingsAsync()).WalletPaymentEnabled;
        walletSummary = await ApiService.GetWalletSummaryAsync();
        CartService.OnCartChanged += StateHasChanged;
    }

    private async Task LoadDrinks()
    {
        drinks = await ApiService.GetDrinksAsync();
        if (drinks != null)
            foreach (var drink in drinks)
                quantities[drink.Id] = 0;
    }

    private IEnumerable<DrinkDto> FilteredDrinks =>
        drinks == null ? Enumerable.Empty<DrinkDto>()
        : selectedCategory == null ? drinks
        : drinks.Where(d => d.CategoryId == selectedCategory);

    // Distinct categories present in the loaded drinks, ordered by their first appearance.
    private IEnumerable<(int Id, string Icon, string Label)> MenuCategories =>
        (drinks ?? Enumerable.Empty<DrinkDto>())
            .GroupBy(d => d.CategoryId)
            .Select(g => (
                Id: g.Key,
                Icon: DrinkVisuals.Emoji(g.First().CategoryIcon),
                Label: DrinkVisuals.Label(g.First().CategoryDisplayName, g.First().CategoryName)));

    private void FilterByCategory(int? categoryId) => selectedCategory = categoryId;

    private void IncreaseQuantity(int drinkId)
    {
        var drink = drinks?.FirstOrDefault(d => d.Id == drinkId);
        if (drink != null && quantities[drinkId] < drink.StockQuantity)
            quantities[drinkId]++;
    }

    private void DecreaseQuantity(int drinkId)
    {
        if (quantities[drinkId] > 0)
            quantities[drinkId]--;
    }

    private void AddToCart(DrinkDto drink)
    {
        var quantity = quantities.GetValueOrDefault(drink.Id, 0);
        if (quantity > 0)
        {
            CartService.AddItem(drink, quantity);
            quantities[drink.Id] = 0;
            ShowAlert(Localizer["Menu_AddedAlertText", quantity, drink.Name].Value, "success");
        }
    }

    private async Task PlaceOrder()
    {
        if (!CartService.Items.Any()) return;

        isPlacingOrder = true;
        showTopUpPrompt = false;

        try
        {
            var sessionToken = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "ticketSessionToken");
            var ticketSession = !string.IsNullOrEmpty(sessionToken) ? await ApiService.GetTicketSessionAsync(sessionToken) : null;

            var createOrderDto = new CreateOrderDto
            {
                TicketSessionId = ticketSession?.Id,
                TicketNumber = string.IsNullOrWhiteSpace(ticketNumber) ? null : ticketNumber.Trim(),
                CustomerNotes = string.IsNullOrWhiteSpace(orderNotes) ? null : orderNotes.Trim(),
                PaymentMethod = payWithWallet ? PaymentMethod.DigitalWallet : null,
                OrderItems = CartService.Items.Select(item => new CreateOrderItemDto
                {
                    DrinkId = item.Drink.Id,
                    Quantity = item.Quantity,
                    SpecialInstructions = item.SpecialInstructions
                }).ToList()
            };

            var result = await ApiService.PlaceOrderAsync(createOrderDto);
            if (result.Success)
            {
                CartService.ClearCart();
                ticketNumber = "";
                orderNotes = "";
                showCart = false;
                ShowAlert(Localizer["Menu_OrderSentAlertText", result.Order?.Id].Value, "success");
                if (payWithWallet)
                    walletSummary = await ApiService.GetWalletSummaryAsync();
            }
            else if (result.InsufficientFunds)
            {
                showTopUpPrompt = true;
                ShowAlert(Localizer["Menu_InsufficientFundsText"].Value, "danger");
            }
            else
            {
                ShowAlert(Localizer["Menu_OrderNotSentMessage"].Value, "danger");
            }
        }
        catch (Exception ex)
        {
            ShowAlert(Localizer["Menu_ErrorSendingOrderMessage", ex.Message].Value, "danger");
        }
        finally
        {
            isPlacingOrder = false;
        }
    }

    private string FormatWalletMoney(decimal amount)
    {
        var currency = walletSummary?.Currency ?? "EUR";
        var symbol = currency == "EUR" ? "€" : currency + " ";
        return $"{symbol}{amount.ToString("N2")}";
    }

    private void ShowAlert(string message, string type)
    {
        alertMessage = message;
        alertType = type;
        StateHasChanged();
        _ = Task.Delay(5000).ContinueWith(_ =>
        {
            alertMessage = "";
            InvokeAsync(StateHasChanged);
        });
    }

    private void ClearAlert() => alertMessage = "";

    public void Dispose() => CartService.OnCartChanged -= StateHasChanged;
}
