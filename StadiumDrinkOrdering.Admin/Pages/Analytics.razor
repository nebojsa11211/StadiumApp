@page "/analytics"
@using StadiumDrinkOrdering.Admin.Services
@using StadiumDrinkOrdering.Shared.DTOs
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Analytics_PageTitle"]</PageTitle>

<div class="console" id="admin-analytics-main-container">
    <!-- Page Header -->
    <PageHeader Id="admin-analytics-header"
                Eyebrow='@L["Analytics_Eyebrow"]'
                Title='@L["Analytics_Title"]'
                Subtitle='@L["Analytics_Subtitle"]'>
        <Actions>
            <button class="icon-btn" @onclick="LoadAnalyticsData" disabled="@isLoading" id="admin-analytics-refresh-btn" title="@L["Analytics_RefreshTitle"]">
                <i class="bi bi-arrow-clockwise @(isLoading ? "spin" : "")"></i>
            </button>
        </Actions>
    </PageHeader>

    @if (isLoading)
    {
        <div class="loading-state" id="admin-analytics-loading">
            <span class="loading-spinner"></span>
            <p>@L["Analytics_Loading"]</p>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="console-alert console-alert--danger" role="alert" id="admin-analytics-error-alert">
            <i class="bi bi-exclamation-triangle"></i>
            <span>@errorMessage</span>
            <button type="button" class="pill-btn pill-btn--danger" @onclick="LoadAnalyticsData" id="admin-analytics-retry-btn">
                <i class="bi bi-arrow-clockwise"></i><span>@L["Analytics_RetryButton"]</span>
            </button>
        </div>
    }
    else
    {
        <!-- Placeholder for Future Analytics -->
        <div class="console-alert console-alert--info" role="alert" id="admin-analytics-info-alert">
            <i class="bi bi-info-circle"></i>
            <span>
                <strong>@L["Analytics_DashboardTitle"]</strong> &mdash; @L["Analytics_InfoMessage"]
            </span>
        </div>

        <section class="board" id="admin-analytics-board">
            <!-- Available Events -->
            @if (availableEvents?.Any() == true)
            {
                <div class="panel" id="admin-analytics-events-panel">
                    <div class="panel__head">
                        <h2 class="panel__title"><i class="bi bi-calendar"></i> @L["Analytics_AvailableEventsTitle"]</h2>
                        @if (seasonOptions.Any())
                        {
                            <select class="field__input" @onchange="OnSeasonChanged" id="admin-analytics-season-select" style="max-width:220px;">
                                <option value="" selected="@(selectedSeasonId == null)">@L["Analytics_AllSeasonsOption"]</option>
                                @foreach (var s in seasonOptions)
                                {
                                    <option value="@s.Id" selected="@(selectedSeasonId == s.Id)">@s.Name</option>
                                }
                            </select>
                        }
                    </div>
                    <table class="console-table" id="admin-analytics-events-table">
                        <thead id="admin-analytics-events-table-head">
                            <tr id="admin-analytics-events-table-header-row">
                                <th class="sortable @(sortState.IsSorted("name") ? "is-sorted" : "")" @onclick='() => SortBy("name")' id="admin-analytics-events-table-header-name">@L["Analytics_EventNameHeader"]<span class="sort-ind">@sortState.Indicator("name")</span></th>
                                <th class="sortable @(sortState.IsSorted("date") ? "is-sorted" : "")" @onclick='() => SortBy("date")' id="admin-analytics-events-table-header-date">@L["Analytics_DateHeader"]<span class="sort-ind">@sortState.Indicator("date")</span></th>
                                <th class="sortable @(sortState.IsSorted("status") ? "is-sorted" : "")" @onclick='() => SortBy("status")' id="admin-analytics-events-table-header-status">@L["Analytics_StatusHeader"]<span class="sort-ind">@sortState.Indicator("status")</span></th>
                            </tr>
                        </thead>
                        <tbody id="admin-analytics-events-table-body">
                            @foreach (var evt in availableEvents.Take(10))
                            {
                                <tr id="@($"admin-analytics-event-row-{evt.Id}")">
                                    <td class="console-table__id" id="@($"admin-analytics-event-cell-name-{evt.Id}")">@evt.Name</td>
                                    <td class="mono console-table__time" id="@($"admin-analytics-event-cell-date-{evt.Id}")">@(evt.Date?.ToString("MMM dd, yyyy") ?? @L["Analytics_TBDLabel"])</td>
                                    <td id="@($"admin-analytics-event-cell-status-{evt.Id}")">
                                        @if (evt.IsActive)
                                        {
                                            <span class="status is-active"><span class="status__dot"></span>@L["Analytics_ActiveStatus"]</span>
                                        }
                                        else
                                        {
                                            <span class="status is-inactive"><span class="status__dot"></span>@L["Analytics_InactiveStatus"]</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <!-- Quick Actions -->
            <div class="rail" id="admin-analytics-quick-actions-rail">
                <div class="panel" id="admin-analytics-quick-actions-panel">
                    <div class="panel__head">
                        <h2 class="panel__title"><i class="bi bi-tools"></i> @L["Analytics_ReportsTitle"]</h2>
                    </div>
                    <div class="actions">
                        <button class="action" @onclick="NavigateToCustomerAnalytics" id="admin-analytics-customer-analytics-btn">
                            <i class="bi bi-people"></i><span>@L["Analytics_CustomerAnalyticsButton"]</span><i class="bi bi-chevron-right action__go"></i>
                        </button>
                        <button class="action" @onclick="NavigateToEvents" id="admin-analytics-events-btn">
                            <i class="bi bi-calendar"></i><span>@L["Analytics_EventManagementButton"]</span><i class="bi bi-chevron-right action__go"></i>
                        </button>
                        <button class="action" @onclick="NavigateToOrders" id="admin-analytics-orders-btn">
                            <i class="bi bi-list-ul"></i><span>@L["Analytics_OrderReportsButton"]</span><i class="bi bi-chevron-right action__go"></i>
                        </button>
                        <button class="action" @onclick="NavigateToLogs" id="admin-analytics-logs-btn">
                            <i class="bi bi-graph-up"></i><span>@L["Analytics_SystemLogsButton"]</span><i class="bi bi-chevron-right action__go"></i>
                        </button>
                    </div>
                </div>
            </div>
        </section>
    }
</div>
