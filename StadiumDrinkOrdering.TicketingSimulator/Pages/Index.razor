@page "/"
@page "/simulator"
@using StadiumDrinkOrdering.Shared.DTOs.Integration
@inject SimulatorApiClient Api
@implements IDisposable

<PageTitle>Ticketing Simulator</PageTitle>

<h1 class="h4 mb-1">External Ticketing Simulator</h1>
<p class="text-muted">Stands in for the real ticketing system. Create an event and simulate sales — everything syncs to the Stadium app via signed webhooks.</p>

<div class="alert @(connectionOk ? "alert-success" : "alert-warning") py-2">
    <i class="bi @(connectionOk ? "bi-plug-fill" : "bi-plug")"></i>
    API: <code>@Api.ApiBaseUrl</code>
    @if (connectionOk) { <span>· @sections.Count sections discovered</span> }
    else { <span>· not reachable @(string.IsNullOrEmpty(connectionError) ? "" : $"({connectionError})")</span> }
    <button class="btn btn-sm btn-outline-secondary ms-2" @onclick="LoadSectionsAsync">Reload</button>
</div>

@* ---------- Step 1: create event ---------- *@
<div class="card mb-3">
    <div class="card-header fw-bold"><i class="bi bi-calendar-plus"></i> 1. Event</div>
    <div class="card-body">
        @if (externalEventId == null)
        {
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Event name</label>
                    <input class="form-control" @bind="eventName" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Date</label>
                    <input type="datetime-local" class="form-control" @bind="eventDate" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Base price</label>
                    <input type="number" step="0.5" min="0" class="form-control" @bind="basePrice" />
                </div>
                <div class="col-md-3">
                    <button class="btn btn-primary w-100" @onclick="CreateEventAsync" disabled="@(busy || !connectionOk)">
                        <i class="bi bi-broadcast"></i> Create &amp; sync
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="d-flex flex-wrap gap-3 align-items-center">
                <div><span class="text-muted">Event:</span> <strong>@eventName</strong></div>
                <div><span class="text-muted">External ID:</span> <code>@externalEventId</code></div>
                <div><span class="text-muted">Stadium event ID:</span> <strong>@(internalEventId?.ToString() ?? "?")</strong></div>
                <div><span class="text-muted">Total sold:</span> <strong>@TotalSold</strong> / @TotalCapacity</div>
                <button class="btn btn-sm btn-outline-danger ms-auto" @onclick="ResetEvent">New event</button>
            </div>
        }
    </div>
</div>

@if (externalEventId != null)
{
    @* ---------- Step 2: sales ---------- *@
    <div class="card mb-3">
        <div class="card-header fw-bold d-flex align-items-center">
            <span><i class="bi bi-cash-coin"></i> 2. Simulate sales</span>
            <div class="ms-auto d-flex align-items-center gap-2">
                <span class="small text-muted">rate</span>
                <input type="number" min="1" max="50" class="form-control form-control-sm" style="width:70px" @bind="autoRate" />
                <span class="small text-muted">per</span>
                <input type="number" min="200" step="100" class="form-control form-control-sm" style="width:90px" @bind="autoIntervalMs" />
                <span class="small text-muted">ms</span>
                <button class="btn btn-sm @(autoSelling ? "btn-danger" : "btn-success")" @onclick="ToggleAutoSell">
                    <i class="bi @(autoSelling ? "bi-stop-fill" : "bi-play-fill")"></i>
                    @(autoSelling ? "Stop auto-sell" : "Start auto-sell")
                </button>
                <button class="btn btn-sm btn-outline-primary" @onclick="() => SellRandomBatchAsync(20)" disabled="@busy">Sell random 20</button>
            </div>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0 align-middle">
                <thead class="table-light">
                    <tr><th>Sector</th><th style="width:45%">Occupancy</th><th class="text-end">Sold / Capacity</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var s in sections)
                    {
                        var sold = SoldCount(s.SectionCode);
                        var pct = s.Capacity > 0 ? (double)sold / s.Capacity * 100 : 0;
                        <tr>
                            <td><strong>@s.SectionCode</strong> <span class="text-muted small">@s.SectionName</span></td>
                            <td>
                                <div class="progress" style="height:14px">
                                    <div class="progress-bar @BarClass(pct)" style="width:@pct.ToString("0.##")%"></div>
                                </div>
                            </td>
                            <td class="text-end">@sold / @s.Capacity</td>
                            <td class="text-end text-nowrap">
                                <button class="btn btn-outline-success btn-sm" @onclick="() => SellAsync(s, 1)" disabled="@(busy || sold >= s.Capacity)">+1</button>
                                <button class="btn btn-outline-success btn-sm" @onclick="() => SellAsync(s, 5)" disabled="@(busy || sold >= s.Capacity)">+5</button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => RefundAsync(s)" disabled="@(busy || sold == 0)">−1</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ---------- Step 3: reconciliation ---------- *@
    <div class="card mb-3">
        <div class="card-header fw-bold">
            <i class="bi bi-arrow-repeat"></i> 3. Reconciliation
            <button class="btn btn-sm btn-outline-secondary ms-2" @onclick="VerifySyncAsync" disabled="@busy">Verify sync</button>
            <button class="btn btn-sm btn-outline-warning ms-1" @onclick="ReplayAsync" disabled="@busy">Replay all sales</button>
            <span class="small text-muted ms-2">Replays local sales to the API (idempotent) to heal any missed webhooks.</span>
        </div>
        @if (snapshot != null)
        {
            <div class="card-body">
                <p class="mb-2">API reports <strong>@snapshot.TotalSold</strong> sold; simulator holds <strong>@TotalSold</strong>.
                    <span class="@(snapshot.TotalSold == TotalSold ? "text-success" : "text-danger")">
                        @(snapshot.TotalSold == TotalSold ? "In sync ✓" : $"Drift: {TotalSold - snapshot.TotalSold}")
                    </span>
                </p>
                <table class="table table-sm">
                    <thead><tr><th>Sector</th><th class="text-end">API sold</th><th class="text-end">Simulator</th></tr></thead>
                    <tbody>
                        @foreach (var sec in snapshot.Sectors)
                        {
                            var local = SoldCount(sec.SectionCode);
                            <tr class="@(sec.Sold == local ? "" : "table-warning")">
                                <td>@sec.SectionCode</td>
                                <td class="text-end">@sec.Sold</td>
                                <td class="text-end">@local</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@* ---------- Activity log ---------- *@
<div class="card">
    <div class="card-header fw-bold"><i class="bi bi-terminal"></i> Activity log</div>
    <div class="card-body" style="max-height:220px; overflow:auto; font-family:monospace; font-size:0.82rem;">
        @if (log.Count == 0)
        {
            <span class="text-muted">No activity yet.</span>
        }
        else
        {
            @foreach (var line in log)
            {
                <div>@line</div>
            }
        }
    </div>
</div>

@code {
    private List<StadiumSectionInfoDto> sections = new();
    private bool connectionOk;
    private string? connectionError;

    private string? externalEventId;
    private int? internalEventId;
    private string eventName = "Simulated Match";
    private DateTime eventDate = DateTime.Today.AddDays(7).AddHours(18);
    private decimal basePrice = 45m;

    // Fixed-key structures created at event creation (safe for concurrent read/write of existing keys).
    private readonly Dictionary<string, int> soldCount = new();
    private readonly Dictionary<string, List<string>> soldIds = new();
    private readonly object _lock = new();

    private bool busy;
    private bool autoSelling;
    private int autoRate = 5;
    private int autoIntervalMs = 800;
    private CancellationTokenSource? autoCts;

    private EventSalesSnapshotDto? snapshot;
    private readonly List<string> log = new();
    private readonly Random _rng = new();

    private static readonly string[] Names =
        { "Ivan Horvat", "Marko Kovač", "Ana Babić", "Petra Novak", "Luka Marić", "Sara Jurić", "Tomislav Knežević", "Maja Vuković" };

    private int TotalCapacity => sections.Sum(s => s.Capacity);
    private int TotalSold => sections.Sum(s => SoldCount(s.SectionCode));
    private int SoldCount(string code) => soldCount.TryGetValue(code, out var c) ? c : 0;

    protected override async Task OnInitializedAsync() => await LoadSectionsAsync();

    private async Task LoadSectionsAsync()
    {
        try
        {
            sections = await Api.GetSectionsAsync();
            connectionOk = true;
            connectionError = null;
        }
        catch (Exception ex)
        {
            connectionOk = false;
            connectionError = ex.Message;
            Log($"Failed to load sections: {ex.Message}");
        }
    }

    private async Task CreateEventAsync()
    {
        if (busy) return;
        busy = true;
        try
        {
            var extId = "SIM-" + Guid.NewGuid().ToString("N")[..8].ToUpperInvariant();
            var envelope = new TicketingWebhookEnvelope
            {
                EventType = TicketingEventTypes.EventCreated,
                IdempotencyKey = Guid.NewGuid().ToString(),
                OccurredAt = DateTime.UtcNow,
                SourceSystem = Api.SourceSystem,
                Event = new ExternalEventDto
                {
                    ExternalEventId = extId,
                    EventName = eventName,
                    EventType = "Football",
                    EventDate = DateTime.SpecifyKind(eventDate, DateTimeKind.Utc),
                    TotalSeats = TotalCapacity,
                    BaseTicketPrice = basePrice,
                    Description = "Simulated event"
                }
            };

            var result = await Api.SendAsync(envelope);
            if (result.Accepted)
            {
                externalEventId = extId;
                internalEventId = result.EventId;
                lock (_lock)
                {
                    soldCount.Clear();
                    soldIds.Clear();
                    foreach (var s in sections)
                    {
                        soldCount[s.SectionCode] = 0;
                        soldIds[s.SectionCode] = new List<string>();
                    }
                }
                Log($"✅ Event created — external {extId} → stadium event #{result.EventId}");
            }
            else
            {
                Log($"❌ Event create rejected: {result.Message}");
            }
        }
        catch (Exception ex)
        {
            Log($"❌ Event create error: {ex.Message}");
        }
        finally
        {
            busy = false;
        }
    }

    private async Task SellAsync(StadiumSectionInfoDto s, int count)
    {
        busy = true;
        try
        {
            var made = 0;
            for (var i = 0; i < count; i++)
            {
                if (SoldCount(s.SectionCode) >= s.Capacity) break;
                if (await SellOneAsync(s)) made++;
                else break;
            }
            if (made > 0) Log($"Sold {made} in {s.SectionCode} (now {SoldCount(s.SectionCode)}/{s.Capacity})");
        }
        finally
        {
            busy = false;
        }
    }

    private async Task<bool> SellOneAsync(StadiumSectionInfoDto s)
    {
        var extTicket = "TCK-" + Guid.NewGuid().ToString("N")[..12].ToUpperInvariant();
        var envelope = new TicketingWebhookEnvelope
        {
            EventType = TicketingEventTypes.TicketSold,
            IdempotencyKey = Guid.NewGuid().ToString(),
            OccurredAt = DateTime.UtcNow,
            SourceSystem = Api.SourceSystem,
            Ticket = new ExternalTicketDto
            {
                ExternalTicketId = extTicket,
                ExternalEventId = externalEventId!,
                SectionCode = s.SectionCode,
                Price = basePrice,
                CustomerName = Names[_rng.Next(Names.Length)],
                SoldAt = DateTime.UtcNow
            }
        };

        try
        {
            var result = await Api.SendAsync(envelope);
            if (result.Accepted && !result.Duplicate)
            {
                lock (_lock)
                {
                    soldIds[s.SectionCode].Add(extTicket);
                    soldCount[s.SectionCode] = soldIds[s.SectionCode].Count;
                }
                return true;
            }
            if (!result.Accepted)
            {
                Log($"⚠ Sell {s.SectionCode} rejected: {result.Message}");
                return false;
            }
            return true; // duplicate — treat as no-op success
        }
        catch (Exception ex)
        {
            Log($"⚠ Sell {s.SectionCode} error: {ex.Message}");
            return false;
        }
    }

    private async Task RefundAsync(StadiumSectionInfoDto s)
    {
        busy = true;
        try
        {
            string? extTicket;
            lock (_lock)
            {
                var list = soldIds[s.SectionCode];
                extTicket = list.Count > 0 ? list[^1] : null;
            }
            if (extTicket == null) return;

            var envelope = new TicketingWebhookEnvelope
            {
                EventType = TicketingEventTypes.TicketRefunded,
                IdempotencyKey = Guid.NewGuid().ToString(),
                OccurredAt = DateTime.UtcNow,
                SourceSystem = Api.SourceSystem,
                Ticket = new ExternalTicketDto { ExternalTicketId = extTicket, ExternalEventId = externalEventId! }
            };

            var result = await Api.SendAsync(envelope);
            if (result.Accepted)
            {
                lock (_lock)
                {
                    soldIds[s.SectionCode].Remove(extTicket);
                    soldCount[s.SectionCode] = soldIds[s.SectionCode].Count;
                }
                Log($"↩ Refunded 1 in {s.SectionCode} (now {SoldCount(s.SectionCode)}/{s.Capacity})");
            }
            else
            {
                Log($"⚠ Refund {s.SectionCode} failed: {result.Message}");
            }
        }
        finally
        {
            busy = false;
        }
    }

    private async Task SellRandomBatchAsync(int count)
    {
        busy = true;
        try
        {
            var made = await SellRandomInternalAsync(count, CancellationToken.None);
            Log($"Sold {made} random tickets (total {TotalSold}/{TotalCapacity})");
        }
        finally
        {
            busy = false;
        }
    }

    private async Task<int> SellRandomInternalAsync(int count, CancellationToken ct)
    {
        var made = 0;
        for (var i = 0; i < count && !ct.IsCancellationRequested; i++)
        {
            var available = sections.Where(s => SoldCount(s.SectionCode) < s.Capacity).ToList();
            if (available.Count == 0) break;
            // Weight by remaining capacity so fuller sectors fill more slowly.
            var totalRemaining = available.Sum(s => s.Capacity - SoldCount(s.SectionCode));
            var pick = _rng.Next(totalRemaining);
            StadiumSectionInfoDto chosen = available[0];
            var acc = 0;
            foreach (var s in available)
            {
                acc += s.Capacity - SoldCount(s.SectionCode);
                if (pick < acc) { chosen = s; break; }
            }
            if (await SellOneAsync(chosen)) made++;
        }
        return made;
    }

    private async Task ToggleAutoSell()
    {
        if (autoSelling)
        {
            autoSelling = false;
            autoCts?.Cancel();
            Log("⏹ Auto-sell stopped");
            return;
        }

        autoSelling = true;
        autoCts = new CancellationTokenSource();
        var token = autoCts.Token;
        Log($"▶ Auto-sell started ({autoRate} / {autoIntervalMs}ms)");

        _ = Task.Run(async () =>
        {
            try
            {
                while (!token.IsCancellationRequested && autoSelling)
                {
                    var made = await SellRandomInternalAsync(autoRate, token);
                    await InvokeAsync(StateHasChanged);
                    if (made == 0)
                    {
                        autoSelling = false;
                        Log("⏹ Auto-sell stopped — stadium is full");
                        await InvokeAsync(StateHasChanged);
                        break;
                    }
                    await Task.Delay(autoIntervalMs, token);
                }
            }
            catch (OperationCanceledException) { /* expected on stop */ }
            catch (Exception ex)
            {
                Log($"Auto-sell error: {ex.Message}");
                await InvokeAsync(StateHasChanged);
            }
        });
    }

    private async Task VerifySyncAsync()
    {
        busy = true;
        try
        {
            snapshot = await Api.GetSnapshotAsync(externalEventId!);
            if (snapshot == null) Log("⚠ No snapshot returned by API");
            else Log($"🔍 Verify: API {snapshot.TotalSold} vs simulator {TotalSold}");
        }
        catch (Exception ex)
        {
            Log($"⚠ Verify error: {ex.Message}");
        }
        finally
        {
            busy = false;
        }
    }

    private async Task ReplayAsync()
    {
        busy = true;
        try
        {
            List<(string section, string ext)> all;
            lock (_lock)
            {
                all = soldIds.SelectMany(kv => kv.Value.Select(id => (kv.Key, id))).ToList();
            }

            var healed = 0;
            foreach (var (section, ext) in all)
            {
                var envelope = new TicketingWebhookEnvelope
                {
                    EventType = TicketingEventTypes.TicketSold,
                    IdempotencyKey = Guid.NewGuid().ToString(),
                    OccurredAt = DateTime.UtcNow,
                    SourceSystem = Api.SourceSystem,
                    Ticket = new ExternalTicketDto
                    {
                        ExternalTicketId = ext,
                        ExternalEventId = externalEventId!,
                        SectionCode = section,
                        Price = basePrice,
                        SoldAt = DateTime.UtcNow
                    }
                };
                var result = await Api.SendAsync(envelope);
                if (result.Accepted && !result.Duplicate) healed++;
            }
            Log($"🔁 Replay complete — {healed} missing sale(s) re-applied, {all.Count - healed} already present");
            await VerifySyncAsync();
        }
        finally
        {
            busy = false;
        }
    }

    private void ResetEvent()
    {
        autoSelling = false;
        autoCts?.Cancel();
        externalEventId = null;
        internalEventId = null;
        snapshot = null;
        lock (_lock) { soldCount.Clear(); soldIds.Clear(); }
        Log("New event — cleared local state");
    }

    private static string BarClass(double pct) => pct switch
    {
        >= 90 => "bg-danger",
        >= 50 => "bg-warning",
        _ => "bg-success"
    };

    private void Log(string message)
    {
        var stamp = DateTime.Now.ToString("HH:mm:ss");
        log.Insert(0, $"[{stamp}] {message}");
        if (log.Count > 40) log.RemoveAt(log.Count - 1);
    }

    public void Dispose()
    {
        autoSelling = false;
        autoCts?.Cancel();
        autoCts?.Dispose();
    }
}
