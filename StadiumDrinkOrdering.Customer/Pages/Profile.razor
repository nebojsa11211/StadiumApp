@page "/profile"
@layout MobileShell
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Customer.Services
@using System.ComponentModel.DataAnnotations
@inject IApiService ApiService
@inject ICustomerAuthStateService AuthStateService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["Profile_PageTitle"]</PageTitle>

<ScreenHeader Title="@Localizer["Profile_ScreenHeader_Title"]" Subtitle="@Localizer["Profile_ScreenHeader_Subtitle"]" BackHref="/home" />

<AuthenticationGuard>
    <div id="customer-profile-container" class="prof-body no-scrollbar">

        @if (isLoading)
        {
            <div id="customer-profile-loading" class="prof-state"><span class="spinner"></span> @Localizer["Profile_Loading"]</div>
        }
        else
        {
            <div id="customer-profile-note" class="prof-note">
                <span class="prof-note-icon">🪪</span>
                <span>@Localizer["Profile_InfoNote"]</span>
            </div>

            <EditForm Model="@profileModel" OnValidSubmit="@HandleSave" class="prof-form" id="customer-profile-form">
                <DataAnnotationsValidator />

                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div id="customer-profile-success" class="ok">@successMessage</div>
                }
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div id="customer-profile-error" class="err">@errorMessage</div>
                }

                <div id="customer-profile-username-group" class="field">
                    <label for="customer-profile-username-input">@Localizer["Profile_UsernameLabel"]</label>
                    <input id="customer-profile-username-input" type="text" value="@username" readonly disabled />
                </div>

                <div id="customer-profile-email-group" class="field">
                    <label for="customer-profile-email-input">@Localizer["Profile_EmailLabel"]</label>
                    <input id="customer-profile-email-input" type="email" value="@email" readonly disabled />
                </div>

                <div id="customer-profile-firstname-group" class="field">
                    <label for="customer-profile-firstname-input">@Localizer["Profile_FirstNameLabel"]</label>
                    <InputText id="customer-profile-firstname-input" @bind-Value="profileModel.FirstName" placeholder="@Localizer["Profile_FirstNamePlaceholder"]" autocomplete="given-name" />
                    <ValidationMessage For="@(() => profileModel.FirstName)" class="verr" />
                </div>

                <div id="customer-profile-lastname-group" class="field">
                    <label for="customer-profile-lastname-input">@Localizer["Profile_LastNameLabel"]</label>
                    <InputText id="customer-profile-lastname-input" @bind-Value="profileModel.LastName" placeholder="@Localizer["Profile_LastNamePlaceholder"]" autocomplete="family-name" />
                    <ValidationMessage For="@(() => profileModel.LastName)" class="verr" />
                </div>

                <div id="customer-profile-phone-group" class="field">
                    <label for="customer-profile-phone-input">@Localizer["Profile_PhoneLabel"]</label>
                    <InputText id="customer-profile-phone-input" type="tel" @bind-Value="profileModel.PhoneNumber" placeholder="@Localizer["Profile_PhonePlaceholder"]" autocomplete="tel" />
                    <ValidationMessage For="@(() => profileModel.PhoneNumber)" class="verr" />
                </div>

                <div id="customer-profile-oib-group" class="field">
                    <label for="customer-profile-oib-input">@Localizer["Profile_OIBLabel"]</label>
                    <InputText id="customer-profile-oib-input" @bind-Value="profileModel.Oib" placeholder="@Localizer["Profile_OIBPlaceholder"]" inputmode="numeric" maxlength="11" autocomplete="off" />
                    <ValidationMessage For="@(() => profileModel.Oib)" class="verr" />
                    <span class="prof-hint">@Localizer["Profile_OIBHint"]</span>
                </div>

                <button type="submit" class="btn btn-primary" disabled="@isSaving" id="customer-profile-save-btn">
                    @if (isSaving)
                    {
                        <span class="spinner" id="customer-profile-spinner"></span> <span>@Localizer["Profile_Saving"]</span>
                    }
                    else
                    {
                        <span>@Localizer["Profile_SaveButton"]</span>
                    }
                </button>
            </EditForm>

            <button id="customer-profile-logout-btn" class="btn btn-ghost" @onclick="HandleLogout">@Localizer["Profile_LogoutButton"]</button>
        }
    </div>
</AuthenticationGuard>

@code {
    private ProfileModel profileModel = new();
    private string username = string.Empty;
    private string email = string.Empty;
    private bool isLoading = true;
    private bool isSaving;
    private string? successMessage;
    private string? errorMessage;

    public class ProfileModel
    {
        [StringLength(50, ErrorMessage = "Ime mora imati manje od 50 znakova")]
        public string? FirstName { get; set; }

        [StringLength(50, ErrorMessage = "Prezime mora imati manje od 50 znakova")]
        public string? LastName { get; set; }

        [Phone(ErrorMessage = "Unesi ispravan broj telefona")]
        [StringLength(30, ErrorMessage = "Broj telefona je predug")]
        public string? PhoneNumber { get; set; }

        // Optional on the profile: empty is allowed, but when supplied it must be exactly 11 digits.
        [RegularExpression(@"^(\d{11})?$", ErrorMessage = "OIB mora imati točno 11 znamenki")]
        public string? Oib { get; set; }
    }

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        isLoading = true;
        var user = await ApiService.GetMyProfileAsync();
        if (user != null)
        {
            username = user.Username;
            email = user.Email;
            profileModel = new ProfileModel
            {
                FirstName = string.IsNullOrEmpty(user.FirstName) ? null : user.FirstName,
                LastName = string.IsNullOrEmpty(user.LastName) ? null : user.LastName,
                PhoneNumber = user.PhoneNumber,
                Oib = user.Oib
            };
        }
        else
        {
            errorMessage = Localizer["Profile_LoadError"];
        }
        isLoading = false;
        StateHasChanged();
    }

    private async Task HandleSave()
    {
        isSaving = true;
        successMessage = null;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var dto = new UpdateProfileDto
            {
                FirstName = string.IsNullOrWhiteSpace(profileModel.FirstName) ? null : profileModel.FirstName.Trim(),
                LastName = string.IsNullOrWhiteSpace(profileModel.LastName) ? null : profileModel.LastName.Trim(),
                PhoneNumber = string.IsNullOrWhiteSpace(profileModel.PhoneNumber) ? null : profileModel.PhoneNumber.Trim(),
                Oib = string.IsNullOrWhiteSpace(profileModel.Oib) ? null : profileModel.Oib.Trim()
            };

            var updated = await ApiService.UpdateProfileAsync(dto);
            if (updated != null)
            {
                username = updated.Username;
                email = updated.Email;
                profileModel = new ProfileModel
                {
                    FirstName = string.IsNullOrEmpty(updated.FirstName) ? null : updated.FirstName,
                    LastName = string.IsNullOrEmpty(updated.LastName) ? null : updated.LastName,
                    PhoneNumber = updated.PhoneNumber,
                    Oib = updated.Oib
                };
                successMessage = Localizer["Profile_SaveSuccess"];
                await ApiService.LogUserActionAsync("CustomerProfileUpdated", "UserAction", "Customer updated their profile");
            }
            else
            {
                errorMessage = Localizer["Profile_SaveError"];
            }
        }
        catch (HttpRequestException)
        {
            errorMessage = Localizer["Profile_ConnectionError"];
        }
        catch (Exception ex)
        {
            errorMessage = Localizer["Profile_UnexpectedError"];
            Console.WriteLine($"Profile save error: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task HandleLogout()
    {
        await AuthStateService.LogoutAsync();
        NavigationManager.NavigateTo("/welcome");
    }
}
