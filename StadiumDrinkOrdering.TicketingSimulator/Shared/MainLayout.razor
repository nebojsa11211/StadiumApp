@inherits LayoutComponentBase

<div id="simulator-layout-shell" class="sim-shell">
    <header id="simulator-layout-topbar" class="sim-topbar">
        <span id="simulator-layout-brand" class="sim-brand"><i class="bi bi-cpu"></i> Stadium Ticketing Simulator</span>
        <span id="simulator-layout-tag" class="sim-tag">external system stand-in</span>
    </header>
    <main id="simulator-layout-main" class="sim-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
