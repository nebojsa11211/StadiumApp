@page "/scan"
@layout MobileShell
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Shared.DTOs
@using Microsoft.Extensions.Localization
@inject NavigationManager Nav
@inject IApiService ApiService
@inject IWebHostEnvironment Env
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["Scan_PageTitle"]</PageTitle>

<ScreenHeader Title="@Localizer["Scan_ScreenHeader"]" BackHref="/welcome" />

<div id="customer-scan-body" class="scan-body">
    <div id="customer-scan-reticle" class="reticle">
        <span class="corner tl"></span><span class="corner tr"></span>
        <span class="corner bl"></span><span class="corner br"></span>
        <div id="customer-scan-qr-emoji" class="qr-emoji">🎟️</div>
        <div id="customer-scan-scanline" class="scanline"></div>
    </div>

    <p class="scan-hint">@Localizer["Scan_HintText"]</p>

    @* DEV-ONLY: pick a real ticket of the live event instead of typing/scanning a code. Never rendered
       in production — the API endpoint that feeds it 404s outside Development, so _testTickets stays empty. *@
    @if (_testTickets is { Count: > 0 })
    {
        <div id="customer-scan-dev-picker" class="manual">
            <div id="customer-scan-dev-label" class="label">@Localizer["Scan_DevLabel"]</div>
            <div id="customer-scan-dev-row" class="manual-row">
                <select id="customer-scan-dev-select" class="form-select form-select-sm" value="@_code" @onchange="OnDevPick">
                    <option value="">@Localizer["Scan_DevPlaceholder"]</option>
                    @foreach (var t in _testTickets)
                    {
                        <option value="@t.TicketNumber">@t.Label</option>
                    }
                </select>
            </div>
        </div>
    }

    <div id="customer-scan-manual" class="manual">
        <div id="customer-scan-manual-label" class="label">@Localizer["Scan_ManualLabel"]</div>
        <div id="customer-scan-manual-row" class="manual-row">
            <input id="customer-scan-code-input" @bind="_code" @bind:event="oninput" placeholder='@Localizer["Scan_ManualPlaceholder"]' @onkeydown="OnKey" />
            <button id="customer-scan-submit-btn" class="btn btn-primary btn-sm" @onclick="Submit" disabled="@string.IsNullOrWhiteSpace(_code)">@Localizer["Scan_ContinueButton"]</button>
        </div>
        @if (_error)
        {
            <div id="customer-scan-error" class="err">@Localizer["Scan_InvalidCode"]</div>
        }
    </div>
</div>

@code {
    private string _code = "";
    private bool _error;
    private List<TestTicketDto>? _testTickets;

    protected override async Task OnInitializedAsync()
    {
        // Only attempt the dev-only lookup in Development; in production the endpoint 404s anyway.
        if (Env.IsDevelopment())
        {
            _testTickets = await ApiService.GetLiveEventTestTicketsAsync();
        }
    }

    private void OnDevPick(ChangeEventArgs e)
    {
        var code = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(code)) return;
        _code = code;
        Nav.NavigateTo($"/t/{code.Trim()}");
    }

    private void OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") Submit();
    }

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(_code)) { _error = true; return; }
        Nav.NavigateTo($"/t/{_code.Trim()}");
    }
}
