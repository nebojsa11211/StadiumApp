@page "/topup"
@using System.Globalization
@inject IStaffApiService ApiService
@inject IAuthStateService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> Localizer
@inject IWebHostEnvironment Env
@implements IAsyncDisposable

<PageTitle>@Localizer["TicketTopup_PageTitle"]</PageTitle>

@if (!AuthService.IsAuthenticated)
{
    <div id="bar-topup-auth-container" class="container mt-5">
        <div id="bar-topup-auth-alert" class="alert alert-warning" role="alert">
            <h4 class="alert-heading">🔐 @Localizer["Dashboard_AuthenticationRequired"]</h4>
            <p>@Localizer["Dashboard_MustBeLoggedIn"]</p>
            <hr>
            <p class="mb-0">
                <a href="/login" class="btn btn-primary">@Localizer["Dashboard_GoToLogin"]</a>
            </p>
        </div>
    </div>
}
else
{
    <div id="bar-topup-container" class="console">
        <div id="bar-topup-header" class="console-head">
            <div id="bar-topup-header-title" class="console-head__title">
                <span class="eyebrow">@Localizer["Dashboard_BarStation"]</span>
                <h1>@Localizer["TicketTopup_Heading"]</h1>
                <p>@Localizer["TicketTopup_Subtitle"]</p>
            </div>
        </div>

        <div id="bar-topup-body" style="max-width: @(ShowIdentifyStep ? "none" : "640px");">
        @if (result != null)
        {
            @* ---------- Step 4: Result ---------- *@
            <div id="bar-topup-result" class="card">
                <div class="card-body text-center">
                    @if (result.Success)
                    {
                        <div id="bar-topup-result-success">
                            <div class="display-5 mb-2">✅</div>
                            <h2 class="h4 mb-3">@Localizer["TicketTopup_SuccessTitle"]</h2>
                            @if (resolved != null)
                            {
                                <p class="mb-1 text-muted">@resolved.FullName</p>
                            }
                            <p class="mb-1">@Localizer["TicketTopup_NewBalance"]:</p>
                            <div id="bar-topup-result-new-balance" class="display-6 fw-bold text-success mb-4">
                                @FormatMoney(result.NewBalance, resolved?.Currency)
                            </div>
                            <button id="bar-topup-new-btn" class="btn btn-primary btn-lg" @onclick="ResetAll">
                                @Localizer["TicketTopup_NewTopupBtn"]
                            </button>
                        </div>
                    }
                    else
                    {
                        <div id="bar-topup-result-failure">
                            <div class="display-5 mb-2">⚠️</div>
                            <h2 class="h4 mb-3">@Localizer["TicketTopup_FailTitle"]</h2>
                            <div id="bar-topup-result-failure-reason" class="alert alert-danger">
                                @FailureText(result.FailureReason)
                            </div>
                            <div class="d-flex gap-2 justify-content-center">
                                <button id="bar-topup-retry-btn" class="btn btn-outline-primary" @onclick="BackToAmount">
                                    @Localizer["TicketTopup_TryAgainBtn"]
                                </button>
                                <button id="bar-topup-new-btn" class="btn btn-primary" @onclick="ResetAll">
                                    @Localizer["TicketTopup_NewTopupBtn"]
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else if (ticketResult != null)
        {
            @* ---------- Ticket wallet result (load or cash-out) ---------- *@
            <div id="bar-ticket-wallet-result" class="card">
                <div class="card-body text-center">
                    @if (ticketResult.Success)
                    {
                        @if (ticketResult.RefundAmount.HasValue)
                        {
                            <div id="bar-ticket-wallet-result-cashout">
                                <div class="display-5 mb-2">💶</div>
                                <h2 class="h4 mb-3">@Localizer["TicketWallet_CashedOutTitle"]</h2>
                                <p class="mb-1">@Localizer["TicketWallet_HandBack"]</p>
                                <div id="bar-ticket-wallet-result-refund" class="display-6 fw-bold text-danger mb-4">
                                    @FormatMoney(ticketResult.RefundAmount.Value, resolved?.Currency)
                                </div>
                            </div>
                        }
                        else
                        {
                            <div id="bar-ticket-wallet-result-loaded">
                                <div class="display-5 mb-2">✅</div>
                                <h2 class="h4 mb-3">@Localizer["TicketWallet_LoadedTitle"]</h2>
                                <p class="mb-1">@Localizer["TicketTopup_NewBalance"]:</p>
                                <div id="bar-ticket-wallet-result-balance" class="display-6 fw-bold text-success mb-4">
                                    @FormatMoney(ticketResult.NewBalance, resolved?.Currency)
                                </div>
                            </div>
                        }
                        <button id="bar-ticket-wallet-new-btn" class="btn btn-primary btn-lg" @onclick="ResetAll">
                            @Localizer["TicketTopup_NewTopupBtn"]
                        </button>
                    }
                    else
                    {
                        <div id="bar-ticket-wallet-result-failure">
                            <div class="display-5 mb-2">⚠️</div>
                            <div id="bar-ticket-wallet-result-failure-reason" class="alert alert-danger">
                                @TicketFailureText(ticketResult.FailureReason)
                            </div>
                            <button id="bar-ticket-wallet-fail-new-btn" class="btn btn-primary" @onclick="ResetAll">
                                @Localizer["TicketTopup_NewTopupBtn"]
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
        else if (claimResult != null)
        {
            @* ---------- Claim-to-account result ---------- *@
            <div id="bar-ticket-wallet-claim-result" class="card">
                <div class="card-body text-center">
                    @if (claimResult.Success)
                    {
                        <div id="bar-ticket-wallet-claim-success">
                            <div class="display-5 mb-2">📧</div>
                            <h2 class="h4 mb-3">@Localizer["TicketWallet_ClaimedTitle"]</h2>
                            <p class="mb-1" id="bar-ticket-wallet-claim-success-msg">
                                @string.Format(Localizer["TicketWallet_ClaimedMsg"].Value,
                                    FormatMoney(claimResult.ClaimedAmount, resolved?.Currency), claimResult.Email)
                            </p>
                            <p class="text-muted small mb-4">@Localizer["TicketWallet_ClaimedEmailNote"]</p>
                            <button id="bar-ticket-wallet-claim-new-btn" class="btn btn-primary btn-lg" @onclick="ResetAll">
                                @Localizer["TicketTopup_NewTopupBtn"]
                            </button>
                        </div>
                    }
                    else
                    {
                        <div id="bar-ticket-wallet-claim-failure">
                            <div class="display-5 mb-2">⚠️</div>
                            <div id="bar-ticket-wallet-claim-failure-reason" class="alert alert-danger">
                                @ClaimFailureText(claimResult.FailureReason)
                            </div>
                            <button id="bar-ticket-wallet-claim-fail-new-btn" class="btn btn-primary" @onclick="ResetAll">
                                @Localizer["TicketTopup_NewTopupBtn"]
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
        else if (resolved != null && resolved.HasAccount)
        {
            @* ---------- Steps 2 & 3: Resolved identity + amount entry ---------- *@
            <div id="bar-topup-identity-card" class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>👤 @Localizer["TicketTopup_IdentityHeader"]</span>
                    @if (!string.IsNullOrWhiteSpace(resolved.MatchedBy))
                    {
                        <span class="badge bg-secondary">@string.Format(Localizer["TicketTopup_MatchedBy"].Value, resolved.MatchedBy)</span>
                    }
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-5 col-sm-4 text-muted">@Localizer["TicketTopup_FullName"]</dt>
                        <dd class="col-7 col-sm-8" id="bar-topup-identity-name">@Display(resolved.FullName)</dd>

                        <dt class="col-5 col-sm-4 text-muted">@Localizer["TicketTopup_Email"]</dt>
                        <dd class="col-7 col-sm-8" id="bar-topup-identity-email">@Display(resolved.Email)</dd>

                        <dt class="col-5 col-sm-4 text-muted">@Localizer["TicketTopup_Oib"]</dt>
                        <dd class="col-7 col-sm-8" id="bar-topup-identity-oib">@Display(resolved.Oib)</dd>

                        <dt class="col-5 col-sm-4 text-muted">@Localizer["TicketTopup_CurrentBalance"]</dt>
                        <dd class="col-7 col-sm-8 fw-bold" id="bar-topup-identity-balance">
                            @FormatMoney(resolved.Balance, resolved.Currency)
                        </dd>
                    </dl>

                    @if (!WalletActive)
                    {
                        <div id="bar-topup-wallet-warning" class="alert alert-warning mt-3 mb-0">
                            @if (string.Equals(resolved.WalletStatus, WalletStatus.Frozen, StringComparison.OrdinalIgnoreCase))
                            {
                                @Localizer["TicketTopup_WalletFrozenWarning"]
                            }
                            else
                            {
                                @string.Format(Localizer["TicketTopup_WalletNotActiveWarning"].Value, resolved.WalletStatus)
                            }
                        </div>
                    }
                </div>
            </div>

            @if (WalletActive)
            {
                <div id="bar-topup-amount-card" class="card mb-3">
                    <div class="card-body">
                        <label for="bar-topup-amount-input" class="form-label">@Localizer["TicketTopup_AmountLabel"]</label>
                        <input id="bar-topup-amount-input" type="number" min="0" step="0.01" inputmode="decimal"
                               class="form-control form-control-lg mb-2" @bind="amountText" @bind:event="oninput"
                               placeholder="@Localizer["TicketTopup_AmountPlaceholder"]" disabled="@isSubmitting" />

                        <div id="bar-topup-quick-amounts" class="d-flex gap-2 mb-3">
                            @foreach (var quick in quickAmounts)
                            {
                                <button type="button" class="btn btn-outline-secondary flex-fill"
                                        id="bar-topup-quick-@quick" @onclick="() => SetQuickAmount(quick)"
                                        disabled="@isSubmitting">
                                    @quick
                                </button>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(submitError))
                        {
                            <div id="bar-topup-submit-error" class="alert alert-danger">@submitError</div>
                        }

                        <button id="bar-topup-confirm-btn" class="btn btn-success btn-lg w-100"
                                @onclick="ConfirmAsync" disabled="@(isSubmitting || ParsedAmount <= 0)">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                <span>@Localizer["TicketTopup_Submitting"]</span>
                            }
                            else
                            {
                                <span>@Localizer["TicketTopup_ConfirmBtn"]</span>
                            }
                        </button>
                    </div>
                </div>
            }

            <button id="bar-topup-cancel-btn" class="btn btn-link text-muted" @onclick="ResetAll">
                @Localizer["TicketTopup_CancelBtn"]
            </button>
        }
        else if (resolved != null && (resolved.AllowTicketWallet || resolved.CanProvisionAccount))
        {
            @if (resolved.CanProvisionAccount)
            {
                @* ---------- Create an account from the ticket's identity (OIB) ---------- *@
                <div id="bar-provision-card" class="card mb-3">
                    <div class="card-header">👤 Kreiraj račun gosta</div>
                    <div class="card-body">
                        @if (!string.IsNullOrWhiteSpace(resolved.FullName))
                        {
                            <p class="mb-1" id="bar-provision-name">@resolved.FullName</p>
                        }
                        <dl class="row mb-2">
                            <dt class="col-5 text-muted">OIB</dt>
                            <dd class="col-7" id="bar-provision-oib">@Display(resolved.Oib)</dd>
                        </dl>
                        <p class="text-muted small">
                            Unesite e-poštu gosta da kreirate račun — sredstva se učitavaju na njegov osobni
                            novčanik i može ih kasnije preuzeti.
                        </p>
                        <label for="bar-provision-email" class="form-label">E-pošta</label>
                        <div class="input-group mb-2">
                            <input id="bar-provision-email" type="email" class="form-control"
                                   @bind="provisionEmail" @bind:event="oninput"
                                   placeholder="ime@@email.hr" disabled="@isProvisioning" />
                            <button id="bar-provision-btn" class="btn btn-primary"
                                    @onclick="ProvisionAsync"
                                    disabled="@(isProvisioning || string.IsNullOrWhiteSpace(provisionEmail))">
                                @if (isProvisioning)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    <span>Kreiram…</span>
                                }
                                else
                                {
                                    <span>Kreiraj račun i nastavi</span>
                                }
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(provisionError))
                        {
                            <div id="bar-provision-error" class="alert alert-danger mb-0">@provisionError</div>
                        }
                        @if (resolved.AllowTicketWallet)
                        {
                            <p class="text-muted small mt-2 mb-0">Ili učitajte izravno na ulaznicu ispod.</p>
                        }
                    </div>
                </div>
            }

            @if (resolved.AllowTicketWallet)
            {
            @* ---------- Anonymous ticket wallet: load funds + cash out ---------- *@
            <div id="bar-ticket-wallet-card" class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>🎟️ @Localizer["TicketWallet_LoadOnTicketTitle"]</span>
                    <span class="badge bg-secondary">@Localizer["TicketWallet_TicketLabel"]: @Display(resolved.TicketNumber)</span>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrWhiteSpace(resolved.FullName))
                    {
                        <p class="mb-1 text-muted" id="bar-ticket-wallet-holder">@resolved.FullName</p>
                    }
                    <dl class="row mb-2">
                        <dt class="col-5 text-muted">@Localizer["TicketWallet_CurrentBalance"]</dt>
                        <dd class="col-7 fw-bold" id="bar-ticket-wallet-balance">@FormatMoney(resolved.Balance, resolved.Currency)</dd>
                    </dl>

                    @if (TicketWalletClosed)
                    {
                        <div id="bar-ticket-wallet-closed" class="alert alert-secondary mb-0">
                            @Localizer["TicketWallet_ClosedNotice"]
                        </div>
                    }
                    else
                    {
                        <div id="bar-ticket-wallet-bearer-warning" class="alert alert-warning">
                            ⚠️ @Localizer["TicketWallet_BearerWarning"]
                        </div>

                        <label for="bar-ticket-wallet-amount-input" class="form-label">@Localizer["TicketTopup_AmountLabel"]</label>
                        <input id="bar-ticket-wallet-amount-input" type="number" min="0" step="0.01" inputmode="decimal"
                               class="form-control form-control-lg mb-2" @bind="amountText" @bind:event="oninput"
                               placeholder="@Localizer["TicketTopup_AmountPlaceholder"]" disabled="@isSubmitting" />

                        <div id="bar-ticket-wallet-quick-amounts" class="d-flex gap-2 mb-2">
                            @foreach (var quick in quickAmounts)
                            {
                                <button type="button" class="btn btn-outline-secondary flex-fill"
                                        id="bar-ticket-wallet-quick-@quick" @onclick="() => SetQuickAmount(quick)"
                                        disabled="@isSubmitting">
                                    @quick
                                </button>
                            }
                        </div>

                        <p class="text-muted small mb-2" id="bar-ticket-wallet-cap-hint">
                            @string.Format(Localizer["TicketWallet_CapHint"].Value, FormatMoney(resolved.TicketWalletMaxBalance, resolved.Currency))
                        </p>

                        @if (!string.IsNullOrEmpty(submitError))
                        {
                            <div id="bar-ticket-wallet-submit-error" class="alert alert-danger">@submitError</div>
                        }

                        <button id="bar-ticket-wallet-load-btn" class="btn btn-success btn-lg w-100 mb-2"
                                @onclick="ConfirmTicketTopupAsync" disabled="@(isSubmitting || ParsedAmount <= 0)">
                            @if (isSubmitting && !isCashingOut)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                <span>@Localizer["TicketTopup_Submitting"]</span>
                            }
                            else
                            {
                                <span>@Localizer["TicketWallet_LoadBtn"]</span>
                            }
                        </button>

                        @if (resolved.Balance > 0)
                        {
                            <button id="bar-ticket-wallet-cashout-btn" class="btn btn-outline-danger btn-lg w-100"
                                    @onclick="CashOutAsync" disabled="@isSubmitting">
                                @if (isCashingOut)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    <span>@Localizer["TicketWallet_CashingOut"]</span>
                                }
                                else
                                {
                                    <span>@string.Format(Localizer["TicketWallet_CashOutBtn"].Value, FormatMoney(resolved.Balance, resolved.Currency))</span>
                                }
                            </button>

                            <hr class="my-3" />
                            <label for="bar-ticket-wallet-claim-email" class="form-label">@Localizer["TicketWallet_ClaimTitle"]</label>
                            <div class="input-group mb-2">
                                <input id="bar-ticket-wallet-claim-email" type="email" class="form-control"
                                       @bind="claimEmail" @bind:event="oninput"
                                       placeholder="@Localizer["TicketWallet_ClaimEmailPlaceholder"]" disabled="@isSubmitting" />
                                <button id="bar-ticket-wallet-claim-btn" class="btn btn-outline-primary"
                                        @onclick="ClaimAsync" disabled="@(isSubmitting || string.IsNullOrWhiteSpace(claimEmail))">
                                    @if (isClaiming)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                        <span>@Localizer["TicketWallet_Claiming"]</span>
                                    }
                                    else
                                    {
                                        <span>@Localizer["TicketWallet_ClaimBtn"]</span>
                                    }
                                </button>
                            </div>
                            <p class="text-muted small mb-0" id="bar-ticket-wallet-claim-hint">@Localizer["TicketWallet_ClaimHint"]</p>
                        }
                    }
                </div>
            </div>
            }

            <button id="bar-ticket-wallet-cancel-btn" class="btn btn-link text-muted" @onclick="ResetAll">
                @Localizer["TicketTopup_CancelBtn"]
            </button>
        }
        else
        {
            @* ---------- Step 1: Identify ---------- *@
            <div id="bar-topup-identify-card" class="card">
                <div class="card-body">
                    @* DEV-ONLY: pick a real ticket of the live event instead of typing/scanning a code.
                       Never rendered in production — the API endpoint that feeds it 404s outside
                       Development, so _testTickets stays empty. *@
                    @if (_testTickets is { Count: > 0 })
                    {
                        <div id="bar-topup-dev-picker" class="mb-3">
                            <label id="bar-topup-dev-label" for="bar-topup-dev-select" class="form-label">
                                🧪 Test (dev): odaberi ulaznicu
                            </label>
                            <select id="bar-topup-dev-select" class="form-select" value="@codeInput"
                                    @onchange="OnDevPick" disabled="@isResolving">
                                <option value="">— odaberi ulaznicu —</option>
                                @foreach (var t in _testTickets)
                                {
                                    <option value="@t.TicketNumber">@t.Label</option>
                                }
                            </select>
                        </div>
                    }

                    <form id="bar-topup-identify-form" @onsubmit="ResolveAsync">
                        <label for="bar-topup-code-input" class="form-label">@Localizer["TicketTopup_IdentifyLabel"]</label>
                        <div class="input-group input-group-lg mb-3">
                            <input id="bar-topup-code-input" type="text" class="form-control"
                                   @bind="codeInput" @bind:event="oninput"
                                   placeholder="@Localizer["TicketTopup_CodePlaceholder"]"
                                   disabled="@isResolving" autocomplete="off" />
                            <button id="bar-topup-resolve-btn" class="btn btn-primary" type="submit"
                                    disabled="@(isResolving || string.IsNullOrWhiteSpace(codeInput))">
                                @if (isResolving)
                                {
                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                }
                                else
                                {
                                    <span>@Localizer["TicketTopup_ResolveBtn"]</span>
                                }
                            </button>
                        </div>
                    </form>

                    @if (!scannerActive)
                    {
                        <button id="bar-topup-scan-btn" class="btn btn-outline-dark w-100" @onclick="RequestScan"
                                disabled="@isResolving">
                            📷 @Localizer["TicketTopup_ScanBtn"]
                        </button>
                    }
                    else
                    {
                        <div id="bar-topup-scanner" class="text-center">
                            <video id="bar-topup-scanner-video" playsinline muted
                                   style="width:100%; max-height:320px; background:#000; border-radius:.5rem;"></video>
                            <p class="text-muted small mt-2 mb-2">@Localizer["TicketTopup_ScanningHint"]</p>
                            <button id="bar-topup-stop-scan-btn" class="btn btn-outline-secondary w-100"
                                    @onclick="StopScannerAsync">
                                @Localizer["TicketTopup_StopScanBtn"]
                            </button>
                        </div>
                    }

                    @if (scannerUnsupported)
                    {
                        <div id="bar-topup-scan-unsupported" class="alert alert-info mt-3 mb-0">
                            @Localizer["TicketTopup_ScanNotSupported"]
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(scannerError))
                    {
                        <div id="bar-topup-scan-error" class="alert alert-warning mt-3 mb-0">
                            @Localizer["TicketTopup_ScanError"]
                        </div>
                    }

                    @if (notFound)
                    {
                        <div id="bar-topup-not-found" class="alert alert-danger mt-3 mb-0">
                            @Localizer["TicketTopup_NotFound"]
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(noAccountMessage))
                    {
                        <div id="bar-topup-no-account" class="alert alert-warning mt-3 mb-0">
                            @noAccountMessage
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(resolveError))
                    {
                        <div id="bar-topup-resolve-error" class="alert alert-danger mt-3 mb-0">
                            @resolveError
                        </div>
                    }
                </div>
            </div>
        }
        </div>
    </div>
}

@code {
    // ---- Identify ----
    private string codeInput = string.Empty;
    private bool isResolving;
    private bool notFound;
    private string? noAccountMessage;
    private string? resolveError;

    // ---- Resolved ----
    private BarTopupResolveResultDto? resolved;

    // ---- Amount ----
    private string amountText = string.Empty;
    private readonly int[] quickAmounts = { 10, 20, 50 };
    private bool isSubmitting;
    private string? submitError;

    // ---- Result ----
    private BarTopupResultDto? result;

    // ---- Anonymous ticket wallet ----
    private TicketWalletResultDto? ticketResult;
    private bool isCashingOut;

    // ---- Claim-to-account ----
    private string claimEmail = string.Empty;
    private bool isClaiming;
    private TicketWalletClaimResultDto? claimResult;

    // ---- Provision-an-account (OIB-identified ticket with no account) ----
    private string provisionEmail = string.Empty;
    private bool isProvisioning;
    private string? provisionError;

    // ---- Dev-only test-ticket picker ----
    private List<TestTicketDto>? _testTickets;

    // ---- Scanner ----
    private bool scannerActive;
    private bool pendingScannerStart;
    private bool scannerUnsupported;
    private string? scannerError;
    private DotNetObjectReference<TicketTopup>? selfRef;
    private const string ScannerVideoId = "bar-topup-scanner-video";

    private bool WalletActive =>
        resolved != null && string.Equals(resolved.WalletStatus, WalletStatus.Active, StringComparison.OrdinalIgnoreCase);

    // A cashed-out ticket wallet is terminal (Closed) — no more top-ups or cash-outs.
    private bool TicketWalletClosed =>
        resolved != null && string.Equals(resolved.WalletStatus, WalletStatus.Closed, StringComparison.OrdinalIgnoreCase);

    // Step 1 (identify) is shown only when nothing else is: no result (account or ticket), and no
    // resolved account or ticket wallet to act on. It only holds a single input row + scan button, so
    // it gets a wider container than the later steps to use the horizontal space.
    private bool ShowIdentifyStep =>
        result == null && ticketResult == null && claimResult == null
        && !(resolved != null && (resolved.HasAccount || resolved.AllowTicketWallet || resolved.CanProvisionAccount));

    private decimal ParsedAmount => TryParseAmount(amountText, out var a) ? a : 0m;

    protected override void OnInitialized()
    {
        // Bounce to login the moment the session ends (mirrors Dashboard/OrderQueue behaviour).
        AuthService.OnAuthenticationStateChanged += OnAuthStateChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        // Only attempt the dev-only lookup in Development; in production the endpoint 404s anyway.
        if (Env.IsDevelopment())
            _testTickets = await ApiService.GetLiveEventTestTicketsAsync();
    }

    // Dev picker: selecting a ticket fills the code box and resolves it, same as typing + submit.
    private async Task OnDevPick(ChangeEventArgs e)
    {
        var code = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(code))
            return;
        codeInput = code;
        await ResolveAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // The <video> element only exists after the render that flips scannerActive on, so the actual
        // camera start is deferred to here (post-render) to guarantee the element is in the DOM.
        if (pendingScannerStart)
        {
            pendingScannerStart = false;
            await StartScannerAsync();
        }
    }

    // ---------------- Identify / resolve ----------------

    private async Task ResolveAsync()
    {
        var query = codeInput?.Trim();
        if (string.IsNullOrWhiteSpace(query) || isResolving)
            return;

        // Any camera session is finished once we start resolving.
        await StopScannerAsync();

        isResolving = true;
        notFound = false;
        noAccountMessage = null;
        resolveError = null;
        resolved = null;
        result = null;
        ticketResult = null;
        claimResult = null;
        StateHasChanged();

        try
        {
            var res = await ApiService.ResolveTopupAsync(query);
            if (res == null)
            {
                resolveError = Localizer["TicketTopup_ResolveError"].Value;
            }
            else if (!res.Found)
            {
                notFound = true;
            }
            else if (!res.HasAccount && (res.AllowTicketWallet || res.CanProvisionAccount))
            {
                // No linked account, but a concrete ticket was scanned. Show the actionable card(s):
                // create an account from the ticket's identity (CanProvisionAccount) and/or load funds
                // directly on the ticket as a bearer balance (AllowTicketWallet).
                resolved = res;
                amountText = string.Empty;
                submitError = null;
                // Prefill the provision email with the address the ticket already carries so the
                // bartender only confirms it (they can still edit) instead of retyping it.
                provisionEmail = res.Email ?? string.Empty;
                provisionError = null;

                // If the ticket already carries an email, provision the account automatically and go
                // straight to the amount step — no manual confirm. On failure ProvisionAsync surfaces
                // the error and the (prefilled) provision card stays visible for the bartender to fix.
                if (res.CanProvisionAccount && !string.IsNullOrWhiteSpace(res.Email))
                    await ProvisionAsync();
            }
            else if (!res.HasAccount)
            {
                // Matched a pass/email/OIB but no linked account and nothing to bind a bearer balance
                // to — surface the server message so the bartender tells the fan to sign in / register.
                noAccountMessage = string.IsNullOrWhiteSpace(res.Message)
                    ? Localizer["TicketTopup_NoAccount"].Value
                    : res.Message;
            }
            else
            {
                resolved = res;
                amountText = string.Empty;
                submitError = null;
            }
        }
        catch (Exception ex)
        {
            resolveError = ex.Message;
        }
        finally
        {
            isResolving = false;
            StateHasChanged();
        }
    }

    // ---------------- Amount / confirm ----------------

    private void SetQuickAmount(int value)
    {
        amountText = value.ToString(CultureInfo.InvariantCulture);
    }

    private async Task ConfirmAsync()
    {
        if (isSubmitting || resolved?.UserId is not int userId || !WalletActive)
            return;
        if (!TryParseAmount(amountText, out var amount) || amount <= 0)
            return;

        isSubmitting = true;
        submitError = null;
        StateHasChanged();

        try
        {
            var request = new BarTopupRequestDto
            {
                UserId = userId,
                Amount = amount,
                // Fresh key per confirmed attempt so a network retry is a safe server-side no-op.
                IdempotencyKey = Guid.NewGuid().ToString()
            };

            var res = await ApiService.SubmitTopupAsync(request);
            if (res == null)
                submitError = Localizer["TicketTopup_Fail_Generic"].Value;
            else
                result = res; // covers both success and structured failure (mapped in the result view)
        }
        catch (Exception ex)
        {
            submitError = ex.Message;
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    // Back to the amount step keeping the resolved fan (used after a failed submit).
    private void BackToAmount()
    {
        result = null;
        submitError = null;
    }

    // ---------------- Anonymous ticket wallet ----------------

    private async Task ConfirmTicketTopupAsync()
    {
        if (isSubmitting || resolved?.TicketId is not int ticketId || !WalletActive)
            return;
        if (!TryParseAmount(amountText, out var amount) || amount <= 0)
            return;

        // Client-side cap check for immediate feedback; the server enforces it authoritatively too.
        var remaining = resolved.TicketWalletMaxBalance - resolved.Balance;
        if (amount > remaining)
        {
            submitError = string.Format(Localizer["TicketWallet_OverCap"].Value,
                FormatMoney(remaining < 0 ? 0m : remaining, resolved.Currency));
            return;
        }

        isSubmitting = true;
        submitError = null;
        StateHasChanged();

        try
        {
            var request = new TicketWalletTopupRequestDto
            {
                TicketId = ticketId,
                Amount = amount,
                // Fresh key per confirmed attempt so a network retry is a safe server-side no-op.
                IdempotencyKey = Guid.NewGuid().ToString()
            };

            var res = await ApiService.TopUpTicketWalletAsync(request);
            if (res == null)
                submitError = Localizer["TicketWallet_Fail_Generic"].Value;
            else
                ticketResult = res;
        }
        catch (Exception ex)
        {
            submitError = ex.Message;
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task CashOutAsync()
    {
        if (isSubmitting || resolved?.TicketId is not int ticketId)
            return;

        isSubmitting = true;
        isCashingOut = true;
        submitError = null;
        StateHasChanged();

        try
        {
            var request = new TicketWalletCashoutRequestDto
            {
                TicketId = ticketId,
                // Fresh key per attempt: a retry completes the same payout; a re-scan of an already
                // cashed-out ticket comes back as AlreadyCashedOut with nothing to pay.
                IdempotencyKey = Guid.NewGuid().ToString()
            };

            var res = await ApiService.CashOutTicketWalletAsync(request);
            if (res == null)
                submitError = Localizer["TicketWallet_Fail_Generic"].Value;
            else
                ticketResult = res;
        }
        catch (Exception ex)
        {
            submitError = ex.Message;
        }
        finally
        {
            isSubmitting = false;
            isCashingOut = false;
            StateHasChanged();
        }
    }

    private string TicketFailureText(string? reason) => reason switch
    {
        "LimitExceeded" => Localizer["TicketWallet_Fail_LimitExceeded"].Value,
        "TicketNotFound" => Localizer["TicketWallet_Fail_TicketNotFound"].Value,
        "AlreadyCashedOut" => Localizer["TicketWallet_Fail_AlreadyCashedOut"].Value,
        "NothingToCashOut" => Localizer["TicketWallet_Fail_NothingToCashOut"].Value,
        "WalletFrozen" => Localizer["TicketWallet_Fail_WalletFrozen"].Value,
        _ => Localizer["TicketWallet_Fail_Generic"].Value
    };

    private async Task ClaimAsync()
    {
        if (isSubmitting || resolved?.TicketId is not int ticketId)
            return;
        var email = claimEmail?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(email))
            return;

        isSubmitting = true;
        isClaiming = true;
        submitError = null;
        StateHasChanged();

        try
        {
            var request = new TicketWalletClaimRequestDto { TicketId = ticketId, Email = email };
            var res = await ApiService.ClaimTicketWalletAsync(request);
            if (res == null)
                submitError = Localizer["TicketWallet_Fail_ClaimGeneric"].Value;
            else
                claimResult = res;
        }
        catch (Exception ex)
        {
            submitError = ex.Message;
        }
        finally
        {
            isSubmitting = false;
            isClaiming = false;
            StateHasChanged();
        }
    }

    private string ClaimFailureText(string? reason) => reason switch
    {
        "AlreadyClaimed" => Localizer["TicketWallet_Fail_AlreadyClaimed"].Value,
        "NothingToClaim" => Localizer["TicketWallet_Fail_NothingToClaim"].Value,
        "TicketNotFound" => Localizer["TicketWallet_Fail_TicketNotFound"].Value,
        "WalletFrozen" => Localizer["TicketWallet_Fail_WalletFrozen"].Value,
        "InvalidEmail" => Localizer["TicketWallet_Fail_InvalidEmail"].Value,
        _ => Localizer["TicketWallet_Fail_ClaimGeneric"].Value
    };

    // Create a claimable account from the scanned ticket's identity (name + OIB) using the email the
    // bartender collected. On success the resolve result becomes an account, so the amount form renders.
    private async Task ProvisionAsync()
    {
        if (isProvisioning || resolved?.TicketId is not int ticketId)
            return;
        var email = provisionEmail?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(email))
            return;

        isProvisioning = true;
        provisionError = null;
        StateHasChanged();

        try
        {
            var request = new BarTopupProvisionRequestDto { TicketId = ticketId, Email = email };
            var res = await ApiService.ProvisionTopupAccountAsync(request);
            if (res is { HasAccount: true })
            {
                resolved = res;        // now a real account — the amount step renders next
                amountText = string.Empty;
                submitError = null;
            }
            else
            {
                provisionError = string.IsNullOrWhiteSpace(res?.Message)
                    ? Localizer["TicketTopup_Fail_Generic"].Value
                    : res!.Message;
            }
        }
        catch (Exception ex)
        {
            provisionError = ex.Message;
        }
        finally
        {
            isProvisioning = false;
            StateHasChanged();
        }
    }

    private async Task ResetAll()
    {
        await StopScannerAsync();
        codeInput = string.Empty;
        amountText = string.Empty;
        resolved = null;
        result = null;
        ticketResult = null;
        isCashingOut = false;
        claimEmail = string.Empty;
        claimResult = null;
        isClaiming = false;
        provisionEmail = string.Empty;
        provisionError = null;
        isProvisioning = false;
        notFound = false;
        noAccountMessage = null;
        resolveError = null;
        submitError = null;
        scannerUnsupported = false;
        scannerError = null;
    }

    // ---------------- Scanner ----------------

    private void RequestScan()
    {
        scannerUnsupported = false;
        scannerError = null;
        scannerActive = true;      // renders the <video> element
        pendingScannerStart = true; // OnAfterRenderAsync starts the camera once it's in the DOM
    }

    private async Task StartScannerAsync()
    {
        selfRef ??= DotNetObjectReference.Create(this);
        try
        {
            var res = await JS.InvokeAsync<ScanStartResult>("barTopupScanner.start", ScannerVideoId, selfRef);
            if (res == null || !res.Supported)
            {
                scannerUnsupported = true;
                scannerActive = false;
            }
            else if (!res.Started)
            {
                scannerError = res.Error;
                scannerActive = false;
            }
        }
        catch (Exception ex)
        {
            scannerError = ex.Message;
            scannerActive = false;
        }
        StateHasChanged();
    }

    private async Task StopScannerAsync()
    {
        pendingScannerStart = false;
        if (!scannerActive)
            return;
        scannerActive = false;
        try { await JS.InvokeVoidAsync("barTopupScanner.stop"); }
        catch (Exception ex) { Console.WriteLine($"Stopping scanner failed: {ex.Message}"); }
    }

    [JSInvokable]
    public Task OnQrDecoded(string text) => InvokeAsync(async () =>
    {
        // JS has already released the camera on a successful decode.
        scannerActive = false;
        pendingScannerStart = false;
        codeInput = text;
        await ResolveAsync();
    });

    // ---------------- Helpers ----------------

    private static bool TryParseAmount(string? s, out decimal amount)
    {
        amount = 0m;
        if (string.IsNullOrWhiteSpace(s))
            return false;
        // Accept both comma and dot decimal separators regardless of active culture.
        s = s.Trim().Replace(',', '.');
        return decimal.TryParse(s, NumberStyles.Number, CultureInfo.InvariantCulture, out amount);
    }

    private string Display(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string FormatMoney(decimal amount, string? currency) =>
        $"{amount.ToString("0.00", CultureInfo.InvariantCulture)} {(string.IsNullOrWhiteSpace(currency) ? "EUR" : currency)}";

    private string FailureText(string? reason) => reason switch
    {
        "WalletFrozen" => Localizer["TicketTopup_Fail_WalletFrozen"].Value,
        "AccountNotFound" => Localizer["TicketTopup_Fail_AccountNotFound"].Value,
        "InvalidAmount" => Localizer["TicketTopup_Fail_InvalidAmount"].Value,
        _ => Localizer["TicketTopup_Fail_Generic"].Value
    };

    private void OnAuthStateChanged()
    {
        if (!AuthService.IsAuthenticated)
            Navigation.NavigateTo("/login");
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        AuthService.OnAuthenticationStateChanged -= OnAuthStateChanged;
        try { await JS.InvokeVoidAsync("barTopupScanner.stop"); }
        catch (Exception ex) { Console.WriteLine($"Scanner disposal stop failed: {ex.Message}"); }
        selfRef?.Dispose();
    }

    // Shape returned by barTopupScanner.start (camelCase JSON → these properties).
    public class ScanStartResult
    {
        public bool Supported { get; set; }
        public bool Started { get; set; }
        public string? Error { get; set; }
    }
}
