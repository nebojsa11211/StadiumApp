    // JavaScript callback for polygon/triangle vertex completion
    [JSInvokable]
    public async Task ShowSectorCreateModalWithVertices(string shapeMode, List<Dictionary<string, double>> vertices)
    {
        try
        {
            Logger.LogInformation($"Polygon/triangle sector created with {vertices.Count} vertices in {shapeMode} mode");

            // Convert JavaScript vertex array to VertexCoordinate objects
            var vertexList = vertices.Select(v => new StadiumDrinkOrdering.Shared.Models.VertexCoordinate
            {
                X = v["x"],
                Y = v["y"]
            }).ToList();

            // Determine shape type from mode
            var shapeType = shapeMode.ToLower() switch
            {
                "triangle" => "triangle",
                "rhombus" => "rhombus",
                "polygon" => "custompolygon",
                _ => "rectangle"
            };

            // Calculate bounding box from vertices
            var minX = vertexList.Min(v => v.X);
            var maxX = vertexList.Max(v => v.X);
            var minY = vertexList.Min(v => v.Y);
            var maxY = vertexList.Max(v => v.Y);

            // Create new sector with vertex data
            var newSector = new SectorOverlay
            {
                Id = Guid.NewGuid().ToString(),
                SectorCode = $"SECT{sectorOverlays.Count + 1}",
                Name = $"New {shapeMode} {sectorOverlays.Count + 1}",
                LeftPercent = minX,
                TopPercent = minY,
                WidthPercent = maxX - minX,
                HeightPercent = maxY - minY,
                ShapeType = shapeType,
                ShapeData = JsonSerializer.Serialize(vertexList), // Store vertices as JSON
                Rows = 10,
                SeatsPerRow = 20,
                Type = "standard",
                Color = "#007bff",
                CreatedDate = DateTime.UtcNow,
                ModifiedDate = DateTime.UtcNow
            };

            // Open modal for user to configure sector details
            OpenNewSectorModal(newSector);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in ShowSectorCreateModalWithVertices");
            ShowAlert($"Error creating polygon sector: {ex.Message}", "danger");
        }
    }
