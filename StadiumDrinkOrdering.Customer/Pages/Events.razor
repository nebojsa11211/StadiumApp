@page "/events"
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Customer.Components
@inject IApiService ApiService
@inject NavigationManager Navigation

<PageTitle>Browse Premium Events - Stadium Drinks</PageTitle>

<CustomerAuthRoute>
<div class="premium-page">
    <!-- Premium Header -->
    <div class="premium-section-header">
        <div class="container py-5">
            <div class="text-center">
                <h1 class="display-3 fw-bold text-white mb-4">🎫 Premium Events</h1>
                <p class="lead text-white-50 mx-auto" style="max-width: 800px;">
                    Discover exclusive sports events, concerts, and premium entertainment experiences.
                    Secure your tickets and enjoy world-class concessions delivered to your seat.
                </p>
            </div>
        </div>
    </div>

    <!-- Advanced Filters Section -->
    <div class="container py-4">
        <div class="premium-card shadow-lg">
            <div class="premium-card-header">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                    <div>
                        <h3 class="h4 fw-bold text-white mb-2">Find Your Perfect Event</h3>
                        <p class="text-white-50 mb-0">Advanced filtering for premium experiences</p>
                    </div>
                    <div class="d-flex gap-2">
                        <span class="badge bg-success">Premium Selection</span>
                        <span class="badge bg-warning text-dark">Curated Events</span>
                    </div>
                </div>
            </div>
            <div class="premium-card-body">
                <div class="row g-4">
                    <div class="col-12 col-md-6 col-lg-3">
                        <div class="mb-3">
                            <label class="form-label text-white">Event Type</label>
                            <select class="form-select premium-form-control" @bind="filterEventType">
                                <option value="">All Premium Events</option>
                                <option value="Football">🏈 Football</option>
                                <option value="Concert">🎵 Premium Concerts</option>
                                <option value="Basketball">🏀 Basketball</option>
                                <option value="Baseball">⚾ Baseball</option>
                                <option value="Hockey">🏒 Hockey</option>
                                <option value="Soccer">⚽ Soccer</option>
                                <option value="Other">🎭 Other Premium Events</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3">
                        <div class="mb-3">
                            <label class="form-label text-white">From Date</label>
                            <input type="date" class="form-control premium-form-control" @bind="filterDateFrom" />
                        </div>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3">
                        <div class="mb-3">
                            <label class="form-label text-white">To Date</label>
                            <input type="date" class="form-control premium-form-control" @bind="filterDateTo" />
                        </div>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3">
                        <div class="mb-3">
                            <label class="form-label text-white">Price Range</label>
                            <div class="d-flex gap-2">
                                <input type="number" class="form-control premium-form-control" placeholder="Min $" @bind="filterMinPrice" step="10" />
                                <input type="number" class="form-control premium-form-control" placeholder="Max $" @bind="filterMaxPrice" step="10" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-3 justify-content-end mt-4">
                    <button class="btn premium-btn-outline" @onclick="ClearFilters">
                        <span>🔄</span>
                        <span>Clear Filters</span>
                    </button>
                    <button class="btn premium-btn-primary" @onclick="ApplyFilters" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>Searching...</span>
                        }
                        else
                        {
                            <span>🔍</span>
                            <span>Apply Filters</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Events Grid -->
    <div class="container pb-5">
        <!-- Loading State -->
        @if (isLoading && events == null)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-success mb-4" style="width: 4rem; height: 4rem;" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <h3 class="h4 fw-bold text-white mb-3">Discovering Premium Events</h3>
                <p class="text-white-50">Please wait while we curate the best experiences for you...</p>
            </div>
        }
        else if (events == null || !events.Any())
        {
            <!-- Empty State -->
            <div class="text-center py-5">
                <div class="mb-4">
                    <span style="font-size: 6rem;">🎭</span>
                </div>
                <h3 class="h3 fw-bold text-white mb-4">No Premium Events Found</h3>
                <p class="text-white-50 mb-4 mx-auto" style="max-width: 600px;">
                    We couldn't find any premium events matching your criteria. Try adjusting your filters or check back later for new exclusive events.
                </p>
                <div class="d-flex gap-3 justify-content-center">
                    <button class="btn premium-btn-outline" @onclick="ClearFilters">
                        <span>🔄</span>
                        <span>Clear All Filters</span>
                    </button>
                    <a href="/" class="btn premium-btn-primary">
                        <span>🏠</span>
                        <span>Back to Home</span>
                    </a>
                </div>
            </div>
        }
        else
        {
            <!-- Events Grid -->
            <div class="row g-4">
                @foreach (var evt in events)
                {
                    var capacityPercent = evt.TotalSeats > 0 ? (int)((decimal)evt.SoldTickets / evt.TotalSeats * 100) : 0;
                    var isSellingFast = evt.AvailableSeats <= 50 && evt.AvailableSeats > 0;
                    var isSoldOut = evt.AvailableSeats <= 0;
                    var isPremiumEvent = evt.BaseTicketPrice > 100;

                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="premium-event-card h-100">
                            <!-- Event Header with Premium Badge -->
                            <div class="premium-event-header position-relative">
                                <div class="premium-event-image">
                                    <div class="text-center text-white">
                                        <div class="fs-1 mb-2">🏟️</div>
                                        <div class="badge bg-dark bg-opacity-50">@evt.VenueInfo</div>
                                    </div>
                                </div>

                                <!-- Premium Event Badge -->
                                @if (isPremiumEvent)
                                {
                                    <div class="position-absolute top-0 start-0 p-3">
                                        <span class="badge bg-warning text-dark">
                                            <span>⭐</span>
                                            <span>Premium</span>
                                        </span>
                                    </div>
                                }

                                <!-- Status Badges -->
                                <div class="position-absolute top-0 end-0 p-3">
                                    <div class="d-flex flex-column gap-2">
                                        <span class="badge bg-success">@evt.EventType</span>
                                        @if (isSellingFast)
                                        {
                                            <span class="badge bg-danger">
                                                <span>⚡</span>
                                                <span>Selling Fast</span>
                                            </span>
                                        }
                                        else if (isSoldOut)
                                        {
                                            <span class="badge bg-secondary">
                                                <span>❌</span>
                                                <span>Sold Out</span>
                                            </span>
                                        }
                                    </div>
                                </div>

                                <!-- Date Badge -->
                                <div class="position-absolute bottom-0 end-0 p-3">
                                    <div class="premium-date-badge">
                                        <div class="text-center">
                                            <div class="text-uppercase small text-muted">@evt.EventDate.ToString("MMM")</div>
                                            <div class="display-6 fw-bold text-dark">@evt.EventDate.ToString("dd")</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Event Details -->
                            <div class="premium-card-body">
                                <div class="d-flex align-items-start justify-content-between mb-3">
                                    <div class="flex-grow-1">
                                        <h3 class="h5 fw-bold text-white mb-2">@evt.EventName</h3>
                                        <p class="text-white-50 small mb-0">@evt.EventDate.ToString("dddd, MMMM dd, yyyy") at @evt.EventDate.ToString("h:mm tt")</p>
                                    </div>
                                    @if (isPremiumEvent)
                                    {
                                        <div class="ms-3">
                                            <div class="premium-star-badge">⭐</div>
                                        </div>
                                    }
                                </div>

                                <!-- Stats Grid -->
                                <div class="row g-2 mb-3">
                                    <div class="col-4">
                                        <div class="premium-stat-box">
                                            <div class="h5 fw-bold mb-0 @(isPremiumEvent ? "text-warning" : "text-success")">$@evt.BaseTicketPrice.ToString("F0")</div>
                                            <div class="small text-white-50">From</div>
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="premium-stat-box">
                                            <div class="h5 fw-bold mb-0 @(evt.AvailableSeats > 100 ? "text-success" : evt.AvailableSeats > 50 ? "text-warning" : "text-danger")">@evt.AvailableSeats</div>
                                            <div class="small text-white-50">Available</div>
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="premium-stat-box">
                                            <div class="h5 fw-bold mb-0 text-white">@capacityPercent%</div>
                                            <div class="small text-white-50">Sold</div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Progress Bar -->
                                <div class="progress mb-3" style="height: 8px;">
                                    <div class="progress-bar bg-gradient bg-success" role="progressbar" style="width: @capacityPercent%" aria-valuenow="@capacityPercent" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>

                                <!-- Action Button -->
                                <button
                                    class="btn @(isSoldOut ? "premium-btn-outline" : "premium-btn-primary") w-100"
                                    @onclick="() => ViewEventDetails(evt.Id)"
                                    disabled="@isSoldOut">
                                    @if (isSoldOut)
                                    {
                                        <span>❌ Sold Out</span>
                                    }
                                    else if (isSellingFast)
                                    {
                                        <span>⚡ Only @evt.AvailableSeats Left - Act Fast!</span>
                                    }
                                    else
                                    {
                                        <span>🎫 @(isPremiumEvent ? "Get Premium Tickets" : "Get Tickets")</span>
                                    }
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
</CustomerAuthRoute>

@code {
    private List<CustomerEventDto>? events;
    private bool isLoading = false;

    // Filter properties
    private string filterEventType = "";
    private DateTime? filterDateFrom;
    private DateTime? filterDateTo;
    private decimal? filterMinPrice;
    private decimal? filterMaxPrice;

    protected override async Task OnInitializedAsync()
    {
        await LoadEvents();
    }

    private async Task LoadEvents()
    {
        isLoading = true;
        try
        {
            var filter = new CustomerEventFilterDto
            {
                EventType = string.IsNullOrEmpty(filterEventType) ? null : filterEventType,
                DateFrom = filterDateFrom,
                DateTo = filterDateTo,
                MinPrice = filterMinPrice,
                MaxPrice = filterMaxPrice
            };

            events = await ApiService.GetAvailableEventsAsync(filter);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading events: {ex.Message}");
            // Could add user-friendly error handling here
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApplyFilters()
    {
        await LoadEvents();
    }

    private async Task ClearFilters()
    {
        filterEventType = "";
        filterDateFrom = null;
        filterDateTo = null;
        filterMinPrice = null;
        filterMaxPrice = null;
        await LoadEvents();
    }

    private void ViewEventDetails(int eventId)
    {
        Navigation.NavigateTo($"/events/{eventId}");
    }
}
