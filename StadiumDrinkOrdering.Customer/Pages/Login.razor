@page "/login"
@layout MobileShell
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Customer.Services
@inject IApiService Api
@inject ICustomerAuthStateService AuthState
@inject NavigationManager Nav

<PageTitle>Prijava — HALFTIME</PageTitle>

<ScreenHeader Title="Prijava" Subtitle="Pretplatnici" BackHref="/welcome" />

<div id="customer-login-body" class="login-body">
    <div id="customer-login-hero" class="login-hero">
        <div id="customer-login-badge" class="badge">⭐ Sezona</div>
        <h1 id="customer-login-title" class="display">DOBRO<br /><span id="customer-login-title-highlight" class="grad-text">DOŠAO</span></h1>
        <p id="customer-login-intro-text">Prijavi se da vidiš svoju sljedeću utakmicu i naručuješ na svoje mjesto.</p>
    </div>

    <EditForm Model="this" OnValidSubmit="HandleLogin" class="login-form" id="customer-login-form">
        @if (!string.IsNullOrEmpty(_error))
        {
            <div id="customer-login-error" class="err">@_error</div>
        }

        <div id="customer-login-email-field" class="field">
            <label for="customer-login-email-input">Email</label>
            <input id="customer-login-email-input" type="email" @bind="_email" @bind:event="oninput" placeholder="ime@email.hr" autocomplete="email" />
        </div>
        <div id="customer-login-password-field" class="field">
            <label for="customer-login-password-input">Lozinka</label>
            <input id="customer-login-password-input" type="password" @bind="_password" @bind:event="oninput" placeholder="••••••••" autocomplete="current-password" />
        </div>

        <button type="submit" class="btn btn-primary" disabled="@_busy" id="customer-login-submit-btn">
            @if (_busy)
            {
                <span class="spinner" id="customer-login-spinner"></span> <span id="customer-login-loading-text">Prijavljujem…</span>
            }
            else
            {
                <span id="customer-login-button-text">Prijavi se</span>
            }
        </button>
    </EditForm>

    <p class="alt">Došao si samo na ovu utakmicu? <a id="customer-login-scan-link" @onclick="@(() => Nav.NavigateTo("/scan"))">Skeniraj ulaznicu</a>.</p>
</div>

@code {
    private string _email = "";
    private string _password = "";
    private string? _error;
    private bool _busy;
    private string? _returnUrl;

    protected override void OnInitialized()
    {
        var q = System.Web.HttpUtility.ParseQueryString(new Uri(Nav.Uri).Query);
        _returnUrl = q["returnUrl"];
        if (AuthState.IsAuthenticated)
            Nav.NavigateTo(string.IsNullOrEmpty(_returnUrl) ? "/home" : _returnUrl);
    }

    private async Task HandleLogin()
    {
        if (_busy) return;
        _busy = true;
        _error = null;

        try
        {
            var result = await Api.LoginAsync(new LoginDto { Email = _email, Password = _password });
            if (result?.Token != null && result.User != null)
            {
                await AuthState.LoginAsync(result.Token, result.User);
                Nav.NavigateTo(string.IsNullOrEmpty(_returnUrl) ? "/home" : _returnUrl, forceLoad: false);
            }
            else
            {
                _error = "Neispravan email ili lozinka.";
            }
        }
        catch (HttpRequestException)
        {
            _error = "Nije moguće spojiti se na poslužitelj.";
        }
        catch (Exception)
        {
            _error = "Došlo je do pogreške. Pokušaj ponovno.";
        }
        finally
        {
            _busy = false;
        }
    }
}
