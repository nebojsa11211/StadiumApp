@page "/events"
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Customer.Components
@inject IApiService ApiService
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["Events_PageTitle"]</PageTitle>

<CustomerAuthRoute>
<div id="customer-events-page" class="premium-page">
    <!-- Premium Header -->
    <div id="customer-events-header" class="premium-section-header">
        <div id="customer-events-header-container" class="container py-5">
            <div id="customer-events-header-center" class="text-center">
                <h1 class="display-3 fw-bold text-white mb-4">🎫 @Localizer["Events_HeaderTitle"]</h1>
                <p class="lead text-white-50 mx-auto" style="max-width: 800px;">
                    @Localizer["Events_HeaderSubtitle"]
                </p>
            </div>
        </div>
    </div>

    <!-- Advanced Filters Section -->
    <div id="customer-events-filters-container" class="container py-4">
        <div id="customer-events-filters-card" class="premium-card shadow-lg">
            <div id="customer-events-filters-header" class="premium-card-header">
                <div id="customer-events-filters-top" class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                    <div id="customer-events-filters-title-group">
                        <h3 class="h4 fw-bold text-white mb-2">@Localizer["Events_FindYourEvent"]</h3>
                        <p class="text-white-50 mb-0">@Localizer["Events_AdvancedFiltering"]</p>
                    </div>
                    <div class="d-flex gap-2">
                        <span class="badge bg-success">@Localizer["Events_PremiumSelection"]</span>
                        <span class="badge bg-warning text-dark">@Localizer["Events_CuratedEvents"]</span>
                    </div>
                </div>
            </div>
            <div id="customer-events-filters-body" class="premium-card-body">
                <div id="customer-events-filter-inputs-row" class="row g-4">
                    <div id="customer-events-filter-type" class="col-12 col-md-6 col-lg-3">
                        <div id="customer-events-filter-type-group" class="mb-3">
                            <label class="form-label text-white">@Localizer["Events_EventType"]</label>
                            <select id="customer-events-filter-type-select" class="form-select premium-form-control" @bind="filterEventType">
                                <option value="">@Localizer["Events_AllPremium"]</option>
                                <option value="Football">🏈 @Localizer["Events_Football"]</option>
                                <option value="Concert">🎵 @Localizer["Events_PremiumConcerts"]</option>
                                <option value="Basketball">🏀 @Localizer["Events_Basketball"]</option>
                                <option value="Baseball">⚾ @Localizer["Events_Baseball"]</option>
                                <option value="Hockey">🏒 @Localizer["Events_Hockey"]</option>
                                <option value="Soccer">⚽ @Localizer["Events_Soccer"]</option>
                                <option value="Other">🎭 @Localizer["Events_OtherPremium"]</option>
                            </select>
                        </div>
                    </div>
                    <div id="customer-events-filter-datefrom" class="col-12 col-md-6 col-lg-3">
                        <div id="customer-events-filter-datefrom-group" class="mb-3">
                            <label class="form-label text-white">@Localizer["Events_FromDate"]</label>
                            <input id="customer-events-filter-datefrom-input" type="date" class="form-control premium-form-control" @bind="filterDateFrom" />
                        </div>
                    </div>
                    <div id="customer-events-filter-dateto" class="col-12 col-md-6 col-lg-3">
                        <div id="customer-events-filter-dateto-group" class="mb-3">
                            <label class="form-label text-white">@Localizer["Events_ToDate"]</label>
                            <input id="customer-events-filter-dateto-input" type="date" class="form-control premium-form-control" @bind="filterDateTo" />
                        </div>
                    </div>
                    <div id="customer-events-filter-price" class="col-12 col-md-6 col-lg-3">
                        <div id="customer-events-filter-price-group" class="mb-3">
                            <label class="form-label text-white">@Localizer["Events_PriceRange"]</label>
                            <div id="customer-events-filter-price-inputs" class="d-flex gap-2">
                                <input id="customer-events-filter-minprice-input" type="number" class="form-control premium-form-control" placeholder="@Localizer["Events_MinPrice"]" @bind="filterMinPrice" step="10" />
                                <input id="customer-events-filter-maxprice-input" type="number" class="form-control premium-form-control" placeholder="@Localizer["Events_MaxPrice"]" @bind="filterMaxPrice" step="10" />
                            </div>
                        </div>
                    </div>
                </div>
                <div id="customer-events-filter-buttons" class="d-flex gap-3 justify-content-end mt-4">
                    <button id="customer-events-clear-filters-btn" class="btn premium-btn-outline" @onclick="ClearFilters">
                        <span>🔄</span>
                        <span>@Localizer["Events_ClearFilters"]</span>
                    </button>
                    <button id="customer-events-apply-filters-btn" class="btn premium-btn-primary" @onclick="ApplyFilters" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>@Localizer["Events_Searching"]</span>
                        }
                        else
                        {
                            <span>🔍</span>
                            <span>@Localizer["Events_ApplyFilters"]</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Events Grid -->
    <div id="customer-events-list-container" class="container pb-5">
        <!-- Loading State -->
        @if (isLoading && events == null)
        {
            <div id="customer-events-loading-state" class="text-center py-5">
                <div id="customer-events-spinner" class="spinner-border text-success mb-4" style="width: 4rem; height: 4rem;" role="status">
                    <span class="visually-hidden">@Localizer["Loading"]</span>
                </div>
                <h3 class="h4 fw-bold text-white mb-3">@Localizer["Events_DiscoveringEvents"]</h3>
                <p class="text-white-50">@Localizer["Events_PleaseWaitCurating"]</p>
            </div>
        }
        else if (events == null || !events.Any())
        {
            <!-- Empty State -->
            <div id="customer-events-empty-state" class="text-center py-5">
                <div id="customer-events-empty-icon" class="mb-4">
                    <span style="font-size: 6rem;">🎭</span>
                </div>
                <h3 class="h3 fw-bold text-white mb-4">@Localizer["Events_NoEventsFound"]</h3>
                <p class="text-white-50 mb-4 mx-auto" style="max-width: 600px;">
                    @Localizer["Events_NoEventsMessage"]
                </p>
                <div id="customer-events-empty-buttons" class="d-flex gap-3 justify-content-center">
                    <button id="customer-events-empty-clear-btn" class="btn premium-btn-outline" @onclick="ClearFilters">
                        <span>🔄</span>
                        <span>@Localizer["Events_ClearAllFilters"]</span>
                    </button>
                    <a id="customer-events-empty-home-link" href="/" class="btn premium-btn-primary">
                        <span>🏠</span>
                        <span>@Localizer["Events_BackToHome"]</span>
                    </a>
                </div>
            </div>
        }
        else
        {
            <!-- Events Grid -->
            <div id="customer-events-grid" class="row g-4">
                @foreach (var evt in events)
                {
                    var capacityPercent = evt.TotalSeats > 0 ? (int)((decimal)evt.SoldTickets / evt.TotalSeats * 100) : 0;
                    var isSellingFast = evt.AvailableSeats <= 50 && evt.AvailableSeats > 0;
                    var isSoldOut = evt.AvailableSeats <= 0;
                    var isPremiumEvent = evt.BaseTicketPrice > 100;

                    <div id="customer-events-col-@evt.Id" class="col-12 col-md-6 col-lg-4">
                        <div id="customer-events-card-@evt.Id" class="premium-event-card h-100">
                            <!-- Event Header with Premium Badge -->
                            <div id="customer-events-card-header-@evt.Id" class="premium-event-header position-relative">
                                <div id="customer-events-card-image-@evt.Id" class="premium-event-image">
                                    <div id="customer-events-card-image-content-@evt.Id" class="text-center text-white">
                                        <div class="fs-1 mb-2">🏟️</div>
                                        <div class="badge bg-dark bg-opacity-50">@evt.VenueInfo</div>
                                    </div>
                                </div>

                                <!-- Premium Event Badge -->
                                @if (isPremiumEvent)
                                {
                                    <div id="customer-events-card-premium-badge-@evt.Id" class="position-absolute top-0 start-0 p-3">
                                        <span class="badge bg-warning text-dark">
                                            <span>⭐</span>
                                            <span>Premium</span>
                                        </span>
                                    </div>
                                }

                                <!-- Status Badges -->
                                <div id="customer-events-card-status-badges-@evt.Id" class="position-absolute top-0 end-0 p-3">
                                    <div id="customer-events-card-badge-group-@evt.Id" class="d-flex flex-column gap-2">
                                        <span class="badge bg-success">@evt.EventType</span>
                                        @if (isSellingFast)
                                        {
                                            <span class="badge bg-danger">
                                                <span>⚡</span>
                                                <span>@Localizer["Events_SellingFast"]</span>
                                            </span>
                                        }
                                        else if (isSoldOut)
                                        {
                                            <span class="badge bg-secondary">
                                                <span>❌</span>
                                                <span>@Localizer["Events_SoldOut"]</span>
                                            </span>
                                        }
                                    </div>
                                </div>

                                <!-- Date Badge -->
                                <div id="customer-events-card-date-badge-@evt.Id" class="position-absolute bottom-0 end-0 p-3">
                                    <div id="customer-events-card-date-@evt.Id" class="premium-date-badge">
                                        <div id="customer-events-card-date-content-@evt.Id" class="text-center">
                                            <div class="text-uppercase small text-muted">@evt.EventDate.ToString("MMM")</div>
                                            <div class="display-6 fw-bold text-dark">@evt.EventDate.ToString("dd")</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Event Details -->
                            <div id="customer-events-card-body-@evt.Id" class="premium-card-body">
                                <div id="customer-events-card-title-@evt.Id" class="d-flex align-items-start justify-content-between mb-3">
                                    <div id="customer-events-card-title-text-@evt.Id" class="flex-grow-1">
                                        <h3 class="h5 fw-bold text-white mb-2">@evt.EventName</h3>
                                        <p class="text-white-50 small mb-0">@evt.EventDate.ToString("dddd, MMMM dd, yyyy") at @evt.EventDate.ToString("h:mm tt")</p>
                                    </div>
                                    @if (isPremiumEvent)
                                    {
                                        <div id="customer-events-card-star-@evt.Id" class="ms-3">
                                            <div class="premium-star-badge">⭐</div>
                                        </div>
                                    }
                                </div>

                                <!-- Stats Grid -->
                                <div id="customer-events-card-stats-@evt.Id" class="row g-2 mb-3">
                                    <div id="customer-events-card-stat-price-@evt.Id" class="col-4">
                                        <div id="customer-events-card-stat-price-box-@evt.Id" class="premium-stat-box">
                                            <div class="h5 fw-bold mb-0 @(isPremiumEvent ? "text-warning" : "text-success")">$@evt.BaseTicketPrice.ToString("F0")</div>
                                            <div class="small text-white-50">@Localizer["Events_From"]</div>
                                        </div>
                                    </div>
                                    <div id="customer-events-card-stat-avail-@evt.Id" class="col-4">
                                        <div id="customer-events-card-stat-avail-box-@evt.Id" class="premium-stat-box">
                                            <div class="h5 fw-bold mb-0 @(evt.AvailableSeats > 100 ? "text-success" : evt.AvailableSeats > 50 ? "text-warning" : "text-danger")">@evt.AvailableSeats</div>
                                            <div class="small text-white-50">@Localizer["Events_Available"]</div>
                                        </div>
                                    </div>
                                    <div id="customer-events-card-stat-sold-@evt.Id" class="col-4">
                                        <div id="customer-events-card-stat-sold-box-@evt.Id" class="premium-stat-box">
                                            <div class="h5 fw-bold mb-0 text-white">@capacityPercent%</div>
                                            <div class="small text-white-50">@Localizer["Events_Sold"]</div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Progress Bar -->
                                <div class="progress mb-3" style="height: 8px;">
                                    <div class="progress-bar bg-gradient bg-success" role="progressbar" style="width: @capacityPercent%" aria-valuenow="@capacityPercent" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>

                                <!-- Action Button -->
                                <button
                                    id="customer-events-action-btn-@evt.Id"
                                    class="btn @(isSoldOut ? "premium-btn-outline" : "premium-btn-primary") w-100"
                                    @onclick="() => ViewEventDetails(evt.Id)"
                                    disabled="@isSoldOut">
                                    @if (isSoldOut)
                                    {
                                        <span>❌ @Localizer["Events_SoldOut"]</span>
                                    }
                                    else if (isSellingFast)
                                    {
                                        <span>⚡ @string.Format(Localizer["Events_OnlyLeftActFast"].Value, evt.AvailableSeats)</span>
                                    }
                                    else
                                    {
                                        <span>🎫 @(isPremiumEvent ? Localizer["Events_GetPremiumTickets"] : Localizer["Events_GetTickets"])</span>
                                    }
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
</CustomerAuthRoute>

@code {
    private List<CustomerEventDto>? events;
    private bool isLoading = false;

    // Filter properties
    private string filterEventType = "";
    private DateTime? filterDateFrom;
    private DateTime? filterDateTo;
    private decimal? filterMinPrice;
    private decimal? filterMaxPrice;

    protected override async Task OnInitializedAsync()
    {
        await LoadEvents();
    }

    private async Task LoadEvents()
    {
        isLoading = true;
        try
        {
            var filter = new CustomerEventFilterDto
            {
                EventType = string.IsNullOrEmpty(filterEventType) ? null : filterEventType,
                DateFrom = filterDateFrom,
                DateTo = filterDateTo,
                MinPrice = filterMinPrice,
                MaxPrice = filterMaxPrice
            };

            events = await ApiService.GetAvailableEventsAsync(filter);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading events: {ex.Message}");
            // Could add user-friendly error handling here
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApplyFilters()
    {
        await LoadEvents();
    }

    private async Task ClearFilters()
    {
        filterEventType = "";
        filterDateFrom = null;
        filterDateTo = null;
        filterMinPrice = null;
        filterMaxPrice = null;
        await LoadEvents();
    }

    private void ViewEventDetails(int eventId)
    {
        Navigation.NavigateTo($"/events/{eventId}");
    }
}
