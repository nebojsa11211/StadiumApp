@page "/"
@layout MobileShell
@using StadiumDrinkOrdering.Customer.Services
@inject ICustomerAuthStateService AuthState
@inject NavigationManager Nav

<PageTitle>HALFTIME</PageTitle>

<div id="customer-index-splash" class="splash">
    <div id="customer-index-wordmark" class="wordmark"><span class="dot"></span>HALF<b>TIME</b></div>
    <span class="spinner"></span>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Season members land on their home; everyone else starts at the scan-first welcome.
        await AuthState.InitializeAsync();
        Nav.NavigateTo(AuthState.IsAuthenticated ? "/home" : "/welcome", forceLoad: false);
    }
}
