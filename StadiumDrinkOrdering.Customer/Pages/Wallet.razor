@page "/wallet"
@layout MobileShell
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Customer.Components
@inject IApiService ApiService

<PageTitle>Novčanik — HALFTIME</PageTitle>

<ScreenHeader Title="Novčanik" Subtitle="Stanje & transakcije" ShowBack="false" />

<AuthenticationGuard>
    <div id="customer-wallet-container" class="wal-body no-scrollbar">

        @if (summary == null)
        {
            <div id="customer-wallet-loading" class="wal-state"><span class="spinner"></span> Učitavam novčanik…</div>
        }
        else if (!summary.Exists && !summary.IsEligible)
        {
            <div id="customer-wallet-not-eligible" class="wal-state wal-empty">
                <div class="wal-emoji">🎟️</div>
                <h2>Novčanik nije dostupan</h2>
                <p id="customer-wallet-not-eligible-message">Novčanik je dostupan samo vlasnicima sezonske ulaznice.</p>
            </div>
        }
        else
        {
            <div id="customer-wallet-balance-card" class="wal-balance">
                <span class="wal-balance-label">Stanje</span>
                <span id="customer-wallet-balance-amount" class="wal-balance-amount tnum">@FormatMoney(summary.Balance)</span>
                @if (summary.Status == WalletStatus.Frozen)
                {
                    <span id="customer-wallet-frozen-badge" class="wal-frozen">❄ Zamrznut</span>
                }
            </div>

            <div id="customer-wallet-deposit-card" class="wal-card">
                <span class="label">Dodaj sredstva</span>
                <div class="field">
                    <label for="customer-wallet-deposit-amount">Iznos (@summary.Currency)</label>
                    <input id="customer-wallet-deposit-amount" type="number" min="0.01" step="0.01" @bind="depositAmount" />
                </div>
                <div class="field">
                    <label for="customer-wallet-deposit-method">Način plaćanja</label>
                    <select id="customer-wallet-deposit-method" class="wal-select" @bind="depositMethod">
                        <option value="CreditCard">Kreditna kartica</option>
                        <option value="PayPal">PayPal</option>
                    </select>
                </div>
                <button id="customer-wallet-deposit-btn" class="btn btn-primary" @onclick="Deposit" disabled="@(isDepositing || depositAmount <= 0 || summary.Status == WalletStatus.Frozen)">
                    @if (isDepositing)
                    {
                        <span class="spinner"></span> <span>Obrađujem…</span>
                    }
                    else
                    {
                        <span>Uplati</span>
                    }
                </button>
            </div>

            <div id="customer-wallet-transactions-card" class="wal-card">
                <span class="label">Transakcije</span>
                @if (transactions == null || transactions.Transactions.Count == 0)
                {
                    <p id="customer-wallet-transactions-empty" class="wal-tx-empty">Još nema transakcija.</p>
                }
                else
                {
                    <div class="wal-tx-list">
                        @foreach (var t in transactions.Transactions)
                        {
                            <div id="customer-wallet-txn-@t.Id" class="wal-tx">
                                <div class="wal-tx-l">
                                    <span id="customer-wallet-txn-type-@t.Id" class="wal-tx-type">@t.Type</span>
                                    <span id="customer-wallet-txn-date-@t.Id" class="wal-tx-date">@t.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy · HH:mm")</span>
                                </div>
                                <span id="customer-wallet-txn-amount-@t.Id" class="wal-tx-amount tnum @(t.Amount < 0 ? "neg" : "pos")">
                                    @(t.Amount < 0 ? "−" : "+")@FormatMoney(t.Amount)
                                </span>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(alertMessage))
    {
        <div id="customer-wallet-alert-container" class="wal-toast @(alertType == "success" ? "ok" : alertType == "info" ? "info" : "bad")">
            <span>@alertMessage</span>
            <button id="customer-wallet-alert-close" class="wal-toast-x" @onclick="() => alertMessage = string.Empty" aria-label="Zatvori">✕</button>
        </div>
    }
</AuthenticationGuard>

@code {
    private WalletSummaryDto? summary;
    private WalletTransactionListDto? transactions;
    private decimal depositAmount = 20m;
    private string depositMethod = "CreditCard";
    private bool isDepositing;
    private string alertMessage = string.Empty;
    private string alertType = string.Empty;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        summary = await ApiService.GetWalletSummaryAsync();
        if (summary is { Exists: true })
            transactions = await ApiService.GetWalletTransactionsAsync(1, 25);
    }

    private async Task Deposit()
    {
        if (isDepositing || depositAmount <= 0) return;
        isDepositing = true;
        try
        {
            var dto = new InitiateDepositDto
            {
                Amount = depositAmount,
                Method = depositMethod,
                IdempotencyKey = Guid.NewGuid().ToString("N")
            };
            var result = await ApiService.DepositToWalletAsync(dto);
            if (result is { RequiresAction: true })
            {
                ShowAlert("Potrebna je potvrda plaćanja.", "info");
            }
            else if (result is { Success: true })
            {
                ShowAlert("Uplata je uspješna.", "success");
                await Load();
            }
            else
            {
                ShowAlert("Uplata nije uspjela.", "danger");
            }
        }
        catch (Exception ex)
        {
            ShowAlert(ex.Message, "danger");
        }
        finally
        {
            isDepositing = false;
        }
    }

    private string FormatMoney(decimal amount)
    {
        var currency = summary?.Currency ?? "EUR";
        var symbol = currency == "EUR" ? "€" : currency + " ";
        return $"{symbol}{Math.Abs(amount).ToString("N2")}";
    }

    private void ShowAlert(string message, string type)
    {
        alertMessage = message;
        alertType = type;
        StateHasChanged();
        _ = Task.Delay(5000).ContinueWith(_ =>
        {
            alertMessage = string.Empty;
            InvokeAsync(StateHasChanged);
        });
    }
}
