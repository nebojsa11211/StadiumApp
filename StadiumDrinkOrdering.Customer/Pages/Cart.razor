@page "/cart"
@layout MobileShell
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Shared.DTOs
@inject OrderSessionState State
@inject IApiService Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Košarica — HALFTIME</PageTitle>

<div id="customer-cart-atmos" class="crowd-atmos" aria-hidden="true"></div>

<ScreenHeader Title="Tvoja košarica" Subtitle="@SubtitleText" BackHref="/order" />

<div id="customer-cart-body" class="body">
    @if (State.Count == 0)
    {
        <div id="customer-cart-empty" class="empty">
            <div id="customer-cart-emoji" class="e-emoji">🛒</div>
            <p>Košarica je prazna.</p>
            <button id="customer-cart-back-btn" class="btn btn-ghost btn-sm" @onclick="@(() => Nav.NavigateTo("/order"))">Natrag na ponudu</button>
        </div>
    }
    else
    {
        <div id="customer-cart-deliver-banner" class="deliver-banner">
            <span class="ic">📍</span>
            <div id="customer-cart-delivery-info">
                <div id="customer-cart-delivery-title" class="t">Dostava na tvoje mjesto</div>
                <div id="customer-cart-delivery-seat" class="s tnum">@State.SeatText</div>
            </div>
        </div>

        <div id="customer-cart-pad" class="pad">
            <div id="customer-cart-items" class="items">
                @foreach (var item in State.Items)
                {
                    <div id="customer-cart-item-@item.DrinkId" class="cart-item">
                        <div id="customer-cart-item-icon-@item.DrinkId" class="th">🥤</div>
                        <div id="customer-cart-item-info-@item.DrinkId" class="ci">
                            <div id="customer-cart-item-name-@item.DrinkId" class="n">@item.DrinkName</div>
                            <div id="customer-cart-item-price-@item.DrinkId" class="p tnum">€@item.UnitPrice.ToString("F2") / kom</div>
                        </div>
                        <div id="customer-cart-item-step-@item.DrinkId" class="mini-step">
                            <button id="customer-cart-item-qty-dec-@item.DrinkId" @onclick="() => Change(item.DrinkId, item.Quantity - 1)" aria-label="Manje">−</button>
                            <span id="customer-cart-item-qty-@item.DrinkId" class="q tnum">@item.Quantity</span>
                            <button id="customer-cart-item-qty-inc-@item.DrinkId" @onclick="() => Change(item.DrinkId, item.Quantity + 1)" aria-label="Više">+</button>
                        </div>
                    </div>
                }
            </div>

            <div id="customer-cart-payment-label" class="label" style="margin:22px 0 12px">Plaćanje</div>
            <div id="customer-cart-pay-wallet" class="pay-opt @(_pay == "wallet" ? "sel" : "")" @onclick="@(() => _pay = "wallet")">
                <div id="customer-cart-wallet-icon" class="pic">@(_wallet is { IsTicketWallet: true } ? "🎟️" : "👛")</div>
                <div id="customer-cart-wallet-info" class="pb">
                    <div id="customer-cart-wallet-title" class="t">@WalletTitle</div>
                    <div id="customer-cart-wallet-balance" class="s tnum">@WalletText</div>
                </div>
                <div class="radio"></div>
            </div>
            <div id="customer-cart-pay-card" class="pay-opt @(_pay == "card" ? "sel" : "")" @onclick="@(() => _pay = "card")">
                <div id="customer-cart-card-icon" class="pic">💳</div>
                <div id="customer-cart-card-info" class="pb">
                    <div id="customer-cart-card-title" class="t">Kartica</div>
                    <div id="customer-cart-card-subtitle" class="s">Visa · Mastercard</div>
                </div>
                <div class="radio"></div>
            </div>
            <div id="customer-cart-pay-cash" class="pay-opt @(_pay == "cash" ? "sel" : "")" @onclick="@(() => _pay = "cash")">
                <div id="customer-cart-cash-icon" class="pic">💵</div>
                <div id="customer-cart-cash-info" class="pb">
                    <div id="customer-cart-cash-title" class="t">Gotovina</div>
                    <div id="customer-cart-cash-subtitle" class="s">Plati pri dostavi</div>
                </div>
                <div class="radio"></div>
            </div>

            <div id="customer-cart-summary" class="summary">
                <div id="customer-cart-summary-subtotal" class="sr"><span>Međuzbroj</span><b class="tnum">€@State.Subtotal.ToString("F2")</b></div>
                <div id="customer-cart-summary-fee" class="sr"><span>Naknada za uslugu</span><b class="tnum">€@ServiceFee.ToString("F2")</b></div>
                <div id="customer-cart-summary-total" class="sr total"><span>Ukupno</span><b class="tnum">€@Total.ToString("F2")</b></div>
            </div>

            @if (State.HasSession && !State.CanOrderDrinks)
            {
                <div id="customer-cart-error-closed" class="err">Naručivanje je zatvoreno jer utakmica trenutno ne traje.</div>
            }
            @if (!string.IsNullOrEmpty(_error))
            {
                <div id="customer-cart-error-message" class="err">@_error</div>
            }
        </div>
    }
</div>

@if (State.Count > 0)
{
    <div id="customer-cart-checkout-footer" class="checkout-foot">
        <button id="customer-cart-checkout-btn" class="btn btn-primary" @onclick="PlaceOrder" disabled="@(_placing || !State.CanOrderDrinks)">
            @if (_placing)
            {
                <span class="spinner"></span> <span>Šaljem…</span>
            }
            else if (!State.CanOrderDrinks)
            {
                <span>Naručivanje nije dostupno</span>
            }
            else
            {
                <span>Naruči · €@Total.ToString("F2")</span>
            }
        </button>
    </div>
}

@code {
    private const decimal ServiceFee = 0.50m;
    private string _pay = "wallet";
    private bool _placing;
    private string? _error;
    private WalletSummaryDto? _wallet;

    private decimal Total => State.Subtotal + (State.Count > 0 ? ServiceFee : 0m);
    private string SubtitleText => State.Count > 0 ? $"{State.Count} {(State.Count == 1 ? "stavka" : "stavke")}" : "Prazno";
    private string WalletText => _wallet is { Exists: true } ? $"Stanje €{_wallet.Balance:F2}" : "Novčanik";
    // Anonymous bearer balance loaded on the scanned ticket vs a registered fan's personal wallet.
    private string WalletTitle => _wallet is { IsTicketWallet: true } ? "Saldo na ulaznici" : "HALFTIME novčanik";

    protected override void OnInitialized() => State.OnChange += StateChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!State.HasSession)
        {
            var token = await JS.InvokeAsync<string?>("sessionStorage.getItem", "htSessionToken");
            if (!string.IsNullOrEmpty(token))
                await State.InitFromTokenAsync(token);
        }

        // Wallet balance is best-effort; failure just falls back to a generic label. Resolved from the ticket
        // session (this walk-up flow has no JWT login) — the API maps the scanned ticket to its owner's wallet.
        if (State.HasSession)
            _wallet = await Api.GetSessionWalletSummaryAsync(State.SessionToken!);

        // Preselect wallet only when there's actually a wallet to charge; otherwise default to card.
        _pay = _wallet is { Exists: true } ? "wallet" : "card";
        StateHasChanged();
    }

    private void Change(int drinkId, int qty) => State.SetQty(drinkId, qty);

    private async Task PlaceOrder()
    {
        if (_placing) return;
        if (!State.CanOrderDrinks)
        {
            _error = "Naručivanje je zatvoreno jer utakmica trenutno ne traje.";
            return;
        }
        _placing = true;
        _error = null;

        // Wallet pays from the ticket owner's HALFTIME wallet (charged server-side); "card" and "cash" move
        // no money at checkout — the order is created unpaid and settled at the bar / on delivery — but the
        // chosen method is recorded so staff know cash vs card. The ticket session is intentionally kept so
        // the fan can track and order again.
        var method = _pay switch
        {
            "cash" => PaymentMethod.Cash,
            "card" => PaymentMethod.CreditCard,
            _ => (PaymentMethod?)null
        };
        var result = await State.CheckoutAsync(payWithWallet: _pay == "wallet", paymentMethod: method);

        if (result is { Success: true })
        {
            // Remember the in-flight order so the fan can jump back to /track after leaving to order more.
            // sessionStorage survives a hard reload; OrderSessionState already mirrors it in-circuit.
            try { await JS.InvokeVoidAsync("sessionStorage.setItem", "htActiveOrderId", result.OrderId); }
            catch { /* no JS — the in-circuit mirror still carries it */ }
            Nav.NavigateTo($"/track/{result.OrderId}");
        }
        else if (result is { InsufficientFunds: true })
        {
            _error = _wallet is { IsTicketWallet: true }
                ? "Nedovoljno sredstava na ulaznici. Nadoplati na šanku ili plati karticom."
                : "Nedovoljno sredstava na novčaniku. Nadoplati novčanik ili plati karticom.";
            _placing = false;
        }
        else
        {
            _error = result?.Error ?? "Narudžbu nije bilo moguće poslati. Pokušaj ponovno.";
            _placing = false;
        }
    }

    private void StateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => State.OnChange -= StateChanged;
}
