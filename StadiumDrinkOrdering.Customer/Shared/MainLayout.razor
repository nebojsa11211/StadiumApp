@using StadiumDrinkOrdering.Customer.Components.Shared
@using StadiumDrinkOrdering.Customer.Services
@inject ICustomerAuthStateService AuthStateService
@inject NavigationManager NavigationManager
@inherits LayoutComponentBase
@implements IDisposable

<PageTitle>Stadium Drinks - Premium Experience</PageTitle>

<!-- Skip Navigation Component for Keyboard Accessibility -->
<SkipNavigation ShowSearchLink="false" />

<!-- Premium Dark Navigation -->
<nav class="premium-navbar" role="navigation" aria-label="Main navigation" id="navigation">
    <div class="container">
        <div class="premium-navbar-content">
            <!-- Brand -->
            <a href="/" class="premium-navbar-brand" aria-label="Stadium Drinks - Home">
                <div class="premium-brand-icon">⚽</div>
                <div class="premium-brand-text">
                    <div class="premium-brand-title">Stadium Drinks</div>
                    <div class="premium-brand-subtitle">Premium Service</div>
                </div>
            </a>

            <!-- Desktop Navigation -->
            <div class="premium-navbar-menu">
                <ul class="premium-nav-list" role="menubar">
                    <li role="none"><a href="/" class="premium-nav-link" role="menuitem" aria-current="@(NavigationManager.Uri.EndsWith("/") ? "page" : null)">Home</a></li>
                    <li role="none"><a href="/events" class="premium-nav-link" role="menuitem" aria-current="@(NavigationManager.Uri.Contains("/events") ? "page" : null)">Events</a></li>
                    <li role="none"><a href="/menu" class="premium-nav-link" role="menuitem" aria-current="@(NavigationManager.Uri.Contains("/menu") ? "page" : null)">Menu</a></li>
                    @if (AuthStateService.IsAuthenticated)
                    {
                        <li role="none"><a href="/orders" class="premium-nav-link" role="menuitem" aria-current="@(NavigationManager.Uri.Contains("/orders") ? "page" : null)">My Orders</a></li>
                    }
                </ul>
                
                <!-- Language Switcher -->
                <LanguageSwitcher />

                <!-- Theme Switcher -->
                <ThemeSwitcher />

                <!-- User Menu -->
                @if (AuthStateService.IsAuthenticated)
                {
                    <div class="relative">
                        <button @onclick="ToggleUserMenu"
                                class="btn btn-secondary btn-sm"
                                id="customer-layout-user-dropdown"
                                aria-label="User menu"
                                aria-expanded="@isUserMenuOpen.ToString().ToLower()"
                                aria-haspopup="true">
                            <div class="flex items-center gap-2">
                                <div class="w-8 h-8 bg-gradient-to-br from-premium-gold-400 to-premium-gold-500 rounded-full flex items-center justify-center" aria-hidden="true">
                                    <span class="text-sm font-bold text-gray-900">
                                        @(GetInitials(AuthStateService.CurrentUser?.Username ?? "U"))
                                    </span>
                                </div>
                                <span>@(AuthStateService.CurrentUser?.Username ?? "User")</span>
                                <svg class="w-4 h-4 transition-transform @(isUserMenuOpen ? "rotate-180" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                                </svg>
                            </div>
                        </button>
                        
                        @if (isUserMenuOpen)
                        {
                            <div class="absolute right-0 mt-3 w-72 bg-white rounded-2xl shadow-2xl border border-gray-200 py-3 z-50 animate-scale-in"
                                 role="menu"
                                 aria-labelledby="customer-layout-user-dropdown">
                                <div class="px-4 py-4 border-b border-gray-100">
                                    <div class="flex items-center gap-3">
                                        <div class="w-12 h-12 bg-gradient-to-br from-premium-gold-400 to-premium-gold-500 rounded-full flex items-center justify-center" aria-hidden="true">
                                            <span class="text-lg font-bold text-gray-900">
                                                @(GetInitials(AuthStateService.CurrentUser?.Username ?? "U"))
                                            </span>
                                        </div>
                                        <div>
                                            <div class="font-semibold text-gray-900">@AuthStateService.CurrentUser?.Username</div>
                                            <div class="text-sm text-gray-500">@AuthStateService.UserEmail</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="py-2">
                                    <a href="/profile"
                                       id="customer-layout-profile-link"
                                       class="flex items-center gap-3 px-4 py-3 text-gray-700 hover:bg-gray-50 transition-colors"
                                       role="menuitem">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                        </svg>
                                        <span>My Profile</span>
                                    </a>
                                    <a href="/orders"
                                       id="customer-layout-orders-link"
                                       class="flex items-center gap-3 px-4 py-3 text-gray-700 hover:bg-gray-50 transition-colors"
                                       role="menuitem">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                                        </svg>
                                        <span>My Orders</span>
                                    </a>
                                </div>
                                <hr class="my-2 border-gray-100" role="separator">
                                <div class="py-2">
                                    <button @onclick="HandleLogout"
                                            id="customer-layout-logout-btn"
                                            class="flex items-center gap-3 w-full px-4 py-3 text-red-600 hover:bg-red-50 transition-colors"
                                            role="menuitem"
                                            aria-label="Sign out of your account">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                                        </svg>
                                        <span>Sign Out</span>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="flex items-center gap-3">
                        <a href="/login" class="btn btn-outline btn-sm" id="customer-layout-sign-in-btn" aria-label="Sign in to your account">Sign In</a>
                        <a href="/register" class="btn btn-primary btn-sm" id="customer-layout-sign-up-btn" aria-label="Create a new account">Sign Up</a>
                    </div>
                }
            </div>

            <!-- Mobile Menu Button -->
            <button @onclick="ToggleMobileMenu"
                    class="lg:hidden btn btn-ghost p-3"
                    id="customer-layout-menu-toggle-btn"
                    aria-label="Toggle mobile navigation menu"
                    aria-expanded="@isMobileMenuOpen.ToString().ToLower()"
                    aria-controls="mobile-menu">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </div>
</nav>

<!-- Mobile Navigation -->
@if (isMobileMenuOpen)
{
    <div class="lg:hidden bg-white border-b border-gray-200 animate-slide-down"
         id="mobile-menu"
         role="navigation"
         aria-label="Mobile navigation">
        <div class="container py-6">
            <ul class="space-y-2" role="menu">
                <li role="none"><a href="/" class="flex items-center gap-3 px-4 py-3 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors" role="menuitem"><span aria-hidden="true">🏠</span> Home</a></li>
                <li role="none"><a href="/events" class="flex items-center gap-3 px-4 py-3 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors" role="menuitem"><span aria-hidden="true">🎟️</span> Events</a></li>
                <li role="none"><a href="/menu" class="flex items-center gap-3 px-4 py-3 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors" role="menuitem"><span aria-hidden="true">🍺</span> Menu</a></li>
                @if (AuthStateService.IsAuthenticated)
                {
                    <li role="none"><a href="/orders" class="flex items-center gap-3 px-4 py-3 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors" role="menuitem"><span aria-hidden="true">📋</span> My Orders</a></li>
                    <li role="none"><hr class="my-4 border-gray-100" role="separator"></li>
                    <li role="none"><a href="/profile" class="flex items-center gap-3 px-4 py-3 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors" role="menuitem"><span aria-hidden="true">👤</span> Profile</a></li>
                    <li role="none"><button @onclick="HandleLogout" class="flex items-center gap-3 w-full px-4 py-3 text-red-600 hover:bg-red-50 rounded-lg transition-colors" role="menuitem" aria-label="Sign out of your account"><span aria-hidden="true">🚪</span> Sign Out</button></li>
                }
                else
                {
                    <li role="none"><hr class="my-4 border-gray-100" role="separator"></li>
                    <li role="none"><a href="/login" class="flex items-center gap-3 px-4 py-3 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors" role="menuitem">Sign In</a></li>
                    <li role="none"><a href="/register" class="flex items-center gap-3 px-4 py-3 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors" role="menuitem">Sign Up</a></li>
                }
            </ul>
        </div>
    </div>
}

<!-- SignalR Connection -->
<SignalRConnection OnOrderStatusChanged="HandleOrderStatusChanged" OnNotificationReceived="HandleNotification" />

<!-- PWA Install Prompt -->
<InstallPrompt />

<!-- Main Content -->
<main class="premium-main-content" id="main-content" role="main" tabindex="-1">
    <div class="container-fluid premium-content-wrapper">
        @Body
    </div>
</main>

