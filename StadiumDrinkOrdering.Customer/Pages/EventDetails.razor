@page "/events/{EventId:int}"
@layout MobileShell
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Customer.Components.Stadium
@inject IApiService ApiService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>@EventTitle — HALFTIME</PageTitle>

<ScreenHeader Title="@EventTitle" Subtitle="@(eventDetails?.EventType)" OnBack="GoBack" />

@if (isLoading)
{
    <div id="customer-event-details-loading" class="ev-state"><span class="spinner"></span> Učitavam utakmicu…</div>
}
else if (eventDetails == null)
{
    <div id="customer-event-details-notfound" class="ev-state ev-notfound">
        <div id="customer-event-details-emoji" class="ev-emoji">🚫</div>
        <h2>Utakmica nije pronađena</h2>
        <p>Ova utakmica više nije dostupna.</p>
        <button id="customer-event-details-notfound-home-btn" class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/welcome"))">Početna</button>
    </div>
}
else
{
    <div id="customer-event-details-body" class="ev-body no-scrollbar">
        <div id="customer-event-details-hero" class="ev-hero">
            <div id="customer-event-details-datechip" class="ev-datechip">
                <span class="d">@eventDetails.EventDate.ToLocalTime().Day</span>
                <span class="m">@MonthShort(eventDetails.EventDate.ToLocalTime())</span>
            </div>
            <div id="customer-event-details-main" class="ev-hero-main">
                <h1 class="ev-name">@eventDetails.EventName</h1>
                <div class="ev-when">@CroatianDay(eventDetails.EventDate.ToLocalTime()) · @eventDetails.EventDate.ToLocalTime().ToString("HH:mm")</div>
                <div id="customer-event-details-meta" class="ev-meta">
                    <span class="ev-tag">🏟️ @eventDetails.VenueInfo</span>
                    <span class="ev-tag @AvailClass(eventDetails.AvailableSeats)">🪑 @eventDetails.AvailableSeats slobodno</span>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(eventDetails.Description))
        {
            <p class="ev-desc">@eventDetails.Description</p>
        }

        @if (eventDetails.PricingTiers.Any())
        {
            <div id="customer-event-details-tiers" class="ev-tiers">
                @foreach (var tier in eventDetails.PricingTiers)
                {
                    var _tierIndex = System.Array.IndexOf(eventDetails.PricingTiers.ToArray(), tier);
                    <div id="customer-event-details-tier-@_tierIndex" class="ev-tier">
                        <span class="ev-tier-name">@tier.Name</span>
                        <span class="ev-tier-price tnum">€@tier.BasePrice.ToString("F0")</span>
                    </div>
                }
            </div>
        }

        @if (!salesEnabled)
        {
            <div id="customer-event-details-sales-disabled" class="ev-empty">
                🎟️ Prodaja ulaznica putem aplikacije trenutno nije dostupna.
            </div>
        }
        else
        {
            <div id="customer-event-details-section-head" class="ev-section-head">
                <span class="label">Odaberi tribinu</span>
                <span class="ev-hint">Dodirni tribinu na karti ili u popisu</span>
            </div>

            @if (eventDetails.SectionAvailability.Any())
            {
                <div id="customer-event-details-stadium" class="ev-stadium">
                    <StadiumSelectorCanvas @ref="stadiumCanvas"
                                           Sections="eventDetails.SectionAvailability"
                                           OnSectorSelected="OnStadiumSectorSelected" />
                </div>

                <div id="customer-event-details-sections" class="ev-sections">
                    @foreach (var sec in eventDetails.SectionAvailability.Values.OrderBy(s => s.SectionName))
                    {
                        var soldOut = sec.AvailableSeats == 0;
                        <button id="customer-event-details-section-btn-@sec.SectionId" class="ev-sec @(soldOut ? "sold" : "")" disabled="@soldOut"
                                @onclick="@(() => ViewSectionSeats(sec.SectionId))">
                            <div id="customer-event-details-section-left-@sec.SectionId" class="ev-sec-l">
                                <span class="ev-sec-name">@sec.SectionName</span>
                                <span class="ev-sec-avail @AvailClass(sec.AvailableSeats)">
                                    @if (soldOut)
                                    {
                                        <span>Rasprodano</span>
                                    }
                                    else
                                    {
                                        <span>@sec.AvailableSeats / @sec.TotalSeats slobodno</span>
                                    }
                                </span>
                            </div>
                            <div id="customer-event-details-section-right-@sec.SectionId" class="ev-sec-r">
                                <span class="ev-sec-price tnum">€@sec.BasePrice.ToString("F0")</span>
                                @if (!soldOut)
                                {
                                    <span class="ev-sec-chev">›</span>
                                }
                            </div>
                        </button>
                    }
                </div>
            }
            else
            {
                <div id="customer-event-details-empty" class="ev-empty">Još nema objavljenih mjesta za ovu utakmicu.</div>
            }
        }
    </div>

    @if (salesEnabled)
    {
        <CartBar Count="cartItems.Count" Total="CartTotal" Label="Tvoja košarica" OnView="() => showCart = true" />
    }
}

@* ---- Seat selection sheet ---- *@
<div id="customer-event-details-scrim-seats" class="scrim @(selectedSection != null ? "show" : "")" @onclick="CloseSeatSheet"></div>
<div id="customer-event-details-sheet-seats" class="sheet @(selectedSection != null ? "show" : "")">
    @if (selectedSection != null)
    {
        <div id="customer-event-details-sheet-grab-seats" class="grab"></div>
        <div id="customer-event-details-sheet-head-seats" class="sheet-head">
            <div id="customer-event-details-sheet-title-seats">
                <div class="sheet-title">@selectedSection.SectionName</div>
                <div class="sheet-sub">@(string.IsNullOrWhiteSpace(selectedSection.TribuneName) ? "Odaberi mjesta" : selectedSection.TribuneName)</div>
            </div>
            <button id="customer-event-details-sheet-close-seats-btn" class="iconbtn" @onclick="CloseSeatSheet" aria-label="Zatvori">✕</button>
        </div>

        @if (isLoadingSeats)
        {
            <div id="customer-event-details-loading-seats" class="ev-state"><span class="spinner"></span> Učitavam mjesta…</div>
        }
        else if (selectedSection.Seats.Any())
        {
            <div id="customer-event-details-seat-legend" class="seat-legend">
                <span id="customer-event-details-seat-legend-free" class="lg"><i class="sw sw-free" aria-hidden="true"></i> Slobodno</span>
                <span id="customer-event-details-seat-legend-selected" class="lg"><i class="sw sw-sel" aria-hidden="true"></i> Odabrano</span>
                <span id="customer-event-details-seat-legend-taken" class="lg"><i class="sw sw-taken" aria-hidden="true"></i> Zauzeto</span>
            </div>

            <div id="customer-event-details-seat-pitch" class="seat-pitch">
                <svg class="pitch-arc" viewBox="0 0 320 40" preserveAspectRatio="none" aria-hidden="true">
                    <path d="M6 34 Q160 4 314 34" fill="none" stroke="var(--brand)" stroke-width="2" stroke-linecap="round" opacity=".55" />
                </svg>
                <span class="pitch-label">⚽ Teren</span>
            </div>

            <div id="customer-event-details-seats-scroll" class="seats-scroll no-scrollbar" role="group" aria-label="Raspored mjesta u tribini">
                @foreach (var rowGroup in selectedSection.Seats.GroupBy(s => s.RowNumber).OrderBy(g => g.Key))
                {
                    <div id="customer-event-details-seat-row-@rowGroup.Key" class="seat-row">
                        <span id="customer-event-details-seat-row-label-@rowGroup.Key" class="rl">Red @rowGroup.Key</span>
                        <div id="customer-event-details-seats-@rowGroup.Key" class="seats">
                            @foreach (var seat in rowGroup.OrderBy(s => s.SeatNumber))
                            {
                                if (seat.IsAvailable)
                                {
                                    var isSel = selectedSeats.Any(s => s.SectorId == seat.SectorId && s.RowNumber == seat.RowNumber && s.SeatNumber == seat.SeatNumber);
                                    <button id="customer-event-details-seat-@seat.SectorId-r@seat.RowNumber-s@seat.SeatNumber" class="seat @(isSel ? "sel" : "")"
                                            @onclick="@(() => ToggleSeatSelection(seat))"
                                            aria-pressed="@isSel"
                                            aria-label='@($"Red {seat.RowNumber}, mjesto {seat.SeatNumber}, €{seat.Price.ToString("F0")} — {(isSel ? "odabrano" : "slobodno")}")'
                                            title="@SeatTitle(seat)">
                                        @seat.SeatNumber
                                    </button>
                                }
                                else
                                {
                                    <button id="customer-event-details-seat-@seat.SectorId-r@seat.RowNumber-s@seat.SeatNumber" class="seat taken" disabled aria-disabled="true"
                                            aria-label='@($"Red {seat.RowNumber}, mjesto {seat.SeatNumber} — zauzeto")'>
                                        @seat.SeatNumber
                                    </button>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div id="customer-event-details-empty-seats" class="ev-empty">Nema dostupnih mjesta u ovoj tribini.</div>
        }

        @if (!string.IsNullOrEmpty(seatSheetError))
        {
            <div id="customer-event-details-seat-error" class="seat-error" role="alert">@seatSheetError</div>
        }

        @if (selectedSeats.Any())
        {
            <div id="customer-event-details-seat-summary" class="seat-summary no-scrollbar" role="group" aria-label="Odabrana mjesta">
                @foreach (var seat in selectedSeats.OrderBy(s => s.RowNumber).ThenBy(s => s.SeatNumber))
                {
                    <button id="customer-event-details-seat-chip-@seat.SectorId-r@seat.RowNumber-s@seat.SeatNumber" class="seat-chip" @onclick="@(() => ToggleSeatSelection(seat))"
                            aria-label='@($"Ukloni: Red {seat.RowNumber}, mjesto {seat.SeatNumber}")'>
                        <span>Red @seat.RowNumber · @seat.SeatNumber</span>
                        <span class="x" aria-hidden="true">✕</span>
                    </button>
                }
            </div>
        }

        <button id="customer-event-details-add-seats-btn" class="btn btn-primary sheet-cta" disabled="@(!selectedSeats.Any())" @onclick="AddSelectedSeatsToCart">
            @if (selectedSeats.Any())
            {
                <span>Dodaj @selectedSeats.Count @Seats(selectedSeats.Count) · €@SelectedTotal</span>
            }
            else
            {
                <span>Odaberi mjesta</span>
            }
        </button>
    }
</div>

@* ---- Cart review sheet ---- *@
<div id="customer-event-details-scrim-cart" class="scrim @(showCart ? "show" : "")" @onclick="@(() => showCart = false)"></div>
<div id="customer-event-details-sheet-cart" class="sheet @(showCart ? "show" : "")">
    @if (showCart)
    {
        <div id="customer-event-details-sheet-grab-cart" class="grab"></div>
        <div id="customer-event-details-sheet-head-cart" class="sheet-head">
            <div id="customer-event-details-sheet-title-cart">
                <div class="sheet-title">Košarica</div>
                <div class="sheet-sub">@cartItems.Count @Seats(cartItems.Count)</div>
            </div>
            <button id="customer-event-details-sheet-close-cart-btn" class="iconbtn" @onclick="@(() => showCart = false)" aria-label="Zatvori">✕</button>
        </div>

        @if (!cartItems.Any())
        {
            <div class="ev-empty">Košarica je prazna. Odaberi mjesta u nekoj tribini.</div>
        }
        else
        {
            <div id="customer-event-details-cart-list" class="cart-list no-scrollbar">
                @foreach (var item in cartItems)
                {
                    var _cartIndex = System.Array.IndexOf(cartItems.ToArray(), item);
                    <div id="customer-event-details-cart-item-@_cartIndex" class="cart-item">
                        <div id="customer-event-details-cart-item-left-@_cartIndex" class="ci-l">
                            <span class="ci-seat">@SeatLabel(item)</span>
                            <span class="ci-sec">@item.SectionName</span>
                        </div>
                        <div id="customer-event-details-cart-item-right-@_cartIndex" class="ci-r">
                            <span class="ci-price tnum">€@item.Price.ToString("F2")</span>
                            <button class="ci-del" @onclick="@(() => RemoveSeatFromCart(item))" aria-label="Ukloni">✕</button>
                        </div>
                    </div>
                }
            </div>

            <div id="customer-event-details-cart-total" class="cart-total">
                <span>Ukupno</span>
                <span class="tnum">€@CartTotal.ToString("F2")</span>
            </div>

            <button id="customer-event-details-cart-checkout-btn" class="btn btn-primary" @onclick="ProceedToCheckout">Nastavi na plaćanje</button>
            <button id="customer-event-details-cart-clear-btn" class="btn btn-ghost cart-clear" @onclick="ClearCart">Isprazni košaricu</button>
        }
    }
</div>

@code {
    [Parameter] public int EventId { get; set; }

    private CustomerEventDetailsDto? eventDetails;
    private SectionAvailabilityDto? selectedSection;
    private List<CustomerSeatDto> selectedSeats = new();
    private List<CartItemDto> cartItems = new();
    private bool isLoading = true;
    private bool isLoadingSeats = false;
    private bool salesEnabled = true;
    private string? seatSheetError;
    private bool showCart = false;
    private string sessionId = "";
    private bool hasInitialized = false;
    private StadiumSelectorCanvas? stadiumCanvas;

    private static readonly string[] MonthsHr =
        { "sij", "velj", "ožu", "tra", "svi", "lip", "srp", "kol", "ruj", "lis", "stu", "pro" };

    private string EventTitle => eventDetails?.EventName ?? "Utakmica";
    private decimal CartTotal => cartItems.Sum(i => i.Price);
    private string SelectedTotal => selectedSeats.Sum(s => s.Price).ToString("F2");

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(sessionId))
            sessionId = Guid.NewGuid().ToString();

        salesEnabled = await ApiService.GetTicketSalesEnabledAsync();
        await LoadEventDetails();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !hasInitialized)
        {
            hasInitialized = true;

            // Reuse the ticketing session across pages so an in-progress cart survives navigation.
            var stored = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "ticketingSessionId");
            if (!string.IsNullOrEmpty(stored))
                sessionId = stored;
            else
                await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "ticketingSessionId", sessionId);

            await LoadCart();
            StateHasChanged();
        }
    }

    private async Task LoadEventDetails()
    {
        try
        {
            eventDetails = await ApiService.GetEventDetailsAsync(EventId);
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading event details: " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadCart()
    {
        try
        {
            var cart = await ApiService.GetCartAsync(sessionId);
            cartItems = cart?.Items ?? new List<CartItemDto>();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading cart: " + ex.Message);
        }
    }

    // Clicking a sector on the stadium map opens the same seat sheet as the list. The clicked
    // overlay id is exactly the section id GetSectionAvailability expects.
    private Task OnStadiumSectorSelected(int overlaySectorId) => ViewSectionSeats(overlaySectorId);

    private async Task ViewSectionSeats(int sectionId)
    {
        if (eventDetails == null) return;

        isLoadingSeats = true;
        selectedSeats.Clear();
        seatSheetError = null;
        selectedSection = new SectionAvailabilityDto(); // open the sheet immediately, then fill

        try
        {
            selectedSection = await ApiService.GetSectionAvailabilityAsync(EventId, sectionId);
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading section seats: " + ex.Message);
        }
        finally
        {
            isLoadingSeats = false;
        }
    }

    private void ToggleSeatSelection(CustomerSeatDto seat)
    {
        var existing = selectedSeats.FirstOrDefault(s =>
            s.SectorId == seat.SectorId && s.RowNumber == seat.RowNumber && s.SeatNumber == seat.SeatNumber);

        if (existing != null)
            selectedSeats.Remove(existing);
        else
            selectedSeats.Add(seat);
    }

    private async Task AddSelectedSeatsToCart()
    {
        if (!selectedSeats.Any() || eventDetails == null) return;

        seatSheetError = null;
        CartAddResult? lastFailure = null;

        // Iterate a snapshot: seats that succeed are removed, seats that fail stay selected
        // so the user can see exactly which ones couldn't be added.
        foreach (var seat in selectedSeats.ToList())
        {
            var result = await ApiService.AddSeatToCartAsync(new AddSeatToCartRequest
            {
                SessionId = sessionId,
                EventId = EventId,
                SectorId = seat.SectorId,
                RowNumber = seat.RowNumber,
                SeatNumber = seat.SeatNumber,
                Price = seat.Price
            });

            if (result.Success)
                selectedSeats.Remove(seat);
            else
                lastFailure = result;
        }

        await LoadCart();

        if (lastFailure != null)
        {
            // Keep the sheet open with the failed seats still selected and show why.
            seatSheetError = lastFailure.Message ?? "Neka mjesta nije moguće dodati u košaricu.";
            return;
        }

        CloseSeatSheet();
    }

    private async Task RemoveSeatFromCart(CartItemDto item)
    {
        var ok = await ApiService.RemoveSeatFromCartAsync(new RemoveSeatFromCartRequest
        {
            SessionId = sessionId,
            EventId = item.EventId,
            SectorId = item.SectorId,
            RowNumber = item.RowNumber,
            SeatNumber = item.SeatNumber
        });
        if (ok)
        {
            await LoadCart();
            if (!cartItems.Any()) showCart = false;
        }
    }

    private async Task ClearCart()
    {
        if (await ApiService.ClearCartAsync(sessionId))
        {
            await LoadCart();
            showCart = false;
        }
    }

    private void CloseSeatSheet()
    {
        selectedSection = null;
        selectedSeats.Clear();
        seatSheetError = null;
    }

    private void ProceedToCheckout() => Navigation.NavigateTo("/checkout?sessionId=" + sessionId);

    private async Task GoBack() => await JSRuntime.InvokeVoidAsync("history.back");

    private static string MonthShort(DateTime date) => MonthsHr[date.Month - 1];

    private static string SeatTitle(CustomerSeatDto seat) =>
        "Red " + seat.RowNumber + ", mjesto " + seat.SeatNumber + " — €" + seat.Price.ToString("F2");

    private static string SeatLabel(CartItemDto item) =>
        string.IsNullOrWhiteSpace(item.SeatCode) ? ("R" + item.RowNumber + " · " + item.SeatNumber) : item.SeatCode;

    private static string AvailClass(int available) =>
        available == 0 ? "is-none" : available <= 20 ? "is-low" : "is-ok";

    // Croatian plural for "mjesto" (seat): 1 uses "mjesto", otherwise "mjesta".
    private static string Seats(int n) => n == 1 ? "mjesto" : "mjesta";

    private static string CroatianDay(DateTime date)
    {
        var days = (date.Date - DateTime.Today).Days;
        if (days == 0) return "Danas";
        if (days == 1) return "Sutra";
        if (days > 1) return "za " + days + " dana";
        return date.ToString("dd.MM.");
    }
}
