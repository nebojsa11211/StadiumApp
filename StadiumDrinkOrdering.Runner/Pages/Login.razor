@page "/login"
@layout EmptyLayout
@inject RunnerApiService Api
@inject RunnerAuthService Auth
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["Login_PageTitle"]</PageTitle>

<div class="login-shell" id="runner-login-shell">
    <main class="login-shell__main" id="runner-login-shell-main">
        <ConsoleLoginCard IdPrefix="runner"
                          Eyebrow="@Localizer["Login_Eyebrow"]"
                          Title="@Localizer["Login_Title"]"
                          Subtitle="@Localizer["Login_DeliveryConsoleAccess"]"
                          EmailLabel="@Localizer["Login_EmailLabel"]"
                          PasswordLabel="@Localizer["Login_PasswordLabel"]"
                          SubmitText="@Localizer["Login_LoginButton"]"
                          LoadingText="@Localizer["Login_LoggingIn"]"
                          ShowPasswordLabel="@Localizer["Login_ShowPassword"]"
                          HidePasswordLabel="@Localizer["Login_HidePassword"]"
                          ErrorMessage="@error"
                          IsLoading="busy"
                          @bind-Email="model.Email"
                          @bind-Password="model.Password"
                          OnSubmit="HandleLogin" />
    </main>
</div>

@code {
    private readonly LoginDto model = new();
    private string? error;
    private bool busy;

    private async Task HandleLogin()
    {
        busy = true;
        error = null;

        var login = await Api.LoginAsync(model);
        if (login is null || string.IsNullOrEmpty(login.Token))
        {
            error = Localizer["Login_ErrorInvalidOrUnreachable"];
            busy = false;
            return;
        }

        var role = login.User?.Role.ToString();
        var allowed = string.Equals(role, "Waiter", StringComparison.OrdinalIgnoreCase)
                   || string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase);
        if (!allowed)
        {
            error = Localizer["Login_ErrorNotRunnerRole"];
            busy = false;
            return;
        }

        await Auth.SetSessionAsync(login);
        Nav.NavigateTo("");
    }
}
