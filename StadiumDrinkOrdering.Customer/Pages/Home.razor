@page "/home"
@layout MobileShell
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Customer.Services
@inject ICustomerAuthStateService AuthState
@inject IApiService Api
@inject OrderSessionState State
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["Home_PageTitle"]</PageTitle>

@if (_loading)
{
    <div id="customer-home-loading" class="center"><span class="spinner big"></span></div>
}
else if (_home is null || !_home.HasPass)
{
    <div id="customer-home-no-pass" class="center pad">
        <div id="customer-home-emoji" style="font-size:52px">🎟️</div>
        <h2>@Localizer["Home_NoPass_Title"]</h2>
        <p class="muted">@Localizer["Home_NoPass_Message"]</p>
        <button id="customer-home-scan-btn" class="btn btn-primary" @onclick="@(() => Nav.NavigateTo("/scan"))">@Localizer["Home_ScanButton"]</button>
        <button id="customer-home-my-tickets-btn" class="btn btn-ghost" @onclick="@(() => Nav.NavigateTo("/my-tickets"))">@Localizer["Home_MyTickets"]</button>
        <button id="customer-layout-profile-link" class="btn btn-ghost" @onclick="@(() => Nav.NavigateTo("/profile"))">@Localizer["Home_ProfileButton"]</button>
        <button id="customer-home-logout-btn" class="btn btn-ghost" @onclick="Logout">@Localizer["Home_LogoutButton"]</button>
    </div>
}
else
{
    <div id="customer-home-greeting" class="home-hi">
        <div id="customer-home-greeting-text">
            <div class="greet">@Localizer["Home_Greeting"]</div>
            <div class="name">@FirstName 👋</div>
        </div>
        <button id="customer-home-avatar-btn" class="avatar" @onclick="@(() => Nav.NavigateTo("/profile"))" title="@Localizer["Home_ProfileTooltip"]">@Initials</button>
    </div>

    <div id="customer-home-pass" class="pass">
        <div id="customer-home-pass-info" class="info">
            <div class="t">@Localizer["Home_SeasonPass"]</div>
            <div class="s">@_home.SeatLabel</div>
            <div class="m tnum">@_home.SeasonName · @_home.PassNumber</div>
        </div>
        <span class="chip-seat"><b>@Localizer["Home_YourSeat"]</b></span>
    </div>

    <a id="customer-home-my-tickets-link" href="/my-tickets" class="home-tickets-link">
        <span>@Localizer["Home_MyTicketsAccountsLink"]</span>
        <span class="chev">›</span>
    </a>

    @if (_home.LiveEvent is not null)
    {
        <div id="customer-home-live-title" class="sec-title"><h3>@Localizer["Home_LiveNow"]</h3></div>
        <div id="customer-home-live-card" class="livecard">
            <div id="customer-home-live-glow" class="glow"></div>
            <div id="customer-home-live-top" class="lc-top">
                <div class="live-badge"><span class="pulse"></span> @Localizer["Home_Live"]</div>
            </div>
            <div class="lc-match">@_home.LiveEvent.EventName</div>
            <div class="lc-meta tnum">@_home.LiveEvent.EventDate.ToLocalTime().ToString("HH:mm")</div>
            @if (!string.IsNullOrEmpty(_orderError))
            {
                <div id="customer-home-live-error" class="err">@_orderError</div>
            }
            <div id="customer-home-live-cta" class="lc-cta">
                @if (!string.IsNullOrEmpty(_home.LiveEvent.SessionQrToken))
                {
                    <button id="customer-home-live-order-btn" class="btn btn-primary" @onclick="() => StartOrdering(_home.LiveEvent.SessionQrToken!)" disabled="@_starting">
                        @if (_starting)
                        {
                            <span class="spinner"></span> <span>@Localizer["Home_OpeningMenu"]</span>
                        }
                        else
                        {
                            <span>@Localizer["Home_OrderButton"]</span>
                        }
                    </button>
                }
                else
                {
                    <div class="soon">@Localizer["Home_OrderingSoon"]</div>
                }
            </div>
        </div>
    }
    else
    {
        <div id="customer-home-next-title" class="sec-title"><h3>@Localizer["Home_UpcomingFixture"]</h3></div>
        <div id="customer-home-no-live" class="nolive">
            <div id="customer-home-no-live-emoji" class="nl-emoji">⏳</div>
            <p>@Localizer["Home_NoLiveEvent"]</p>
        </div>
    }

    @if (_home.Upcoming.Any())
    {
        <div id="customer-home-upcoming-title" class="sec-title"><h3>@Localizer["Home_Schedule"]</h3></div>
        @foreach (var fx in _home.Upcoming)
        {
            var _fixtureIndex = System.Array.IndexOf(_home.Upcoming.ToArray(), fx);
            <div id="customer-home-fixture-@_fixtureIndex" class="fixture-row">
                <div id="customer-home-fixture-date-@_fixtureIndex" class="date">
                    <div id="customer-home-fixture-day-@_fixtureIndex" class="d tnum">@fx.EventDate.ToLocalTime().Day.ToString("D2")</div>
                    <div id="customer-home-fixture-month-@_fixtureIndex" class="mo">@MonthHr(fx.EventDate.ToLocalTime())</div>
                </div>
                <div id="customer-home-fixture-info-@_fixtureIndex" class="fx">
                    <div id="customer-home-fixture-name-@_fixtureIndex" class="op">@fx.EventName</div>
                    <div id="customer-home-fixture-time-@_fixtureIndex" class="meta tnum">@fx.EventDate.ToLocalTime().ToString("HH:mm")</div>
                </div>
                <span class="countdown">@Countdown(fx.EventDate)</span>
            </div>
        }
    }

    <div style="height:24px"></div>
}

@code {
    private bool _loading = true;
    private SeasonHomeDto? _home;
    private bool _starting;
    private string? _orderError;

    private string FirstName => (_home?.HolderName ?? "").Split(' ').FirstOrDefault() ?? "Navijaču";
    private string Initials
    {
        get
        {
            var n = (_home?.HolderName ?? "").Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (n.Length == 0) return "🙂";
            return n.Length == 1 ? n[0][..1].ToUpper() : (n[0][..1] + n[1][..1]).ToUpper();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await AuthState.InitializeAsync();
        if (!AuthState.IsAuthenticated)
        {
            Nav.NavigateTo("/login?returnUrl=/home");
            return;
        }

        _home = await Api.GetSeasonHomeAsync();
        _loading = false;
        StateHasChanged();
    }

    private async Task StartOrdering(string token)
    {
        if (_starting) return;
        _starting = true;
        _orderError = null;

        // Device binding: present the SessionId this device already holds for this ticket (if any) so a
        // re-click resumes the same session instead of being blocked as a second device.
        var deviceKey = $"ht.session.{token}";
        string? deviceToken = null;
        try { deviceToken = await JS.InvokeAsync<string?>("localStorage.getItem", deviceKey); }
        catch { /* localStorage unavailable — proceed as a fresh device */ }

        var (ok, error) = await State.InitFromQrAsync(token, deviceToken);
        if (ok)
        {
            try { await JS.InvokeVoidAsync("localStorage.setItem", deviceKey, State.SessionToken); }
            catch { /* localStorage unavailable — same-device resume just won't be possible */ }
            await JS.InvokeVoidAsync("sessionStorage.setItem", "htSessionToken", State.SessionToken);
            Nav.NavigateTo("/order");
        }
        else
        {
            _orderError = error;
            _starting = false;
        }
    }

    private async Task Logout()
    {
        await AuthState.LogoutAsync();
        Nav.NavigateTo("/welcome");
    }

    private static string MonthHr(DateTime d) => new[]
    {
        "sij", "velj", "ožu", "tra", "svi", "lip", "srp", "kol", "ruj", "lis", "stu", "pro"
    }[d.Month - 1];

    private static string Countdown(DateTime eventDateUtc)
    {
        var days = (eventDateUtc.Date - DateTime.UtcNow.Date).Days;
        return days <= 0 ? "danas" : days == 1 ? "sutra" : $"za {days} dana";
    }
}
