@page "/categories"

<PageTitle>Drink Categories</PageTitle>

<div class="console" id="admin-categories-container">
    <header class="console-head" id="admin-categories-header">
        <div class="console-head__title" id="admin-categories-header-title">
            <span class="eyebrow">Menu</span>
            <h1 id="admin-categories-title">Drink Categories</h1>
            <p id="admin-categories-subtitle">Create, edit and remove the categories used to group drinks.</p>
        </div>
        <div class="console-head__actions" id="admin-categories-header-actions">
            <button class="pill-btn pill-btn--primary" @onclick="ShowCreateModal" id="admin-add-category-btn">
                <i class="bi bi-plus"></i><span>New Category</span>
            </button>
        </div>
    </header>

    @if (!string.IsNullOrEmpty(alertMessage))
    {
        <div class="console-alert @(alertType == "success" ? "console-alert--success" : "console-alert--danger")" role="alert" id="admin-categories-alert">
            <i class="bi @(alertType == "success" ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
            <div>@alertMessage</div>
            <button class="pill-btn" style="margin-left:auto;" @onclick="ClearAlert" id="admin-categories-alert-close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }

    @if (categories == null)
    {
        <div class="loading-state" id="admin-categories-loading">
            <span class="loading-spinner"></span>
            <p>Loading categories…</p>
        </div>
    }
    else if (loadingFailed)
    {
        <div class="console-alert console-alert--danger" role="alert" id="admin-categories-error">
            <i class="bi bi-exclamation-triangle"></i>
            <div>
                <strong>Could not load categories</strong>
                <div>@loadingError</div>
            </div>
            <button class="pill-btn" style="margin-left:auto;" @onclick="LoadCategories" id="admin-categories-retry-btn">
                <i class="bi bi-arrow-clockwise"></i><span>Retry</span>
            </button>
        </div>
    }
    else if (!categories.Any())
    {
        <div class="empty" id="admin-categories-empty">
            <i class="bi bi-tags"></i>
            <p id="admin-categories-empty-title">No categories yet</p>
            <span id="admin-categories-empty-message">Add a category to start grouping drinks.</span>
            <div style="margin-top:1rem;">
                <button class="pill-btn pill-btn--primary" @onclick="ShowCreateModal" id="admin-add-first-category-btn">
                    <i class="bi bi-plus"></i><span>Add First Category</span>
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="panel" id="admin-categories-table-panel">
            <div class="panel__head" id="admin-categories-table-header">
                <h2 class="panel__title" id="admin-categories-table-title">Categories <span class="panel__count mono">@categories.Count</span></h2>
            </div>
            <table class="console-table" id="admin-categories-grid">
                <thead>
                    <tr>
                        <th style="width:64px;">Icon</th>
                        <th>Name</th>
                        <th>Display Name</th>
                        <th class="num">Order</th>
                        <th class="num">Drinks</th>
                        <th>Status</th>
                        <th class="actions-col">Actions</th>
                    </tr>
                </thead>
                <tbody id="admin-categories-table-body">
                    @foreach (var category in categories)
                    {
                        <tr id="admin-category-row-@category.Id">
                            <td style="font-size:1.4rem;" id="admin-category-icon-@category.Id">@category.Icon</td>
                            <td id="admin-category-name-@category.Id"><span class="drink-name">@category.Name</span></td>
                            <td class="console-table__muted" id="admin-category-display-@category.Id">@category.DisplayName</td>
                            <td class="num mono" id="admin-category-order-@category.Id">@category.SortOrder</td>
                            <td class="num mono" id="admin-category-drinkcount-@category.Id">@category.DrinkCount</td>
                            <td id="admin-category-status-cell-@category.Id">
                                @if (category.IsActive)
                                {
                                    <span class="status is-active" id="admin-category-status-active-@category.Id">
                                        <span class="status__dot"></span>Active
                                    </span>
                                }
                                else
                                {
                                    <span class="status is-cancelled" id="admin-category-status-inactive-@category.Id">
                                        <span class="status__dot"></span>Inactive
                                    </span>
                                }
                            </td>
                            <td class="actions-col" id="admin-category-actions-cell-@category.Id">
                                <div class="row-actions">
                                    <button class="row-btn row-btn--label" @onclick="() => ShowEditModal(category)" id="admin-edit-category-@category.Id">
                                        <i class="bi bi-pencil"></i> Edit
                                    </button>
                                    <button class="row-btn row-btn--label row-btn--danger" @onclick="() => DeleteCategory(category)" id="admin-delete-category-@category.Id">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (showModal)
{
    <div class="drink-modal-overlay" id="admin-category-modal" @onclick="HideModal">
        <div class="drink-modal" @onclick:stopPropagation="true">
            <div class="drink-modal__content" id="admin-category-modal-content">
                <header class="drink-modal__head" id="admin-category-modal-header">
                    <div class="drink-modal__head-left">
                        <span class="drink-modal__icon"><i class="bi bi-tags"></i></span>
                        <div class="drink-modal__head-text">
                            <span class="eyebrow">Category</span>
                            <h5 class="drink-modal__title" id="admin-category-modal-title">@(editingId == null ? "Add Category" : "Edit Category")</h5>
                        </div>
                    </div>
                    <button type="button" class="drink-modal__close" @onclick="HideModal" id="admin-category-modal-close-btn" aria-label="Close">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </header>
                <div class="drink-modal__body" id="admin-category-modal-body">
                    <div class="field">
                        <label class="field__label" for="admin-category-form-name">Name *</label>
                        <input type="text" class="field__input" @bind="form.Name" required id="admin-category-form-name" placeholder="e.g. Wine">
                    </div>
                    <div class="field">
                        <label class="field__label" for="admin-category-form-display">Display Name</label>
                        <input type="text" class="field__input" @bind="form.DisplayName" id="admin-category-form-display" placeholder="Shown to customers (optional)">
                    </div>
                    <div class="drink-modal__row">
                        <div class="field field--grow">
                            <label class="field__label" for="admin-category-form-icon">Icon (emoji)</label>
                            <input type="text" class="field__input" @bind="form.Icon" maxlength="16" id="admin-category-form-icon" placeholder="🍷">
                        </div>
                        <div class="field field--grow">
                            <label class="field__label" for="admin-category-form-sort">Sort Order</label>
                            <input type="number" class="field__input" @bind="form.SortOrder" min="0" id="admin-category-form-sort">
                        </div>
                    </div>
                    <label class="drink-check" id="admin-category-form-active-label">
                        <input type="checkbox" class="check-box" @bind="form.IsActive" id="admin-category-form-active">
                        <span>Active (available when creating drinks)</span>
                    </label>
                </div>
                <footer class="drink-modal__foot" id="admin-category-modal-footer">
                    <button type="button" class="pill-btn" @onclick="HideModal" id="admin-category-modal-cancel-btn">Cancel</button>
                    <button type="button" class="pill-btn pill-btn--primary" @onclick="SaveCategory" disabled="@isSaving" id="admin-category-modal-save-btn">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                            <span>Saving…</span>
                        }
                        else
                        {
                            <i class="bi bi-check-lg"></i>
                            <span>Save</span>
                        }
                    </button>
                </footer>
            </div>
        </div>
    </div>
}
