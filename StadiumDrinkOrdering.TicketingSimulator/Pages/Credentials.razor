@page "/credentials"
@using StadiumDrinkOrdering.Shared.DTOs.Integration
@inject SimulatorApiClient Api
@inject IStringLocalizer<SharedResources> Localizer
@inject IJSRuntime JSRuntime

<PageTitle>Credentials</PageTitle>

<h1 class="h4 mb-1">@Localizer["Credentials_MainTitle"]</h1>
<p class="text-muted">@Localizer["Credentials_MainSubtitle"]</p>

<div id="simulator-credentials-note" class="alert alert-info py-2">
    <i class="bi bi-info-circle"></i> @Localizer["Credentials_HashNote"]
</div>

@* ---------- Filters ---------- *@
<div id="simulator-credentials-filter-card" class="card mb-3">
    <div id="simulator-credentials-filter-body" class="card-body py-2 d-flex flex-wrap align-items-center gap-2">
        <div id="simulator-credentials-search-group" class="flex-grow-1" style="min-width:220px">
            <input id="simulator-credentials-search-input" class="form-control form-control-sm"
                   placeholder="@Localizer["Credentials_SearchPlaceholder"]"
                   value="@search" @oninput="OnSearchChanged" />
        </div>
        <div id="simulator-credentials-role-group">
            <select id="simulator-credentials-role-select" class="form-select form-select-sm" @bind="roleFilter">
                <option value="">@Localizer["Credentials_AllRoles"]</option>
                @foreach (var role in AvailableRoles)
                {
                    <option value="@role">@role</option>
                }
            </select>
        </div>
        <div id="simulator-credentials-known-group" class="form-check form-switch mb-0">
            <input id="simulator-credentials-known-input" class="form-check-input" type="checkbox" @bind="onlyKnown" />
            <label id="simulator-credentials-known-label" class="form-check-label small" for="simulator-credentials-known-input">
                @Localizer["Credentials_OnlyKnown"]
            </label>
        </div>
        <div id="simulator-credentials-shell-group" class="form-check form-switch mb-0">
            <input id="simulator-credentials-shell-input" class="form-check-input" type="checkbox" @bind="showShell" />
            <label id="simulator-credentials-shell-label" class="form-check-label small" for="simulator-credentials-shell-input">
                @Localizer["Credentials_ShowShell"] (@shellCount)
            </label>
        </div>
        <button id="simulator-credentials-reload-btn" class="btn btn-sm btn-outline-secondary ms-auto" @onclick="LoadUsersAsync">
            <i class="bi bi-arrow-clockwise"></i> @Localizer["Credentials_ReloadButton"]
        </button>
    </div>
</div>

@* ---------- Accounts ---------- *@
<div id="simulator-credentials-card" class="card mb-3">
    <div id="simulator-credentials-header" class="card-header fw-bold d-flex align-items-center">
        <span><i class="bi bi-people"></i> @Localizer["Credentials_AccountsHeader"]</span>
        @if (users.Count > 0)
        {
            <span id="simulator-credentials-count-badge" class="badge bg-secondary ms-2">@FilteredUsers.Count / @users.Count</span>
        }
    </div>
    <div id="simulator-credentials-body" class="card-body">
        @if (loading)
        {
            <p id="simulator-credentials-loading" class="text-muted mb-0">
                <span class="spinner-border spinner-border-sm"></span> @Localizer["Credentials_Loading"]
            </p>
        }
        else if (users.Count == 0)
        {
            <p id="simulator-credentials-empty" class="text-muted mb-0">@Localizer["Credentials_Empty"]</p>
        }
        else if (FilteredUsers.Count == 0)
        {
            <p id="simulator-credentials-no-match" class="text-muted mb-0">@Localizer["Credentials_NoMatch"]</p>
        }
        else
        {
            <table id="simulator-credentials-table" class="table table-sm align-middle mb-0">
                <thead id="simulator-credentials-thead" class="table-light">
                    <tr id="simulator-credentials-header-row">
                        <th id="simulator-credentials-th-role">@Localizer["Credentials_RoleColumn"]</th>
                        <th id="simulator-credentials-th-username">@Localizer["Credentials_UsernameColumn"]</th>
                        <th id="simulator-credentials-th-email">@Localizer["Credentials_EmailColumn"]</th>
                        <th id="simulator-credentials-th-password">@Localizer["Credentials_PasswordColumn"]</th>
                        <th id="simulator-credentials-th-status">@Localizer["Credentials_StatusColumn"]</th>
                        <th id="simulator-credentials-th-lastlogin">@Localizer["Credentials_LastLoginColumn"]</th>
                    </tr>
                </thead>
                <tbody id="simulator-credentials-tbody">
                    @foreach (var u in FilteredUsers)
                    {
                        <tr id="simulator-credentials-row-@u.Id">
                            <td id="simulator-credentials-role-@u.Id">
                                <span class="badge @RoleBadgeClass(u.Role)">@u.Role</span>
                            </td>
                            <td id="simulator-credentials-username-@u.Id">
                                <code>@u.Username</code>
                                @if (!string.IsNullOrWhiteSpace(u.FullName))
                                {
                                    <div class="small text-muted">@u.FullName</div>
                                }
                            </td>
                            <td id="simulator-credentials-email-@u.Id" class="small">@u.Email</td>
                            <td id="simulator-credentials-password-@u.Id">
                                @if (u.IsShellAccount)
                                {
                                    <span class="text-muted small"><i class="bi bi-slash-circle"></i> @Localizer["Credentials_ShellAccount"]</span>
                                }
                                else if (u.KnownPassword is not null)
                                {
                                    <code>@u.KnownPassword</code>
                                    <button id="simulator-credentials-copy-btn-@u.Id" class="btn btn-sm btn-outline-secondary ms-1 py-0"
                                            title="@Localizer["Credentials_CopyTitle"]"
                                            @onclick="() => CopyAsync(u.KnownPassword!)">
                                        <i class="bi bi-clipboard"></i>
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted small">@Localizer["Credentials_UnknownPassword"]</span>
                                }
                            </td>
                            <td id="simulator-credentials-status-@u.Id">
                                @if (u.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success-emphasis">@Localizer["Credentials_Active"]</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary-emphasis">@Localizer["Credentials_Inactive"]</span>
                                }
                            </td>
                            <td id="simulator-credentials-lastlogin-@u.Id" class="small text-muted">
                                @(u.LastLoginAt?.ToLocalTime().ToString("g") ?? "—")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(copyMessage))
{
    <div id="simulator-credentials-copy-toast" class="alert alert-success py-1 px-2 small d-inline-block">
        <i class="bi bi-check2"></i> @copyMessage
    </div>
}

@code {
    private List<IntegrationUserDto> users = new();
    private bool loading = true;
    private string search = string.Empty;
    private string roleFilter = string.Empty;
    private bool onlyKnown;
    // Shell accounts (auto-provisioned from ticket emails) can never be logged into and vastly
    // outnumber the real ones, so they're hidden until asked for.
    private bool showShell;
    private int shellCount;
    private string? copyMessage;

    // Roles actually present in the data, so the dropdown never offers an empty filter.
    private List<string> AvailableRoles =>
        users.Select(u => u.Role).Distinct().OrderBy(r => r).ToList();

    private List<IntegrationUserDto> FilteredUsers =>
        users.Where(u =>
                (showShell || !u.IsShellAccount)
                && (string.IsNullOrEmpty(roleFilter) || u.Role == roleFilter)
                && (!onlyKnown || u.KnownPassword is not null)
                && (string.IsNullOrWhiteSpace(search)
                    || u.Username.Contains(search, StringComparison.OrdinalIgnoreCase)
                    || u.Email.Contains(search, StringComparison.OrdinalIgnoreCase)
                    || (u.FullName?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false)))
            .ToList();

    protected override async Task OnInitializedAsync() => await LoadUsersAsync();

    private async Task LoadUsersAsync()
    {
        loading = true;
        try
        {
            users = await Api.GetUsersAsync();
            shellCount = users.Count(u => u.IsShellAccount);
        }
        catch
        {
            // API unreachable or not in Development — the empty-state message covers it.
            users = new List<IntegrationUserDto>();
        }
        finally
        {
            loading = false;
        }
    }

    private void OnSearchChanged(ChangeEventArgs e) => search = e.Value?.ToString() ?? string.Empty;

    private async Task CopyAsync(string value)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", value);
            copyMessage = Localizer["Credentials_Copied"];
        }
        catch
        {
            copyMessage = null; // clipboard blocked (insecure context) — stay silent
        }
    }

    private static string RoleBadgeClass(string role) => role switch
    {
        "Admin" => "bg-dark",
        "Bartender" => "bg-primary",
        "Waiter" => "bg-success",
        "Customer" => "bg-info text-dark",
        _ => "bg-secondary"
    };
}
