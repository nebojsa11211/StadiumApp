@inherits LayoutComponentBase

@* Chrome-less mobile shell. No desktop navbar/footer — each screen owns its header.
   On wide viewports the app is centred at phone width against a floodlit backdrop. *@

<div id="customer-mobile-shell-backdrop" class="app-backdrop">
    <div id="customer-mobile-shell-frame" class="app-frame">
        @Body
    </div>
</div>
