@page "/orders"
@using StadiumDrinkOrdering.Shared.Models
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Orders_PageTitle"]</PageTitle>

<div class="console" id="admin-orders-main-container">
    <!-- Page Header -->
    <PageHeader Id="admin-orders-header"
                Eyebrow='@L["Orders_Eyebrow"]'
                Title='@L["Orders_Title"]'
                Subtitle='@L["Orders_Subtitle"]'>
        <Actions>
            <button class="pill-btn pill-btn--primary" @onclick="CreateNewOrder" id="admin-orders-create-btn">
                <i class="bi bi-plus-lg"></i><span>@L["Orders_NewButton"]</span>
            </button>
            <button class="icon-btn" @onclick="RefreshData" disabled="@isLoading" id="admin-orders-refresh-btn" title="@L["Orders_RefreshTitle"]">
                <i class="bi bi-arrow-clockwise @(isLoading ? "spin" : "")"></i>
            </button>
        </Actions>
    </PageHeader>

    <!-- Key Metrics Cards -->
    <section class="metrics">
        <!-- Total Orders -->
        <article class="metric" id="admin-orders-total-card">
            <div class="metric__head">
                <span class="metric__label">@L["Orders_TotalLabel"]</span>
                <i class="oi oi-list-rich metric__icon"></i>
            </div>
            <div class="metric__value mono">@totalOrders</div>
            <div class="metric__foot">
                <span class="metric__hint">@L["Orders_TotalHint"]</span>
            </div>
        </article>

        <!-- Pending Orders (accent: needs attention now) -->
        <article class="metric metric--accent" id="admin-orders-pending-card">
            <div class="metric__head">
                <span class="metric__label">@L["Orders_PendingLabel"]</span>
                <i class="oi oi-clock metric__icon"></i>
            </div>
            <div class="metric__value mono">@pendingOrders</div>
            <div class="metric__foot">
                <span class="metric__hint">@L["Orders_PendingHint"]</span>
            </div>
        </article>

        <!-- Completed Today -->
        <article class="metric" id="admin-orders-completed-card">
            <div class="metric__head">
                <span class="metric__label">@L["Orders_CompletedLabel"]</span>
                <i class="oi oi-circle-check metric__icon is-ok"></i>
            </div>
            <div class="metric__value mono">@completedToday</div>
            <div class="metric__foot">
                <span class="metric__hint">@L["Orders_CompletedHint"]</span>
            </div>
        </article>

        <!-- Revenue Today -->
        <article class="metric" id="admin-orders-revenue-card">
            <div class="metric__head">
                <span class="metric__label">@L["Orders_RevenueLabel"]</span>
                <i class="oi oi-dollar metric__icon"></i>
            </div>
            <div class="metric__value mono"><span class="metric__unit">€</span>@revenueToday.ToString("N0")</div>
            <div class="metric__foot">
                <span class="metric__hint">@L["Orders_RevenueHint"]</span>
            </div>
        </article>
    </section>

    <!-- Filters -->
    <div class="panel filters-panel" id="admin-orders-filters-panel">
        <div class="panel__head" id="admin-orders-filters-head">
            <h2 class="panel__title" id="admin-orders-filters-title">@L["Orders_FiltersTitle"]</h2>
            <button class="link-btn" @onclick="ClearFilters" id="admin-orders-clear-filters-btn">
                <i class="oi oi-x"></i> @L["Orders_ClearButton"]
            </button>
        </div>
        <div class="filters" id="admin-orders-filters-container">
            <div class="field" id="admin-orders-season-field">
                <label class="field__label" id="admin-orders-season-label">@L["Orders_SeasonLabel"]</label>
                <select class="field__input" id="admin-orders-season-select" @bind="selectedSeasonId" @bind:after="OnSeasonChanged">
                    <option value="">@L["Orders_AllSeasonsOption"]</option>
                    @foreach (var s in seasonOptions)
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
            </div>
            <div class="field" id="admin-orders-event-field">
                <label class="field__label" id="admin-orders-event-label">@L["Orders_EventLabel"]</label>
                <select class="field__input" id="admin-orders-event-select" @bind="selectedEventId" @bind:after="FilterOrders">
                    <option value="">@L["Orders_AllEventsOption"]</option>
                    @foreach (var ev in eventOptions)
                    {
                        <option value="@ev.Id">@ev.Name</option>
                    }
                </select>
            </div>
            <div class="field" id="admin-orders-status-field">
                <label class="field__label" id="admin-orders-status-label">@L["Orders_StatusLabel"]</label>
                <select class="field__input" id="admin-orders-status-select" @bind="selectedStatus" @bind:after="FilterOrders">
                    <option value="">@L["Orders_AllStatusesOption"]</option>
                    <option value="Pending">@L["Orders_PendingOption"]</option>
                    <option value="Accepted">@L["Orders_AcceptedOption"]</option>
                    <option value="InPreparation">@L["Orders_InPreparationOption"]</option>
                    <option value="Ready">@L["Orders_ReadyOption"]</option>
                    <option value="OutForDelivery">@L["Orders_OutForDeliveryOption"]</option>
                    <option value="Delivered">@L["Orders_DeliveredOption"]</option>
                    <option value="Cancelled">@L["Orders_CancelledOption"]</option>
                </select>
            </div>
            <div class="field field--grow" id="admin-orders-search-field">
                <label class="field__label" id="admin-orders-search-label">@L["Orders_CustomerSearchLabel"]</label>
                <input type="text" class="field__input" id="admin-orders-search-input" placeholder="@L["Orders_SearchPlaceholder"]"
                       @bind="customerSearch" @oninput="FilterOrders" />
            </div>
            <div class="field" id="admin-orders-fromdate-field">
                <label class="field__label" id="admin-orders-fromdate-label">@L["Orders_FromDateLabel"]</label>
                <input type="date" class="field__input" id="admin-orders-fromdate-input" @bind="fromDate" @bind:after="FilterOrders" />
            </div>
            <div class="field" id="admin-orders-todate-field">
                <label class="field__label" id="admin-orders-todate-label">@L["Orders_ToDateLabel"]</label>
                <input type="date" class="field__input" id="admin-orders-todate-input" @bind="toDate" @bind:after="FilterOrders" />
            </div>
        </div>
    </div>

    <!-- Statistics (reflect the current filter selection) -->
    @if (!isLoading && allOrders.Count > 0)
    {
        <div class="panel stats-panel" id="admin-orders-stats-panel">
            <div class="panel__head" id="admin-orders-stats-head">
                <h2 class="panel__title" id="admin-orders-stats-title">@L["Statistics_Title"]</h2>
                <span class="stats-scope" id="admin-orders-stats-scope">@L["Statistics_Subtitle"]</span>
            </div>

            @if (statOrderCount > 0)
            {
                <div class="stats-body" id="admin-orders-stats-body">
                    <div class="stat-figures" id="admin-orders-stat-figures">
                        <div class="stat-fig" id="admin-orders-stat-revenue">
                            <span class="stat-fig__label">@L["Statistics_Revenue"]</span>
                            <span class="stat-fig__value mono"><span class="metric__unit">€</span>@statRevenue.ToString("N2")</span>
                        </div>
                        <div class="stat-fig" id="admin-orders-stat-avg">
                            <span class="stat-fig__label">@L["Statistics_AvgOrder"]</span>
                            <span class="stat-fig__value mono"><span class="metric__unit">€</span>@statAvgOrder.ToString("N2")</span>
                        </div>
                        <div class="stat-fig" id="admin-orders-stat-items">
                            <span class="stat-fig__label">@L["Statistics_ItemsSold"]</span>
                            <span class="stat-fig__value mono">@statItemsSold</span>
                        </div>
                        <div class="stat-fig" id="admin-orders-stat-customers">
                            <span class="stat-fig__label">@L["Statistics_Customers"]</span>
                            <span class="stat-fig__value mono">@statUniqueCustomers</span>
                        </div>
                    </div>

                    <div class="stats-cols">
                        <!-- Status distribution -->
                        <div class="stats-block" id="admin-orders-stats-status-block">
                            <h3 class="stats-block__title">@L["Statistics_StatusDistribution"]</h3>
                            <div class="stat-bar" id="admin-orders-stat-bar">
                                @foreach (var s in statusBreakdown)
                                {
                                    <div class="stat-bar__seg @GetStatusModifier(s.Status)"
                                         style="width:@s.Percent.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%"
                                         title="@GetStatusLabel(s.Status): @s.Count"></div>
                                }
                            </div>
                            <ul class="stat-legend" id="admin-orders-stat-legend">
                                @foreach (var s in statusBreakdown)
                                {
                                    <li class="stat-legend__item">
                                        <span class="status @GetStatusModifier(s.Status)">
                                            <span class="status__dot"></span>@GetStatusLabel(s.Status)
                                        </span>
                                        <span class="stat-legend__val mono">@s.Count<span class="stat-legend__pct">@s.Percent.ToString("0")%</span></span>
                                    </li>
                                }
                            </ul>
                        </div>

                        <!-- Top drinks -->
                        <div class="stats-block" id="admin-orders-stats-drinks-block">
                            <h3 class="stats-block__title">@L["Statistics_TopDrinks"]</h3>
                            @if (topDrinks.Any())
                            {
                                var maxQty = topDrinks.Max(d => d.Quantity);
                                <ul class="stat-rank" id="admin-orders-stat-drinks-list">
                                    @foreach (var d in topDrinks)
                                    {
                                        <li class="stat-rank__item">
                                            <span class="stat-rank__name" title="@d.Name">@d.Name</span>
                                            <span class="stat-rank__track">
                                                <span class="stat-rank__fill" style="width:@((maxQty > 0 ? (double)d.Quantity / maxQty * 100 : 0).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%"></span>
                                            </span>
                                            <span class="stat-rank__val mono">@d.Quantity</span>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <p class="stat-empty">@L["Statistics_NoData"]</p>
                            }
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="stats-body">
                    <p class="stat-empty" id="admin-orders-stats-empty">@L["Statistics_NoData"]</p>
                </div>
            }
        </div>
    }

    @if (isLoading)
    {
        <div class="loading-state" id="admin-orders-loading">
            <span class="loading-spinner" id="admin-orders-loading-spinner"></span>
            <p id="admin-orders-loading-text">@L["Orders_Loading"]</p>
        </div>
    }
    else
    {
        <!-- Orders Table -->
        <div class="panel" id="admin-orders-table-panel">
            <div class="panel__head" id="admin-orders-panel-head">
                <h2 class="panel__title" id="admin-orders-panel-title">@L["Orders_PanelTitle"] <span class="panel__count mono" id="admin-orders-panel-count">@filteredOrders.Count</span></h2>
                @if (selectedOrderIds.Any())
                {
                    <div class="bulk-actions" id="admin-orders-bulk-actions">
                        <button class="pill-btn pill-btn--danger" @onclick="BulkCancel" id="admin-orders-bulk-cancel-btn">
                            <i class="oi oi-x"></i><span>@L["Orders_CancelBulkButton"]</span>
                        </button>
                    </div>
                }
            </div>

            @if (filteredOrders?.Any() == true)
            {
                <table class="order-table" id="admin-orders-table">
                    <thead id="admin-orders-thead">
                        <tr id="admin-orders-header-row">
                            <th class="check" id="admin-orders-header-check">
                                <input type="checkbox" class="check-box" id="admin-orders-select-all-checkbox" @onchange="ToggleSelectAll" />
                            </th>
                            <th class="sortable @(sortState.IsSorted("order") ? "is-sorted" : "")" @onclick='() => SortBy("order")' id="admin-orders-header-orderid">@L["Orders_OrderHeader"]<span class="sort-ind">@sortState.Indicator("order")</span></th>
                            <th class="sortable @(sortState.IsSorted("customer") ? "is-sorted" : "")" @onclick='() => SortBy("customer")' id="admin-orders-header-customer">@L["Orders_CustomerHeader"]<span class="sort-ind">@sortState.Indicator("customer")</span></th>
                            <th class="sortable @(sortState.IsSorted("items") ? "is-sorted" : "")" @onclick='() => SortBy("items")' id="admin-orders-header-items">@L["Orders_ItemsHeader"]<span class="sort-ind">@sortState.Indicator("items")</span></th>
                            <th class="num sortable @(sortState.IsSorted("total") ? "is-sorted" : "")" @onclick='() => SortBy("total")' id="admin-orders-header-total">@L["Orders_TotalHeader"]<span class="sort-ind">@sortState.Indicator("total")</span></th>
                            <th class="sortable @(sortState.IsSorted("status") ? "is-sorted" : "")" @onclick='() => SortBy("status")' id="admin-orders-header-status">@L["Orders_StatusHeader"]<span class="sort-ind">@sortState.Indicator("status")</span></th>
                            <th class="num sortable @(sortState.IsSorted("created") ? "is-sorted" : "")" @onclick='() => SortBy("created")' id="admin-orders-header-created">@L["Orders_CreatedHeader"]<span class="sort-ind">@sortState.Indicator("created")</span></th>
                            <th class="actions-col" id="admin-orders-header-actions">@L["Orders_ActionsHeader"]</th>
                        </tr>
                    </thead>
                    <tbody id="admin-orders-tbody">
                        @foreach (var order in pager.PageItems)
                        {
                            <tr class="@(selectedOrderIds.Contains(order.Id) ? "is-selected" : "")" id="@($"admin-orders-row-{order.Id}")">
                                <td class="check" id="@($"admin-orders-checkbox-{order.Id}")">
                                    <input type="checkbox" class="check-box" id="@($"admin-orders-select-{order.Id}")"
                                           checked="@selectedOrderIds.Contains(order.Id)"
                                           @onchange="@((e) => ToggleOrderSelection(order.Id, (bool)e.Value!))" />
                                </td>
                                <td class="mono order-table__id" id="@($"admin-orders-id-{order.Id}")">#@order.Id</td>
                                <td id="@($"admin-orders-customer-{order.Id}")">@order.CustomerName</td>
                                <td class="order-table__muted" id="@($"admin-orders-items-{order.Id}")">@order.OrderItems.Count @L["Orders_ItemsSuffix"]</td>
                                <td class="num mono" id="@($"admin-orders-total-{order.Id}")">€@order.TotalAmount.ToString("N2")</td>
                                <td id="@($"admin-orders-status-{order.Id}")">
                                    <span class="status @GetStatusModifier(order.Status)" id="@($"admin-orders-status-badge-{order.Id}")">
                                        <span class="status__dot"></span>@order.Status
                                    </span>
                                </td>
                                <td class="num mono order-table__time" id="@($"admin-orders-created-{order.Id}")">@order.CreatedAt.ToString("MMM dd, HH:mm")</td>
                                <td class="actions-col" id="@($"admin-orders-actions-{order.Id}")">
                                    <div class="row-actions" id="@($"admin-orders-actions-group-{order.Id}")">
                                        <button class="row-btn" title="@L["Orders_ViewTitle"]" @onclick="@(() => ViewOrder(order.Id))" id="@($"admin-orders-view-btn-{order.Id}")">
                                            <i class="oi oi-eye"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <TablePager TItem="OrderDto" View="pager" IdPrefix="admin-orders-table" OnChanged="StateHasChanged" />
            }
            else
            {
                <div class="empty" id="admin-orders-empty-state">
                    <i class="oi oi-inbox" id="admin-orders-empty-icon"></i>
                    <p id="admin-orders-empty-title">@L["Orders_NoOrdersFound"]</p>
                    <span id="admin-orders-empty-message">@L["Orders_NoOrdersMessage"]</span>
                </div>
            }
        </div>
    }

@if (viewOrder != null)
{
    <div class="detail-modal-scrim" id="admin-orders-detail-scrim" @onclick="CloseOrderModal">
        <div class="detail-modal" id="admin-orders-detail-modal" @onclick:stopPropagation="true">
            <div class="detail-modal__head" id="admin-orders-detail-head">
                <div>
                    <span class="eyebrow">@L["Orders_DetailEyebrow"]</span>
                    <h2 class="detail-modal__title mono" id="admin-orders-detail-title">
                        #@viewOrder.Id
                        @if (isLoadingDetail)
                        {
                            <i class="oi oi-reload spin" id="admin-orders-detail-loading"></i>
                        }
                    </h2>
                </div>
                <div class="detail-modal__head-right">
                    <span class="status @GetStatusModifier(viewOrder.Status)" id="admin-orders-detail-status">
                        <span class="status__dot"></span>@viewOrder.Status
                    </span>
                    <button class="icon-btn" title="@L["Orders_CloseTitle"]" @onclick="CloseOrderModal" id="admin-orders-detail-close-btn">
                        <i class="oi oi-x"></i>
                    </button>
                </div>
            </div>

            <div class="detail-modal__body" id="admin-orders-detail-body">
                <dl class="detail-grid" id="admin-orders-detail-meta">
                    <div class="detail-cell">
                        <dt>@L["Orders_CustomerHeader"]</dt>
                        <dd>@viewOrder.CustomerName</dd>
                    </div>
                    <div class="detail-cell">
                        <dt>@L["Orders_EventLabel"]</dt>
                        <dd>@(viewOrder.Event?.EventName ?? "—")</dd>
                    </div>
                    <div class="detail-cell">
                        <dt>@L["Orders_SeatLabel"]</dt>
                        <dd>@(!string.IsNullOrWhiteSpace(viewOrder.SeatPath) ? viewOrder.SeatPath
                              : !string.IsNullOrWhiteSpace(viewOrder.SeatNumber) ? viewOrder.SeatNumber : "—")</dd>
                    </div>
                    <div class="detail-cell">
                        <dt>@L["Orders_TicketLabel"]</dt>
                        <dd class="mono">@(string.IsNullOrWhiteSpace(viewOrder.TicketNumber) ? "—" : viewOrder.TicketNumber)</dd>
                    </div>
                    <div class="detail-cell">
                        <dt>@L["Orders_CreatedHeader"]</dt>
                        <dd>@viewOrder.CreatedAt.ToString("MMM dd, yyyy HH:mm")</dd>
                    </div>
                </dl>

                <h3 class="detail-section-title">@L["Orders_ItemsHeader"]</h3>
                @if (viewOrder.OrderItems.Any())
                {
                    <table class="detail-table" id="admin-orders-detail-items">
                        <thead>
                            <tr>
                                <th>@L["Orders_ItemNameHeader"]</th>
                                <th class="num">@L["Orders_QtyHeader"]</th>
                                <th class="num">@L["Orders_UnitHeader"]</th>
                                <th class="num">@L["Orders_TotalHeader"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in viewOrder.OrderItems)
                            {
                                <tr>
                                    <td>@item.DrinkName</td>
                                    <td class="num mono">@item.Quantity</td>
                                    <td class="num mono">€@item.UnitPrice.ToString("N2")</td>
                                    <td class="num mono">€@item.TotalPrice.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" class="num">@L["Orders_TotalHeader"]</td>
                                <td class="num mono detail-total">€@viewOrder.TotalAmount.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                }
                else
                {
                    <p class="detail-empty">@L["Orders_NoItems"]</p>
                }

                @if (!string.IsNullOrWhiteSpace(viewOrder.CustomerNotes) || !string.IsNullOrWhiteSpace(viewOrder.Notes))
                {
                    <h3 class="detail-section-title">@L["Orders_NotesLabel"]</h3>
                    @if (!string.IsNullOrWhiteSpace(viewOrder.CustomerNotes))
                    {
                        <p class="detail-note">@viewOrder.CustomerNotes</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(viewOrder.Notes))
                    {
                        <p class="detail-note">@viewOrder.Notes</p>
                    }
                }

                <h3 class="detail-section-title">@L["Orders_TimelineLabel"]</h3>
                @{
                    var steps = new (string Label, DateTime? At, string? By)[]
                    {
                        (L["Orders_AcceptedOption"], viewOrder.AcceptedAt, viewOrder.AcceptedByUserName),
                        (L["Orders_InPreparationOption"], viewOrder.InPreparationAt, viewOrder.InPreparationByUserName),
                        (L["Orders_ReadyOption"], viewOrder.PreparedAt, viewOrder.PreparedByUserName),
                        (L["Orders_DeliveredOption"], viewOrder.DeliveredAt, viewOrder.DeliveredByUserName),
                    };
                }
                <ul class="detail-timeline" id="admin-orders-detail-timeline">
                    @foreach (var s in steps)
                    {
                        <li class="@(s.At.HasValue ? "is-done" : "")">
                            <span class="detail-timeline__dot"></span>
                            <span class="detail-timeline__label">@s.Label</span>
                            <span class="detail-timeline__time mono">@(s.At.HasValue ? s.At.Value.ToString("MMM dd, HH:mm") : "—")@(string.IsNullOrWhiteSpace(s.By) ? "" : $" · {s.By}")</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
}
</div>
