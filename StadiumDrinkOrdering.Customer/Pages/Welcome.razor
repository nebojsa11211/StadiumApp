@page "/welcome"
@layout MobileShell
@using System.Globalization
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Shared.Configuration
@using StadiumDrinkOrdering.Customer.Services
@inject IApiService Api
@inject IConfiguration Configuration
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject OrderSessionState State
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["Welcome_PageTitle"]</PageTitle>

<div id="customer-welcome-container" class="welcome">
    <div id="customer-welcome-crowd" class="wl-crowd"></div>

    <header class="wl-top">
        <div id="customer-welcome-logo" class="wl-logo">@Localizer["Welcome_Wordmark_Part1"]<span>@Localizer["Welcome_Wordmark_Part2"]</span></div>

        @* Account chip, top-right. With a scanned ticket it opens the account sheet (who you are, seat,
           fixture, wallet); with no session there is no account to show, so it routes to sign-in. *@
        @if (_hasSession)
        {
            <button id="customer-welcome-account-btn" class="wl-account" type="button"
                    aria-label="@Localizer["Welcome_AccountAriaLabel"]"
                    aria-haspopup="dialog" aria-expanded="@_accountOpen"
                    @onclick="@(() => _accountOpen = true)">
                <span id="customer-welcome-account-avatar" class="wl-account-avatar">@Initials(FanName)</span>
            </button>
        }
        else
        {
            <button id="customer-welcome-account-signin-btn" class="wl-account" type="button"
                    aria-label="@Localizer["Welcome_AccountSignIn"]"
                    @onclick="@(() => Nav.NavigateTo("/login"))">
                <svg class="wl-account-ico" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12a4.5 4.5 0 1 0 0-9 4.5 4.5 0 0 0 0 9Zm0 2c-4.4 0-8 2.4-8 5.3V21h16v-1.7c0-2.9-3.6-5.3-8-5.3Z"/></svg>
            </button>
        }
    </header>

    <div id="customer-welcome-hero" class="hero">
        <div id="customer-welcome-glow" class="glow"></div>
        <div id="customer-welcome-grid-lines" class="grid-lines"></div>
        <div id="customer-welcome-hero-content" class="hero-content">
            <div id="customer-welcome-place" class="wl-place">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2c-3.9 0-7 3.1-7 7 0 5 7 13 7 13s7-8 7-13c0-3.9-3.1-7-7-7Zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5Z"/></svg>
                <span>@PlaceLabel</span>
            </div>
            <h1 class="display big-mark">
                <span>@Localizer["Welcome_HeroLine1"]</span>
                <span class="grad-text">@Localizer["Welcome_HeroLine2"]</span>
                <span class="grad-text">@Localizer["Welcome_HeroLine3"]</span>
            </h1>
            <p class="hero-lede">@Localizer["Welcome_HeroLede"]</p>
        </div>
    </div>

    @if (_season?.UpcomingEvents is { Count: > 0 } fixtures)
    {
        <div id="customer-welcome-fixture-wrap" class="wl-fixture-wrap">
            @if (!string.IsNullOrWhiteSpace(_season!.Name))
            {
                <div id="customer-welcome-season" class="wl-season">@_season.Name</div>
            }
            @* Horizontally scrollable strip of every upcoming/live fixture; the first is the "next" one. *@
            <div id="customer-welcome-fixture-scroll" class="wl-fixture-scroll">
                @for (var i = 0; i < fixtures.Count; i++)
                {
                    var evt = fixtures[i];
                    var isFirst = i == 0;
                    var teams = ResolveTeams(evt);
                    var isVersus = !string.IsNullOrWhiteSpace(teams.away);
                    // The home side of a home match is one of the venue's own clubs, so its crest
                    // and colours come from admin Venue Settings rather than the name-guess table.
                    var homeClub = ResolveHomeClub(evt);
                    var homeLogo = HomeCrestUrl(evt, homeClub, teams.home);
                    var home = CrestColors(teams.home, homeClub);
                    var away = CrestColors(teams.away, null);
                    var start = evt.EventDate.ToLocalTime();
                    var end = evt.EventEndDate?.ToLocalTime();
                    var label = evt.IsLive ? Localizer["Welcome_LiveNow"].Value : (isFirst ? Localizer["Welcome_NextFixture"].Value : Localizer["Welcome_Fixture"].Value);
                    <div id="customer-welcome-vs-card-@evt.Id" class="vs-card" role="button" tabindex="0"
                         @onclick="@(() => Nav.NavigateTo($"/events/{evt.Id}"))"
                         @onkeydown="@(e => { if (e.Key is "Enter" or " ") Nav.NavigateTo($"/events/{evt.Id}"); })">
                        @if (evt.HasPoster)
                        {
                            @* An approved poster IS the card: the crests, team names, venue and
                               kick-off are composed into the artwork itself, so rendering the DOM
                               layout on top would duplicate them. The same facts stay in the markup
                               as visually-hidden text, because text baked into pixels is invisible
                               to screen readers and untranslatable. Only unapproved posters are
                               withheld — those fixtures fall through to the layout below. *@
                            <img id="customer-welcome-vs-poster-@evt.Id" class="vs-poster"
                                 src="@PosterUrl(evt.Id)" alt="" aria-hidden="true" loading="lazy" />
                            <span class="vs-sr" id="customer-welcome-vs-sr-@evt.Id">
                                @label:
                                @(isVersus ? $"{teams.home} – {teams.away}" : evt.EventName),
                                @DayLabel(start) @TimeRange(start, end)
                            </span>
                            @if (evt.IsLive)
                            {
                                @* Live state is the one fact that cannot be baked in — it changes
                                   after the artwork is made — so it stays an overlay. *@
                                <span class="vs-live vs-live--onposter" id="customer-welcome-vs-live-@evt.Id">
                                    <span class="pulse"></span>@Localizer["Welcome_Live"]
                                </span>
                            }
                        }
                        else
                        {
                        <div id="customer-welcome-vs-label-@evt.Id" class="vs-label">@label</div>
                        @if (isVersus)
                        {
                            <div id="customer-welcome-vs-body-@evt.Id" class="vs-body">
                                <div id="customer-welcome-vs-team-home-@evt.Id" class="vs-team">
                                    <div id="customer-welcome-crest-home-@evt.Id" class="crest" style="--c1:@home.a;--c2:@home.b">
                                        <svg class="crest-svg" viewBox="0 0 72 84" aria-hidden="true">
                                            <path d="M36 2.5 L69 13.5 V43 C69 63 55.5 75.5 36 81.5 C16.5 75.5 3 63 3 43 V13.5 Z" style="fill:var(--c1);stroke:rgba(255,255,255,.92);stroke-width:3"></path>
                                            <path d="M3 44 C16.5 44 55.5 44 69 44 C69 63 55.5 75.5 36 81.5 C16.5 75.5 3 63 3 44 Z" style="fill:rgba(0,0,0,.20)"></path>
                                        </svg>
                                        @if (homeLogo is not null)
                                        {
                                            <img id="customer-welcome-crest-home-logo-@evt.Id" class="crest-logo" src="@homeLogo" alt="@teams.home" />
                                        }
                                        else
                                        {
                                            <span class="crest-mono" style="color:@home.fg">@Initials(teams.home)</span>
                                        }
                                    </div>
                                    <div id="customer-welcome-vs-name-home-@evt.Id" class="vs-name">@teams.home</div>
                                </div>
                                <div id="customer-welcome-vs-mid-@evt.Id" class="vs-mid">
                                    <span id="customer-welcome-vs-day-@evt.Id" class="vs-when tnum">@DayLabel(start)</span>
                                    <span id="customer-welcome-vs-time-@evt.Id" class="vs-time tnum">@TimeRange(start, end)</span>
                                    @if (evt.IsLive)
                                    {
                                        <span class="vs-live"><span class="pulse"></span>@Localizer["Welcome_Live"]</span>
                                    }
                                </div>
                                <div id="customer-welcome-vs-team-away-@evt.Id" class="vs-team">
                                    <div id="customer-welcome-crest-away-@evt.Id" class="crest" style="--c1:@away.a;--c2:@away.b">
                                        <svg class="crest-svg" viewBox="0 0 72 84" aria-hidden="true">
                                            <path d="M36 2.5 L69 13.5 V43 C69 63 55.5 75.5 36 81.5 C16.5 75.5 3 63 3 43 V13.5 Z" style="fill:var(--c1);stroke:rgba(255,255,255,.92);stroke-width:3"></path>
                                            <path d="M3 44 C16.5 44 55.5 44 69 44 C69 63 55.5 75.5 36 81.5 C16.5 75.5 3 63 3 44 Z" style="fill:rgba(0,0,0,.20)"></path>
                                        </svg>
                                        <span class="crest-mono" style="color:@away.fg">@Initials(teams.away)</span>
                                    </div>
                                    <div id="customer-welcome-vs-name-away-@evt.Id" class="vs-name">@teams.away</div>
                                </div>
                            </div>
                        }
                        else
                        {
                            @* Non-versus event (concert, one-off show): a single act/title, no opponent. *@
                            <div id="customer-welcome-vs-solo-@evt.Id" class="vs-solo">
                                <div id="customer-welcome-crest-solo-@evt.Id" class="crest" style="--c1:@home.a;--c2:@home.b">
                                    <svg class="crest-svg" viewBox="0 0 72 84" aria-hidden="true">
                                        <path d="M36 2.5 L69 13.5 V43 C69 63 55.5 75.5 36 81.5 C16.5 75.5 3 63 3 43 V13.5 Z" style="fill:var(--c1);stroke:rgba(255,255,255,.92);stroke-width:3"></path>
                                        <path d="M3 44 C16.5 44 55.5 44 69 44 C69 63 55.5 75.5 36 81.5 C16.5 75.5 3 63 3 44 Z" style="fill:rgba(0,0,0,.20)"></path>
                                    </svg>
                                    <span class="crest-mono" style="color:@home.fg">@Initials(teams.home)</span>
                                </div>
                                <div id="customer-welcome-vs-solo-title-@evt.Id" class="vs-solo-title">@evt.EventName</div>
                                <div id="customer-welcome-vs-solo-when-@evt.Id" class="vs-mid">
                                    <span id="customer-welcome-vs-day-@evt.Id" class="vs-when tnum">@DayLabel(start)</span>
                                    <span id="customer-welcome-vs-time-@evt.Id" class="vs-time tnum">@TimeRange(start, end)</span>
                                    @if (evt.IsLive)
                                    {
                                        <span class="vs-live"><span class="pulse"></span>@Localizer["Welcome_Live"]</span>
                                    }
                                </div>
                            </div>
                        }
                        } @* end of the no-approved-poster fallback *@
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div id="customer-welcome-fixture-wrap-empty" class="wl-fixture-wrap">
            @if (!string.IsNullOrWhiteSpace(_season?.Name))
            {
                <div id="customer-welcome-season-empty" class="wl-season">@_season!.Name</div>
            }
            <div id="customer-welcome-fixture-empty" class="fixture-empty">@Localizer["Welcome_NoFixtures"]</div>
        </div>
    }

    <div id="customer-welcome-wl-mark" class="wl-mark">@Localizer["Welcome_Wordmark_Part1"]<span>@Localizer["Welcome_Wordmark_Part2"]</span></div>

    <div id="customer-welcome-cta" class="welcome-cta">
        @if (_hasSession)
        {
            @* Ticket already scanned this session — jump back into ordering instead of scanning again.
               Who you are, your seat and your balance live in the header account button. *@
            <button id="customer-welcome-continue-btn" class="btn wl-scan" @onclick="@(() => Nav.NavigateTo("/order"))">
                <svg class="btn-ico" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
                @Localizer["Welcome_ContinueOrdering"]
            </button>
        }
        else if (_matchLive)
        {
            @* Scanning is only useful while a match is actually running — off game day the ticket
               opens nothing to order from, so the CTA is sign-in only. *@
            <button id="customer-welcome-scan-btn" class="btn wl-scan" @onclick="@(() => Nav.NavigateTo("/scan"))">
                <svg class="btn-ico" viewBox="0 0 24 24" aria-hidden="true"><rect x="2.5" y="6" width="19" height="12" rx="2"/><circle cx="12" cy="12" r="2.4"/><path d="M6 9.5v5M18 9.5v5"/></svg>
                @Localizer["Welcome_ScanTicket"]
            </button>
            <button id="customer-welcome-login-btn" class="btn btn-ghost" @onclick="@(() => Nav.NavigateTo("/login"))">@Localizer["Welcome_SignIn"]</button>
        }
        else
        {
            <button id="customer-welcome-login-btn" class="btn wl-scan" @onclick="@(() => Nav.NavigateTo("/login"))">@Localizer["Welcome_SignIn"]</button>
        }
    </div>

    <footer class="wl-foot">
        @if (!_hasSession && _matchLive)
        {
            @* Redundant once a ticket is scanned — the CTA above already offers "continue ordering",
               and pointless with no live match, same as the scan CTA. *@
            <button id="customer-welcome-foot-scan" class="wl-foot-scan" @onclick="@(() => Nav.NavigateTo("/scan"))">
                <span>@Localizer["Welcome_SingleTicketScan"]</span>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 3h7v7H3V3Zm2 2v3h3V5H5Zm9-2h7v7h-7V3Zm2 2v3h3V5h-3ZM3 14h7v7H3v-7Zm2 2v3h3v-3H5Zm11-2h2v2h-2v-2Zm3 0h2v2h-2v-2Zm-3 3h2v2h-2v-2Zm0 3h2v-2h3v2h-2v-1h-1v3h-2v-2Zm3-3h2v2h-2v-2Z"/></svg>
            </button>
        }
        <div id="customer-welcome-lang" class="wl-lang" role="group" aria-label="Jezik">
            <button id="customer-welcome-lang-hr-btn" class="@(IsHr ? "on" : "")" @onclick='() => SetCulture("hr")'>HR</button>
            <span aria-hidden="true">/</span>
            <button id="customer-welcome-lang-en-btn" class="@(IsHr ? "" : "on")" @onclick='() => SetCulture("en")'>EN</button>
        </div>
    </footer>

    @* Account bottom sheet — opened from the header button. The single place the fan's identity, seat,
       fixture and spendable balance are shown. *@
    @if (_accountOpen)
    {
        <div id="customer-welcome-account-scrim" class="wl-sheet-scrim" @onclick="@(() => _accountOpen = false)"></div>
        <div id="customer-welcome-account-sheet" class="wl-sheet" role="dialog" aria-modal="true"
             aria-label="@Localizer["Welcome_AccountTitle"]">
            <div class="wl-sheet-grip" aria-hidden="true"></div>
            <div class="wl-sheet-head">
                <div class="wl-fan-id">
                    <div id="customer-welcome-account-sheet-avatar" class="wl-fan-avatar">@Initials(FanName)</div>
                    <div class="wl-fan-meta">
                        <div class="wl-fan-hi">@Localizer["Welcome_AccountTitle"]</div>
                        <div id="customer-welcome-account-sheet-name" class="wl-fan-name">@FanName</div>
                    </div>
                </div>
                <button id="customer-welcome-account-close" class="wl-sheet-x" @onclick="@(() => _accountOpen = false)"
                        aria-label="@Localizer["Welcome_CloseLabel"]">✕</button>
            </div>

            @* Three views of the same account: who/where (ticket), what they bought, and where the money
               went. History is fetched on first switch to its tab, not on open. *@
            <div id="customer-welcome-account-tabs" class="wl-seg" role="tablist" aria-label="@Localizer["Welcome_AccountTitle"]">
                <button id="customer-welcome-account-tab-details" class="wl-seg-btn @(_accountTab == AccountTab.Details ? "on" : "")"
                        role="tab" aria-selected="@(_accountTab == AccountTab.Details)"
                        @onclick="@(() => SwitchAccountTab(AccountTab.Details))">@Localizer["Welcome_AccountTab_Ticket"]</button>
                <button id="customer-welcome-account-tab-orders" class="wl-seg-btn @(_accountTab == AccountTab.Orders ? "on" : "")"
                        role="tab" aria-selected="@(_accountTab == AccountTab.Orders)"
                        @onclick="@(() => SwitchAccountTab(AccountTab.Orders))">@Localizer["Welcome_AccountTab_Orders"]</button>
                <button id="customer-welcome-account-tab-wallet" class="wl-seg-btn @(_accountTab == AccountTab.Wallet ? "on" : "")"
                        role="tab" aria-selected="@(_accountTab == AccountTab.Wallet)"
                        @onclick="@(() => SwitchAccountTab(AccountTab.Wallet))">@Localizer["Welcome_AccountTab_Wallet"]</button>
            </div>

            <div id="customer-welcome-account-body" class="wl-account-body">
                @if (_accountTab == AccountTab.Details)
                {
                    <div id="customer-welcome-account-details" class="wl-fan-details">
                        @if (!string.IsNullOrWhiteSpace(State.TicketNumber))
                        {
                            <div class="wl-fan-row">
                                <span class="k">@Localizer["Welcome_TicketLabel"]</span>
                                <span id="customer-welcome-account-ticket" class="v tnum">@State.TicketNumber</span>
                            </div>
                        }
                        <div class="wl-fan-row">
                            <span class="k">@Localizer["Welcome_SeatLabel"]</span>
                            <span id="customer-welcome-account-seat" class="v tnum">@State.SeatText</span>
                        </div>
                        <div class="wl-fan-row">
                            <span class="k">@Localizer["Welcome_EventLabel"]</span>
                            <span id="customer-welcome-account-event" class="v">@EventTitle</span>
                        </div>
                        @if (State.EventDate is { } adt)
                        {
                            <div class="wl-fan-row">
                                <span class="k">@Localizer["Welcome_DateLabel"]</span>
                                <span id="customer-welcome-account-date" class="v tnum">@adt.ToLocalTime().ToString("dd.MM.yyyy · HH:mm")</span>
                            </div>
                        }
                        <div class="wl-fan-row">
                            <span class="k">@WalletLabel</span>
                            <span id="customer-welcome-account-balance" class="v tnum">
                                @(_wallet is { Exists: true } ? $"€{_wallet.Balance.ToString("F2")}" : Localizer["Welcome_NoBalance"].Value)
                            </span>
                        </div>
                    </div>
                }
                else if (_accountTab == AccountTab.Orders)
                {
                    @if (_historyBusy && _orders is null)
                    {
                        <div class="wl-hist-empty"><span class="spinner"></span></div>
                    }
                    else if (_orders is null or { Orders.Count: 0 })
                    {
                        <div id="customer-welcome-account-orders-empty" class="wl-hist-empty">@Localizer["Welcome_NoOrdersYet"]</div>
                    }
                    else
                    {
                        <div id="customer-welcome-account-orders" class="wl-hist">
                            @foreach (var o in _orders!.Orders)
                            {
                                <div id="customer-welcome-account-order-@o.OrderId" class="wl-hist-row" role="button" tabindex="0"
                                     @onclick="@(() => Nav.NavigateTo($"/track/{o.OrderId}"))"
                                     @onkeydown="@(e => { if (e.Key is "Enter" or " ") Nav.NavigateTo($"/track/{o.OrderId}"); })">
                                    <div class="wl-hist-main">
                                        <div class="wl-hist-title">@string.Join(" · ", o.Items.Select(i => $"{i.Quantity}× {i.DrinkName}"))</div>
                                        <div class="wl-hist-sub tnum">
                                            @o.CreatedAt.ToLocalTime().ToString("dd.MM. HH:mm")
                                            <span class="wl-hist-status">· @OrderStatusText(o.Status)</span>
                                        </div>
                                    </div>
                                    <div class="wl-hist-amt tnum">€@o.TotalAmount.ToString("F2")</div>
                                </div>
                            }
                        </div>
                        <div id="customer-welcome-account-orders-total" class="wl-hist-foot">
                            <span class="k">@Localizer["Welcome_TotalSpent"]</span>
                            <span class="v tnum">€@_orders!.TotalSpent.ToString("F2")</span>
                        </div>
                    }
                }
                else
                {
                    @if (_historyBusy && _txns is null)
                    {
                        <div class="wl-hist-empty"><span class="spinner"></span></div>
                    }
                    else if (_txns is null or { Transactions.Count: 0 })
                    {
                        <div id="customer-welcome-account-txns-empty" class="wl-hist-empty">@Localizer["Welcome_NoWalletActivity"]</div>
                    }
                    else
                    {
                        <div id="customer-welcome-account-txns" class="wl-hist">
                            @foreach (var t in _txns!.Transactions)
                            {
                                @* Debits are stored as negative amounts; the sign drives both the label colour
                                   and the explicit +/- so a spend never reads as a top-up. *@
                                var credit = t.Amount >= 0;
                                <div id="customer-welcome-account-txn-@t.Id" class="wl-hist-row">
                                    <div class="wl-hist-main">
                                        <div class="wl-hist-title">@TransactionText(t)</div>
                                        <div class="wl-hist-sub tnum">@t.CreatedAt.ToLocalTime().ToString("dd.MM. HH:mm")</div>
                                    </div>
                                    <div class="wl-hist-amt tnum @(credit ? "in" : "out")">
                                        @(credit ? "+" : "−")€@Math.Abs(t.Amount).ToString("F2")
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            </div>

            @* Hand off to the wallet sheet rather than duplicating its top-up/withdraw form here. *@
            <button id="customer-welcome-account-topup-btn" class="btn wl-scan wl-sheet-pay"
                    @onclick="@(() => { _accountOpen = false; OpenTopup(); })">
                @Localizer["Welcome_TopUpButton"]
            </button>
        </div>
    }

    @* Online wallet bottom sheet — opened by tapping the wallet balance. Top up (card charge) or withdraw
       (refund to card) the session's wallet — the registered HALFTIME account wallet, or the ticket's bearer
       balance — via the payment gateway. *@
    @if (_sheetOpen)
    {
        <div id="customer-welcome-topup-scrim" class="wl-sheet-scrim" @onclick="CloseSheet"></div>
        <div id="customer-welcome-topup-sheet" class="wl-sheet" role="dialog" aria-modal="true" aria-label="@Localizer["Welcome_WalletSheetLabel"]">
            <div class="wl-sheet-grip" aria-hidden="true"></div>
            <div class="wl-sheet-head">
                <div>
                    <div id="customer-welcome-topup-title" class="wl-sheet-title">@(_withdrawMode ? Localizer["Welcome_WithdrawTitle"] : Localizer["Welcome_TopUpSheetTitle"])</div>
                    <div class="wl-sheet-sub">@WalletLabel</div>
                </div>
                <button id="customer-welcome-topup-close" class="wl-sheet-x" @onclick="CloseSheet" aria-label="@Localizer["Welcome_CloseLabel"]">✕</button>
            </div>

            @* Segmented toggle between top-up and withdraw. Withdraw is disabled with no balance to pay out. *@
            <div id="customer-welcome-sheet-modes" class="wl-seg" role="tablist" aria-label="@Localizer["Welcome_ModeLabel"]">
                <button id="customer-welcome-mode-topup" class="wl-seg-btn @(_withdrawMode ? "" : "on")"
                        role="tab" aria-selected="@(!_withdrawMode)" @onclick="@(() => SetSheetMode(false))">@Localizer["Welcome_TopUpMode"]</button>
                <button id="customer-welcome-mode-withdraw" class="wl-seg-btn @(_withdrawMode ? "on" : "")"
                        role="tab" aria-selected="@_withdrawMode"
                        disabled="@(!(_wallet is { Exists: true } && _wallet.Balance > 0))"
                        @onclick="@(() => SetSheetMode(true))">@Localizer["Welcome_WithdrawMode"]</button>
            </div>

            @if (!_withdrawMode)
            {
                @* --- Top up (charge card → credit wallet) --- *@
                <div id="customer-welcome-topup-chips" class="wl-amt-chips">
                    @foreach (var p in _presets)
                    {
                        <button id="customer-welcome-topup-preset-@p" class="wl-amt-chip @(_topupAmount == p ? "on" : "")"
                                @onclick="@(() => SelectPreset(p))">€@p</button>
                    }
                </div>

                <div class="wl-amt-field">
                    <label for="customer-welcome-topup-amount">@Localizer["Welcome_AmountLabel"]</label>
                    <input id="customer-welcome-topup-amount" type="number" min="1" step="1" inputmode="decimal"
                           @bind="_topupAmount" @bind:event="oninput" />
                </div>

                @if (!string.IsNullOrEmpty(_sheetError))
                {
                    <div id="customer-welcome-topup-error" class="wl-sheet-err" role="alert">@_sheetError</div>
                }

                <button id="customer-welcome-topup-submit" class="btn wl-scan wl-sheet-pay"
                        @onclick="SubmitTopup" disabled="@(_sheetBusy || _topupAmount <= 0)">
                    @if (_sheetBusy)
                    {
                        <span class="spinner"></span> <span>@Localizer["Welcome_Processing"]</span>
                    }
                    else
                    {
                        <span>@string.Format(Localizer["Welcome_PayAmount"].Value, _topupAmount.ToString("0.##"))</span>
                    }
                </button>
                <p class="wl-sheet-note">@Localizer["Welcome_FundsAvailableNote"]</p>
            }
            else
            {
                @* --- Withdraw (debit wallet → refund to card) --- *@
                <div id="customer-welcome-withdraw-avail" class="wl-withdraw-avail">
                    <span class="k">@Localizer["Welcome_AvailableForWithdraw"]</span>
                    <span id="customer-welcome-withdraw-bal" class="v tnum">€@((_wallet?.Balance ?? 0m).ToString("F2"))</span>
                </div>

                <div class="wl-amt-field">
                    <label for="customer-welcome-withdraw-amount">@Localizer["Welcome_WithdrawAmountLabel"]</label>
                    <input id="customer-welcome-withdraw-amount" type="number" min="1" step="1" inputmode="decimal"
                           @bind="_withdrawAmount" @bind:event="oninput" />
                </div>

                @if (!string.IsNullOrEmpty(_sheetError))
                {
                    <div id="customer-welcome-withdraw-error" class="wl-sheet-err" role="alert">@_sheetError</div>
                }

                <button id="customer-welcome-withdraw-submit" class="btn wl-scan wl-sheet-pay"
                        @onclick="SubmitWithdraw" disabled="@(_sheetBusy || _withdrawAmount <= 0)">
                    @if (_sheetBusy)
                    {
                        <span class="spinner"></span> <span>@Localizer["Welcome_Processing"]</span>
                    }
                    else
                    {
                        <span>@string.Format(Localizer["Welcome_WithdrawAmount"].Value, _withdrawAmount.ToString("0.##"))</span>
                    }
                </button>
                <button id="customer-welcome-withdraw-all" class="wl-linkbtn" @onclick="WithdrawAll" disabled="@_sheetBusy">
                    @Localizer["Welcome_WithdrawAll"]
                </button>
                <p class="wl-sheet-note">@Localizer["Welcome_RefundNote"]</p>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(_toast))
    {
        <div id="customer-welcome-topup-toast" class="wl-toast" role="status">@_toast</div>
    }
</div>

@code {
    private CurrentSeasonDto? _season;
    private VenueDto? _venue;
    private bool _hasSession;
    private WalletSummaryDto? _wallet;

    // Account sheet opened from the header button, and which of its three tabs is showing.
    private bool _accountOpen;
    private AccountTab _accountTab = AccountTab.Details;
    private enum AccountTab { Details, Orders, Wallet }

    // History is loaded lazily per tab and then kept for the rest of the visit — null means "never
    // fetched", an empty list means "fetched, nothing there".
    private SessionOrderHistoryDto? _orders;
    private WalletTransactionListDto? _txns;
    private bool _historyBusy;

    // Wallet bottom sheet (opened by tapping the balance). Top-up and withdraw share the open/busy/error
    // state and toggle via _withdrawMode.
    private bool _sheetOpen;
    private bool _sheetBusy;
    private bool _withdrawMode;
    private string _sheetError = "";
    private decimal _topupAmount = 20m;
    private decimal _withdrawAmount;
    private string _toast = "";
    private static readonly int[] _presets = { 10, 20, 50 };

    // Ticket holder's name for the "welcome back" banner; falls back to a neutral label for anonymous tickets.
    private string FanName => string.IsNullOrWhiteSpace(State.CustomerName) ? Localizer["Welcome_GuestName"].Value : State.CustomerName;

    // Label matches the wallet kind the balance came from: a registered fan's HALFTIME wallet vs the bearer
    // balance loaded on the scanned ticket at the bar counter.
    private string WalletLabel => _wallet is { IsTicketWallet: true } ? Localizer["Welcome_TicketBalance"].Value : Localizer["Welcome_HalftimeWallet"].Value;

    // Fixture name for the expanded details; em dash when the session carries no event name.
    private string EventTitle => string.IsNullOrWhiteSpace(State.EventName) ? "—" : State.EventName;

    private static readonly string[] MonthsHr =
        { "sij", "velj", "ožu", "tra", "svi", "lip", "srp", "kol", "ruj", "lis", "stu", "pro" };

    private bool IsHr => CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "hr";

    // A ticket can only be scanned into an ordering session while a match is actually running, so the
    // scan CTAs hang off the same flag the fixture cards use for their "LIVE" badge. IsLive already
    // means "game-day status, kicked off, not yet ended" (i.e. drink ordering open) — see
    // SeasonService. False while _season is still loading or the API is unreachable, which is the
    // safe default: no scan button rather than one that leads to a dead end.
    private bool _matchLive => _season?.UpcomingEvents.Any(e => e.IsLive) == true;

    // Location line under the hero — driven by the admin Venue Settings (name + city). Falls back
    // to the stadium's own name if no city is set, and to a sensible default if the venue is
    // unavailable (public landing must never break when the API is unreachable).
    private string PlaceLabel
    {
        get
        {
            var name = string.IsNullOrWhiteSpace(_venue?.Name) ? "Stadion Rujevica" : _venue!.Name;
            var city = _venue?.City;
            return string.IsNullOrWhiteSpace(city) ? name : $"{name} · {city}";
        }
    }

    // Absolute URL to the venue-level club logo uploaded in admin Venue Settings. Only rendered
    // when _venue.HasClubLogo is true, so the image endpoint always has content.
    private string ClubLogoUrl =>
        $"{AppConfiguration.ResolveApiBaseUrl(Configuration)}/api/venue/club-logo";

    // Absolute URL to a specific resident club's crest (public endpoint, same as the venue read).
    private string ClubCrestUrl(int clubId) =>
        $"{AppConfiguration.ResolveApiBaseUrl(Configuration)}/api/venue/clubs/{clubId}/logo";

    /// <summary>
    /// The venue's resident club playing at home in this fixture, or null when the home side isn't
    /// one of ours (a fixture staged here between two visiting sides, or a non-versus event).
    /// Prefers the FK the API links at event creation; falls back to a name match so fixtures
    /// created before the link existed — or typed with a slightly different spelling — still get
    /// their real crest.
    /// </summary>
    private ClubDto? ResolveHomeClub(UpcomingEventDto e)
    {
        var clubs = _venue?.Clubs;
        if (clubs is not { Count: > 0 }) return null;

        if (e.HomeClubId is int id)
        {
            var linked = clubs.FirstOrDefault(c => c.Id == id);
            if (linked is not null) return linked;
        }

        var home = ResolveTeams(e).home;
        return string.IsNullOrWhiteSpace(home) ? null : clubs.FirstOrDefault(c => NameMatches(c, home));
    }

    // A club matches a free-text team name on either its full or short name, case-insensitively.
    private static bool NameMatches(ClubDto club, string team) =>
        string.Equals(club.Name, team, StringComparison.OrdinalIgnoreCase)
        || (!string.IsNullOrWhiteSpace(club.ShortName)
            && string.Equals(club.ShortName, team, StringComparison.OrdinalIgnoreCase));

    /// <summary>
    /// Crest image for the home side, or null to fall back to the monogram shield. Prefers the
    /// resolved club's own uploaded logo. The single venue-level logo is used only when the home
    /// side really is the venue's headline club — stamping it on any visiting side that happens to
    /// be nominal home would show fans the wrong badge.
    /// </summary>
    private string? HomeCrestUrl(UpcomingEventDto e, ClubDto? club, string homeTeam)
    {
        if (club is { HasLogo: true }) return ClubCrestUrl(club.Id);
        if (_venue?.HasClubLogo != true) return null;

        var isHeadline = club?.IsPrimary == true
            || (!string.IsNullOrWhiteSpace(_venue.ClubName)
                && string.Equals(_venue.ClubName, homeTeam, StringComparison.OrdinalIgnoreCase));
        return isHeadline ? ClubLogoUrl : null;
    }

    /// <summary>
    /// Public URL of a fixture's generated artwork. Requests the "thumb" variant: the strip renders
    /// up to 20 cards, and serving the multi-MB originals here would cost tens of megabytes on
    /// mobile. The endpoint falls back to the full image for posters saved without a thumbnail.
    /// </summary>
    private string PosterUrl(int eventId) =>
        $"{AppConfiguration.ResolveApiBaseUrl(Configuration)}/events/{eventId}/image?variant=thumb";

    protected override async Task OnInitializedAsync()
    {
        // In-circuit session (soft navigation back to /welcome after a scan) is known immediately.
        _hasSession = State.HasSession;

        // Anonymous landing — these endpoints are public. Fail silently so the panels are optional
        // and the landing never breaks if the API is unreachable.
        try
        {
            _season = await Api.GetAsync<CurrentSeasonDto>("seasons/current");
        }
        catch { /* ignore — panel is optional */ }

        try
        {
            _venue = await Api.GetAsync<VenueDto>("api/venue");
        }
        catch { /* ignore — branding falls back to defaults */ }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // On a fresh page load / QR reopen the in-memory session is gone, but the token was
        // persisted to sessionStorage on scan. Rehydrate it (interactive-only, never during
        // prerender) so the CTA offers "continue ordering" instead of "scan again".
        if (!_hasSession)
        {
            string? token = null;
            try { token = await JS.InvokeAsync<string?>("sessionStorage.getItem", "htSessionToken"); }
            catch { /* prerender / no JS — ignore */ }

            if (!string.IsNullOrEmpty(token))
            {
                if (await State.InitFromTokenAsync(token))
                {
                    _hasSession = true;
                }
                else
                {
                    // Stale/expired token — drop it so we don't keep probing a dead session.
                    try { await JS.InvokeVoidAsync("sessionStorage.removeItem", "htSessionToken"); }
                    catch { /* ignore */ }
                }
            }
        }

        // With a live session, pull the fan's spendable balance for the banner. Best-effort — a failure
        // just leaves the wallet portion showing "no balance"; the name still renders from the session.
        if (_hasSession)
        {
            _wallet = await Api.GetSessionWalletSummaryAsync(State.SessionToken!);
            StateHasChanged();
        }
    }

    private async Task SetCulture(string culture)
    {
        if (culture == CultureInfo.CurrentUICulture.TwoLetterISOLanguageName) return;
        await JS.InvokeVoidAsync("blazorCulture.set", culture);
        Nav.NavigateTo(Nav.Uri, forceLoad: true);
    }

    // ---- Account sheet history ----

    // Fetch on first view of a tab only; the sheet reopens instantly afterwards. Failures leave the DTO
    // null, which renders as the empty state — history is informational and must not break the landing.
    private async Task SwitchAccountTab(AccountTab tab)
    {
        _accountTab = tab;
        if (string.IsNullOrEmpty(State.SessionToken)) return;

        if (tab == AccountTab.Orders && _orders is null)
        {
            _historyBusy = true;
            try { _orders = await Api.GetSessionOrdersAsync(State.SessionToken!); }
            catch (Exception ex) { Console.WriteLine($"Order history failed: {ex.Message}"); }
            finally { _historyBusy = false; }
        }
        else if (tab == AccountTab.Wallet && _txns is null)
        {
            _historyBusy = true;
            try { _txns = await Api.GetSessionWalletTransactionsAsync(State.SessionToken!); }
            catch (Exception ex) { Console.WriteLine($"Wallet history failed: {ex.Message}"); }
            finally { _historyBusy = false; }
        }
    }

    private string OrderStatusText(OrderStatus status) => status switch
    {
        OrderStatus.Pending => Localizer["OrderStatus_Pending"].Value,
        OrderStatus.Accepted => Localizer["OrderStatus_Accepted"].Value,
        OrderStatus.InPreparation => Localizer["OrderStatus_InPreparation"].Value,
        OrderStatus.Ready => Localizer["OrderStatus_Ready"].Value,
        OrderStatus.OutForDelivery => Localizer["OrderStatus_OutForDelivery"].Value,
        OrderStatus.Delivered => Localizer["OrderStatus_Delivered"].Value,
        OrderStatus.Cancelled => Localizer["OrderStatus_Cancelled"].Value,
        OrderStatus.DeliveryFailed => Localizer["OrderStatus_DeliveryFailed"].Value,
        _ => status.ToString()
    };

    // Ledger rows carry a free-text description written server-side; prefer it, and fall back to the
    // reference tag (CashTopup, TicketTopup, …) so a row is never blank.
    private string TransactionText(WalletTransactionDto t)
    {
        if (!string.IsNullOrWhiteSpace(t.Description)) return t.Description!;
        return t.ReferenceType switch
        {
            "CashTopup" or "TicketTopup" => Localizer["Welcome_Txn_TopUp"].Value,
            "TicketCashOut" or "Withdrawal" => Localizer["Welcome_Txn_Withdrawal"].Value,
            "Order" => Localizer["Welcome_Txn_Order"].Value,
            _ => t.Type.ToString()
        };
    }

    // ---- Online wallet top-up / withdrawal ----

    private void OpenTopup()
    {
        _sheetError = "";
        _withdrawMode = false;
        if (_topupAmount <= 0) _topupAmount = 20m;
        _sheetOpen = true;
    }

    private void CloseSheet() => _sheetOpen = false;

    // Switch the sheet between top-up and withdraw. Entering withdraw seeds the amount to the full available
    // balance — "withdraw the remaining funds" is the common case.
    private void SetSheetMode(bool withdraw)
    {
        _withdrawMode = withdraw;
        _sheetError = "";
        if (withdraw)
        {
            var bal = _wallet?.Balance ?? 0m;
            if (_withdrawAmount <= 0 || _withdrawAmount > bal) _withdrawAmount = bal;
        }
    }

    private void WithdrawAll()
    {
        _withdrawAmount = _wallet?.Balance ?? 0m;
        _sheetError = "";
    }

    private void SelectPreset(int amount)
    {
        _topupAmount = amount;
        _sheetError = "";
    }

    // Charge the chosen amount to the wallet behind the scanned ticket. The server resolves which wallet
    // (registered HALFTIME account wallet vs the ticket's bearer balance); we just re-read the summary after
    // so the banner reflects the authoritative balance and correct wallet kind.
    private async Task SubmitTopup()
    {
        if (_sheetBusy || _topupAmount <= 0 || string.IsNullOrEmpty(State.SessionToken)) return;
        _sheetBusy = true;
        _sheetError = "";
        try
        {
            var req = new SessionWalletTopupRequestDto
            {
                SessionToken = State.SessionToken!,
                Amount = _topupAmount,
                Method = "CreditCard",
                IdempotencyKey = Guid.NewGuid().ToString("N")
            };
            var result = await Api.TopUpSessionWalletAsync(req);
            if (result is { Success: true })
            {
                _wallet = await Api.GetSessionWalletSummaryAsync(State.SessionToken!);
                // The money just moved, so the cached ledger is stale — drop it and let the wallet tab refetch.
                _txns = null;
                _sheetOpen = false;
                ShowToast($"Novčanik nadoplaćen · €{result.NewBalance.ToString("F2")}");
            }
            else
            {
                _sheetError = TranslateTopupFailure(result?.FailureReason);
            }
        }
        catch (Exception ex)
        {
            _sheetError = Localizer["Welcome_GeneralError"].Value;
            Console.WriteLine($"Top-up failed: {ex.Message}");
        }
        finally
        {
            _sheetBusy = false;
        }
    }

    // Refund the chosen amount from the session's wallet back to card. Same server-side wallet resolution as
    // top-up; we re-read the summary after so the banner reflects the authoritative balance.
    private async Task SubmitWithdraw()
    {
        var bal = _wallet?.Balance ?? 0m;
        if (_sheetBusy || _withdrawAmount <= 0 || string.IsNullOrEmpty(State.SessionToken)) return;
        if (_withdrawAmount > bal)
        {
            _sheetError = Localizer["Welcome_InsufficientFunds"].Value;
            return;
        }
        _sheetBusy = true;
        _sheetError = "";
        try
        {
            var req = new SessionWalletWithdrawRequestDto
            {
                SessionToken = State.SessionToken!,
                Amount = _withdrawAmount,
                IdempotencyKey = Guid.NewGuid().ToString("N")
            };
            var result = await Api.WithdrawSessionWalletAsync(req);
            if (result is { Success: true })
            {
                _wallet = await Api.GetSessionWalletSummaryAsync(State.SessionToken!);
                // The money just moved, so the cached ledger is stale — drop it and let the wallet tab refetch.
                _txns = null;
                _sheetOpen = false;
                ShowToast($"Isplaćeno €{result.Amount.ToString("F2")} · stanje €{result.NewBalance.ToString("F2")}");
            }
            else
            {
                _sheetError = TranslateWithdrawFailure(result?.FailureReason);
            }
        }
        catch (Exception ex)
        {
            _sheetError = Localizer["Welcome_GeneralError"].Value;
            Console.WriteLine($"Withdraw failed: {ex.Message}");
        }
        finally
        {
            _sheetBusy = false;
        }
    }

    private string TranslateTopupFailure(string? reason) => reason switch
    {
        "LimitExceeded" => Localizer["Welcome_TopupError_LimitExceeded"].Value,
        "WalletFrozen" => Localizer["Welcome_TopupError_WalletFrozen"].Value,
        "GatewayDeclined" => Localizer["Welcome_TopupError_GatewayDeclined"].Value,
        "GatewayUnavailable" => Localizer["Welcome_TopupError_GatewayUnavailable"].Value,
        "SessionExpired" => Localizer["Welcome_TopupError_SessionExpired"].Value,
        "TicketNotFound" => Localizer["Welcome_TopupError_TicketNotFound"].Value,
        "NotEligible" => Localizer["Welcome_TopupError_NotEligible"].Value,
        "InvalidAmount" => Localizer["Welcome_TopupError_InvalidAmount"].Value,
        _ => Localizer["Welcome_TopupError_General"].Value
    };

    private string TranslateWithdrawFailure(string? reason) => reason switch
    {
        "InsufficientFunds" => Localizer["Welcome_WithdrawError_InsufficientFunds"].Value,
        "WalletFrozen" => Localizer["Welcome_WithdrawError_WalletFrozen"].Value,
        "GatewayDeclined" => Localizer["Welcome_WithdrawError_GatewayDeclined"].Value,
        "GatewayUnavailable" => Localizer["Welcome_WithdrawError_GatewayUnavailable"].Value,
        "SessionExpired" => Localizer["Welcome_WithdrawError_SessionExpired"].Value,
        "TicketNotFound" or "WalletNotFound" => Localizer["Welcome_WithdrawError_WalletNotFound"].Value,
        "InvalidAmount" => Localizer["Welcome_WithdrawError_InvalidAmount"].Value,
        _ => Localizer["Welcome_WithdrawError_General"].Value
    };

    private void ShowToast(string message)
    {
        _toast = message;
        _ = Task.Delay(4000).ContinueWith(_ =>
        {
            _toast = "";
            InvokeAsync(StateHasChanged);
        });
    }

    // Prefer the event's explicit team fields; fall back to parsing the title for legacy events that
    // predate the HomeTeam/AwayTeam columns. A non-versus event (concert, one-off) yields an empty
    // away side, which drives the single-title layout.
    private static (string home, string away) ResolveTeams(UpcomingEventDto e)
    {
        if (!string.IsNullOrWhiteSpace(e.HomeTeam) || !string.IsNullOrWhiteSpace(e.AwayTeam))
            return (e.HomeTeam?.Trim() ?? "", e.AwayTeam?.Trim() ?? "");
        return SplitTeams(e.EventName);
    }

    // Legacy fallback: the DTO carries a single "Home – Away" title; split it so each side gets a crest.
    private static (string home, string away) SplitTeams(string eventName)
    {
        var seps = new[] { " - ", " – ", " — ", " vs ", " VS ", " v ", " x " };
        foreach (var s in seps)
        {
            var idx = eventName.IndexOf(s, StringComparison.OrdinalIgnoreCase);
            if (idx > 0)
                return (eventName[..idx].Trim(), eventName[(idx + s.Length)..].Trim());
        }
        return (eventName.Trim(), "");
    }

    // Monogram crest fallback — first letter of each word, up to three, digits ignored.
    private static string Initials(string team)
    {
        if (string.IsNullOrWhiteSpace(team)) return "?";
        var letters = team
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Where(w => char.IsLetter(w[0]))
            .Select(w => char.ToUpperInvariant(w[0]))
            .Take(3);
        var s = string.Concat(letters);
        return s.Length > 0 ? s : "?";
    }

    /// <summary>
    /// Shield colours. A resident club's own palette from admin Venue Settings wins; otherwise we
    /// fall back to the built-in table of known Croatian clubs, then a neutral navy badge.
    /// </summary>
    private static (string a, string b, string fg) CrestColors(string team, ClubDto? club)
    {
        if (club is not null && !string.IsNullOrWhiteSpace(club.PrimaryColor))
        {
            var primary = club.PrimaryColor!;
            // Secondary is optional in venue settings; reuse the primary as the shadow tone so a
            // half-configured club still renders a coherent shield rather than a clashing default.
            var secondary = string.IsNullOrWhiteSpace(club.SecondaryColor) ? primary : club.SecondaryColor!;
            return (primary, secondary, ReadableOn(primary));
        }

        var t = team.ToLowerInvariant();
        if (t.Contains("rijeka")) return ("#1F6FE0", "#0B2B63", "#FFFFFF");
        if (t.Contains("istra")) return ("#2FA83A", "#123A0C", "#F6D50B");
        if (t.Contains("hajduk")) return ("#EDEFF5", "#9AA4B2", "#123A6B");
        if (t.Contains("dinamo")) return ("#1E63C8", "#0C2E63", "#FFFFFF");
        if (t.Contains("osijek")) return ("#1B5FA6", "#0B2E52", "#FFFFFF");
        if (t.Contains("gorica")) return ("#2FA83A", "#123A0C", "#FFFFFF");
        return ("#3A5B87", "#1A2942", "#FFFFFF");
    }

    // Monogram colour for an admin-chosen shield fill: white on dark, near-black on light, so a
    // club that picks a pale primary (e.g. Hajduk white) still has legible initials.
    private static string ReadableOn(string hex)
    {
        var h = hex.TrimStart('#');
        // Expand the #abc shorthand so both CSS forms parse.
        if (h.Length == 3)
            h = string.Concat(h[0], h[0], h[1], h[1], h[2], h[2]);
        if (h.Length < 6
            || !int.TryParse(h[..2], NumberStyles.HexNumber, CultureInfo.InvariantCulture, out var r)
            || !int.TryParse(h.Substring(2, 2), NumberStyles.HexNumber, CultureInfo.InvariantCulture, out var g)
            || !int.TryParse(h.Substring(4, 2), NumberStyles.HexNumber, CultureInfo.InvariantCulture, out var b))
            return "#FFFFFF";

        // Perceived brightness (ITU-R BT.601) — good enough for a two-way text colour choice.
        var luma = (0.299 * r + 0.587 * g + 0.114 * b) / 255.0;
        return luma > 0.6 ? "#12203A" : "#FFFFFF";
    }

    // The day portion of the fixture label. Previous day / Today / Tomorrow for adjacent days;
    // otherwise shown explicitly as "6. srp 2026".
    private string DayLabel(DateTime local)
    {
        var days = (local.Date - DateTime.Today).Days;
        return days switch
        {
            -1 => Localizer["Welcome_Day_Yesterday"].Value,
            0 => Localizer["Welcome_Day_Today"].Value,
            1 => Localizer["Welcome_Day_Tomorrow"].Value,
            _ => $"{local.Day}. {MonthsHr[local.Month - 1]} {local.Year}"
        };
    }

    // Kick-off time, plus the end time as a range when the fixture has an explicit end ("19:00 – 21:00").
    private static string TimeRange(DateTime start, DateTime? end)
        => end is { } e ? $"{start:HH:mm} – {e:HH:mm}" : start.ToString("HH:mm");
}
