@{
    string containerClass = Type switch
    {
        SkeletonType.Card => "skeleton-card-container",
        SkeletonType.Table => "skeleton-table-container",
        SkeletonType.Button => "skeleton-button-container",
        SkeletonType.List => "skeleton-list-container",
        _ => "skeleton-container"
    };
}

<div id="bar-loadingskeleton-container" class="@containerClass">
    @if (Type == SkeletonType.Card)
    {
        <div id="bar-loadingskeleton-card" class="skeleton-card @AdditionalClass">
            <div id="bar-loadingskeleton-card-header" class="skeleton-header">
                <div id="bar-loadingskeleton-card-title" class="skeleton-text skeleton-title"></div>
                <div id="bar-loadingskeleton-card-subtitle" class="skeleton-text skeleton-subtitle"></div>
            </div>
            <div id="bar-loadingskeleton-card-icon" class="skeleton-icon"></div>
        </div>
    }
    else if (Type == SkeletonType.Table)
    {
        <div id="bar-loadingskeleton-table" class="skeleton-table @AdditionalClass">
            <div id="bar-loadingskeleton-table-header" class="skeleton-table-header">
                @for (int i = 0; i < Columns; i++)
                {
                    <div id="bar-loadingskeleton-header-cell-@i" class="skeleton-text skeleton-header-cell"></div>
                }
            </div>
            @for (int row = 0; row < Rows; row++)
            {
                <div id="bar-loadingskeleton-table-row-@row" class="skeleton-table-row">
                    @for (int col = 0; col < Columns; col++)
                    {
                        <div id="bar-loadingskeleton-cell-@row-@col" class="skeleton-text skeleton-cell"></div>
                    }
                </div>
            }
        </div>
    }
    else if (Type == SkeletonType.Button)
    {
        @for (int i = 0; i < Count; i++)
        {
            <div id="bar-loadingskeleton-button-@i" class="skeleton-button @AdditionalClass mb-2"></div>
        }
    }
    else if (Type == SkeletonType.List)
    {
        @for (int i = 0; i < Count; i++)
        {
            <div id="bar-loadingskeleton-list-item-@i" class="skeleton-list-item @AdditionalClass mb-3">
                <div id="bar-loadingskeleton-list-primary-@i" class="skeleton-text skeleton-primary"></div>
                <div id="bar-loadingskeleton-list-secondary-@i" class="skeleton-text skeleton-secondary"></div>
            </div>
        }
    }
    else if (Type == SkeletonType.Text)
    {
        @for (int i = 0; i < Count; i++)
        {
            <div id="bar-loadingskeleton-text-@i" class="skeleton-text @AdditionalClass mb-2" style="width: @(Width ?? "100%");"></div>
        }
    }
    else if (Type == SkeletonType.Circle)
    {
        <div id="bar-loadingskeleton-circle" class="skeleton-circle @AdditionalClass" style="width: @(Width ?? "40px"); height: @(Width ?? "40px");"></div>
    }
    else
    {
        <div id="bar-loadingskeleton-placeholder" class="skeleton-placeholder @AdditionalClass" style="height: @(Height ?? "20px"); width: @(Width ?? "100%");"></div>
    }
</div>

@code {
    [Parameter] public SkeletonType Type { get; set; } = SkeletonType.Text;
    [Parameter] public int Count { get; set; } = 1;
    [Parameter] public int Rows { get; set; } = 3;
    [Parameter] public int Columns { get; set; } = 4;
    [Parameter] public string? Width { get; set; }
    [Parameter] public string? Height { get; set; }
    [Parameter] public string AdditionalClass { get; set; } = "";

    public enum SkeletonType
    {
        Card,
        Table,
        Button,
        List,
        Text,
        Circle,
        Custom
    }
}