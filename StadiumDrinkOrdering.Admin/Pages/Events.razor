@page "/events"
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Shared.DTOs
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Events_PageTitle"]</PageTitle>

<div class="console" id="admin-events-main-container">
    <!-- Page Header -->
    <header class="console-head" id="admin-events-header">
        <div class="console-head__title">
            <span class="eyebrow">@L["Events_Eyebrow"]</span>
            <h1 id="admin-events-title">@L["Events_Title"]</h1>
            <p>@L["Events_Subtitle"]</p>
        </div>
        <div class="console-head__actions">
            <button class="pill-btn pill-btn--primary" @onclick="ShowCreateEventModal" id="admin-events-create-btn">
                <i class="bi bi-plus-circle"></i><span>@L["Events_CreateButton"]</span>
            </button>
        </div>
    </header>

    @if (events == null)
    {
        <div class="loading-state" id="admin-events-loading">
            <span class="loading-spinner" id="admin-events-loading-spinner"></span>
            <p id="admin-events-loading-text">@L["Events_Loading"]</p>
        </div>
    }
    else if (loadingFailed)
    {
        <div class="console-alert console-alert--danger" role="alert" id="admin-events-error">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div id="admin-events-error-actions">
                <strong id="admin-events-error-title">@L["Events_ErrorTitle"]</strong>
                <p class="mb-0" id="admin-events-error-message">@loadingError</p>
                <hr id="admin-events-error-divider">
                <button class="pill-btn" @onclick="async () => await LoadEvents()" id="admin-events-retry-btn">
                    <i class="bi bi-arrow-clockwise"></i><span>@L["Events_RetryButton"]</span>
                </button>
            </div>
        </div>
    }
    else if (!events.Any())
    {
        <div class="empty" id="admin-events-empty">
            <i class="bi bi-calendar-event" id="admin-events-empty-icon"></i>
            <p id="admin-events-empty-title">@L["Events_NoEventsFound"]</p>
            <span id="admin-events-empty-message">@L["Events_EmptyMessage"]</span>
            <div class="mt-3">
                <button class="pill-btn pill-btn--primary" @onclick="ShowCreateEventModal" id="admin-events-first-event-btn">
                    <i class="bi bi-plus-circle"></i><span>@L["Events_CreateFirstButton"]</span>
                </button>
            </div>
        </div>
    }
    else
    {
        <!-- Key Metrics Cards -->
        <section class="metrics metrics--3">
            <article class="metric" id="admin-events-metric-total">
                <div class="metric__head">
                    <span class="metric__label">@L["Events_TotalEventsLabel"]</span>
                    <i class="bi bi-calendar-event metric__icon"></i>
                </div>
                <div class="metric__value mono">@events.Count</div>
                <div class="metric__foot">
                    <span class="metric__hint">@L["Events_TotalEventsHint"]</span>
                </div>
            </article>

            <article class="metric metric--accent" id="admin-events-metric-active">
                <div class="metric__head">
                    <span class="metric__label">@L["Events_OnSaleLabel"]</span>
                    <i class="bi bi-broadcast metric__icon is-ok"></i>
                </div>
                <div class="metric__value mono">@events.Count(e => e.CanSellTickets)</div>
                <div class="metric__foot">
                    <span class="metric__hint">@L["Events_OnSaleHint"]</span>
                </div>
            </article>

            <article class="metric" id="admin-events-metric-capacity">
                <div class="metric__head">
                    <span class="metric__label">@L["Events_TotalCapacityLabel"]</span>
                    <i class="bi bi-people metric__icon"></i>
                </div>
                <div class="metric__value mono">@((events.Any() ? events.Max(e => e.Capacity) : 0).ToString("N0"))</div>
                <div class="metric__foot">
                    <span class="metric__hint">@L["Events_TotalCapacityHint"]</span>
                </div>
            </article>
        </section>

        <!-- Events Grid -->
        <div class="panel" id="admin-events-panel">
            <div class="panel__head">
                <h2 class="panel__title">@L["Events_PanelTitle"] <span class="panel__count mono">@FilteredEvents.Count()</span></h2>
                @if (seasons != null && seasons.Any())
                {
                    <div class="ms-auto d-flex align-items-center gap-2">
                        <label class="form-label mb-0 small text-muted" for="admin-events-season-filter">Season</label>
                        <select id="admin-events-season-filter" class="form-select form-select-sm" style="width:auto" @bind="seasonFilterValue">
                            <option value="">All seasons</option>
                            <option value="none">No season</option>
                            @foreach (var s in seasons.OrderByDescending(x => x.StartDate))
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>
                }
            </div>
            <div class="panel__body">
                <div class="row" id="admin-events-list">
                    @foreach (var evt in FilteredEvents.OrderBy(e => e.Date ?? DateTime.MaxValue))
                    {
                        <div class="col-md-6 col-lg-4 mb-4" id="admin-event-col-@evt.Id">
                            <div class="panel event-card" id="admin-event-card-@evt.Id">
                                <div class="panel__head" id="admin-event-header-@evt.Id">
                                    <h3 class="panel__title" id="admin-event-header-content-@evt.Id">
                                        <span id="admin-event-name-@evt.Id">@evt.Name</span>
                                    </h3>
                                    <span class="status @StatusBadgeClass(evt.Status)" id="admin-event-status-badge-@evt.Id" title="Phase: @evt.Phase">
                                        <span class="status__dot"></span>@StatusDisplay(evt.Status)
                                    </span>
                                </div>
                                <div class="panel__body" id="admin-event-body-@evt.Id">
                                    <dl class="event-meta" id="admin-event-details-@evt.Id">
                                        <dt><i class="bi bi-calendar3"></i> @L["Events_DateLabel"]</dt>
                                        <dd class="mono" id="admin-event-date-@evt.Id">@evt.Date?.ToString("MMM dd, yyyy HH:mm")</dd>
                                        <dt><i class="bi bi-geo-alt"></i> @L["Events_LocationLabel"]</dt>
                                        <dd id="admin-event-location-@evt.Id">@evt.Location</dd>
                                        <dt><i class="bi bi-person-fill"></i> @L["Events_CapacityLabel"]</dt>
                                        <dd class="mono" id="admin-event-capacity-@evt.Id">@evt.Capacity.ToString("N0") @L["Events_SeatsLabel"]</dd>
                                        <dt><i class="bi bi-cash"></i> @L["Events_BasePriceLabel"]</dt>
                                        <dd class="mono" id="admin-event-price-@evt.Id">$@evt.BasePrice.ToString("F2")</dd>
                                        <dt><i class="bi bi-calendar-range"></i> Season</dt>
                                        <dd id="admin-event-season-@evt.Id">
                                            @if (!string.IsNullOrEmpty(evt.SeasonName))
                                            {
                                                <span class="status is-active"><span class="status__dot"></span>@evt.SeasonName</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </dd>
                                        <dt><i class="bi bi-diagram-3"></i> @L["Events_PhaseLabel"]</dt>
                                        <dd id="admin-event-phase-@evt.Id">
                                            @evt.Phase
                                            @if (evt.CanSellTickets)
                                            {
                                                <span class="status is-accepted ms-2" id="admin-event-selling-@evt.Id"><span class="status__dot"></span>@L["Events_SellingStatus"]</span>
                                            }
                                            @if (evt.CanOrderDrinks)
                                            {
                                                <span class="status is-active ms-2" id="admin-event-ordering-@evt.Id"><span class="status__dot"></span>@L["Events_OrdersStatus"]</span>
                                            }
                                        </dd>
                                    </dl>
                                    @if (!string.IsNullOrEmpty(evt.Description))
                                    {
                                        <p class="event-card__desc" id="admin-event-description-@evt.Id">@evt.Description</p>
                                    }
                                </div>
                                <div class="event-card__foot" id="admin-event-footer-@evt.Id">
                                    <div class="event-card__actions" id="admin-event-buttons-@evt.Id">
                                        <button class="pill-btn" @onclick="() => ShowEditEventModal(evt)" id="admin-event-edit-btn-@evt.Id">
                                            <i class="bi bi-pencil"></i><span>@L["Events_EditButton"]</span>
                                        </button>
                                        <a class="pill-btn" href="admin/stadium-overview?eventId=@evt.Id" id="admin-event-occupancy-btn-@evt.Id">
                                            <i class="bi bi-graph-up-arrow"></i><span>@L["Events_LiveOccupancyButton"]</span>
                                        </a>
                                        @foreach (var target in EventLifecycle.AllowedNextStatuses(evt.Status))
                                        {
                                            var meta = TransitionMeta(target);
                                            <button class="@TransitionButtonClass(target)" @onclick="() => TransitionStatus(evt, target)" id="admin-event-transition-@(target.ToString().ToLowerInvariant())-btn-@evt.Id">
                                                <i class="bi @meta.Icon"></i><span>@meta.Label</span>
                                            </button>
                                        }
                                        <button class="pill-btn pill-btn--danger" @onclick="() => DeleteEvent(evt.Id)" id="admin-event-delete-btn-@evt.Id">
                                            <i class="bi bi-trash"></i><span>@L["Events_DeleteButton"]</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- Create/Edit Event Modal -->
@if (showEventModal)
{
    <div id="admin-event-modal">
        <div class="modal-dialog" id="admin-event-modal-dialog">
            <div class="modal-content" id="admin-event-modal-content">
                <div class="modal-header" id="admin-event-modal-header">
                    <h5 class="modal-title" id="admin-event-modal-title">@(editingEvent == null ? @L["Events_CreateModalTitle"] : @L["Events_EditModalTitle"])</h5>
                    <button type="button" class="btn-close" @onclick="HideEventModal" id="admin-event-modal-close"></button>
                </div>
                <div class="modal-body" id="admin-event-modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">@L["Events_EventNameLabel"]</label>
                                <input type="text" class="form-control" @bind="eventForm.Name" required id="admin-event-form-name">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">@L["Events_LocationFieldLabel"]</label>
                                <input type="text" class="form-control" @bind="eventForm.Location" required id="admin-event-form-location">
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">@L["Events_DescriptionFieldLabel"]</label>
                        <textarea class="form-control" rows="3" @bind="eventForm.Description" id="admin-event-form-description"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">@L["Events_StartDateTimeLabel"]</label>
                                <input type="datetime-local" class="form-control" @bind="eventForm.Date" required id="admin-event-form-date">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">@L["Events_EndDateTimeLabel"]</label>
                                <input type="datetime-local" class="form-control" @bind="eventForm.EndDate" required id="admin-event-form-end-date">
                                @if (eventForm.EndDate <= eventForm.Date)
                                {
                                    <div class="text-danger small mt-1">@L["Events_EndAfterStartValidation"]</div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">@L["Events_CapacityFieldLabel"]</label>
                                <input type="number" class="form-control" @bind="eventForm.Capacity" min="1" required id="admin-event-form-capacity">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">@L["Events_BasePriceFieldLabel"]</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" @bind="eventForm.BasePrice"
                                           step="0.01" min="0" required id="admin-event-form-price">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">@L["Events_StatusFieldLabel"]</label>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" @bind="eventForm.IsActive" id="admin-event-form-active">
                                    <label class="form-check-label">
                                        @L["Events_ActiveLabel"]
                                    </label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label"><i class="bi bi-calendar-range"></i> Season</label>
                                <select class="form-control" @bind="eventForm.SeasonId" id="admin-event-form-season">
                                    <option value="">(no season)</option>
                                    @if (seasons != null)
                                    {
                                        @foreach (var s in seasons.OrderByDescending(x => x.StartDate))
                                        {
                                            <option value="@s.Id">@s.Name @(s.IsCurrent ? "(current)" : "")</option>
                                        }
                                    }
                                </select>
                                <div class="form-text">Linking backfills this season's passes with a match ticket.</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer" id="admin-event-modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HideEventModal" id="admin-event-modal-cancel-btn">
                        @L["Events_CancelButton"]
                    </button>
                    <button type="button" class="btn btn-primary" @onclick="SaveEvent" disabled="@isSaving" id="admin-event-modal-save-btn">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        @(editingEvent == null ? @L["Events_CreateEventButton"] : @L["Events_SaveChangesButton"])
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(alertMessage))
{
    <div class="position-fixed top-0 end-0 p-3" style="z-index: 1055;" id="admin-event-alert-container">
        <div class="console-alert @(alertType == "success" ? "console-alert--success" : "console-alert--danger")" id="admin-event-alert">
            <i class="bi @(alertType == "success" ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
            <span>@alertMessage</span>
            <button type="button" class="icon-btn" @onclick="ClearAlert" id="admin-event-alert-close" style="margin-left: auto;">
                <i class="bi bi-x"></i>
            </button>
        </div>
    </div>
}