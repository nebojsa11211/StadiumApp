@page "/my-deliveries"
@implements IDisposable
@inject RunnerApiService Api
@inject OutboxService Outbox
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["MyDeliveries_PageTitle"]</PageTitle>

<div class="runner-page" id="runner-my-deliveries-page">
    <div class="runner-page-head" id="runner-my-deliveries-page-head">
        <h1 class="runner-page-title" id="runner-my-deliveries-title">@Localizer["MyDeliveries_Title"]</h1>
        <button class="runner-refresh" @onclick="Load" aria-label="@Localizer["MyDeliveries_Refresh"]" id="runner-mine-refresh">↻</button>
    </div>

    @if (loading && mine is null)
    {
        <div class="runner-loading" id="runner-my-deliveries-loading"><div class="runner-cta-spinner" id="runner-my-deliveries-spinner"></div></div>
    }
    else if (active.Count == 0 && syncing.Count == 0)
    {
        <div class="runner-empty" id="runner-my-deliveries-empty">
            <div class="runner-empty-icon" id="runner-my-deliveries-empty-icon" aria-hidden="true">✅</div>
            <div class="runner-empty-text" id="runner-my-deliveries-empty-text">@Localizer["MyDeliveries_EmptyMessage"] <a href="/" id="runner-my-deliveries-pool-link">@Localizer["MyDeliveries_PoolLink"]</a>.</div>
        </div>
    }
    else
    {
        @foreach (var o in active)
        {
            <div class="runner-card" id="runner-mine-card-@o.Id">
                <div class="runner-card-top" id="@($"runner-mine-card-{o.Id}-top")">
                    <span class="runner-seat-label">@Localizer["MyDeliveries_SeatLabel"]</span>
                    <span class="runner-card-meta"><span class="runner-order-id">#@o.Id</span></span>
                </div>
                <div class="runner-seat" id="@($"runner-mine-card-{o.Id}-seat")">@SeatText(o)</div>
                <div class="runner-items" id="@($"runner-mine-card-{o.Id}-items")">
                    @foreach (var it in o.OrderItems)
                    {
                        <div id="@($"runner-mine-card-{o.Id}-item-{o.OrderItems.IndexOf(it)}")"><span class="runner-qty">@it.Quantity×</span> @it.DrinkName</div>
                    }
                </div>
                <div class="runner-total" id="runner-mine-total-@o.Id">
                    <span class="runner-total-label">@Localizer["Home_TotalLabel"]</span>
                    <span class="runner-total-amount">€@o.TotalAmount.ToString("F2")</span>
                </div>
                <button class="runner-cta" @onclick="() => Deliver(o.Id)" id="runner-mine-delivered-@o.Id">
                    <span class="runner-cta-icon" aria-hidden="true">✓</span>
                    <span>@Localizer["MyDeliveries_MarkDeliveredButton"]</span>
                </button>
                <button class="runner-cta runner-cta-secondary" @onclick="() => OpenReasonSheet(o.Id)" id="runner-mine-cant-deliver-@o.Id">
                    <span class="runner-cta-icon" aria-hidden="true">↩</span>
                    <span>@Localizer["MyDeliveries_CantDeliverButton"]</span>
                </button>
            </div>
        }

        @if (syncing.Count > 0)
        {
            <div class="runner-sync-head" id="runner-my-deliveries-sync-head">@(syncing.Any(o => Outbox.IsPendingDeliveryFailed(o.Id)) ? Localizer["MyDeliveries_ReturnedSection"] : Localizer["MyDeliveries_DeliveredSection"]) (@syncing.Count)</div>
            @foreach (var o in syncing)
            {
                <div class="runner-card runner-card-pending" id="runner-mine-pending-@o.Id">
                    <div class="runner-card-top" id="@($"runner-mine-pending-{o.Id}-top")">
                        <span class="runner-seat-label">@Localizer["MyDeliveries_SeatLabel"]</span>
                        @if (Outbox.IsOnline)
                        {
                            <span class="runner-pending-badge runner-pending-badge-sync" id="@($"runner-mine-pending-{o.Id}-sync")">⏳ @Localizer["MyDeliveries_SyncingBadge"]</span>
                        }
                        else
                        {
                            <span class="runner-pending-badge runner-pending-badge-offline" id="@($"runner-mine-pending-{o.Id}-offline")">⚠ @Localizer["MyDeliveries_OfflineBadge"]</span>
                        }
                    </div>
                    <div class="runner-seat" id="@($"runner-mine-pending-{o.Id}-seat")">@SeatText(o)</div>
                    <div class="runner-items" id="@($"runner-mine-pending-{o.Id}-items")">
                        <span class="runner-order-id">#@o.Id</span> · @(Outbox.IsPendingDeliveryFailed(o.Id) ? Localizer["MyDeliveries_MarkedReturned"] : Localizer["MyDeliveries_MarkedDelivered"])
                    </div>
                </div>
            }
        }
    }
</div>

@if (failingOrderId is not null)
{
    <div class="runner-sheet-backdrop" @onclick="CloseReasonSheet" id="runner-mine-reason-backdrop">
        <div class="runner-sheet" @onclick:stopPropagation="true" role="dialog" aria-modal="true" id="runner-mine-reason-sheet">
            <div class="runner-sheet-title" id="runner-mine-reason-title">@Localizer["MyDeliveries_ReasonSheetTitle"]</div>
            <div class="runner-sheet-hint" id="runner-mine-reason-hint">@Localizer["MyDeliveries_ReasonSheetHint"]</div>
            <button class="runner-sheet-option" @onclick="() => PickReason(DeliveryFailureReason.CustomerNotAtSeat)" id="runner-mine-reason-not-at-seat">@Localizer["MyDeliveries_ReasonNotAtSeat"]</button>
            <button class="runner-sheet-option" @onclick="() => PickReason(DeliveryFailureReason.CustomerRefused)" id="runner-mine-reason-refused">@Localizer["MyDeliveries_ReasonRefused"]</button>
            <button class="runner-sheet-option" @onclick="() => PickReason(DeliveryFailureReason.WrongSeat)" id="runner-mine-reason-wrong-seat">@Localizer["MyDeliveries_ReasonWrongSeat"]</button>
            <button class="runner-sheet-option" @onclick="() => PickReason(DeliveryFailureReason.Other)" id="runner-mine-reason-other">@Localizer["MyDeliveries_ReasonOther"]</button>
            <button class="runner-sheet-cancel" @onclick="CloseReasonSheet" id="runner-mine-reason-cancel">@Localizer["MyDeliveries_ReasonCancel"]</button>
        </div>
    </div>
}

@code {
    private List<OrderDto>? mine;
    private List<OrderDto> active = new();
    private List<OrderDto> syncing = new();
    private bool loading;
    // The order whose "why couldn't you deliver?" reason sheet is open, or null when none is.
    private int? failingOrderId;

    protected override async Task OnInitializedAsync()
    {
        Outbox.OnChange += OnOutboxChanged;
        await Load();
    }

    private async Task Load()
    {
        loading = true;
        mine = await Api.GetMyDeliveriesAsync();
        Recompute();
        loading = false;
        StateHasChanged();
    }

    private void Recompute()
    {
        var outForDelivery = mine?.Where(o => o.Status == OrderStatus.OutForDelivery).ToList() ?? new();
        // An order whose delivery OR couldn't-deliver report is queued in the outbox is shown as
        // "syncing", not still-to-deliver — so tapping either action drops the card immediately.
        bool Queued(OrderDto o) => Outbox.IsPendingDeliver(o.Id) || Outbox.IsPendingDeliveryFailed(o.Id);
        active = outForDelivery.Where(o => !Queued(o)).ToList();
        syncing = outForDelivery.Where(Queued).ToList();
    }

    private void OpenReasonSheet(int orderId)
    {
        failingOrderId = orderId;
        _ = Haptic();
    }

    private void CloseReasonSheet() => failingOrderId = null;

    private async Task PickReason(DeliveryFailureReason reason)
    {
        var orderId = failingOrderId;
        failingOrderId = null;
        if (orderId is null) return;

        await Haptic();
        // Optimistic + offline-safe: queue the report, reflect immediately, let the outbox sync later.
        await Outbox.EnqueueDeliveryFailedAsync(orderId.Value, reason);
        Recompute();
        StateHasChanged();
    }

    private async Task Haptic()
    {
        try { await JS.InvokeVoidAsync("runnerHaptic", 15); } catch { /* JS unavailable — ignore */ }
    }

    private async Task Deliver(int orderId)
    {
        try { await JS.InvokeVoidAsync("runnerHaptic", 15); } catch { /* JS unavailable — ignore */ }
        // Optimistic + offline-safe: queue it, reflect immediately, let the outbox sync when possible.
        await Outbox.EnqueueDeliverAsync(orderId);
        Recompute();
        StateHasChanged();
    }

    // Full seat location from the server (section · row · seat), falling back to the short seat
    // number and finally an em dash when neither is present.
    private static string SeatText(OrderDto o)
    {
        if (!string.IsNullOrWhiteSpace(o.SeatPath)) return o.SeatPath;
        return string.IsNullOrWhiteSpace(o.SeatNumber) ? "—" : o.SeatNumber;
    }

    private void OnOutboxChanged() => InvokeAsync(() =>
    {
        Recompute();     // instant: reflect new pending set against the data we already have
        StateHasChanged();
        _ = Load();      // background: reconcile against the server (drops synced-then-Delivered orders)
    });

    public void Dispose() => Outbox.OnChange -= OnOutboxChanged;
}
