@page "/admin/wallets"
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Admin.Services
@using StadiumDrinkOrdering.Admin.Common
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Wallets_PageTitle"]</PageTitle>

<div class="console" id="admin-wallets-main-container">
    <PageHeader Id="admin-wallets-header"
                Eyebrow='@L["Wallets_Eyebrow"]'
                Title='@L["Wallets_Title"]'
                Subtitle='@L["Wallets_Intro"]'>
        <Actions>
            <input type="text" class="form-control" style="max-width:260px;" placeholder="@L["Wallets_SearchPlaceholder"]"
                   @bind="search" @bind:event="oninput" @onkeyup="OnSearchKey" id="admin-wallets-search" />
            <button class="pill-btn pill-btn--primary" @onclick="Load" id="admin-wallets-search-btn">
                <i class="bi bi-search"></i><span>@L["Wallets_Search"]</span>
            </button>
        </Actions>
    </PageHeader>

    @if (list == null)
    {
        <div class="loading-state" id="admin-wallets-loading">
            <span class="loading-spinner"></span><p id="admin-wallets-loading-text">@L["Wallets_Loading"]</p>
        </div>
    }
    else if (!list.Wallets.Any())
    {
        <div class="empty" id="admin-wallets-empty">
            <i class="bi bi-wallet2"></i>
            <p id="admin-wallets-empty-title">@L["Wallets_NoneTitle"]</p>
            <span id="admin-wallets-empty-desc">@L["Wallets_NoneDesc"]</span>
        </div>
    }
    else
    {
        <div class="table-responsive" id="admin-wallets-table-responsive">
            <table class="table align-middle" id="admin-wallets-table">
                <thead id="admin-wallets-thead">
                    <tr id="admin-wallets-header-row">
                        <th class="sortable @(sortState.IsSorted("user") ? "is-sorted" : "")" @onclick='() => SortBy("user")' id="admin-wallets-header-user">@L["Wallets_ColUser"]<span class="sort-ind">@sortState.Indicator("user")</span></th>
                        <th class="text-end sortable @(sortState.IsSorted("balance") ? "is-sorted" : "")" @onclick='() => SortBy("balance")' id="admin-wallets-header-balance">@L["Wallets_ColBalance"]<span class="sort-ind">@sortState.Indicator("balance")</span></th>
                        <th class="sortable @(sortState.IsSorted("status") ? "is-sorted" : "")" @onclick='() => SortBy("status")' id="admin-wallets-header-status">@L["Wallets_ColStatus"]<span class="sort-ind">@sortState.Indicator("status")</span></th>
                        <th class="text-end" id="admin-wallets-header-actions">@L["Wallets_ColActions"]</th>
                    </tr>
                </thead>
                <tbody id="admin-wallets-tbody">
                    @{ pager.Source = SortedWallets.ToList(); }
                    @foreach (var w in pager.PageItems)
                    {
                        <tr id="admin-wallet-row-@w.WalletId">
                            <td>
                                <div class="fw-semibold" id="admin-wallet-owner-@w.WalletId">
                                    @if (w.OwnerType == "Ticket")
                                    {
                                        <span class="badge bg-info-subtle text-info-emphasis me-1">🎟️ @L["Wallets_TicketBadge"]</span>
                                    }
                                    @OwnerName(w)
                                </div>
                                <div class="text-muted small">@OwnerSub(w)</div>
                            </td>
                            <td class="text-end fw-bold" id="admin-wallet-balance-@w.WalletId">@FormatMoney(w.Balance, w.Currency)</td>
                            <td>
                                <span class="badge @(w.Status == WalletStatus.Active ? "bg-success" : w.Status == WalletStatus.Frozen ? "bg-danger" : "bg-secondary")"
                                      id="admin-wallet-status-@w.WalletId">@w.Status</span>
                            </td>
                            <td class="text-end">
                                <button class="pill-btn" @onclick="() => OpenManage(w)" id="admin-wallet-manage-btn-@w.WalletId">
                                    <i class="bi bi-gear"></i><span>@L["Wallets_Manage"]</span>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <TablePager TItem="WalletAdminDto" View="pager" IdPrefix="admin-wallets-table" OnChanged="StateHasChanged" />
    }
</div>

@if (managed != null)
{
    <div id="admin-wallet-modal">
        <div class="modal-dialog modal-lg" id="admin-wallet-modal-dialog">
            <div class="modal-content" id="admin-wallet-modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="admin-wallet-modal-title">
                        @L["Wallets_ManageTitle"]: @OwnerName(managed)
                        <span class="badge @(managed.Status == WalletStatus.Active ? "bg-success" : "bg-danger") ms-2">@managed.Status</span>
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => managed = null" id="admin-wallet-modal-close"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <div class="text-muted small">@L["Wallets_ColBalance"]</div>
                            <div class="h4 mb-0" id="admin-wallet-modal-balance">@FormatMoney(managed.Balance, managed.Currency)</div>
                        </div>
                        @if (managed.Status == WalletStatus.Active)
                        {
                            <button class="btn btn-outline-danger" @onclick="Freeze" disabled="@busy" id="admin-wallet-freeze-btn">
                                <i class="bi bi-snow"></i> @L["Wallets_Freeze"]
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-success" @onclick="Unfreeze" disabled="@busy" id="admin-wallet-unfreeze-btn">
                                <i class="bi bi-fire"></i> @L["Wallets_Unfreeze"]
                            </button>
                        }
                    </div>

                    <div class="row g-3 mb-3" id="admin-wallet-modal-actions-row">
                        <div class="col-md-6" id="admin-wallet-modal-adjust-col">
                            <div class="card h-100" id="admin-wallet-adjust-card"><div class="card-body" id="admin-wallet-adjust-body">
                                <h6 id="admin-wallet-adjust-title">@L["Wallets_Adjust"]</h6>
                                <input type="number" step="0.01" class="form-control mb-2" placeholder="@L["Wallets_AmountSigned"]"
                                       @bind="adjustAmount" id="admin-wallet-adjust-amount" />
                                <input type="text" class="form-control mb-2" placeholder="@L["Wallets_Reason"]"
                                       @bind="adjustReason" id="admin-wallet-adjust-reason" />
                                <button class="btn btn-primary w-100" @onclick="Adjust"
                                        disabled="@(busy || adjustAmount == 0 || string.IsNullOrWhiteSpace(adjustReason))" id="admin-wallet-adjust-btn">
                                    @L["Wallets_ApplyAdjust"]
                                </button>
                            </div></div>
                        </div>
                        <div class="col-md-6" id="admin-wallet-modal-refund-col">
                            <div class="card h-100" id="admin-wallet-refund-card"><div class="card-body" id="admin-wallet-refund-body">
                                <h6 id="admin-wallet-refund-title">@L["Wallets_Refund"]</h6>
                                <input type="number" step="0.01" min="0.01" class="form-control mb-2" placeholder="@L["Wallets_Amount"]"
                                       @bind="refundAmount" id="admin-wallet-refund-amount" />
                                <input type="text" class="form-control mb-2" placeholder="@L["Wallets_Reason"]"
                                       @bind="refundReason" id="admin-wallet-refund-reason" />
                                <button class="btn btn-success w-100" @onclick="Refund"
                                        disabled="@(busy || refundAmount <= 0 || string.IsNullOrWhiteSpace(refundReason))" id="admin-wallet-refund-btn">
                                    @L["Wallets_ApplyRefund"]
                                </button>
                            </div></div>
                        </div>
                    </div>

                    <h6 id="admin-wallet-ledger-title">@L["Wallets_Ledger"]</h6>
                    @if (ledger == null)
                    {
                        <p class="text-muted small" id="admin-wallet-ledger-loading">@L["Wallets_Loading"]</p>
                    }
                    else if (ledger.Transactions.Count == 0)
                    {
                        <p class="text-muted small" id="admin-wallet-ledger-empty">@L["Wallets_LedgerEmpty"]</p>
                    }
                    else
                    {
                        <div class="table-responsive" style="max-height:280px;overflow:auto;" id="admin-wallet-ledger-responsive">
                            <table class="table table-sm" id="admin-wallet-ledger-table">
                                <thead id="admin-wallet-ledger-thead"><tr id="admin-wallet-ledger-header-row">
                                    <th id="admin-wallet-ledger-header-date">@L["Wallets_LedgerDate"]</th>
                                    <th id="admin-wallet-ledger-header-type">@L["Wallets_LedgerType"]</th>
                                    <th id="admin-wallet-ledger-header-reason">@L["Wallets_Reason"]</th>
                                    <th class="text-end" id="admin-wallet-ledger-header-amount">@L["Wallets_Amount"]</th>
                                    <th class="text-end" id="admin-wallet-ledger-header-after">@L["Wallets_LedgerAfter"]</th>
                                </tr></thead>
                                <tbody id="admin-wallet-ledger-tbody">
                                    @foreach (var t in ledger.Transactions)
                                    {
                                        <tr id="@($"admin-wallet-ledger-row-{t.Id}")">
                                            <td class="small text-nowrap">@t.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>@t.Type</td>
                                            <td class="small text-muted">@t.Description</td>
                                            <td class="text-end fw-bold @(t.Amount < 0 ? "text-danger" : "text-success")">
                                                @(t.Amount < 0 ? "" : "+")@FormatMoney(t.Amount, managed.Currency)
                                            </td>
                                            <td class="text-end">@FormatMoney(t.BalanceAfter, managed.Currency)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => managed = null" id="admin-wallet-modal-close-btn">@L["Wallets_Close"]</button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(alertMessage))
{
    <div class="position-fixed top-0 end-0 p-3" style="z-index: 1055;" id="admin-wallet-alert-container">
        <div class="console-alert @(alertType == "success" ? "console-alert--success" : "console-alert--danger")" id="admin-wallet-alert">
            <i class="bi @(alertType == "success" ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
            <span>@alertMessage</span>
            <button type="button" class="icon-btn" @onclick="() => alertMessage = string.Empty" style="margin-left:auto;" id="admin-wallet-alert-close">
                <i class="bi bi-x"></i>
            </button>
        </div>
    </div>
}
