@inherits LayoutComponentBase

<div class="sim-shell">
    <header class="sim-topbar">
        <span class="sim-brand"><i class="bi bi-cpu"></i> Stadium Ticketing Simulator</span>
        <span class="sim-tag">external system stand-in</span>
    </header>
    <main class="sim-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
