@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Customer.Components
@inject ICustomerAuthStateService AuthStateService

<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <AuthenticationInitializer>
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(MobileShell)" />
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </AuthenticationInitializer>
    </Found>
    <NotFound>
        <PageTitle>Stranica nije pronađena — HALFTIME</PageTitle>
        <LayoutView Layout="@typeof(MobileShell)">
            <ScreenHeader Title="Nije pronađeno" BackHref="/" />
            <div class="gate" role="alert">
                <div class="gate-icon">🔍</div>
                <h2>Ništa ovdje</h2>
                <p>Stranica koju tražiš ne postoji ili je premještena.</p>
                <div class="gate-actions">
                    <a class="btn btn-primary" href="/">Početna</a>
                </div>
            </div>
        </LayoutView>
    </NotFound>
</Router>

@code {
    protected override async Task OnInitializedAsync()
    {
        await AuthStateService.InitializeAsync();
    }
}
