@page "/logs"

<PageTitle>@L["Logs_PageTitle"]</PageTitle>

@inject IStringLocalizer<SharedResources> L

<div class="console" id="admin-logs-main-container">
    <!-- Page Header -->
    <header class="console-head" id="admin-logs-header">
        <div class="console-head__title" id="admin-logs-header-title">
            <span class="eyebrow">@L["Logs_EyebrowText"]</span>
            <h1 id="admin-logs-main-heading">@L["Logs_MainHeading"]</h1>
            <p id="admin-logs-description">@L["Logs_Description"]</p>
        </div>
        <div class="console-head__actions" id="admin-logs-header-actions">
            <div class="form-check form-switch m-0" id="admin-logs-toggle-group">
                <input class="form-check-input" type="checkbox" role="switch" id="consoleToSystemToggle" @onchange="ToggleConsoleToSystemLogging" checked="@isConsoleToSystemLoggingEnabled">
                <label class="form-check-label" for="consoleToSystemToggle" id="admin-logs-toggle-label">
                    @L["Logs_ConsoleToggleLabel"]
                </label>
            </div>
            <button class="pill-btn pill-btn--primary" @onclick="RefreshLogs" id="admin-logs-refresh-btn">
                <i class="fas fa-sync-alt"></i><span>@L["Logs_RefreshButton"]</span>
            </button>
            <button class="pill-btn pill-btn--danger" @onclick="ClearAllLogs" id="admin-logs-clear-btn">
                <i class="fas fa-trash"></i><span>@L["Logs_ClearAllButton"]</span>
            </button>
        </div>
    </header>

    @if (isLoading)
    {
        <div class="loading-state" id="admin-logs-loading-state">
            <span class="loading-spinner"></span>
            <p>@L["Logs_LoadingMessage"]</p>
        </div>
    }
    else if (logSummary != null)
    {
        <!-- Summary Stat Cards -->
        <section class="metrics" id="admin-logs-metrics-section">
            <article class="metric" id="admin-logs-total-card">
                <div class="metric__head">
                    <span class="metric__label">@L["Logs_TotalLogsLabel"]</span>
                    <i class="fas fa-list metric__icon"></i>
                </div>
                <div class="metric__value mono">@logSummary.TotalLogs</div>
                <div class="metric__foot">
                    <span class="metric__hint">@L["Logs_TotalLogsHint"]</span>
                </div>
            </article>

            <article class="metric metric--accent" id="admin-logs-errors-card">
                <div class="metric__head">
                    <span class="metric__label">@L["Logs_ErrorsLabel"]</span>
                    <i class="fas fa-exclamation-triangle metric__icon"></i>
                </div>
                <div class="metric__value mono">@logSummary.ErrorCount</div>
                <div class="metric__foot">
                    <span class="metric__hint">@L["Logs_ErrorsHint"]</span>
                </div>
            </article>

            <article class="metric" id="admin-logs-warnings-card">
                <div class="metric__head">
                    <span class="metric__label">@L["Logs_WarningsLabel"]</span>
                    <i class="fas fa-exclamation metric__icon"></i>
                </div>
                <div class="metric__value mono">@logSummary.WarningCount</div>
                <div class="metric__foot">
                    <span class="metric__hint">@L["Logs_WarningsHint"]</span>
                </div>
            </article>

            <article class="metric" id="admin-logs-info-card">
                <div class="metric__head">
                    <span class="metric__label">@L["Logs_InfoLabel"]</span>
                    <i class="fas fa-info-circle metric__icon is-ok"></i>
                </div>
                <div class="metric__value mono">@logSummary.InfoCount</div>
                <div class="metric__foot">
                    <span class="metric__hint">@L["Logs_InfoHint"]</span>
                </div>
            </article>
        </section>

        <!-- Filters -->
        <div class="panel filters-panel" id="admin-logs-filters-panel">
            <div class="panel__head" id="admin-logs-filters-panel-head">
                <h2 class="panel__title" id="admin-logs-filters-title">@L["Logs_FiltersPanelTitle"]</h2>
            </div>
            <div class="panel__body" id="admin-logs-filters-panel-body">
                <!-- Date Range Filters -->
                <div class="field" id="admin-logs-date-range-field">
                    <label class="field__label">@L["Logs_TimeRangeLabel"]</label>
                    <div class="filters" id="admin-logs-date-buttons">
                        <button class="pill-btn @(selectedDateRange == "last24hours" ? "pill-btn--primary" : "")"
                                @onclick="@(() => SetDateRange("last24hours"))" id="admin-logs-filter-24h-btn">
                            <i class="fas fa-clock"></i><span>@L["Logs_Last24HoursButton"]</span>
                        </button>
                        <button class="pill-btn @(selectedDateRange == "today" ? "pill-btn--primary" : "")"
                                @onclick="@(() => SetDateRange("today"))" id="admin-logs-filter-today-btn">
                            <i class="fas fa-calendar-day"></i><span>@L["Logs_TodayButton"]</span>
                        </button>
                        <button class="pill-btn @(selectedDateRange == "last7days" ? "pill-btn--primary" : "")"
                                @onclick="@(() => SetDateRange("last7days"))" id="admin-logs-filter-7days-btn">
                            <i class="fas fa-calendar-week"></i><span>@L["Logs_Last7DaysButton"]</span>
                        </button>
                        <button class="pill-btn @(selectedDateRange == "last30days" ? "pill-btn--primary" : "")"
                                @onclick="@(() => SetDateRange("last30days"))" id="admin-logs-filter-30days-btn">
                            <i class="fas fa-calendar-alt"></i><span>@L["Logs_Last30DaysButton"]</span>
                        </button>
                        <button class="pill-btn @(selectedDateRange == "all" ? "pill-btn--primary" : "")"
                                @onclick="@(() => SetDateRange("all"))" id="admin-logs-filter-alltime-btn">
                            <i class="fas fa-infinity"></i><span>@L["Logs_AllTimeButton"]</span>
                        </button>
                        <button class="pill-btn @(selectedDateRange == "custom" ? "pill-btn--primary" : "")"
                                @onclick="@(() => ToggleCustomDateRange())" id="admin-logs-filter-custom-btn">
                            <i class="fas fa-calendar"></i><span>@L["Logs_CustomRangeButton"]</span>
                        </button>
                    </div>
                </div>

                <!-- Custom Date Range -->
                @if (showCustomDateRange)
                {
                    <div class="filters" id="admin-logs-custom-date-range">
                        <div class="field" id="admin-logs-from-date-field">
                            <label class="field__label">@L["Logs_FromDateLabel"]</label>
                            <input type="datetime-local" class="field__input" @bind="customFromDate" id="admin-logs-from-date-input" />
                        </div>
                        <div class="field" id="admin-logs-to-date-field">
                            <label class="field__label">@L["Logs_ToDateLabel"]</label>
                            <input type="datetime-local" class="field__input" @bind="customToDate" id="admin-logs-to-date-input" />
                        </div>
                        <div class="field" id="admin-logs-apply-field">
                            <label class="field__label">&nbsp;</label>
                            <button class="pill-btn pill-btn--primary" @onclick="ApplyCustomDateRange" id="admin-logs-custom-date-apply-btn">
                                <i class="fas fa-check"></i><span>@L["Logs_ApplyButton"]</span>
                            </button>
                        </div>
                    </div>
                }

                <!-- Current Filter Info -->
                @if (!string.IsNullOrEmpty(currentFilterDescription))
                {
                    <div class="console-alert console-alert--info" id="admin-logs-current-filter-alert">
                        <i class="fas fa-filter"></i> <strong>@L["Logs_CurrentFilterLabel"]</strong> @currentFilterDescription
                        @if (logs != null)
                        {
                            <span class="ms-2">(@logs.TotalCount @L["Logs_LogsFoundCount"])</span>
                        }
                    </div>
                }

                <!-- Level Filters -->
                <div class="field" id="admin-logs-level-filter-field">
                    <label class="field__label">@L["Logs_FilterByLevelLabel"]</label>
                    <div class="filters" id="admin-logs-level-filter-buttons">
                        <button class="pill-btn @(selectedLevel == "Error" ? "pill-btn--danger" : "")" @onclick="@(() => FilterByLevel("Error"))" id="admin-logs-filter-error-btn">
                            <span>@L["Logs_ErrorsFilterButton"] (@logSummary.ErrorCount)</span>
                        </button>
                        <button class="pill-btn @(selectedLevel == "Warning" ? "pill-btn--primary" : "")" @onclick="@(() => FilterByLevel("Warning"))" id="admin-logs-filter-warning-btn">
                            <span>@L["Logs_WarningsFilterButton"] (@logSummary.WarningCount)</span>
                        </button>
                        <button class="pill-btn @(selectedLevel == "Info" ? "pill-btn--primary" : "")" @onclick="@(() => FilterByLevel("Info"))" id="admin-logs-filter-info-btn">
                            <span>@L["Logs_InfoFilterButton"] (@logSummary.InfoCount)</span>
                        </button>
                        <button class="pill-btn @(selectedLevel == "" ? "pill-btn--primary" : "")" @onclick="@(() => FilterByLevel(""))" id="admin-logs-filter-all-btn">
                            <span>@L["Logs_AllLevelsButton"]</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Logs Table -->
        <div class="panel" id="admin-logs-table-panel">
            <div class="panel__head" id="admin-logs-table-panel-head">
                <h2 class="panel__title" id="admin-logs-table-title">@L["Logs_LogsPanelTitle"] <span class="panel__count mono">@(logs?.TotalCount ?? 0)</span></h2>
            </div>

            @if (logs?.Logs?.Any() == true)
            {
                <table class="console-table" id="admin-logs-table">
                    <thead id="admin-logs-table-head">
                        <tr id="admin-logs-table-header-row">
                            <th class="sortable @(sortState.IsSorted("time") ? "is-sorted" : "")" @onclick='() => SortBy("time")' id="admin-logs-th-time">@L["Logs_TimeHeader"]<span class="sort-ind">@sortState.Indicator("time")</span></th>
                            <th class="sortable @(sortState.IsSorted("level") ? "is-sorted" : "")" @onclick='() => SortBy("level")' id="admin-logs-th-level">@L["Logs_LevelHeader"]<span class="sort-ind">@sortState.Indicator("level")</span></th>
                            <th class="sortable @(sortState.IsSorted("action") ? "is-sorted" : "")" @onclick='() => SortBy("action")' id="admin-logs-th-action">@L["Logs_ActionHeader"]<span class="sort-ind">@sortState.Indicator("action")</span></th>
                            <th class="sortable @(sortState.IsSorted("user") ? "is-sorted" : "")" @onclick='() => SortBy("user")' id="admin-logs-th-user">@L["Logs_UserHeader"]<span class="sort-ind">@sortState.Indicator("user")</span></th>
                            <th class="sortable @(sortState.IsSorted("source") ? "is-sorted" : "")" @onclick='() => SortBy("source")' id="admin-logs-th-source">@L["Logs_SourceHeader"]<span class="sort-ind">@sortState.Indicator("source")</span></th>
                            <th class="sortable @(sortState.IsSorted("message") ? "is-sorted" : "")" @onclick='() => SortBy("message")' id="admin-logs-th-message">@L["Logs_MessageHeader"]<span class="sort-ind">@sortState.Indicator("message")</span></th>
                        </tr>
                    </thead>
                    <tbody id="admin-logs-table-body">
                        @{ pager.Source = logs.Logs; }
                        @foreach (var log in pager.PageItems)
                        {
                            <tr id="admin-logs-row-@log.Id">
                                <td class="mono console-table__time" id="admin-logs-cell-time-@log.Id">@log.Timestamp.ToLocalTime().ToString("MM-dd HH:mm:ss")</td>
                                <td id="admin-logs-cell-level-@log.Id">
                                    <span class="status @(log.Level switch { "Error" => "is-cancelled", "Critical" => "is-cancelled", "Warning" => "is-pending", "Info" => "is-accepted", _ => "is-delivered" })">
                                        <span class="status__dot"></span>@log.Level
                                    </span>
                                </td>
                                <td id="admin-logs-cell-action-@log.Id">@log.Action</td>
                                <td class="console-table__muted" id="admin-logs-cell-user-@log.Id">
                                    @if (!string.IsNullOrEmpty(log.UserEmail))
                                    {
                                        @log.UserEmail
                                    }
                                </td>
                                <td id="admin-logs-cell-source-@log.Id">
                                    <span class="console-table__muted">@log.Source</span>
                                </td>
                                <td style="max-width: 400px;" id="admin-logs-cell-message-@log.Id">
                                    @if (!string.IsNullOrEmpty(log.Message))
                                    {
                                        @if (log.Message.Length > 100)
                                        {
                                            <div class="message-cell" id="admin-logs-message-cell-@log.Id">
                                                <div class="message-preview" @onclick="@(() => ToggleMessage(log.Id))" id="admin-logs-message-preview-@log.Id">
                                                    <small>@log.Message.Substring(0, 100)...</small>
                                                    <button class="row-btn" title="Expand message" id="admin-logs-expand-message-btn-@log.Id">
                                                        <i class="fas fa-expand-alt"></i>
                                                    </button>
                                                </div>
                                                @if (expandedMessages.Contains(log.Id))
                                                {
                                                    <div class="message-full mt-2 p-2 border rounded" style="background-color: rgba(0,0,0,0.05); word-break: break-word; white-space: pre-wrap;" id="admin-logs-message-full-@log.Id">
                                                        <small>@log.Message</small>
                                                        <button class="row-btn float-end" title="Collapse message" @onclick="@(() => ToggleMessage(log.Id))" id="admin-logs-collapse-message-btn-@log.Id">
                                                            <i class="fas fa-compress-alt"></i>
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <small style="word-break: break-word;" id="admin-logs-message-short-@log.Id">@log.Message</small>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <TablePager TItem="LogEntryDto" View="pager" IdPrefix="admin-logs-table" OnChanged="StateHasChanged" />
            }
            else
            {
                <div class="empty" id="admin-logs-empty-state">
                    <i class="fas fa-inbox"></i>
                    <p id="admin-logs-empty-title">@L["Logs_NoLogsFound"]</p>
                    <span id="admin-logs-empty-message">@L["Logs_NoLogsDescription"]</span>
                </div>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="console-alert @(isSuccess ? "console-alert--success" : "console-alert--danger")" id="admin-logs-status-alert">
            <span id="admin-logs-status-message">@statusMessage</span>
        </div>
    }
</div>
