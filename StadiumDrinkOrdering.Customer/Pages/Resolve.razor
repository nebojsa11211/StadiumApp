@page "/t/{Token}"
@layout MobileShell
@using StadiumDrinkOrdering.Customer.Services
@inject OrderSessionState State
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>HALFTIME</PageTitle>

<div id="customer-resolve-container" class="resolve">
    @if (_phase == Phase.Validating)
    {
        <div id="customer-resolve-validating" class="center">
            <span class="spinner big"></span>
            <p>Provjeravam tvoju ulaznicu…</p>
        </div>
    }
    else if (_phase == Phase.Ready)
    {
        <div id="customer-resolve-ready" class="center">
            <div id="customer-resolve-tick" class="tick">✓</div>
            <h2>Spreman si!</h2>
            <div id="customer-resolve-seatcard" class="seatcard">
                <div id="customer-resolve-match" class="match">@State.EventName</div>
                <div id="customer-resolve-row" class="row"><span>Mjesto</span><b>@State.SeatText</b></div>
            </div>
            <div id="customer-resolve-redirecting" class="redirecting"><span class="spinner"></span> Vodim te na meni…</div>
            <button class="btn btn-primary" @onclick="Go">Započni naručivanje</button>
        </div>
    }
    else
    {
        <div id="customer-resolve-error" class="center">
            <div id="customer-resolve-cross" class="cross">✕</div>
            <h2>Ups…</h2>
            <p class="err">@_error</p>
            <button class="btn btn-primary" @onclick="@(() => Nav.NavigateTo("/scan"))">Skeniraj ponovno</button>
            <button class="btn btn-ghost" @onclick="@(() => Nav.NavigateTo("/welcome"))">Početna</button>
        </div>
    }
</div>

@code {
    [Parameter] public string Token { get; set; } = "";

    private enum Phase { Validating, Ready, Failed }
    private Phase _phase = Phase.Validating;
    private string? _error;
    private Timer? _forward;
    private bool _started;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Resolve the ticket exactly once, and ONLY on the interactive client.
        // OnAfterRenderAsync never runs during ServerPrerendered prerendering, so doing the
        // resolve here (instead of OnInitializedAsync) avoids the double-execution that would
        // consume a single-use ticket during prerender and then fail the interactive render
        // with "already used". The page shows the "Validating" spinner until this completes.
        if (!firstRender || _started) return;
        _started = true;

        var (ok, error) = await State.InitFromQrAsync(Token);
        _phase = ok ? Phase.Ready : Phase.Failed;
        _error = error;
        StateHasChanged();

        if (_phase != Phase.Ready) return;

        // Persist the session token so a hard reload on /order or /track can recover it.
        await JS.InvokeVoidAsync("sessionStorage.setItem", "htSessionToken", State.SessionToken);

        // "Immediately redirected": auto-forward into ordering after a brief confirmation beat.
        _forward = new Timer(_ => InvokeAsync(Go), null, 1300, Timeout.Infinite);
    }

    private void Go()
    {
        _forward?.Dispose();
        Nav.NavigateTo("/order");
    }

    public void Dispose() => _forward?.Dispose();
}
