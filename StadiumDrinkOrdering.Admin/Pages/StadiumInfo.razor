@page "/admin/stadium-info"
@using System.Net.Http
@using System.Net.Http.Json
@using System.Text.Json
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Shared.DTOs
@inject HttpClient HttpClient
@inject IConfiguration Configuration
@inject ILogger<StadiumInfo> Logger
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["StadiumInfo_PageTitle"]</PageTitle>

<div id="admin-stadium-info-main-container" class="container-fluid">
    <div class="row mb-3" id="admin-stadium-info-header-row">
        <div class="col-12" id="admin-stadium-info-header-col">
            <h1 id="admin-stadium-info-title" class="mb-1">@L["StadiumInfo_Heading"]</h1>
            <p class="text-muted" id="admin-stadium-info-subtitle">@L["StadiumInfo_Subtitle"]</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div id="admin-stadium-info-loading" class="d-flex align-items-center text-muted">
            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
            <span>@L["StadiumInfo_Loading"]</span>
        </div>
    }
    else if (loadError)
    {
        <div id="admin-stadium-info-error" class="alert alert-danger d-flex justify-content-between align-items-center" role="alert">
            <span>@L["StadiumInfo_Error"]</span>
            <button id="admin-stadium-info-retry-btn" class="btn btn-sm btn-outline-danger" @onclick="LoadSectors">
                @L["StadiumInfo_Retry"]
            </button>
        </div>
    }
    else if (sectors.Count == 0)
    {
        <div id="admin-stadium-info-empty" class="alert alert-info" role="alert">
            @L["StadiumInfo_Empty"]
        </div>
    }
    else
    {
        <!-- Summary cards -->
        <div class="row g-3 mb-4" id="admin-stadium-info-summary-row">
            <div class="col-sm-6 col-lg-3" id="admin-stadium-info-sectors-col">
                <div class="card h-100" id="admin-stadium-info-card-sectors">
                    <div class="card-body" id="admin-stadium-info-sectors-body">
                        <h6 class="text-muted mb-1">@L["StadiumInfo_TotalSectors"]</h6>
                        <div class="display-6 fw-bold" id="admin-stadium-info-total-sectors">@sectors.Count</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3" id="admin-stadium-info-seats-col">
                <div class="card h-100" id="admin-stadium-info-card-seats">
                    <div class="card-body" id="admin-stadium-info-seats-body">
                        <h6 class="text-muted mb-1">@L["StadiumInfo_TotalSeats"]</h6>
                        <div class="display-6 fw-bold" id="admin-stadium-info-total-seats">@TotalSeats.ToString("N0")</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Type breakdown -->
        <div class="card mb-4" id="admin-stadium-info-breakdown-card">
            <div class="card-header">
                <h5 class="mb-0" id="admin-stadium-info-breakdown-title">@L["StadiumInfo_TypeBreakdownTitle"]</h5>
            </div>
            <div class="card-body" id="admin-stadium-info-breakdown-body">
                <div class="table-responsive" id="admin-stadium-info-breakdown-responsive">
                    <table class="table table-sm mb-0" id="admin-stadium-info-breakdown-table">
                        <thead id="admin-stadium-info-breakdown-thead">
                            <tr id="admin-stadium-info-breakdown-header-row">
                                <th id="admin-stadium-info-breakdown-col-type">@L["StadiumInfo_ColType"]</th>
                                <th class="text-end" id="admin-stadium-info-breakdown-col-sectors">@L["StadiumInfo_TotalSectors"]</th>
                                <th class="text-end" id="admin-stadium-info-breakdown-col-seats">@L["StadiumInfo_ColTotalSeats"]</th>
                            </tr>
                        </thead>
                        <tbody id="admin-stadium-info-breakdown-tbody">
                            @foreach (var group in TypeBreakdown)
                            {
                                <tr id="admin-stadium-info-breakdown-row-@group.Type">
                                    <td>
                                        <span class="badge rounded-pill text-bg-secondary text-capitalize">@group.Type</span>
                                    </td>
                                    <td class="text-end">@group.SectorCount</td>
                                    <td class="text-end">@group.SeatCount.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Per-sector list -->
        <div class="card" id="admin-stadium-info-sector-list-card">
            <div class="card-header">
                <h5 class="mb-0" id="admin-stadium-info-sector-list-title">@L["StadiumInfo_SectorListTitle"]</h5>
            </div>
            <div class="card-body" id="admin-stadium-info-sector-body">
                <div class="table-responsive" id="admin-stadium-info-sector-responsive">
                    <table class="table table-striped table-hover mb-0" id="admin-stadium-info-sector-table">
                        <thead id="admin-stadium-info-sector-thead">
                            <tr id="admin-stadium-info-sector-header-row">
                                <th style="width:2rem;" id="admin-stadium-info-sector-col-expand"></th>
                                <th id="admin-stadium-info-sector-col-code">@L["StadiumInfo_ColCode"]</th>
                                <th id="admin-stadium-info-sector-col-name">@L["StadiumInfo_ColName"]</th>
                                <th id="admin-stadium-info-sector-col-type">@L["StadiumInfo_ColType"]</th>
                                <th class="text-end" id="admin-stadium-info-sector-col-rows">@L["StadiumInfo_ColRows"]</th>
                                <th class="text-end" id="admin-stadium-info-sector-col-seatsperrow">@L["StadiumInfo_ColSeatsPerRow"]</th>
                                <th class="text-end" id="admin-stadium-info-sector-col-totalseats">@L["StadiumInfo_ColTotalSeats"]</th>
                            </tr>
                        </thead>
                        <tbody id="admin-stadium-info-sector-tbody">
                            @foreach (var sector in sectors)
                            {
                                var isExpanded = expandedSectorIds.Contains(sector.Id);
                                <tr id="admin-stadium-info-sector-row-@sector.Id"
                                    class="admin-stadium-info-sector-row"
                                    style="cursor:pointer;"
                                    @onclick="() => ToggleSector(sector)">
                                    <td class="text-center">
                                        <i class="bi @(isExpanded ? "bi-chevron-down" : "bi-chevron-right")"></i>
                                    </td>
                                    <td>
                                        <span class="badge" style="background-color:@sector.Color;">@sector.SectorCode</span>
                                    </td>
                                    <td>@sector.Name</td>
                                    <td class="text-capitalize">@sector.Type</td>
                                    <td class="text-end">@sector.Rows</td>
                                    <td class="text-end">@sector.SeatsPerRow</td>
                                    <td class="text-end">@sector.TotalSeats.ToString("N0")</td>
                                </tr>
                                @if (isExpanded)
                                {
                                    var loadingSummary = loadingSectorSummaries.Contains(sector.Id);
                                    sectorPersisted.TryGetValue(sector.Id, out var pInfo);
                                    var persisted = pInfo is { IsPersisted: true };
                                    var rows = persisted
                                        ? pInfo!.Rows.Select(r => new RowDetail { RowNumber = r.RowNumber, Seats = r.SeatCount }).ToList()
                                        : GetRowBreakdown(sector).ToList();
                                    var headRowCount = persisted ? pInfo!.Rows.Count : sector.Rows;
                                    var headSeatCount = persisted ? pInfo!.TotalSeats : sector.TotalSeats;

                                    <tr id="admin-stadium-info-sector-detail-@sector.Id" class="admin-stadium-info-sector-detail">
                                        <td id="admin-stadium-info-detail-expand-@sector.Id"></td>
                                        <td colspan="6" class="admin-stadium-info-detail-cell" id="admin-stadium-info-detail-cell-@sector.Id">

                                            <div class="admin-stadium-info-detail-head" id="admin-stadium-info-detail-head-@sector.Id">
                                                <div class="admin-stadium-info-detail-title" id="admin-stadium-info-detail-title-@sector.Id">
                                                    <span class="fw-semibold">@L["StadiumInfo_RowDetailTitle", sector.Name]</span>

                                                    @if (loadingSummary)
                                                    {
                                                        <span class="admin-stadium-info-source-badge loading" id="admin-stadium-info-source-@sector.Id">
                                                            <span class="spinner-border spinner-border-sm" role="status"></span>@L["StadiumInfo_CheckingSeats"]
                                                        </span>
                                                    }
                                                    else if (persisted)
                                                    {
                                                        <span class="admin-stadium-info-source-badge persisted"
                                                              id="admin-stadium-info-source-@sector.Id"
                                                              title="@L["StadiumInfo_SourcePersistedHint", pInfo!.MatchedSectorName ?? pInfo!.SectorCode]">
                                                            <i class="bi bi-database-check me-1"></i>@L["StadiumInfo_SourcePersisted"]
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="admin-stadium-info-source-badge derived"
                                                              id="admin-stadium-info-source-@sector.Id"
                                                              title="@L["StadiumInfo_SourceDerivedHint"]">
                                                            <i class="bi bi-calculator me-1"></i>@L["StadiumInfo_SourceDerived"]
                                                        </span>
                                                    }

                                                    <span class="admin-stadium-info-detail-sub" id="admin-stadium-info-detail-sub-@sector.Id">
                                                        @headRowCount&nbsp;@L["StadiumInfo_ColRows"]
                                                        <span class="admin-stadium-info-dot" id="admin-stadium-info-detail-dot-1-@sector.Id">·</span>
                                                        @headSeatCount.ToString("N0")&nbsp;@L["StadiumInfo_ColSeats"]
                                                        @if (persisted)
                                                        {
                                                            <span class="admin-stadium-info-dot" id="admin-stadium-info-detail-dot-2-@sector.Id">·</span>
                                                            <span class="admin-stadium-info-avail" id="admin-stadium-info-detail-avail-@sector.Id">@pInfo!.AvailableSeats.ToString("N0")&nbsp;@L["StadiumInfo_Available"]</span>
                                                        }
                                                    </span>
                                                </div>

                                                @if (SectorHasOpenRows(sector.Id))
                                                {
                                                    <button type="button"
                                                            class="btn btn-sm btn-link admin-stadium-info-collapse-rows"
                                                            id="admin-stadium-info-collapse-rows-@sector.Id"
                                                            @onclick="() => CollapseSectorRows(sector.Id)">
                                                        <i class="bi bi-chevron-bar-up me-1"></i>@L["StadiumInfo_CollapseAllRows"]
                                                    </button>
                                                }
                                            </div>

                                            @if (persisted && pInfo!.TotalSeats != sector.TotalSeats)
                                            {
                                                <div class="admin-stadium-info-mismatch" id="admin-stadium-info-mismatch-@sector.Id">
                                                    <i class="bi bi-exclamation-triangle me-1"></i>@L["StadiumInfo_CountMismatch", sector.TotalSeats, pInfo!.TotalSeats]
                                                </div>
                                            }

                                            @if (loadingSummary)
                                            {
                                                <div class="admin-stadium-info-seatgrid-loading" id="admin-stadium-info-loading-@sector.Id">
                                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>@L["StadiumInfo_CheckingSeats"]
                                                </div>
                                            }
                                            else if (rows.Count == 0)
                                            {
                                                <div class="admin-stadium-info-empty-rows text-muted" id="admin-stadium-info-empty-rows-@sector.Id">
                                                    @L["StadiumInfo_NoRows"]
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="admin-stadium-info-rows" id="admin-stadium-info-rows-@sector.Id">
                                                    @foreach (var rd in rows)
                                                    {
                                                        var rowKey = $"{sector.Id}:{rd.RowNumber}";
                                                        var rowOpen = expandedRowKeys.Contains(rowKey);
                                                        var seatGridId = $"admin-stadium-info-seatgrid-{sector.Id}-{rd.RowNumber}";
                                                        var pRow = persisted ? pInfo!.Rows.FirstOrDefault(r => r.RowNumber == rd.RowNumber) : null;
                                                        var rowCountLabel = pRow != null ? $"{pRow.AvailableCount}/{pRow.SeatCount}" : rd.Seats.ToString();

                                                        <div class="admin-stadium-info-row-block @(rowOpen ? "is-open" : null)"
                                                             id="admin-stadium-info-row-@sector.Id-@rd.RowNumber">

                                                            <button type="button"
                                                                    class="admin-stadium-info-row-toggle"
                                                                    style="--sector-color:@sector.Color;"
                                                                    id="admin-stadium-info-row-toggle-@sector.Id-@rd.RowNumber"
                                                                    aria-expanded="@(rowOpen ? "true" : "false")"
                                                                    aria-controls="@seatGridId"
                                                                    @onclick="() => ToggleRow(sector, rd.RowNumber)">
                                                                <i class="bi @(rowOpen ? "bi-chevron-down" : "bi-chevron-right") admin-stadium-info-row-chevron" id="admin-stadium-info-row-chevron-@sector.Id-@rd.RowNumber"></i>
                                                                <span class="admin-stadium-info-row-label" id="admin-stadium-info-row-label-@sector.Id-@rd.RowNumber">@L["StadiumInfo_ColRow"]&nbsp;@rd.RowNumber</span>
                                                                <span class="admin-stadium-info-row-count" id="admin-stadium-info-row-count-@sector.Id-@rd.RowNumber">@rowCountLabel&nbsp;@L["StadiumInfo_ColSeats"]</span>
                                                            </button>

                                                            @if (rowOpen)
                                                            {
                                                                @if (persisted)
                                                                {
                                                                    @if (loadingRowSeats.Contains(rowKey))
                                                                    {
                                                                        <div class="admin-stadium-info-seatgrid-loading" id="admin-stadium-info-row-loading-@sector.Id-@rd.RowNumber">
                                                                            <span class="spinner-border spinner-border-sm me-2" role="status" id="admin-stadium-info-row-loading-spinner-@sector.Id-@rd.RowNumber"></span>@L["StadiumInfo_LoadingSeats"]
                                                                        </div>
                                                                    }
                                                                    else if (rowPersistedSeats.TryGetValue(rowKey, out var pSeats) && pSeats.Count > 0)
                                                                    {
                                                                        <div class="admin-stadium-info-seatgrid"
                                                                             id="@seatGridId"
                                                                             role="list"
                                                                             aria-label="@L["StadiumInfo_RowSeatsAria", sector.Name, rd.RowNumber]">
                                                                            @foreach (var seat in pSeats.Take(MaxSeatsPerRowRendered))
                                                                            {
                                                                                <span class="admin-stadium-info-seat @(seat.IsAvailable ? null : "is-unavailable")"
                                                                                      role="listitem"
                                                                                      style="--sector-color:@sector.Color;"
                                                                                      id="admin-stadium-info-seat-@sector.Id-@seat.RowNumber-@seat.SeatNumber"
                                                                                      title="@(seat.IsAvailable ? seat.UniqueCode : seat.UniqueCode + " — " + L["StadiumInfo_Unavailable"])">
                                                                                    <span class="admin-stadium-info-seat-num" id="admin-stadium-info-seat-num-@sector.Id-@seat.RowNumber-@seat.SeatNumber">@seat.SeatNumber</span>
                                                                                    <span class="admin-stadium-info-seat-code" id="admin-stadium-info-seat-code-@sector.Id-@seat.RowNumber-@seat.SeatNumber">@seat.UniqueCode</span>
                                                                                </span>
                                                                            }
                                                                            @if (pSeats.Count > MaxSeatsPerRowRendered)
                                                                            {
                                                                                <span class="admin-stadium-info-seat-more" id="admin-stadium-info-seat-more-@sector.Id-@rd.RowNumber">
                                                                                    @L["StadiumInfo_SeatsShownOf", MaxSeatsPerRowRendered, pSeats.Count]
                                                                                </span>
                                                                            }
                                                                        </div>
                                                                    }
                                                                    else
                                                                    {
                                                                        <div class="admin-stadium-info-empty-rows text-muted" id="admin-stadium-info-row-empty-@sector.Id-@rd.RowNumber">
                                                                            @L["StadiumInfo_NoPersistedRowSeats"]
                                                                        </div>
                                                                    }
                                                                }
                                                                else
                                                                {
                                                                    var seats = GetSeatsForRow(sector, rd.RowNumber).Take(MaxSeatsPerRowRendered).ToList();
                                                                    <div class="admin-stadium-info-seatgrid"
                                                                         id="@seatGridId"
                                                                         role="list"
                                                                         aria-label="@L["StadiumInfo_RowSeatsAria", sector.Name, rd.RowNumber]">
                                                                        @foreach (var seat in seats)
                                                                        {
                                                                            <span class="admin-stadium-info-seat"
                                                                                  role="listitem"
                                                                                  style="--sector-color:@sector.Color;"
                                                                                  id="admin-stadium-info-seat-@sector.Id-@seat.RowNumber-@seat.SeatNumber"
                                                                                  title="@seat.UniqueCode">
                                                                                <span class="admin-stadium-info-seat-num" id="admin-stadium-info-seat-num-@sector.Id-@seat.RowNumber-@seat.SeatNumber">@seat.SeatNumber</span>
                                                                                <span class="admin-stadium-info-seat-code" id="admin-stadium-info-seat-code-@sector.Id-@seat.RowNumber-@seat.SeatNumber">@seat.UniqueCode</span>
                                                                            </span>
                                                                        }
                                                                        @if (rd.Seats > MaxSeatsPerRowRendered)
                                                                        {
                                                                            <span class="admin-stadium-info-seat-more" id="admin-stadium-info-seat-more-@sector.Id-@rd.RowNumber">
                                                                                @L["StadiumInfo_SeatsShownOf", seats.Count, rd.Seats]
                                                                            </span>
                                                                        }
                                                                    </div>
                                                                }
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot id="admin-stadium-info-sector-tfoot">
                            <tr class="fw-bold" id="admin-stadium-info-sector-footer-row">
                                <td colspan="6" class="text-end" id="admin-stadium-info-sector-footer-label">@L["StadiumInfo_TotalSeats"]</td>
                                <td class="text-end" id="admin-stadium-info-table-total">@TotalSeats.ToString("N0")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private bool loadError = false;
    private List<StadiumSectorOverlay> sectors = new();
    private readonly HashSet<int> expandedSectorIds = new();

    // Persisted-seat state, fetched on demand. An overlay sector is matched to a hierarchy
    // Sector by code server-side; when real seats exist we show them, otherwise we fall back
    // to the computed layout below.
    private readonly Dictionary<int, SectorPersistedSeatsDto?> sectorPersisted = new();
    private readonly HashSet<int> loadingSectorSummaries = new();
    private readonly Dictionary<string, List<PersistedSeatDto>> rowPersistedSeats = new();
    private readonly HashSet<string> loadingRowSeats = new();

    private static readonly JsonSerializerOptions JsonOpts = new()
    {
        PropertyNameCaseInsensitive = true,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };

    private string ApiBaseUrl =>
        Configuration.GetValue<string>("ApiSettings:BaseUrl")?.TrimEnd('/') ?? "https://localhost:7010";

    private bool IsSectorPersisted(int sectorId) =>
        sectorPersisted.TryGetValue(sectorId, out var info) && info is { IsPersisted: true };

    private async Task ToggleSector(StadiumSectorOverlay sector)
    {
        if (!expandedSectorIds.Remove(sector.Id))
        {
            expandedSectorIds.Add(sector.Id);
            // Resolve persisted seats once per sector, on first expand.
            if (!sectorPersisted.ContainsKey(sector.Id) && !loadingSectorSummaries.Contains(sector.Id))
            {
                await LoadSectorSummary(sector);
            }
        }
        else
        {
            // Dropping opened rows on collapse keeps reopening clean and avoids stale keys.
            CollapseSectorRows(sector.Id);
        }
    }

    private async Task LoadSectorSummary(StadiumSectorOverlay sector)
    {
        loadingSectorSummaries.Add(sector.Id);
        StateHasChanged();
        try
        {
            var dto = await HttpClient.GetFromJsonAsync<SectorPersistedSeatsDto>(
                $"{ApiBaseUrl}/api/StadiumSectorOverlay/{sector.Id}/persisted-seats", JsonOpts);
            sectorPersisted[sector.Id] = dto;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading persisted seat summary for sector {Id}", sector.Id);
            sectorPersisted[sector.Id] = null; // treated as not-persisted → derived fallback
        }
        finally
        {
            loadingSectorSummaries.Remove(sector.Id);
            StateHasChanged();
        }
    }

    /// <summary>
    /// Builds the per-row seat breakdown for a sector, honoring variable-seating patterns
    /// when configured, otherwise falling back to a uniform Rows x SeatsPerRow layout.
    /// </summary>
    private IEnumerable<RowDetail> GetRowBreakdown(StadiumSectorOverlay sector)
    {
        if (sector.UseVariableSeating && !string.IsNullOrEmpty(sector.VariableSeatingData))
        {
            List<RowPattern>? patterns = null;
            try
            {
                patterns = JsonSerializer.Deserialize<List<RowPattern>>(sector.VariableSeatingData, JsonOpts);
            }
            catch
            {
                patterns = null;
            }

            if (patterns != null && patterns.Count > 0)
            {
                var rows = new List<RowDetail>();
                foreach (var pattern in patterns.OrderBy(p => p.FromRow))
                {
                    for (var row = pattern.FromRow; row <= pattern.ToRow; row++)
                    {
                        rows.Add(new RowDetail { RowNumber = row, Seats = pattern.SeatsPerRow });
                    }
                }
                return rows;
            }
        }

        return Enumerable.Range(1, sector.Rows)
            .Select(row => new RowDetail { RowNumber = row, Seats = sector.SeatsPerRow });
    }

    private class RowDetail
    {
        public int RowNumber { get; set; }
        public int Seats { get; set; }
    }

    // Safety cap so a single row can never flood the DOM (model caps SeatsPerRow at 200,
    // so this is defensive — it only ever engages on bad/legacy data).
    private const int MaxSeatsPerRowRendered = 300;

    // Tracks which individual rows (keyed "{sectorId}:{row}") have their seat grid expanded,
    // so we only render seat chips for rows the admin explicitly opens (huge sectors otherwise).
    private readonly HashSet<string> expandedRowKeys = new();

    private async Task ToggleRow(StadiumSectorOverlay sector, int rowNumber)
    {
        var rowKey = $"{sector.Id}:{rowNumber}";
        if (!expandedRowKeys.Remove(rowKey))
        {
            expandedRowKeys.Add(rowKey);
            // Lazily fetch this row's persisted seats the first time it is opened.
            if (IsSectorPersisted(sector.Id) && !rowPersistedSeats.ContainsKey(rowKey) && !loadingRowSeats.Contains(rowKey))
            {
                await LoadRowSeats(sector, rowNumber);
            }
        }
    }

    private async Task LoadRowSeats(StadiumSectorOverlay sector, int rowNumber)
    {
        var rowKey = $"{sector.Id}:{rowNumber}";
        loadingRowSeats.Add(rowKey);
        StateHasChanged();
        try
        {
            var seats = await HttpClient.GetFromJsonAsync<List<PersistedSeatDto>>(
                $"{ApiBaseUrl}/api/StadiumSectorOverlay/{sector.Id}/persisted-seats/{rowNumber}", JsonOpts);
            rowPersistedSeats[rowKey] = seats ?? new();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading persisted seats for sector {Id} row {Row}", sector.Id, rowNumber);
            rowPersistedSeats[rowKey] = new();
        }
        finally
        {
            loadingRowSeats.Remove(rowKey);
            StateHasChanged();
        }
    }

    private bool SectorHasOpenRows(int sectorId)
    {
        var prefix = $"{sectorId}:";
        return expandedRowKeys.Any(k => k.StartsWith(prefix, StringComparison.Ordinal));
    }

    private void CollapseSectorRows(int sectorId)
    {
        var prefix = $"{sectorId}:";
        expandedRowKeys.RemoveWhere(k => k.StartsWith(prefix, StringComparison.Ordinal));
    }

    /// <summary>
    /// Generates the computed (fallback) seats for a single row of a sector, each with a
    /// deterministic code of the form "{SectorCode}-R{row}-S{seat}". Used only when a sector
    /// has no persisted database seats linked.
    /// </summary>
    private IEnumerable<SeatDetail> GetSeatsForRow(StadiumSectorOverlay sector, int rowNumber)
    {
        var row = GetRowBreakdown(sector).FirstOrDefault(r => r.RowNumber == rowNumber);
        var seatsInRow = row?.Seats ?? 0;

        for (var seat = 1; seat <= seatsInRow; seat++)
        {
            yield return new SeatDetail
            {
                RowNumber = rowNumber,
                SeatNumber = seat,
                UniqueCode = $"{sector.SectorCode}-R{rowNumber}-S{seat}"
            };
        }
    }

    private class SeatDetail
    {
        public int RowNumber { get; set; }
        public int SeatNumber { get; set; }
        public string UniqueCode { get; set; } = string.Empty;
    }

    private int TotalSeats => sectors.Sum(s => s.TotalSeats);

    private IEnumerable<TypeGroup> TypeBreakdown =>
        sectors
            .GroupBy(s => string.IsNullOrWhiteSpace(s.Type) ? "standard" : s.Type)
            .Select(g => new TypeGroup
            {
                Type = g.Key,
                SectorCount = g.Count(),
                SeatCount = g.Sum(s => s.TotalSeats)
            })
            .OrderByDescending(g => g.SeatCount);

    protected override async Task OnInitializedAsync()
    {
        await LoadSectors();
    }

    private async Task LoadSectors()
    {
        isLoading = true;
        loadError = false;
        // Reset drill-down + persisted caches so a reload starts clean.
        expandedSectorIds.Clear();
        expandedRowKeys.Clear();
        sectorPersisted.Clear();
        loadingSectorSummaries.Clear();
        rowPersistedSeats.Clear();
        loadingRowSeats.Clear();
        StateHasChanged();

        try
        {
            var result = await HttpClient.GetFromJsonAsync<List<StadiumSectorOverlay>>(
                $"{ApiBaseUrl}/api/StadiumSectorOverlay", JsonOpts);

            sectors = result ?? new List<StadiumSectorOverlay>();
            Logger.LogInformation("Loaded {Count} sector overlays for stadium info page", sectors.Count);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading sector overlays for stadium info page");
            loadError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private class TypeGroup
    {
        public string Type { get; set; } = string.Empty;
        public int SectorCount { get; set; }
        public int SeatCount { get; set; }
    }
}
