@inherits LayoutComponentBase
@using Microsoft.Extensions.Localization
@using StadiumDrinkOrdering.Admin
@inject IStringLocalizer<SharedResources> L

@* Modern dashboard shell: shared sidebar (admin-dashboard-sidebar) + page content in dash-main. *@
<div class="dash dashboard-shell-root" id="admin-dashboard">

    @* ============================ SIDEBAR ============================ *@
    <aside class="dash-sidebar" id="admin-dashboard-sidebar">
        <div class="dash-brand" id="admin-dashboard-brand">
            <div class="dash-brand-logo" id="admin-dashboard-brand-logo" aria-hidden="true">
                @* Inline SVG stadium mark: self-contained so the logo renders even if the
                   CDN icon font fails to load. currentColor inherits the white brand colour. *@
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <ellipse cx="12" cy="10" rx="9" ry="5.5" stroke="currentColor" stroke-width="1.6" />
                    <ellipse cx="12" cy="10" rx="3.6" ry="2.2" fill="currentColor" fill-opacity="0.4" stroke="currentColor" stroke-width="1.2" />
                    <path d="M3 10v3.5c0 1.6 4.03 3.2 9 3.2s9-1.6 9-3.2V10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                </svg>
            </div>
            <div class="dash-brand-text" id="admin-dashboard-brand-text">
                <span class="dash-brand-name">STADIUM</span>
                <span class="dash-brand-sub">ADMIN</span>
            </div>
        </div>

        <div class="dash-clock" id="admin-dashboard-clock">
            <div class="dash-clock-time">@_now.ToString("HH:mm:ss")</div>
            <div class="dash-clock-date">@_now.ToString("dd/MM/yy") <span class="dash-clock-hr">HR</span></div>
        </div>

        <nav class="dash-nav" id="admin-dashboard-nav">
            <a href="" class="@NavClass("")" id="admin-dashboard-nav-dashboard">
                <i class="bi bi-grid-1x2"></i><span>@L["Nav_Dashboard"]</span>
            </a>

            <div class="dash-nav-group">@L["Nav_GroupOperations"]</div>
            <a href="orders" class="@NavClass("orders", "dash-nav-sub")" id="admin-dashboard-nav-orders">
                <i class="bi bi-cart3"></i><span>@L["Nav_Orders"]</span>
            </a>
            <a href="drinks" class="@NavClass("drinks", "dash-nav-sub")" id="admin-dashboard-nav-drinks">
                <i class="bi bi-cup-straw"></i><span>@L["Nav_Drinks"]</span>
            </a>
            <a href="admin/wallets" class="@NavClass("admin/wallets", "dash-nav-sub")" id="admin-dashboard-nav-wallets">
                <i class="bi bi-wallet2"></i><span>@L["Nav_Wallets"]</span>
            </a>

            <div class="dash-nav-group">@L["Nav_GroupEvents"]</div>
            <a href="events" class="@NavClass("events", "dash-nav-sub")" id="admin-dashboard-nav-events">
                <i class="bi bi-calendar-event"></i><span>@L["Nav_Events"]</span>
            </a>
            <a href="admin/seasons" class="@NavClass("admin/seasons", "dash-nav-sub")" id="admin-dashboard-nav-seasons">
                <i class="bi bi-calendar-range"></i><span>@L["Nav_Seasons"]</span>
            </a>
            <a href="admin/teams" class="@NavClass("admin/teams", "dash-nav-sub")" id="admin-dashboard-nav-teams">
                <i class="bi bi-shield"></i><span>@L["Nav_Teams"]</span>
            </a>
            <a href="tickets" class="@NavClass("tickets", "dash-nav-sub")" id="admin-dashboard-nav-tickets">
                <i class="bi bi-ticket-perforated"></i><span>@L["Nav_Tickets"]</span>
            </a>

            <div class="dash-nav-group">@L["Nav_GroupStadium"]</div>
            <a href="admin/stadium-overview" class="@NavClass("admin/stadium-overview", "dash-nav-sub")" id="admin-dashboard-nav-overview">
                <i class="bi bi-eye"></i><span>@L["Nav_Overview"]</span>
            </a>
            <a href="admin/stadium-drawing-tool" class="@NavClass("admin/stadium-drawing-tool", "dash-nav-sub")" id="admin-dashboard-nav-drawing">
                <i class="bi bi-brush"></i><span>@L["Nav_DrawingTool"]</span>
            </a>
            <a href="admin/stadium-info" class="@NavClass("admin/stadium-info", "dash-nav-sub")" id="admin-dashboard-nav-stadium-info">
                <i class="bi bi-info-circle"></i><span>@L["Nav_StadiumInfo"]</span>
            </a>
            <a href="admin/venue-settings" class="@NavClass("admin/venue-settings", "dash-nav-sub")" id="admin-dashboard-nav-venue">
                <i class="bi bi-buildings"></i><span>@L["Nav_Venue"]</span>
            </a>

            <div class="dash-nav-group">@L["Nav_GroupAnalytics"]</div>
            <a href="analytics" class="@NavClass("analytics", "dash-nav-sub")" id="admin-dashboard-nav-analytics">
                <i class="bi bi-bar-chart-line"></i><span>@L["Nav_Analytics"]</span>
            </a>
            <a href="customers" class="@NavClass("customers", "dash-nav-sub")" id="admin-dashboard-nav-customers">
                <i class="bi bi-person-vcard"></i><span>@L["Nav_Customers"]</span>
            </a>
            <a href="customer-analytics" class="@NavClass("customer-analytics", "dash-nav-sub")" id="admin-dashboard-nav-customer-analytics">
                <i class="bi bi-people"></i><span>@L["Nav_CustomerAnalytics"]</span>
            </a>

            <div class="dash-nav-group">@L["Nav_GroupSystem"]</div>
            <a href="users" class="@NavClass("users", "dash-nav-sub")" id="admin-dashboard-nav-security">
                <i class="bi bi-shield-lock"></i><span>@L["Nav_Security"]</span>
            </a>
            <a href="logs" class="@NavClass("logs", "dash-nav-sub")" id="admin-dashboard-nav-logs">
                <i class="bi bi-card-list"></i><span>@L["Nav_Logs"]</span>
            </a>
            <a href="datagrid" class="@NavClass("datagrid", "dash-nav-sub")" id="admin-dashboard-nav-database">
                <i class="bi bi-database"></i><span>@L["Nav_Database"]</span>
            </a>
            <a href="admin/settings" class="@NavClass("admin/settings", "dash-nav-sub")" id="admin-dashboard-nav-settings">
                <i class="bi bi-gear"></i><span>@L["Nav_Settings"]</span>
            </a>
            <a href="admin/setup" class="@NavClass("admin/setup", "dash-nav-sub")" id="admin-dashboard-nav-setup">
                <i class="bi bi-rocket-takeoff"></i><span>@L["Nav_Setup"]</span>
            </a>
        </nav>

        <div class="dash-sidebar-footer" id="admin-dashboard-sidebar-footer">
            <div class="dash-logging-panel" id="admin-dashboard-logging-panel">
                <i class="bi bi-broadcast-pin"></i>
                <div>
                    <div class="dash-logging-title">@L["Sidebar_LoggingTitle"]</div>
                    <div class="dash-logging-meta">@L["Sidebar_LastPublished"] @_now.ToString("HH:mm")</div>
                </div>
            </div>

            <div class="dash-profile" id="admin-dashboard-profile" role="button" tabindex="0"
                 title="@L["Profile_ViewDetails"]" @onclick="OpenProfile">
                <div class="dash-avatar" id="admin-dashboard-avatar">@GetInitials()</div>
                <div class="dash-profile-info" id="admin-dashboard-profile-info">
                    <button class="dash-logout" id="admin-dashboard-logout-btn"
                            @onclick="HandleLogout" @onclick:stopPropagation="true">@L["Logout"]</button>
                    <div class="dash-profile-email">@_userEmail</div>
                </div>
            </div>

            <div class="dash-lang" id="admin-dashboard-lang">
                <span class="dash-lang-label">HR/EN</span>
                <div class="dash-lang-switch" id="admin-dashboard-lang-switch">
                    <button class="@LangClass("hr")" @onclick="@(() => SetLang("hr"))" id="admin-dashboard-lang-hr">HR</button>
                    <button class="@LangClass("en")" @onclick="@(() => SetLang("en"))" id="admin-dashboard-lang-en">EN</button>
                </div>
            </div>
        </div>
    </aside>

    @* ============================ MAIN ============================ *@
    <main class="dash-main" id="admin-dashboard-main">
        @* First-run nudge: shown until the minimum config is in place or the admin dismisses it. *@
        @if (Setup.ShouldShowBanner)
        {
            <div class="alert alert-warning d-flex align-items-center gap-2 mb-3" role="alert" id="admin-dashboard-setup-banner">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span class="flex-grow-1">@L["Setup_BannerText"]</span>
                <a href="admin/setup" class="btn btn-sm btn-warning" id="admin-dashboard-setup-banner-link">@L["Setup_BannerAction"]</a>
            </div>
        }

        @* Shell-wide season scope. Rendered here so every admin page carries
           #admin-dashboard-current-season. Pages read the selection from SeasonState. *@
        <SeasonFilterBanner Seasons="SeasonState.Seasons"
                            Value="@SeasonState.SelectedValue"
                            ValueChanged="OnSeasonChanged"
                            IdPrefix="admin-dashboard-current-season" />

        @* Read-only live-event bar. Skipped on the dashboard, which renders its own interactive
           #admin-dashboard-event-bar — two would collide on the same id. *@
        @if (!IsDashboardRoute)
        {
            <LiveEventBar Event="LiveEvents.LiveEvent" />
        }
        @Body
    </main>

    <StadiumDrinkOrdering.UI.Components.DatabaseBadge />

    @* ============================ PROFILE OVERLAY ============================ *@
    @if (_showProfile)
    {
        <div class="dash-profile-overlay" id="admin-dashboard-profile-overlay" @onclick="CloseProfile">
            <div class="dash-profile-modal" id="admin-dashboard-profile-modal" @onclick:stopPropagation="true">
                <button type="button" class="dash-profile-modal-close" id="admin-dashboard-profile-modal-close"
                        aria-label="@L["Close"]" @onclick="CloseProfile">
                    <i class="bi bi-x-lg"></i>
                </button>

                <div class="dash-profile-modal-head" id="admin-dashboard-profile-modal-head">
                    <div class="dash-avatar dash-profile-modal-avatar" id="admin-dashboard-profile-modal-avatar">@GetInitials()</div>
                    <div class="dash-profile-modal-title">@L["Profile_Title"]</div>
                    <div class="dash-profile-modal-email" id="admin-dashboard-profile-modal-email">@_userEmail</div>
                </div>

                <dl class="dash-profile-modal-body" id="admin-dashboard-profile-modal-body">
                    <div class="dash-profile-row">
                        <dt><i class="bi bi-envelope"></i> @L["Profile_Email"]</dt>
                        <dd id="admin-dashboard-profile-field-email">@_userEmail</dd>
                    </div>
                    <div class="dash-profile-row">
                        <dt><i class="bi bi-shield-lock"></i> @L["Profile_Role"]</dt>
                        <dd id="admin-dashboard-profile-field-role">@(_userRole ?? "—")</dd>
                    </div>
                    <div class="dash-profile-row">
                        <dt><i class="bi bi-person-badge"></i> @L["Profile_UserId"]</dt>
                        <dd id="admin-dashboard-profile-field-id">@(_userId ?? "—")</dd>
                    </div>
                    <div class="dash-profile-row">
                        <dt><i class="bi bi-translate"></i> @L["Profile_Language"]</dt>
                        <dd id="admin-dashboard-profile-field-lang">@_lang.ToUpperInvariant()</dd>
                    </div>
                    <div class="dash-profile-row">
                        <dt><i class="bi bi-check-circle"></i> @L["Profile_Status"]</dt>
                        <dd id="admin-dashboard-profile-field-status">
                            <span class="dash-profile-status-dot"></span>@L["Profile_Authenticated"]
                        </dd>
                    </div>
                </dl>

                <div class="dash-profile-modal-foot" id="admin-dashboard-profile-modal-foot">
                    <button type="button" class="dash-profile-logout-btn" id="admin-dashboard-profile-modal-logout"
                            @onclick="HandleLogout">
                        <i class="bi bi-box-arrow-right"></i> @L["Logout"]
                    </button>
                </div>
            </div>
        </div>
    }
</div>
