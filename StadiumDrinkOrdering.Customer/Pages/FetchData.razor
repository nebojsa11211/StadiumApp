@page "/fetchdata"

<PageTitle>Weather forecast</PageTitle>

@using StadiumDrinkOrdering.Customer.Data
@inject WeatherForecastService ForecastService

<h1>Weather forecast</h1>

<p>This component demonstrates fetching data from a service.</p>

@if (forecasts == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table id="customer-fetchdata-forecasts-table" class="table">
        <thead id="customer-fetchdata-table-head">
            <tr id="customer-fetchdata-header-row">
                <th id="customer-fetchdata-header-date">Date</th>
                <th id="customer-fetchdata-header-temp-c">Temp. (C)</th>
                <th id="customer-fetchdata-header-temp-f">Temp. (F)</th>
                <th id="customer-fetchdata-header-summary">Summary</th>
            </tr>
        </thead>
        <tbody id="customer-fetchdata-table-body">
            @foreach (var forecast in forecasts)
            {
                <tr id="customer-fetchdata-row-@forecast.Date.Ticks">
                    <td id="customer-fetchdata-date-@forecast.Date.Ticks">@forecast.Date.ToShortDateString()</td>
                    <td id="customer-fetchdata-temp-c-@forecast.Date.Ticks">@forecast.TemperatureC</td>
                    <td id="customer-fetchdata-temp-f-@forecast.Date.Ticks">@forecast.TemperatureF</td>
                    <td id="customer-fetchdata-summary-@forecast.Date.Ticks">@forecast.Summary</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private WeatherForecast[]? forecasts;

    protected override async Task OnInitializedAsync()
    {
        forecasts = await ForecastService.GetForecastAsync(DateTime.Now);
    }
}
