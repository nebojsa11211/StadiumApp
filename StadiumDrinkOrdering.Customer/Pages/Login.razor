@page "/login"
@layout MobileShell
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Customer.Services
@inject IApiService Api
@inject ICustomerAuthStateService AuthState
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["Login_PageTitle"]</PageTitle>

<ScreenHeader Title="@Localizer["Login_ScreenHeader_Title"]" Subtitle="@Localizer["Login_ScreenHeader_Subtitle"]" BackHref="/welcome" />

<div id="customer-login-body" class="login-body">
    <div id="customer-login-hero" class="login-hero">
        <div id="customer-login-badge" class="badge">@Localizer["Login_Badge"]</div>
        <h1 id="customer-login-title" class="display">@Localizer["Login_WelcomeLine1"]<br /><span id="customer-login-title-highlight" class="grad-text">@Localizer["Login_WelcomeLine2"]</span></h1>
        <p id="customer-login-intro-text">@Localizer["Login_IntroText"]</p>
    </div>

    <EditForm Model="this" OnValidSubmit="HandleLogin" class="login-form" id="customer-login-form">
        @if (!string.IsNullOrEmpty(_error))
        {
            <div id="customer-login-error" class="err">@_error</div>
        }

        <div id="customer-login-email-field" class="field">
            <label for="customer-login-email-input">@Localizer["Login_EmailLabel"]</label>
            <input id="customer-login-email-input" type="email" @bind="_email" @bind:event="oninput" placeholder='@Localizer["Login_EmailPlaceholder"]' autocomplete="email" />
        </div>
        <div id="customer-login-password-field" class="field">
            <label for="customer-login-password-input">@Localizer["Login_PasswordLabel"]</label>
            <input id="customer-login-password-input" type="password" @bind="_password" @bind:event="oninput" placeholder="••••••••" autocomplete="current-password" />
        </div>

        <button type="submit" class="btn btn-primary" disabled="@_busy" id="customer-login-submit-btn">
            @if (_busy)
            {
                <span class="spinner" id="customer-login-spinner"></span> <span id="customer-login-loading-text">@Localizer["Login_SigningIn"]</span>
            }
            else
            {
                <span id="customer-login-button-text">@Localizer["Login_SignInButton"]</span>
            }
        </button>
    </EditForm>

    <p class="alt">@Localizer["Login_AltText"] <a id="customer-login-scan-link" @onclick="@(() => Nav.NavigateTo("/scan"))">@Localizer["Login_ScanLink"]</a>.</p>
</div>

@code {
    private string _email = "";
    private string _password = "";
    private string? _error;
    private bool _busy;
    private string? _returnUrl;

    protected override void OnInitialized()
    {
        var q = System.Web.HttpUtility.ParseQueryString(new Uri(Nav.Uri).Query);
        _returnUrl = q["returnUrl"];
        if (AuthState.IsAuthenticated)
            Nav.NavigateTo(string.IsNullOrEmpty(_returnUrl) ? "/home" : _returnUrl);
    }

    private async Task HandleLogin()
    {
        if (_busy) return;
        _busy = true;
        _error = null;

        try
        {
            var result = await Api.LoginAsync(new LoginDto { Email = _email, Password = _password });
            if (result?.Token != null && result.User != null)
            {
                await AuthState.LoginAsync(result.Token, result.User);
                Nav.NavigateTo(string.IsNullOrEmpty(_returnUrl) ? "/home" : _returnUrl, forceLoad: false);
            }
            else
            {
                _error = Localizer["Login_InvalidCredentials"];
            }
        }
        catch (HttpRequestException)
        {
            _error = Localizer["Login_ConnectionError"];
        }
        catch (Exception)
        {
            _error = Localizer["Login_UnexpectedError"];
        }
        finally
        {
            _busy = false;
        }
    }
}
