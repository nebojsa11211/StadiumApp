@page "/login"
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Admin.Services
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Login_PageTitle"]</PageTitle>

<div class="console" id="admin-login-container">
    <div id="admin-login-row" style="display:flex; justify-content:center;">
        <div id="admin-login-col" style="width:100%; max-width:420px; margin:3rem 0;">
            <div class="panel" id="admin-login-card">
                <div class="panel__body" id="admin-login-body">
                    <div class="console-head__title" id="admin-login-header" style="text-align:center; margin-bottom:1.5rem;">
                        <span class="eyebrow">@L["Login_StadiumAdmin"]</span>
                        <h1 id="admin-login-title" style="font-size:1.5rem; margin-bottom:0.35rem;">@L["SignIn"]</h1>
                        <p>@L["Login_OperationsConsoleAccess"]</p>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="console-alert console-alert--danger" id="admin-login-error">
                            @errorMessage
                        </div>
                    }

                    <form @onsubmit="HandleLogin" id="admin-login-form">
                        <div class="field" id="admin-login-email-group" style="margin-bottom:1rem;">
                            <label class="field__label" for="admin-login-email-input">@L["Email"]</label>
                            <input type="email" class="field__input" @bind="email" required id="admin-login-email-input" />
                        </div>

                        <div class="field" id="admin-login-password-group" style="margin-bottom:1.25rem;">
                            <label class="field__label" for="admin-login-password-input">@L["Password"]</label>
                            <input type="password" class="field__input" @bind="password" required id="admin-login-password-input" />
                        </div>

                        <div id="admin-login-button-group">
                            <button type="submit" class="pill-btn pill-btn--primary" style="width:100%; justify-content:center;" disabled="@isLoading" id="admin-login-submit-btn">
                                @if (isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" id="admin-login-spinner"></span>
                                    <span id="admin-login-loading-text">@L["Login_LoggingIn"]</span>
                                }
                                else
                                {
                                    <span id="admin-login-button-text">@L["Login"]</span>
                                }
                            </button>
                        </div>
                    </form>

                    <div id="admin-login-demo-info" style="margin-top:1.25rem; text-align:center;">
                        <small class="text-muted" id="admin-login-demo-text">
                            @L["Login_DemoCredentialsHint"]
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
