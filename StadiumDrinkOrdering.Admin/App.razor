@using Microsoft.Extensions.Localization
@using StadiumDrinkOrdering.Admin
@inject IStringLocalizer<SharedResources> L

@if (!isInitialized)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
        <div class="text-center">
            <div class="spinner-border text-primary mb-3" role="status">
                <span class="visually-hidden">@L["Loading"]</span>
            </div>
            <p class="text-muted">@L["App_InitializingApplication"]</p>
        </div>
    </div>
}
else
{
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            @if (IsLoginPage(routeData.PageType))
            {
                <RouteView RouteData="@routeData" DefaultLayout="@typeof(LoginLayout)" />
            }
            else
            {
                <AuthRoute>
                    <RouteView RouteData="@routeData" DefaultLayout="@typeof(DashboardLayout)" />
                </AuthRoute>
            }
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>@L["App_NotFound"]</PageTitle>
            <AuthRoute>
                <LayoutView Layout="@typeof(DashboardLayout)">
                    <p role="alert">@L["App_NothingAtAddress"]</p>
                </LayoutView>
            </AuthRoute>
        </NotFound>
    </Router>
}
