@page "/order"
@layout MobileShell
@using Microsoft.AspNetCore.WebUtilities
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Shared.DTOs
@inject OrderSessionState State
@inject IApiService Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> Localizer
@implements IDisposable

<PageTitle>@Localizer["Order_PageTitle"]</PageTitle>

@if (!State.HasSession && !_loading)
{
    <div id="customer-order-no-session-1" class="gate">
        <div id="customer-order-no-session-emoji-1" class="gate-icon" aria-hidden="true">🎟️</div>
        <h2 id="customer-order-no-session-heading-1">@Localizer["Order_NoSession_Title"]</h2>
        <p id="customer-order-no-session-message-1">@Localizer["Order_NoSession_Message"]</p>
        <div class="gate-actions">
            <button id="customer-order-scan-btn-1" class="btn btn-primary" @onclick="@(() => Nav.NavigateTo("/scan"))">@Localizer["Order_ScanTicketButton"]</button>
        </div>
    </div>
}
else if (State.HasSession && !State.CanOrderDrinks && !_loading)
{
    <div id="customer-order-no-session-2" class="gate">
        <div id="customer-order-no-session-emoji-2" class="gate-icon paused" aria-hidden="true">⏸️</div>
        <h2 id="customer-order-no-session-heading-2">@Localizer["Order_Paused_Title"]</h2>
        <p id="customer-order-no-session-message-2">@Localizer["Order_Paused_Message"]</p>
        <div id="customer-order-no-session-slots-2" class="seat-line seat-line--center">
            <span id="customer-order-no-session-slot-4" class="seat-cell"><span class="k">@Localizer["Order_SectorLabel"]</span><span class="v tnum">@Coord(State.SeatSection)</span></span>
            <span class="seat-dot"></span>
            <span id="customer-order-no-session-slot-5" class="seat-cell"><span class="k">@Localizer["Order_RowLabel"]</span><span class="v tnum">@Coord(State.SeatRow)</span></span>
            <span class="seat-dot"></span>
            <span id="customer-order-no-session-slot-6" class="seat-cell seat"><span class="k">@Localizer["Order_SeatLabel"]</span><span class="v tnum">@Coord(State.SeatNumber)</span></span>
        </div>
        <div class="gate-actions">
            <button id="customer-order-home-btn" class="btn btn-primary" @onclick="@(() => Nav.NavigateTo("/"))">@Localizer["Order_HomeButton"]</button>
        </div>
    </div>
}
else
{
    <div id="customer-order-atmos" class="crowd-atmos" aria-hidden="true"></div>
    <div id="customer-order-head" class="order-head">
        <div id="customer-order-top" class="head-bar">
            <button id="customer-order-back-btn" class="iconbtn" @onclick="@(() => Nav.NavigateTo("/"))" aria-label="@Localizer["Common_BackAria"]">‹</button>
            <div id="customer-order-match-info" class="head-titles">
                <div id="customer-order-pass-match" class="head-title">@(string.IsNullOrWhiteSpace(State.EventName) ? Localizer["Order_Event_Label"] : State.EventName)</div>
                <div id="customer-order-pass-eyebrow" class="head-sub">@Localizer["Order_EventSubtitle"]</div>
            </div>
            <span id="customer-order-pass-live" class="live-badge"><span class="pulse"></span>@Localizer["Order_LiveBadge"]</span>
        </div>
        <div id="customer-order-seat-coords" class="seat-line">
            <span id="customer-order-coord-sector" class="seat-cell"><span class="k">@Localizer["Order_CoordSector"]</span><span class="v tnum">@Coord(State.SeatSection)</span></span>
            <span id="customer-order-cdiv-1" class="seat-dot"></span>
            <span id="customer-order-coord-row" class="seat-cell"><span class="k">@Localizer["Order_CoordRow"]</span><span class="v tnum">@Coord(State.SeatRow)</span></span>
            <span id="customer-order-cdiv-2" class="seat-dot"></span>
            <span id="customer-order-coord-seat" class="seat-cell seat"><span class="k">@Localizer["Order_CoordSeat"]</span><span class="v tnum">@Coord(State.SeatNumber)</span></span>
        </div>
        @* Identity and balance deliberately do not live here: the holder is confirmed at scan time and
           shown again at checkout, and the balance only constrains a decision once there's a cart —
           so it rides the CartBar instead of permanently occupying the sticky header. *@
        <div id="customer-order-tabs" class="tabs no-scrollbar">
            @foreach (var cat in _categories)
            {
                var n = CatCount(cat.Id);
                <button id="customer-order-tab-@cat.Id" class="tab @(cat.Id == _selected ? "on" : "")" @onclick="() => _selected = cat.Id">
                    <span class="tab-emoji" aria-hidden="true">@cat.Icon</span> @cat.Label
                    @if (n > 0)
                    {
                        <span id="customer-order-tab-count-@cat.Id" class="cnt tnum">@n</span>
                    }
                </button>
            }
        </div>
    </div>

    <div id="customer-order-body" class="body no-scrollbar" style="padding-bottom:120px">
        @if (State.ActiveOrderId is { } activeOrderId)
        {
            @* The fan placed an order, then came back here to order more — offer a jump back to tracking it. *@
            <button id="customer-order-track-active-btn" class="track-active"
                    @onclick="@(() => Nav.NavigateTo($"/track/{activeOrderId}"))">
                <span id="customer-order-track-active-dot" class="ta-ic"><span class="pulse"></span></span>
                <span id="customer-order-track-active-text" class="ta-txt">@Localizer["Order_TrackActive", activeOrderId]</span>
                <span id="customer-order-track-active-go" class="ta-go">Prati ›</span>
            </button>
        }
        @if (_loading)
        {
            <div id="customer-order-loading" class="loading"><span class="spinner"></span> @Localizer["Order_Loading"]</div>
        }
        else
        {
            <div id="customer-order-menu-grid" class="menu-grid">
                @foreach (var drink in Filtered())
                {
                    <DrinkCard Drink="drink"
                               Qty="State.QtyOf(drink.Id)"
                               OnAdd="() => QuickAdd(drink)"
                               OnInc="() => State.AddDrink(drink, 1)"
                               OnDec="() => State.SetQty(drink.Id, State.QtyOf(drink.Id) - 1)"
                               OnOpen="() => _sheetDrink = drink" />
                }
            </div>
        }
    </div>

    <CartBar Count="State.Count" Total="State.Subtotal"
             Balance="@SpendableBalance"
             OnView="@(() => Nav.NavigateTo("/cart"))"
             OnTopUp="@(() => Nav.NavigateTo("/wallet"))" />

    <DrinkSheet Drink="_sheetDrink" OnClose="() => _sheetDrink = null" OnAdd="SheetAdd"
                Available="@SpendableAfterCart"
                OnTopUp="@(() => Nav.NavigateTo("/wallet"))" />
}

@code {
    private bool _loading = true;
    private List<DrinkDto> _drinks = new();
    private List<CatTab> _categories = new();
    private int _selected;
    private DrinkDto? _sheetDrink;
    private WalletSummaryDto? _wallet;
    private int? _lastSeenOrderId;

    // Drives the CartBar's affordability line. Null — no wallet, or the best-effort load failed — means
    // the line is omitted rather than shown as an unreadable placeholder, so it never claims "€0.00"
    // when the truth is "we don't know".
    private decimal? SpendableBalance => _wallet is { Exists: true } ? _wallet.Balance : null;

    // What the drink sheet measures its line total against: the balance less the cart already committed,
    // so adding a fourth beer is judged against what's actually left, not the untouched balance.
    private decimal? SpendableAfterCart => SpendableBalance - State.Subtotal;

    // Lightweight category descriptor for the tab strip, built from the loaded drinks.
    private record CatTab(int Id, string Icon, string Label);

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateChanged;

        if (!State.HasSession)
        {
            // Direct-entry / testing bootstrap: /order?qr={token} or /order?s={sessionToken}.
            var q = QueryHelpers.ParseQuery(new Uri(Nav.Uri).Query);
            if (q.TryGetValue("qr", out var qr) && !string.IsNullOrEmpty(qr))
                await State.InitFromQrAsync(qr!);
            else if (q.TryGetValue("s", out var st) && !string.IsNullOrEmpty(st))
                await State.InitFromTokenAsync(st!);
        }

        await LoadDrinks();
        await LoadWallet();
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Persist the session token so a hard reload can recover it; or restore if we arrived cold.
        if (State.HasSession)
        {
            await JS.InvokeVoidAsync("sessionStorage.setItem", "htSessionToken", State.SessionToken);
        }
        else
        {
            var token = await JS.InvokeAsync<string?>("sessionStorage.getItem", "htSessionToken");
            if (!string.IsNullOrEmpty(token) && await State.InitFromTokenAsync(token))
            {
                await LoadDrinks();
                await LoadWallet();
                _loading = false;
                StateHasChanged();
            }
        }

        // Recover the in-flight order after a hard reload so the "track your order" banner reappears.
        if (State.ActiveOrderId == null)
        {
            var active = await JS.InvokeAsync<string?>("sessionStorage.getItem", "htActiveOrderId");
            if (int.TryParse(active, out var activeId) && activeId > 0)
            {
                State.SetActiveOrder(activeId);
                StateHasChanged();
            }
        }
    }

    private async Task LoadDrinks()
    {
        _drinks = await Api.GetDrinksAsync() ?? new();
        _categories = _drinks.Where(d => d.IsAvailable)
            .GroupBy(d => d.CategoryId)
            .Select(g => new CatTab(
                g.Key,
                DrinkVisuals.Emoji(g.First().CategoryIcon),
                DrinkVisuals.Label(g.First().CategoryDisplayName, g.First().CategoryName)))
            .ToList();
        if (_categories.Any() && _categories.All(c => c.Id != _selected))
            _selected = _categories.First().Id;
    }

    // Best-effort spendable balance for the scanned ticket; a failure leaves SpendableBalance null,
    // which simply hides the CartBar's affordability line.
    private async Task LoadWallet()
    {
        if (!State.HasSession) return;
        _wallet = await Api.GetSessionWalletSummaryAsync(State.SessionToken!);
    }

    // A wallet-paid checkout spends money that this page is still quoting. Today /order re-initializes
    // on the way back from /track, but that's incidental — refetch whenever a new order appears so the
    // balance can't go stale if this page is ever kept alive across checkout.
    private async Task RefreshWalletIfOrderPlaced()
    {
        if (State.ActiveOrderId is not { } id || id == _lastSeenOrderId) return;
        _lastSeenOrderId = id;
        await LoadWallet();
        StateHasChanged();
    }

    private IEnumerable<DrinkDto> Filtered() =>
        _drinks.Where(d => d.CategoryId == _selected).OrderByDescending(d => d.IsAvailable && d.StockQuantity > 0).ThenBy(d => d.Name);

    private void QuickAdd(DrinkDto drink) => State.AddDrink(drink, 1);

    // Total cart quantity for a category — powers the count badge on each tab.
    private int CatCount(int categoryId) => _drinks.Where(d => d.CategoryId == categoryId).Sum(d => State.QtyOf(d.Id));

    // A seat coordinate for the pass; falls back to an em dash so the ticket layout never collapses.
    private static string Coord(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value.Trim();

    private void SheetAdd(DrinkOrderRequest req)
    {
        var drink = _drinks.FirstOrDefault(d => d.Id == req.DrinkId);
        if (drink != null) State.AddDrink(drink, req.Quantity, req.Note);
        _sheetDrink = null;
    }

    private void StateChanged() => InvokeAsync(async () =>
    {
        StateHasChanged();
        await RefreshWalletIfOrderPlaced();
    });

    public void Dispose() => State.OnChange -= StateChanged;
}
