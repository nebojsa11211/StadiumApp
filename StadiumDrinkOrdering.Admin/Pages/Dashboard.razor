@page "/dashboard"
@using StadiumDrinkOrdering.Admin.Components.Skeleton

@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Dash_PageTitle"]</PageTitle>

<div class="console" id="admin-dashboard-main-container">
    <!-- Dashboard Header -->
    <header class="console-head" id="admin-dashboard-header">
        <div class="console-head__title" id="admin-dashboard-title-section">
            <span class="eyebrow">@L["Dash_Eyebrow"]</span>
            <h1>@L["Dash_Title"]</h1>
            <p>@L["Dash_Subtitle"]</p>
        </div>
        <div class="console-head__actions" id="admin-dashboard-action-buttons">
            <span class="live-pill" title="@L["Dash_AutoRefreshing"]">
                <span class="live-dot @(isLoading ? "is-busy" : "")"></span>
                @(isLoading ? @L["Dash_Syncing"] : @L["Dash_Live"])
            </span>
            <button class="icon-btn" @onclick="RefreshData" disabled="@isLoading" id="admin-dashboard-refresh-btn" title="@L["Dash_RefreshData"]">
                <i class="oi oi-reload @(isLoading ? "spin" : "")"></i>
            </button>
            <button class="icon-btn" @onclick="ToggleTheme" id="admin-dashboard-toggle-theme-btn" title="@L["Dash_ToggleTheme"]">
                <i class="oi oi-moon"></i>
            </button>
        </div>
    </header>

    <!-- Loading Progress and Status -->
    @if (isLoading)
    {
        <div class="status-line" id="admin-dashboard-status-line-loading">
            <div class="progress" id="admin-dashboard-progress-bar-container" style="height: 3px;">
                <div class="progress-bar progress-bar-animated" id="admin-dashboard-progress-bar"
                     role="progressbar"
                     style="width: @(loadingProgress)%"
                     aria-valuenow="@loadingProgress"
                     aria-valuemin="0"
                     aria-valuemax="100"
                     aria-label="@L["Dash_LoadingProgress"]">
                </div>
            </div>
            <div class="status-line__meta" id="admin-dashboard-status-line-meta">
                <span id="admin-dashboard-loading-message">@loadingMessage</span>
                <span class="mono" id="admin-dashboard-loading-percent">@(loadingProgress)%</span>
            </div>
        </div>
    }
    else if (lastUpdated.HasValue)
    {
        <div class="status-line status-line--idle" id="admin-dashboard-status-line-idle">
            <span class="status-line__pulse"></span>
            <span>@L["Dash_Updated"] <span class="mono">@lastUpdated.Value.ToString("HH:mm:ss")</span> · @L["Dash_AutoRefreshOn"]</span>
        </div>
    }

    <!-- ARIA Live Region for Screen Readers -->
    <div aria-live="polite" aria-label="@L["Dash_LoadingStatus"]" class="visually-hidden" id="dashboard-loading-status">
        @loadingMessage
    </div>

    <!-- Key Metrics Cards -->
    @if (isLoadingMetrics)
    {
        <div class="row g-4 mb-4" id="admin-dashboard-skeleton-metrics-row" role="status" aria-label="@L["Dash_LoadingMetrics"]">
            <div class="col-lg-3 col-md-6" id="admin-dashboard-skeleton-metrics-col-1">
                <SkeletonMetricCard CardType="Orders" AnimationDelayMs="0" />
            </div>
            <div class="col-lg-3 col-md-6" id="admin-dashboard-skeleton-metrics-col-2">
                <SkeletonMetricCard CardType="Active" AnimationDelayMs="100" />
            </div>
            <div class="col-lg-3 col-md-6" id="admin-dashboard-skeleton-metrics-col-3">
                <SkeletonMetricCard CardType="Revenue" AnimationDelayMs="200" />
            </div>
            <div class="col-lg-3 col-md-6" id="admin-dashboard-skeleton-metrics-col-4">
                <SkeletonMetricCard CardType="Health" AnimationDelayMs="300" />
            </div>
        </div>
    }
    else if (!isLoading || totalOrders > 0)
    {
        <section class="metrics skeleton-fade-in" id="admin-dashboard-metrics-section">
            <!-- Total Orders -->
            <article class="metric metric--clickable" @onclick="NavigateToOrders" id="admin-dashboard-metric-orders">
                <div class="metric__head">
                    <span class="metric__label">@L["Dash_TotalOrders"]</span>
                    <i class="oi oi-list-rich metric__icon"></i>
                </div>
                <div class="metric__value mono">@totalOrders</div>
                <div class="metric__foot">
                    <span class="delta delta--up">&#9650; @ordersTrend.ToString("0.#")%</span>
                    <span class="metric__hint">@L["Dash_VsYesterday"]</span>
                </div>
            </article>

            <!-- Active Orders (accent: this is what needs attention now) -->
            <article class="metric metric--accent" id="admin-dashboard-metric-active">
                <div class="metric__head">
                    <span class="metric__label">@L["Dash_ActiveOrders"]</span>
                    <i class="oi oi-clock metric__icon"></i>
                </div>
                <div class="metric__value mono">@activeOrders</div>
                <div class="metric__foot">
                    <span class="metric__hint">@L["Dash_InQueue"]</span>
                </div>
            </article>

            <!-- Today's Revenue -->
            <article class="metric" id="admin-dashboard-metric-revenue">
                <div class="metric__head">
                    <span class="metric__label">@L["Dash_TodaysRevenue"]</span>
                    <i class="oi oi-dollar metric__icon"></i>
                </div>
                <div class="metric__value mono"><span class="metric__unit">$</span>@todaysRevenue.ToString("N0")</div>
                <div class="metric__foot">
                    <span class="delta delta--up">&#9650; @revenueTrend.ToString("0.#")%</span>
                    <span class="metric__hint">@L["Dash_VsYesterday"]</span>
                </div>
            </article>

            <!-- System Health -->
            <article class="metric" id="admin-dashboard-metric-health">
                <div class="metric__head">
                    <span class="metric__label">@L["Dash_SystemHealth"]</span>
                    <i class="@GetHealthIcon() metric__icon @GetHealthIconModifier()"></i>
                </div>
                <div class="metric__value metric__value--text">
                    <span class="health-dot @GetHealthDotModifier()"></span>@systemHealth
                </div>
                <div class="metric__foot">
                    <span class="metric__hint">@systemLoad</span>
                </div>
            </article>
        </section>
    }

    <!-- Main Content Row -->
    @if (isLoadingOrders || isLoadingSystemStatus)
    {
        <div class="row g-4" id="admin-dashboard-skeleton-content-row" role="status" aria-label="@L["Dash_LoadingOrdersSystem"]">
            <div class="col-lg-8" id="admin-dashboard-skeleton-content-col-left">
                <SkeletonTable TableType="Orders" RowCount="5" ShowActionButton="true" AnimationDelayMs="400" />
            </div>
            <div class="col-lg-4" id="admin-dashboard-skeleton-content-col-right">
                <SkeletonActionButtons SectionType="Dashboard"
                                     ButtonCount="4"
                                     IncludeSystemStatus="true"
                                     StatusItemCount="4"
                                     AnimationDelayMs="500" />
            </div>
        </div>
    }
    else if (!isLoading || recentOrders != null)
    {
        <section class="board skeleton-fade-in" id="admin-dashboard-content-board">
            <!-- Recent Orders -->
            <div class="panel" id="admin-dashboard-recent-orders-panel">
                <div class="panel__head" id="admin-dashboard-recent-orders-panel-head">
                    <h2 class="panel__title" id="admin-dashboard-recent-orders-title">@L["Dash_RecentOrders"]</h2>
                    <button class="link-btn" @onclick="NavigateToOrders" id="admin-dashboard-orders-view-all-btn">
                        @L["Dash_ViewAll"] <i class="oi oi-arrow-right"></i>
                    </button>
                </div>
                @if (recentOrders?.Any() == true)
                {
                    <table class="order-table" id="admin-dashboard-recent-orders-table">
                        <thead id="admin-dashboard-recent-orders-table-head">
                            <tr id="admin-dashboard-recent-orders-table-header-row">
                                <th id="admin-dashboard-recent-orders-table-header-order">@L["Dash_HeaderOrder"]</th>
                                <th id="admin-dashboard-recent-orders-table-header-customer">@L["Dash_HeaderCustomer"]</th>
                                <th class="num" id="admin-dashboard-recent-orders-table-header-amount">@L["Dash_HeaderAmount"]</th>
                                <th id="admin-dashboard-recent-orders-table-header-status">@L["Dash_HeaderStatus"]</th>
                                <th class="num" id="admin-dashboard-recent-orders-table-header-time">@L["Dash_HeaderTime"]</th>
                            </tr>
                        </thead>
                        <tbody id="admin-dashboard-recent-orders-table-body">
                            @foreach (var order in recentOrders.Take(6))
                            {
                                <tr id="@($"admin-dashboard-recent-order-row-{order.Id}")" @onclick="@(() => NavigateToOrder(order.Id))">
                                    <td class="mono order-table__id" id="@($"admin-dashboard-recent-order-id-{order.Id}")">#@order.Id</td>
                                    <td id="@($"admin-dashboard-recent-order-customer-{order.Id}")">@order.CustomerName</td>
                                    <td class="num mono" id="@($"admin-dashboard-recent-order-amount-{order.Id}")">$@order.TotalAmount.ToString("N2")</td>
                                    <td id="@($"admin-dashboard-recent-order-status-{order.Id}")">
                                        <span class="status @GetStatusModifier(order.Status)">
                                            <span class="status__dot"></span>@order.Status
                                        </span>
                                    </td>
                                    <td class="num mono order-table__time" id="@($"admin-dashboard-recent-order-time-{order.Id}")">@order.CreatedAt.ToString("HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty">
                        <i class="oi oi-inbox"></i>
                        <p>@L["Dash_NoOrdersToday"]</p>
                        <span>@L["Dash_OrdersAppearHere"]</span>
                    </div>
                }
            </div>

            <!-- Right rail -->
            <div class="rail" id="admin-dashboard-right-rail">
                <div class="panel" id="admin-dashboard-quick-actions-panel">
                    <div class="panel__head" id="admin-dashboard-quick-actions-panel-head">
                        <h2 class="panel__title" id="admin-dashboard-quick-actions-title">@L["Dash_QuickActions"]</h2>
                    </div>
                    <div class="actions" id="admin-dashboard-quick-actions-list">
                        <button class="action" @onclick="NavigateToOrders" id="admin-dashboard-orders-manage-btn">
                            <i class="oi oi-plus"></i><span>@L["Dash_NewOrder"]</span><i class="oi oi-chevron-right action__go"></i>
                        </button>
                        <button class="action" @onclick="NavigateToUsers" id="admin-dashboard-users-manage-btn">
                            <i class="oi oi-person"></i><span>@L["Dash_AddUser"]</span><i class="oi oi-chevron-right action__go"></i>
                        </button>
                        <button class="action" @onclick="NavigateToReports" id="admin-dashboard-reports-view-btn">
                            <i class="oi oi-spreadsheet"></i><span>@L["Dash_ExportReports"]</span><i class="oi oi-chevron-right action__go"></i>
                        </button>
                        <button class="action" @onclick="NavigateToLogs" id="admin-dashboard-logs-view-btn">
                            <i class="oi oi-list"></i><span>@L["Dash_ViewLogs"]</span><i class="oi oi-chevron-right action__go"></i>
                        </button>
                    </div>
                </div>

                <div class="panel" id="admin-dashboard-system-status-panel">
                    <div class="panel__head" id="admin-dashboard-system-status-panel-head">
                        <h2 class="panel__title" id="admin-dashboard-system-status-title">@L["Dash_SystemStatus"]</h2>
                    </div>
                    <ul class="statuses" id="admin-dashboard-system-status-list">
                        <li id="admin-dashboard-status-database">
                            <span class="statuses__name">@L["Dash_Database"]</span>
                            <span class="chip chip--ok"><span class="chip__dot"></span>@L["Dash_Connected"]</span>
                        </li>
                        <li id="admin-dashboard-status-api">
                            <span class="statuses__name">@L["Dash_APIHealth"]</span>
                            <span class="chip chip--ok"><span class="chip__dot"></span>@L["Dash_Healthy"]</span>
                        </li>
                        <li id="admin-dashboard-status-cache">
                            <span class="statuses__name">@L["Dash_Cache"]</span>
                            <span class="chip chip--ok"><span class="chip__dot"></span>@L["Dash_Active"]</span>
                        </li>
                        <li id="admin-dashboard-status-background">
                            <span class="statuses__name">@L["Dash_BackgroundServices"]</span>
                            <span class="chip chip--ok"><span class="chip__dot"></span>@L["Dash_Running"]</span>
                        </li>
                    </ul>
                </div>
            </div>
        </section>
    }
</div>
