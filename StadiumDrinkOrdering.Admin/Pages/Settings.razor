@page "/admin/settings"
@using System.IO
@using System.Net.Http
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Shared.Services
@using StadiumDrinkOrdering.Shared.Authentication.Interfaces
@inject IImageGenerationClient ImageGen
@inject IHttpClientFactory HttpClientFactory
@inject IConfiguration Configuration
@inject ITokenStorageService TokenStorage
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject ILogger<Settings> Logger
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Settings_PageTitle"]</PageTitle>

<div id="admin-settings-main-container" class="container-fluid">
    <PageHeader Id="admin-settings-header"
                Eyebrow='@L["Settings_Eyebrow"]'
                Title='@L["Settings_Heading"]'
                Subtitle='@L["Settings_Subtitle"]' />

    @if (!string.IsNullOrEmpty(alertMessage))
    {
        <div id="admin-settings-alert" class="alert @alertClass alert-dismissible d-flex justify-content-between align-items-center" role="alert">
            <span id="admin-settings-alert-text">@alertMessage</span>
            <button type="button" id="admin-settings-alert-close" class="btn-close" @onclick="() => alertMessage = null"></button>
        </div>
    }

    @if (isLoading)
    {
        <div id="admin-settings-loading" class="d-flex align-items-center text-muted">
            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
            <span>@L["Settings_Loading"]</span>
        </div>
    }
    else if (loadError || settings is null)
    {
        <div id="admin-settings-error" class="alert alert-danger d-flex justify-content-between align-items-center" role="alert">
            <span>@L["Settings_Error"]</span>
            <button id="admin-settings-retry-btn" class="btn btn-sm btn-outline-danger" @onclick="LoadAsync">@L["Settings_Retry"]</button>
        </div>
    }
    else
    {
        <ul class="nav nav-tabs mb-4" id="admin-settings-tabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button type="button" id="admin-settings-tab-ticketing"
                        class="nav-link @(activeTab == "ticketing" ? "active" : "")"
                        @onclick='() => activeTab = "ticketing"'>
                    <i class="bi bi-ticket-perforated me-1"></i>@L["Settings_TicketingSection"]
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" id="admin-settings-tab-payments"
                        class="nav-link @(activeTab == "payments" ? "active" : "")"
                        @onclick='() => activeTab = "payments"'>
                    <i class="bi bi-credit-card me-1"></i>@L["Settings_PaymentsSection"]
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" id="admin-settings-tab-email"
                        class="nav-link @(activeTab == "email" ? "active" : "")"
                        @onclick='() => activeTab = "email"'>
                    <i class="bi bi-envelope me-1"></i>@L["Settings_EmailSection"]
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" id="admin-settings-tab-backup"
                        class="nav-link @(activeTab == "backup" ? "active" : "")"
                        @onclick='() => activeTab = "backup"'>
                    <i class="bi bi-hdd me-1"></i>@L["Settings_BackupSection"]
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" id="admin-settings-tab-imagegen"
                        class="nav-link @(activeTab == "imagegen" ? "active" : "")"
                        @onclick='() => activeTab = "imagegen"'>
                    <i class="bi bi-image me-1"></i>@L["Settings_ImageGenSection"]
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" id="admin-settings-tab-danger"
                        class="nav-link text-danger @(activeTab == "danger" ? "active" : "")"
                        @onclick='() => activeTab = "danger"'>
                    <i class="bi bi-exclamation-octagon me-1"></i>@L["Settings_DangerSection"]
                </button>
            </li>
        </ul>

        @if (activeTab == "ticketing")
        {
        <div class="card mb-4" id="admin-settings-ticketing-card">
            <div class="card-header">
                <h5 class="mb-0" id="admin-settings-ticketing-title">@L["Settings_TicketingSection"]</h5>
            </div>
            <div class="card-body" id="admin-settings-ticketing-body">
                <div class="form-check form-switch" id="admin-settings-ticket-sales-group">
                    <input class="form-check-input" type="checkbox" role="switch"
                           id="admin-settings-ticket-sales-input"
                           checked="@settings.TicketSalesEnabled"
                           @onchange="OnTicketSalesToggled" />
                    <label class="form-check-label fw-semibold" for="admin-settings-ticket-sales-input">
                        @L["Settings_TicketSalesEnabled"]
                    </label>
                </div>
                <div class="form-text mt-1" id="admin-settings-ticket-sales-hint">@L["Settings_TicketSalesEnabledHint"]</div>

                <div id="admin-settings-ticket-sales-status" class="alert @(settings.TicketSalesEnabled ? "alert-success" : "alert-warning") mt-3 mb-0 py-2">
                    <i class="bi @(settings.TicketSalesEnabled ? "bi-check-circle" : "bi-slash-circle") me-1"></i>
                    @(settings.TicketSalesEnabled ? L["Settings_TicketSalesOn"] : L["Settings_TicketSalesOff"])
                </div>

                <div class="d-flex align-items-center gap-3 mt-4">
                    <button type="button" id="admin-settings-save-btn" class="btn btn-primary" @onclick="SaveAsync" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        @L["Settings_Save"]
                    </button>
                </div>
            </div>
        </div>
        }

        @if (activeTab == "payments")
        {
        <div class="card mb-4" id="admin-settings-payments-card">
            <div class="card-header">
                <h5 class="mb-0" id="admin-settings-payments-title">@L["Settings_PaymentsSection"]</h5>
            </div>
            <div class="card-body" id="admin-settings-payments-body">
                <p class="text-muted" id="admin-settings-payments-intro">@L["Settings_PaymentsIntro"]</p>

                <div class="form-check form-switch" id="admin-settings-pay-wallet-group">
                    <input class="form-check-input" type="checkbox" role="switch"
                           id="admin-settings-pay-wallet-input"
                           checked="@settings.WalletPaymentEnabled"
                           @onchange="@(e => OnPaymentToggled("wallet", e))" />
                    <label class="form-check-label fw-semibold" for="admin-settings-pay-wallet-input">
                        @L["Settings_PayWallet"]
                    </label>
                </div>
                <div class="form-text mb-3" id="admin-settings-pay-wallet-hint">@L["Settings_PayWalletHint"]</div>

                <div class="form-check form-switch" id="admin-settings-pay-card-group">
                    <input class="form-check-input" type="checkbox" role="switch"
                           id="admin-settings-pay-card-input"
                           checked="@settings.CardPaymentEnabled"
                           @onchange="@(e => OnPaymentToggled("card", e))" />
                    <label class="form-check-label fw-semibold" for="admin-settings-pay-card-input">
                        @L["Settings_PayCard"]
                    </label>
                </div>
                <div class="form-text mb-3" id="admin-settings-pay-card-hint">@L["Settings_PayCardHint"]</div>

                <div class="form-check form-switch" id="admin-settings-pay-cash-group">
                    <input class="form-check-input" type="checkbox" role="switch"
                           id="admin-settings-pay-cash-input"
                           checked="@settings.CashPaymentEnabled"
                           @onchange="@(e => OnPaymentToggled("cash", e))" />
                    <label class="form-check-label fw-semibold" for="admin-settings-pay-cash-input">
                        @L["Settings_PayCash"]
                    </label>
                </div>
                <div class="form-text" id="admin-settings-pay-cash-hint">@L["Settings_PayCashHint"]</div>

                @if (!settings.HasAnyPaymentMethod)
                {
                    <div id="admin-settings-payments-none" class="alert alert-danger mt-3 mb-0 py-2">
                        <i class="bi bi-exclamation-triangle me-1"></i>@L["Settings_PaymentsNoneWarning"]
                    </div>
                }

                <div class="d-flex align-items-center gap-3 mt-4">
                    <button type="button" id="admin-settings-payments-save-btn" class="btn btn-primary"
                            @onclick="SaveAsync" disabled="@(isSaving || !settings.HasAnyPaymentMethod)">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        @L["Settings_Save"]
                    </button>
                </div>
            </div>
        </div>
        }

        @if (activeTab == "email")
        {
        <div class="card mb-4" id="admin-settings-email-card">
            <div class="card-header">
                <h5 class="mb-0" id="admin-settings-email-title">@L["Settings_EmailSection"]</h5>
            </div>
            <div class="card-body" id="admin-settings-email-body">
                <p class="text-muted" id="admin-settings-email-subtitle">@L["Settings_EmailSubtitle"]</p>

                @if (email is null)
                {
                    <div id="admin-settings-email-loading" class="text-muted">
                        <div class="spinner-border spinner-border-sm me-2" role="status"></div>@L["Settings_Loading"]
                    </div>
                }
                else
                {
                    <div class="form-check form-switch mb-3" id="admin-settings-email-enabled-group">
                        <input class="form-check-input" type="checkbox" role="switch"
                               id="admin-settings-email-enabled-input"
                               checked="@email.EmailEnabled"
                               @onchange="e => email.EmailEnabled = e.Value is bool b && b" />
                        <label class="form-check-label fw-semibold" for="admin-settings-email-enabled-input">
                            @L["Settings_EmailEnabled"]
                        </label>
                        <div class="form-text" id="admin-settings-email-enabled-hint">@L["Settings_EmailEnabledHint"]</div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-8" id="admin-settings-email-host-group">
                            <label class="form-label" for="admin-settings-email-host-input">@L["Settings_EmailHost"]</label>
                            <input type="text" class="form-control" id="admin-settings-email-host-input"
                                   @bind="email.SmtpHost" placeholder="smtp.example.com" autocomplete="off" />
                        </div>
                        <div class="col-md-4" id="admin-settings-email-port-group">
                            <label class="form-label" for="admin-settings-email-port-input">@L["Settings_EmailPort"]</label>
                            <input type="number" min="1" max="65535" class="form-control" id="admin-settings-email-port-input"
                                   @bind="email.SmtpPort" />
                        </div>
                        <div class="col-md-6" id="admin-settings-email-username-group">
                            <label class="form-label" for="admin-settings-email-username-input">@L["Settings_EmailUsername"]</label>
                            <input type="text" class="form-control" id="admin-settings-email-username-input"
                                   @bind="email.SmtpUsername" autocomplete="off" />
                        </div>
                        <div class="col-md-6" id="admin-settings-email-password-group">
                            <label class="form-label" for="admin-settings-email-password-input">@L["Settings_EmailPassword"]</label>
                            <input type="password" class="form-control" id="admin-settings-email-password-input"
                                   @bind="email.Password" autocomplete="new-password"
                                   placeholder="@(email.HasPassword ? "••••••••" : "")" />
                            <div class="form-text" id="admin-settings-email-password-hint">
                                @(email.HasPassword ? L["Settings_EmailPasswordStoredHint"] : L["Settings_EmailPasswordHint"])
                            </div>
                        </div>
                        <div class="col-md-6" id="admin-settings-email-from-address-group">
                            <label class="form-label" for="admin-settings-email-from-address-input">@L["Settings_EmailFromAddress"]</label>
                            <input type="email" class="form-control" id="admin-settings-email-from-address-input"
                                   @bind="email.FromAddress" placeholder="no-reply@@stadium.local" autocomplete="off" />
                        </div>
                        <div class="col-md-6" id="admin-settings-email-from-name-group">
                            <label class="form-label" for="admin-settings-email-from-name-input">@L["Settings_EmailFromName"]</label>
                            <input type="text" class="form-control" id="admin-settings-email-from-name-input"
                                   @bind="email.FromName" placeholder="Stadium" autocomplete="off" />
                        </div>
                    </div>

                    <div class="form-check form-switch mt-3" id="admin-settings-email-ssl-group">
                        <input class="form-check-input" type="checkbox" role="switch"
                               id="admin-settings-email-ssl-input"
                               checked="@email.SmtpUseSsl"
                               @onchange="e => email.SmtpUseSsl = e.Value is bool b && b" />
                        <label class="form-check-label" for="admin-settings-email-ssl-input">@L["Settings_EmailUseSsl"]</label>
                    </div>

                    <div class="mt-4">
                        <button type="button" id="admin-settings-email-save-btn" class="btn btn-primary"
                                @onclick="SaveEmailAsync" disabled="@isSavingEmail">
                            @if (isSavingEmail)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            }
                            @L["Settings_EmailSave"]
                        </button>
                    </div>

                    <hr class="my-4" />

                    <h6 class="fw-semibold" id="admin-settings-email-test-title">@L["Settings_EmailTestTitle"]</h6>
                    <p class="form-text mt-0" id="admin-settings-email-test-hint">@L["Settings_EmailTestHint"]</p>
                    <div class="row g-2 align-items-end">
                        <div class="col-md-6" id="admin-settings-email-test-recipient-group">
                            <label class="form-label" for="admin-settings-email-test-recipient-input">@L["Settings_EmailTestRecipient"]</label>
                            <input type="email" class="form-control" id="admin-settings-email-test-recipient-input"
                                   @bind="testRecipient" autocomplete="off" />
                        </div>
                        <div class="col-md-6" id="admin-settings-email-test-btn-group">
                            <button type="button" id="admin-settings-email-test-btn" class="btn btn-outline-primary"
                                    @onclick="SendTestEmailAsync"
                                    disabled="@(isTestingEmail || string.IsNullOrWhiteSpace(testRecipient) || string.IsNullOrWhiteSpace(email.SmtpHost))">
                                @if (isTestingEmail)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                }
                                <i class="bi bi-send me-1"></i>@L["Settings_EmailTestButton"]
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="card mb-4" id="admin-settings-email-templates-card">
            <div class="card-header">
                <h5 class="mb-0" id="admin-settings-email-templates-title">@L["Settings_EmailTemplatesSection"]</h5>
            </div>
            <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2" id="admin-settings-email-templates-body">
                <p class="text-muted mb-0" id="admin-settings-email-templates-subtitle">@L["Settings_EmailTemplatesSubtitle"]</p>
                <a class="btn btn-outline-primary" id="admin-settings-email-templates-link" href="/admin/email-templates">
                    <i class="bi bi-envelope-paper me-1"></i>@L["Settings_EmailTemplatesButton"]
                </a>
            </div>
        </div>
        }

        @if (activeTab == "backup")
        {
        <div class="card mb-4" id="admin-settings-backup-card">
            <div class="card-header">
                <h5 class="mb-0" id="admin-settings-backup-title">@L["Settings_BackupSection"]</h5>
            </div>
            <div class="card-body" id="admin-settings-backup-body">
                <p class="text-muted" id="admin-settings-backup-subtitle">@L["Settings_BackupSubtitle"]</p>

                <h6 class="fw-semibold" id="admin-settings-backup-export-title">@L["Settings_BackupExportTitle"]</h6>
                <p class="form-text mt-0" id="admin-settings-backup-export-hint">@L["Settings_BackupExportHint"]</p>

                @if (backupTables is null)
                {
                    <div id="admin-settings-backup-loading" class="text-muted">
                        <div class="spinner-border spinner-border-sm me-2" role="status"></div>@L["Settings_Loading"]
                    </div>
                }
                else
                {
                    @foreach (var group in BackupGroupOrder)
                    {
                        var tablesInGroup = backupTables.Where(t => t.Group == group).ToList();
                        if (tablesInGroup.Count == 0) continue;
                        <div class="mb-3" id="@($"admin-settings-backup-group-{group}")">
                            <div class="form-check form-check-inline fw-semibold">
                                <input class="form-check-input" type="checkbox"
                                       id="@($"admin-settings-backup-group-check-{group}")"
                                       checked="@tablesInGroup.All(t => backupSelected.Contains(t.Key))"
                                       @onchange="e => ToggleBackupGroup(group, e.Value is bool b && b)" />
                                <label class="form-check-label" for="@($"admin-settings-backup-group-check-{group}")">
                                    @GroupLabel(group)
                                </label>
                            </div>
                            <div class="ms-4 row g-1">
                                @foreach (var table in tablesInGroup)
                                {
                                    <div class="col-md-6 col-lg-4 form-check" id="@($"admin-settings-backup-item-{table.Key}")">
                                        <input class="form-check-input" type="checkbox"
                                               id="@($"admin-settings-backup-check-{table.Key}")"
                                               checked="@backupSelected.Contains(table.Key)"
                                               @onchange="e => ToggleBackupTable(table.Key, e.Value is bool b && b)" />
                                        <label class="form-check-label small" for="@($"admin-settings-backup-check-{table.Key}")">
                                            @table.DisplayName
                                            <span class="text-muted">(@table.RowCount)</span>
                                            @if (table.Sensitive)
                                            {
                                                <i class="bi bi-shield-lock text-warning ms-1" title="@L["Settings_BackupSensitiveHint"]"></i>
                                            }
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <button type="button" id="admin-settings-backup-download-btn" class="btn btn-primary mt-2"
                            @onclick="DownloadBackupAsync" disabled="@(isBackingUp || backupSelected.Count == 0)">
                        @if (isBackingUp)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        <i class="bi bi-download me-1"></i>@L["Settings_BackupDownload"]
                    </button>
                }

                <hr class="my-4" />

                <h6 class="fw-semibold" id="admin-settings-restore-title">@L["Settings_RestoreTitle"]</h6>
                <div class="alert alert-warning py-2" id="admin-settings-restore-warning">
                    <i class="bi bi-exclamation-triangle me-1"></i>@L["Settings_RestoreWarning"]
                </div>

                <div class="mb-2" id="admin-settings-restore-file-group">
                    <label class="form-label" for="admin-settings-restore-file-input">@L["Settings_RestoreSelectFile"]</label>
                    <InputFile OnChange="OnRestoreFileSelected" accept=".json"
                               class="form-control" id="admin-settings-restore-file-input" />
                </div>

                @if (isPreviewing)
                {
                    <div id="admin-settings-restore-previewing" class="text-muted">
                        <div class="spinner-border spinner-border-sm me-2" role="status"></div>@L["Settings_RestorePreviewing"]
                    </div>
                }
                else if (restorePreview is not null)
                {
                    <div class="border rounded p-3 mt-2" id="admin-settings-restore-preview">
                        <div class="small text-muted mb-2" id="admin-settings-restore-preview-meta">
                            @L["Settings_RestoreFileMeta", restoreFileName ?? "", restorePreview.Meta.CreatedUtc.ToLocalTime().ToString("g")]
                        </div>

                        @if (restorePreview.Tables.Count == 0)
                        {
                            <div class="text-muted" id="admin-settings-restore-empty">@L["Settings_RestoreNoKnownTables"]</div>
                        }
                        else
                        {
                            <div class="row g-1">
                                @foreach (var table in restorePreview.Tables)
                                {
                                    <div class="col-md-6 col-lg-4 form-check" id="@($"admin-settings-restore-item-{table.Key}")">
                                        <input class="form-check-input" type="checkbox"
                                               id="@($"admin-settings-restore-check-{table.Key}")"
                                               checked="@restoreSelected.Contains(table.Key)"
                                               @onchange="e => ToggleRestoreTable(table.Key, e.Value is bool b && b)" />
                                        <label class="form-check-label small" for="@($"admin-settings-restore-check-{table.Key}")">
                                            @table.DisplayName <span class="text-muted">(@table.RowCount)</span>
                                        </label>
                                    </div>
                                }
                            </div>
                        }

                        @if (restorePreview.UnknownTables.Count > 0)
                        {
                            <div class="alert alert-secondary py-2 mt-2 mb-0 small" id="admin-settings-restore-unknown">
                                @L["Settings_RestoreUnknownTables", string.Join(", ", restorePreview.UnknownTables)]
                            </div>
                        }

                        <button type="button" id="admin-settings-restore-btn" class="btn btn-outline-danger mt-3"
                                @onclick="OpenRestoreModal" disabled="@(isRestoring || restoreSelected.Count == 0)">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>@L["Settings_RestoreButton"]
                        </button>
                    </div>
                }
            </div>
        </div>
        }

        @if (activeTab == "imagegen")
        {
        <div class="card mb-4" id="admin-settings-imagegen-card">
            <div class="card-header">
                <h5 class="mb-0" id="admin-settings-imagegen-title">@L["Settings_ImageGenSection"]</h5>
            </div>
            <div class="card-body" id="admin-settings-imagegen-body">
                <p class="text-muted" id="admin-settings-imagegen-subtitle">@L["Settings_ImageGenSubtitle"]</p>

                <div class="mb-3" id="admin-settings-imagegen-prompt-group">
                    <label class="form-label" for="admin-settings-imagegen-prompt-input">@L["Settings_ImageGenPrompt"]</label>
                    <textarea class="form-control" id="admin-settings-imagegen-prompt-input" rows="3"
                              @bind="imageGenPrompt" @bind:event="oninput"
                              placeholder="@L["Settings_ImageGenPromptPlaceholder"]"></textarea>
                </div>

                <div class="row g-3">
                    <div class="col-md-3" id="admin-settings-imagegen-width-group">
                        <label class="form-label" for="admin-settings-imagegen-width-input">@L["Settings_ImageGenWidth"]</label>
                        <input type="number" min="64" max="4096" class="form-control"
                               id="admin-settings-imagegen-width-input" @bind="imageGenWidth" />
                    </div>
                    <div class="col-md-3" id="admin-settings-imagegen-height-group">
                        <label class="form-label" for="admin-settings-imagegen-height-input">@L["Settings_ImageGenHeight"]</label>
                        <input type="number" min="64" max="4096" class="form-control"
                               id="admin-settings-imagegen-height-input" @bind="imageGenHeight" />
                    </div>
                </div>

                <div class="mt-4 d-flex align-items-center gap-2">
                    <button type="button" id="admin-settings-imagegen-generate-btn" class="btn btn-primary"
                            @onclick="GenerateImageAsync"
                            disabled="@(isGenerating || string.IsNullOrWhiteSpace(imageGenPrompt))">
                        @if (isGenerating)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        <i class="bi bi-magic me-1"></i>@L["Settings_ImageGenGenerate"]
                    </button>
                    @if (imageResult is not null && !imageIsPlaceholder)
                    {
                        <button type="button" id="admin-settings-imagegen-download-btn" class="btn btn-outline-secondary"
                                @onclick="DownloadImageAsync">
                            <i class="bi bi-download me-1"></i>@L["Settings_ImageGenDownload"]
                        </button>
                    }
                </div>

                @if (imageGenError is not null)
                {
                    <div class="alert alert-danger mt-3 mb-0" id="admin-settings-imagegen-error">
                        <i class="bi bi-exclamation-triangle me-1"></i>@imageGenError
                    </div>
                }

                @if (imageResult is not null)
                {
                    @if (imageIsPlaceholder)
                    {
                        <div class="alert alert-warning mt-3 mb-0" id="admin-settings-imagegen-placeholder">
                            <i class="bi bi-exclamation-triangle me-1"></i>@L["Settings_ImageGenPlaceholder"]
                        </div>
                    }
                    else
                    {
                        <div class="mt-3" id="admin-settings-imagegen-result">
                            <div class="border rounded p-2 d-inline-block">
