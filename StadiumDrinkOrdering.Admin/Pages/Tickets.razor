@page "/tickets"
@using StadiumDrinkOrdering.Shared.Models
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Tickets_PageTitle"]</PageTitle>

<div class="console" id="admin-tickets-main-container">
    <!-- Page Header -->
    <PageHeader Id="admin-tickets-header"
                Eyebrow='@L["Tickets_Eyebrow"]'
                Title='@L["Tickets_Title"]'
                Subtitle='@L["Tickets_Description"]' />

    @if (selectedEventId.HasValue && events != null)
    {
        var selectedEvent = events.FirstOrDefault(e => e.Id == selectedEventId.Value);
        if (selectedEvent != null)
        {
            <div class="console-alert console-alert--info" id="admin-tickets-event-banner">
                <i class="bi bi-info-circle"></i>
                <span id="admin-tickets-event-banner-text">@L["Tickets_ShowingFor"] <strong>@selectedEvent.Name</strong> (@selectedEvent.Date?.ToString("MMM dd, yyyy")) &middot; <a href="/events" class="link-btn" id="admin-tickets-back-to-events-link">@L["Tickets_BackToEvents"]</a></span>
            </div>
        }
    }

    @if (isLoading)
    {
        <div class="loading-state" id="admin-tickets-loading">
            <span class="loading-spinner"></span>
            <p id="admin-tickets-loading-message">@L["Tickets_LoadingTickets"]</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="console-alert console-alert--danger" role="alert" id="admin-tickets-error-alert">
            <span id="admin-tickets-error-message">@errorMessage</span>
        </div>
    }
    else
    {
        <!-- Filters -->
        <div class="panel filters-panel" id="admin-tickets-filters-panel">
            <div class="panel__head" id="admin-tickets-filters-header">
                <h2 class="panel__title" id="admin-tickets-filters-title">@L["Tickets_FiltersPanelTitle"]</h2>
                <button id="admin-tickets-reset-filters-btn" class="link-btn" @onclick="ResetFilters">
                    <i class="bi bi-arrow-clockwise"></i> @L["Tickets_ResetButton"]
                </button>
            </div>
            <div class="filters" id="admin-tickets-filter-controls">
                <div class="field" id="admin-tickets-filter-season-field">
                    <label class="field__label" for="admin-tickets-season-select">@L["Tickets_FilterBySeasonLabel"]</label>
                    <select class="field__input" @onchange="@(async (e) => await FilterBySeason(e.Value?.ToString()))" id="admin-tickets-season-select">
                        <option value="" selected="@(selectedSeasonId == null)">@L["Tickets_AllSeasonsOption"]</option>
                        @foreach (var s in seasonOptions)
                        {
                            <option value="@s.Id" selected="@(selectedSeasonId == s.Id)">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="field field--grow" id="admin-tickets-filter-event-field">
                    <label class="field__label" for="admin-tickets-event-select">@L["Tickets_FilterByEventLabel"]</label>
                    <select class="field__input" @onchange="@(async (e) => await FilterByEvent(e.Value?.ToString()))" value="@(selectedEventId?.ToString() ?? "")" id="admin-tickets-event-select">
                        <option value="">@L["Tickets_AllEventsOption"]</option>
                        @foreach (var evt in EventOptionsForSeason)
                        {
                            <option value="@evt.Id" selected="@(selectedEventId == evt.Id)">@evt.Name - @evt.Date?.ToString("MMM dd, yyyy")</option>
                        }
                    </select>
                </div>
                <div class="field" id="admin-tickets-filter-status-field">
                    <label class="field__label" for="admin-tickets-status-select">@L["Tickets_FilterByStatusLabel"]</label>
                    <select class="field__input" @onchange="@(async (e) => await FilterByStatus(e.Value?.ToString()))" id="admin-tickets-status-select">
                        <option value="" selected="@(selectedStatus == null)">@L["Tickets_AllTicketsOption"]</option>
                        <option value="Active" selected="@(selectedStatus == "Active")">@L["Tickets_ActiveOption"]</option>
                        <option value="Expired" selected="@(selectedStatus == "Expired")">@L["Tickets_ExpiredOption"]</option>
                        <option value="Used" selected="@(selectedStatus == "Used")">@L["Tickets_UsedOption"]</option>
                        <option value="Cancelled" selected="@(selectedStatus == "Cancelled")">@L["Tickets_CancelledOption"]</option>
                    </select>
                </div>
                <div class="field field--grow" id="admin-tickets-filter-search-field">
                    <label class="field__label" for="admin-tickets-search-input">@L["Tickets_SearchLabel"]</label>
                    <input type="text" class="field__input" placeholder="@L["Tickets_SearchPlaceholder"]"
                           @bind="searchTerm" @bind:event="oninput" @onkeyup="@(async () => await SearchTickets())" id="admin-tickets-search-input" />
                </div>
            </div>
        </div>

        <!-- Key Metrics Cards -->
        <section class="metrics" id="admin-tickets-metrics-section">
            <article class="metric" id="admin-tickets-total-card">
                <div class="metric__head" id="admin-tickets-metric-total-head">
                    <span class="metric__label">@L["Tickets_TotalTicketsLabel"]</span>
                    <i class="bi bi-ticket-perforated metric__icon"></i>
                </div>
                <div class="metric__value mono" id="admin-tickets-metric-total-value">@filteredTickets?.Count</div>
                <div class="metric__foot" id="admin-tickets-metric-total-foot">
                    <span class="metric__hint">@L["Tickets_AllTicketsRecordHint"]</span>
                </div>
            </article>

            <article class="metric metric--accent" id="admin-tickets-active-card">
                <div class="metric__head" id="admin-tickets-metric-active-head">
                    <span class="metric__label">@L["Tickets_ActiveTicketsLabel"]</span>
                    <i class="bi bi-check-circle metric__icon is-ok"></i>
                </div>
                <div class="metric__value mono" id="admin-tickets-metric-active-value">@filteredTickets?.Count(t => StateOf(t) == TicketState.Active)</div>
                <div class="metric__foot" id="admin-tickets-metric-active-foot">
                    <span class="metric__hint">@L["Tickets_CurrentlyValidHint"]</span>
                </div>
            </article>

            <article class="metric" id="admin-tickets-revenue-card">
                <div class="metric__head" id="admin-tickets-metric-revenue-head">
                    <span class="metric__label">@L["Tickets_TotalRevenueLabel"]</span>
                    <i class="bi bi-currency-dollar metric__icon"></i>
                </div>
                <div class="metric__value mono" id="admin-tickets-metric-revenue-value"><span class="metric__unit">€</span>@filteredTickets?.Sum(t => t.Price).ToString("F2")</div>
                <div class="metric__foot" id="admin-tickets-metric-revenue-foot">
                    <span class="metric__hint">@L["Tickets_AcrossAllTicketsHint"]</span>
                </div>
            </article>

            <article class="metric" id="admin-tickets-events-card">
                <div class="metric__head" id="admin-tickets-metric-events-head">
                    <span class="metric__label">@L["Tickets_UniqueEventsLabel"]</span>
                    <i class="bi bi-calendar-event metric__icon"></i>
                </div>
                <div class="metric__value mono" id="admin-tickets-metric-events-value">@filteredTickets?.Select(t => t.EventId).Distinct().Count()</div>
                <div class="metric__foot" id="admin-tickets-metric-events-foot">
                    <span class="metric__hint">@L["Tickets_EventsWithTicketsHint"]</span>
                </div>
            </article>
        </section>

        @if (filteredTickets == null || !filteredTickets.Any())
        {
            <div class="panel" id="admin-tickets-empty-panel">
                <div class="empty" id="admin-tickets-empty-state">
                    <i class="bi bi-ticket-perforated"></i>
                    <p id="admin-tickets-empty-title">@L["Tickets_NoTicketsFound"]</p>
                    <span id="admin-tickets-empty-message">@L["Tickets_NoTicketsFilters"]</span>
                </div>
            </div>
        }
        else
        {
            <!-- Tickets Table -->
            <div class="panel" id="admin-tickets-table-panel">
                <div class="panel__head" id="admin-tickets-table-panel-head">
                    <h2 class="panel__title" id="admin-tickets-table-title">@L["Tickets_TicketsPanelTitle"] <span class="panel__count mono">@filteredTickets.Count</span></h2>
                </div>

                <table class="console-table" id="admin-tickets-table">
                    <thead id="admin-tickets-table-head">
                        <tr id="admin-tickets-table-header-row">
                            <th class="sortable @(sortState.IsSorted("number") ? "is-sorted" : "")" @onclick='() => SortBy("number")' id="admin-tickets-th-number">@L["Tickets_TicketNumberHeader"]<span class="sort-ind">@sortState.Indicator("number")</span></th>
                            <th class="sortable @(sortState.IsSorted("event") ? "is-sorted" : "")" @onclick='() => SortBy("event")' id="admin-tickets-th-event">@L["Tickets_EventHeader"]<span class="sort-ind">@sortState.Indicator("event")</span></th>
                            <th class="sortable @(sortState.IsSorted("date") ? "is-sorted" : "")" @onclick='() => SortBy("date")' id="admin-tickets-th-date">@L["Tickets_DateHeader"]<span class="sort-ind">@sortState.Indicator("date")</span></th>
                            <th class="sortable @(sortState.IsSorted("seat") ? "is-sorted" : "")" @onclick='() => SortBy("seat")' id="admin-tickets-th-seat">@L["Tickets_SeatHeader"]<span class="sort-ind">@sortState.Indicator("seat")</span></th>
                            <th class="sortable @(sortState.IsSorted("customer") ? "is-sorted" : "")" @onclick='() => SortBy("customer")' id="admin-tickets-th-customer">@L["Tickets_CustomerHeader"]<span class="sort-ind">@sortState.Indicator("customer")</span></th>
                            <th class="sortable @(sortState.IsSorted("purchase") ? "is-sorted" : "")" @onclick='() => SortBy("purchase")' id="admin-tickets-th-purchase-date">@L["Tickets_PurchaseDateHeader"]<span class="sort-ind">@sortState.Indicator("purchase")</span></th>
                            <th class="num sortable @(sortState.IsSorted("price") ? "is-sorted" : "")" @onclick='() => SortBy("price")' id="admin-tickets-th-price">@L["Tickets_PriceHeader"]<span class="sort-ind">@sortState.Indicator("price")</span></th>
                            <th class="sortable @(sortState.IsSorted("status") ? "is-sorted" : "")" @onclick='() => SortBy("status")' id="admin-tickets-th-status">@L["Tickets_StatusHeader"]<span class="sort-ind">@sortState.Indicator("status")</span></th>
                            <th class="actions-col" id="admin-tickets-th-actions">@L["Tickets_ActionsHeader"]</th>
                        </tr>
                    </thead>
                    <tbody id="admin-tickets-table-body">
                        @foreach (var ticket in pager.PageItems)
                        {
                            <tr id="admin-tickets-row-@ticket.Id">
                                <td class="mono" id="admin-tickets-cell-number-@ticket.Id">
                                    <button type="button" class="ticket-link" id="admin-tickets-open-detail-@ticket.Id" @onclick="() => OpenDetail(ticket.Id)">@ticket.TicketNumber</button>
                                </td>
                                <td id="admin-tickets-cell-event-@ticket.Id">
                                    @ticket.EventName
                                    @if (ticket.Kind == TicketKind.Season)
                                    {
                                        <span class="badge-pill badge-pill--season" id="admin-tickets-kind-badge-@ticket.Id" title="@L["Tickets_SeasonPassBadge"]">@L["Tickets_SeasonPassBadge"]</span>
                                    }
                                </td>
                                <td class="mono" id="admin-tickets-cell-date-@ticket.Id">@ticket.EventDate?.ToString("MMM dd, yyyy HH:mm")</td>
                                <td id="admin-tickets-cell-seat-@ticket.Id">
                                    @if (!string.IsNullOrEmpty(ticket.Section))
                                    {
                                        <span>@ticket.Section</span>
                                        @if (!string.IsNullOrEmpty(ticket.Row))
                                        {
                                            <span> @L["Tickets_RowLabel"] @ticket.Row</span>
                                        }
                                        @if (!string.IsNullOrEmpty(ticket.SeatNumber))
                                        {
                                            <span> @L["Tickets_SeatLabel"] @ticket.SeatNumber</span>
                                        }
                                    }
                                </td>
                                <td id="admin-tickets-cell-customer-@ticket.Id">
                                    @if (!string.IsNullOrEmpty(ticket.CustomerName))
                                    {
                                        <div id="admin-tickets-customer-name-@ticket.Id">@ticket.CustomerName</div>
                                    }
                                    @if (!string.IsNullOrEmpty(ticket.CustomerEmail))
                                    {
                                        <small class="text-muted" id="admin-tickets-customer-email-@ticket.Id">@ticket.CustomerEmail</small>
                                    }
                                </td>
                                <td class="mono" id="admin-tickets-cell-purchase-date-@ticket.Id">@ticket.PurchaseDate?.ToString("MMM dd, yyyy HH:mm")</td>
                                <td class="num mono" id="admin-tickets-cell-price-@ticket.Id">
                                    @if (ticket.Kind == TicketKind.Season && ticket.Price == 0m)
                                    {
                                        <span class="price-included" id="admin-tickets-price-included-@ticket.Id">@L["Tickets_IncludedPrice"]</span>
                                    }
                                    else
                                    {
                                        @($"€{ticket.Price.ToString("F2")}")
                                    }
                                </td>
                                <td id="admin-tickets-cell-status-@ticket.Id">
                                    @switch (StateOf(ticket))
                                    {
                                        case TicketState.Active:
                                            <span class="status is-active" id="admin-tickets-status-active-@ticket.Id"><span class="status__dot"></span>@L["Tickets_ActiveStatus"]</span>
                                            break;
                                        case TicketState.Expired:
                                            <span class="status is-expired" id="admin-tickets-status-expired-@ticket.Id"><span class="status__dot"></span>@L["Tickets_ExpiredStatus"]</span>
                                            break;
                                        case TicketState.Used:
                                            <span class="status is-used" id="admin-tickets-status-used-@ticket.Id"><span class="status__dot"></span>@L["Tickets_UsedStatus"]</span>
                                            break;
                                        default:
                                            <span class="status is-cancelled" id="admin-tickets-status-cancelled-@ticket.Id"><span class="status__dot"></span>@L["Tickets_CancelledStatus"]</span>
                                            break;
                                    }
                                </td>
                                <td class="actions-col" id="admin-tickets-cell-actions-@ticket.Id">
                                    <div class="row-actions" id="admin-tickets-row-actions-@ticket.Id">
                                        <button id="admin-tickets-details-btn-@ticket.Id" class="row-btn" @onclick="() => OpenDetail(ticket.Id)"
                                                title="@L["Tickets_DetailViewTitle"]">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        @if (ticket.OrderId.HasValue)
                                        {
                                            <button id="admin-tickets-view-order-btn-@ticket.Id" class="row-btn" @onclick="() => ViewOrder(ticket.OrderId.Value)"
                                                    title="@L["Tickets_ViewOrderTitle"]">
                                                <i class="bi bi-receipt"></i>
                                            </button>
                                        }
                                        <button id="admin-tickets-validate-btn-@ticket.Id" class="row-btn" @onclick="() => ValidateTicket(ticket.TicketNumber)"
                                                title="@L["Tickets_ValidateTicketTitle"]">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                        @if (ticket.IsActive)
                                        {
                                            <button id="admin-tickets-deactivate-btn-@ticket.Id" class="row-btn row-btn--danger" @onclick="() => DeactivateTicket(ticket.Id)"
                                                    title="@L["Tickets_DeactivateTicketTitle"]">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button id="admin-tickets-activate-btn-@ticket.Id" class="row-btn row-btn--ok" @onclick="() => ActivateTicket(ticket.Id)"
                                                    title="@L["Tickets_ActivateTicketTitle"]">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <TablePager TItem="TicketDto" View="pager" IdPrefix="admin-tickets-table" OnChanged="StateHasChanged" />
            </div>
        }
    }

    @if (showDetail)
    {
        <div class="ticket-detail-overlay" id="admin-tickets-detail-overlay" @onclick="CloseDetail">
            <div class="ticket-detail-modal" id="admin-tickets-detail-modal" @onclick:stopPropagation="true">
                <header class="ticket-detail-modal__head" id="admin-tickets-detail-head">
                    <div>
                        <span class="eyebrow">@L["Tickets_DetailTitle"]</span>
                        <h2 id="admin-tickets-detail-number">@(selectedDetail?.TicketNumber ?? "")</h2>
                    </div>
                    <button type="button" class="ticket-detail-modal__close" id="admin-tickets-detail-close-btn"
                            title="@L["Tickets_DetailClose"]" @onclick="CloseDetail">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </header>

                @if (detailLoading)
                {
                    <div class="loading-state" id="admin-tickets-detail-loading">
                        <span class="loading-spinner"></span>
                        <p>@L["Tickets_DetailLoading"]</p>
                    </div>
                }
                else if (selectedDetail == null)
                {
                    <div class="console-alert console-alert--danger" id="admin-tickets-detail-error">
                        <span>@(detailError ?? errorMessage)</span>
                    </div>
                }
                else
                {
                    <div class="ticket-detail-body" id="admin-tickets-detail-body">
                        <!-- LEFT: visual ticket card + PDF download -->
                        <div class="ticket-detail-left" id="admin-tickets-detail-left">
                            <span class="section-label">@L["Tickets_DetailCardPreview"]</span>
                            <div class="tcard" id="admin-tickets-detail-card">
                                <div class="tcard__head">
                                    <div>
                                        <span class="tcard__eyebrow">STADIUM ENTRY TICKET</span>
                                        <div class="tcard__event">@selectedDetail.EventName</div>
                                    </div>
                                    @if (selectedDetail.Kind == TicketKind.Season)
                                    {
                                        <span class="tcard__season">@L["Tickets_SeasonPassBadge"]</span>
                                    }
                                </div>
                                <div class="tcard__body">
                                    <div class="tcard__info">
                                        <div class="tcard__field">
                                            <span>DATE &amp; TIME</span>
                                            <strong>@(selectedDetail.EventDate?.ToString("ddd, dd MMM yyyy HH:mm") ?? "—")</strong>
                                        </div>
                                        <div class="tcard__seatrow">
                                            <div class="tcard__field"><span>SECTION</span><strong>@Dash(selectedDetail.Section)</strong></div>
                                            <div class="tcard__field"><span>ROW</span><strong>@Dash(selectedDetail.Row)</strong></div>
                                            <div class="tcard__field"><span>SEAT</span><strong>@Dash(selectedDetail.SeatNumber)</strong></div>
                                        </div>
                                    </div>
                                    <div class="tcard__qr">
                                        @if (!string.IsNullOrEmpty(selectedDetail.QrImageDataUri))
                                        {
                                            <img src="@selectedDetail.QrImageDataUri" alt="QR" id="admin-tickets-detail-qr" />
                                        }
                                        <span class="tcard__num">@selectedDetail.TicketNumber</span>
                                    </div>
                                </div>
                                <div class="tcard__foot">
                                    <div>
                                        <span class="tcard__pricelabel">@L["Tickets_DetailTicketPrice"]</span>
                                        <div class="tcard__price">@Money(selectedDetail.TicketPrice)</div>
                                    </div>
                                    <span class="tcard__purchased">@L["Tickets_DetailPurchased"] @selectedDetail.PurchaseDate.ToString("dd MMM yyyy")</span>
                                </div>
                            </div>

                            <button type="button" class="pill-btn pill-btn--primary tcard__download" id="admin-tickets-detail-download-btn"
                                    disabled="@pdfDownloading" @onclick="DownloadCardPdf">
                                @if (pdfDownloading)
                                {
                                    <span class="loading-spinner loading-spinner--sm"></span>
                                }
                                else
                                {
                                    <i class="bi bi-file-earmark-pdf"></i>
                                }
                                <span>@L["Tickets_DetailDownloadPdf"]</span>
                            </button>
                            @if (!string.IsNullOrEmpty(pdfError))
                            {
                                <div class="console-alert console-alert--danger" id="admin-tickets-detail-pdf-error">
                                    <span>@pdfError</span>
                                </div>
                            }

                            <!-- Stadium blueprint locator: real drawing-tool image with a pin on this seat's sector -->
                            <div class="seatmap" id="admin-tickets-detail-seatmap">
                                <span class="section-label">@L["Tickets_DetailSeatLocation"]</span>
                                <div class="seatmap__frame" id="admin-tickets-detail-seatmap-frame">
                                    <img class="seatmap__img" src="/images/stadium-blueprint.png"
                                         alt="@L["Tickets_DetailSeatLocation"]" id="admin-tickets-detail-seatmap-img" />
                                    @if (matchedOverlay != null)
                                    {
                                        var pinX = seatPinXPercent ?? OverlayCenterX(matchedOverlay);
                                        var pinY = seatPinYPercent ?? OverlayCenterY(matchedOverlay);
                                        <div class="seatmap__sector"
                                             id="admin-tickets-detail-seatmap-sector"
                                             style="left:@(Pct(matchedOverlay.LeftPercent))%;top:@(Pct(matchedOverlay.TopPercent))%;width:@(Pct(matchedOverlay.WidthPercent))%;height:@(Pct(matchedOverlay.HeightPercent))%;"></div>
                                        <div class="seatmap__pin@(seatPinXPercent.HasValue ? " seatmap__pin--seat" : "")"
                                             id="admin-tickets-detail-seatmap-pin"
                                             style="left:@(Pct(pinX))%;top:@(Pct(pinY))%;"
                                             title="@SeatText(selectedDetail)"></div>
                                    }
                                </div>
                                <span class="seatmap__caption" id="admin-tickets-detail-seatmap-caption">
                                    @if (matchedOverlay != null)
                                    {
                                        @SeatText(selectedDetail)
                                    }
                                    else
                                    {
                                        @L["Tickets_DetailLocationUnknown"]
                                    }
                                </span>
                            </div>
                        </div>

                        <!-- RIGHT: facts + spending breakdown -->
                        <div class="ticket-detail-right" id="admin-tickets-detail-right">
                            <div class="detail-group" id="admin-tickets-detail-eventseat">
                                <span class="section-label">@L["Tickets_DetailEventSeat"]</span>
                                <dl class="detail-list">
                                    <dt>@L["Tickets_EventHeader"]</dt><dd>@selectedDetail.EventName</dd>
                                    <dt>@L["Tickets_DateHeader"]</dt><dd>@(selectedDetail.EventDate?.ToString("MMM dd, yyyy HH:mm") ?? "—")</dd>
                                    <dt>@L["Tickets_SeatHeader"]</dt><dd>@SeatText(selectedDetail)</dd>
                                    <dt>@L["Tickets_StatusHeader"]</dt>
                                    <dd>
                                        @if (selectedDetail.IsActive)
                                        {
                                            <span class="status is-active"><span class="status__dot"></span>@L["Tickets_ActiveStatus"]</span>
                                        }
                                        else
                                        {
                                            <span class="status is-inactive"><span class="status__dot"></span>@L["Tickets_InactiveStatus"]</span>
                                        }
                                        <span class="used-flag">· @(selectedDetail.IsUsed ? L["Tickets_DetailUsed"] : L["Tickets_DetailNotUsed"])</span>
                                    </dd>
                                </dl>
                            </div>

                            @if (!string.IsNullOrEmpty(selectedDetail.CustomerName) || !string.IsNullOrEmpty(selectedDetail.CustomerEmail) || !string.IsNullOrEmpty(selectedDetail.CustomerPhone) || !string.IsNullOrEmpty(selectedDetail.CustomerOib) || !string.IsNullOrEmpty(selectedDetail.CustomerDocumentNumber))
                            {
                                <div class="detail-group" id="admin-tickets-detail-customer">
                                    <span class="section-label">@L["Tickets_DetailCustomer"]</span>
                                    <dl class="detail-list">
                                        @if (!string.IsNullOrEmpty(selectedDetail.CustomerName))
                                        {
                                            <dt>@L["Tickets_DetailName"]</dt><dd>@selectedDetail.CustomerName</dd>
                                        }
                                        @if (!string.IsNullOrEmpty(selectedDetail.CustomerEmail))
                                        {
                                            <dt>@L["Tickets_DetailEmail"]</dt><dd>@selectedDetail.CustomerEmail</dd>
                                        }
                                        @if (!string.IsNullOrEmpty(selectedDetail.CustomerPhone))
                                        {
                                            <dt>@L["Tickets_DetailPhone"]</dt><dd>@selectedDetail.CustomerPhone</dd>
                                        }
                                        @if (!string.IsNullOrEmpty(selectedDetail.CustomerOib))
                                        {
                                            <dt>@L["Tickets_DetailOib"]</dt><dd id="admin-tickets-detail-oib">@selectedDetail.CustomerOib</dd>
                                        }
                                        @if (!string.IsNullOrEmpty(selectedDetail.CustomerDocumentNumber))
                                        {
                                            <dt>@L["Tickets_DetailDocument"]</dt><dd id="admin-tickets-detail-document">@selectedDetail.CustomerDocumentNumber</dd>
                                        }
                                    </dl>
                                </div>
                            }

                            <div class="detail-group" id="admin-tickets-detail-wallet">
                                <span class="section-label">@L["Tickets_DetailWallet"]</span>
                                @if (selectedDetail.CustomerHasWallet)
                                {
                                    <div class="wallet-balance" id="admin-tickets-detail-wallet-balance">
                                        <i class="bi bi-wallet2"></i>
                                        <span class="wallet-balance__amount mono">@Money(selectedDetail.WalletBalance ?? 0m)</span>
                                        @if (!string.IsNullOrEmpty(selectedDetail.WalletStatus) && selectedDetail.WalletStatus != "Active")
                                        {
                                            <span class="wallet-balance__status">· @selectedDetail.WalletStatus</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="wallet-balance wallet-balance--none" id="admin-tickets-detail-wallet-none">
                                        <i class="bi bi-wallet2"></i>
                                        <span class="wallet-balance__empty">@L["Tickets_DetailNoWallet"]</span>
                                    </div>
                                }
                            </div>

                            <div class="detail-group" id="admin-tickets-detail-spending">
                                <span class="section-label">@L["Tickets_DetailSpending"]</span>

                                <div class="spend-row spend-row--head">
                                    <span>@L["Tickets_DetailTicketPrice"]</span>
                                    <span class="mono">@Money(selectedDetail.TicketPrice)</span>
                                </div>

                                <div class="spend-subhead">@L["Tickets_DetailDrinksOrders"]</div>
                                @if (selectedDetail.DrinkOrders.Count == 0)
                                {
                                    <p class="spend-empty" id="admin-tickets-detail-no-orders">@L["Tickets_DetailNoOrders"]</p>
                                }
                                else
                                {
                                    @foreach (var order in selectedDetail.DrinkOrders)
                                    {
                                        <div class="order-block" id="admin-tickets-detail-order-@order.OrderId">
                                            <div class="order-block__head">
                                                <span>@L["Tickets_DetailOrder"] #@order.OrderId · @order.Status</span>
                                                <span class="mono">@Money(order.OrderTotal)</span>
                                            </div>
                                            <table class="order-items">
                                                <thead>
                                                    <tr>
                                                        <th>@L["Tickets_DetailDrinksOrders"]</th>
                                                        <th class="num">@L["Tickets_DetailQty"]</th>
                                                        <th class="num">@L["Tickets_DetailUnit"]</th>
                                                        <th class="num">@L["Tickets_DetailItemTotal"]</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var item in order.Items)
                                                    {
                                                        <tr>
                                                            <td>@item.DrinkName</td>
                                                            <td class="num mono">@item.Quantity</td>
                                                            <td class="num mono">@Money(item.UnitPrice)</td>
                                                            <td class="num mono">@Money(item.TotalPrice)</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                            @if (order.Payment != null)
                                            {
                                                <div class="order-block__pay">
                                                    <i class="bi bi-credit-card"></i>
                                                    @L["Tickets_DetailPayment"]: @order.Payment.Method · @order.Payment.Status · @Money(order.Payment.Amount)
                                                </div>
                                            }
                                        </div>
                                    }

                                    <div class="spend-row">
                                        <span>@L["Tickets_DetailDrinksTotal"]</span>
                                        <span class="mono">@Money(selectedDetail.DrinksTotal)</span>
                                    </div>
                                }

                                <div class="spend-row spend-row--grand">
                                    <span>@L["Tickets_DetailGrandTotal"]</span>
                                    <span class="mono">@Money(selectedDetail.GrandTotal)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
