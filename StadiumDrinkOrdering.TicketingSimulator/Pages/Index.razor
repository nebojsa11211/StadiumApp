@page "/"
@page "/simulator"
@using StadiumDrinkOrdering.Shared.DTOs.Integration
@inject SimulatorApiClient Api
@inject IStringLocalizer<SharedResources> Localizer
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Ticketing Simulator</PageTitle>

<h1 class="h4 mb-1">@Localizer["Index_MainTitle"]</h1>
<p class="text-muted">@Localizer["Index_MainSubtitle"]</p>

<div id="simulator-index-connection-alert" class="alert @(connectionOk ? "alert-success" : "alert-warning") py-2">
    <i class="bi @(connectionOk ? "bi-plug-fill" : "bi-plug")"></i>
    @Localizer["Index_ApiLabel"]: <code>@Api.ApiBaseUrl</code>
    @if (connectionOk) { <span>· @sections.Count @Localizer["Index_SectionsDiscovered"]</span> }
    else { <span>· @Localizer["Index_NotReachable"] @(string.IsNullOrEmpty(connectionError) ? "" : $"({connectionError})")</span> }
    <button id="simulator-index-reload-btn" class="btn btn-sm btn-outline-secondary ms-2" @onclick="LoadSectionsAsync">@Localizer["Index_ReloadButton"]</button>
</div>

@* ---------- Step 0: seasons ---------- *@
<div id="simulator-index-season-card" class="card mb-3">
    <div id="simulator-index-season-header" class="card-header fw-bold d-flex align-items-center">
        <span><i class="bi bi-calendar-range"></i> @Localizer["Index_SeasonsHeader"]</span>
        @if (seasons.Count > 0) { <span class="badge bg-secondary ms-2">@seasons.Count</span> }
        <button id="simulator-index-season-refresh-btn" class="btn btn-sm btn-outline-secondary ms-auto" @onclick="LoadSeasonsAsync" disabled="@busy">@Localizer["Index_RefreshButton"]</button>
    </div>
    <div id="simulator-index-season-body" class="card-body">
        <div id="simulator-index-season-form-row" class="row g-2 align-items-end mb-3">
            <div class="col-md-3">
                <label class="form-label">@Localizer["Index_SeasonNameLabel"]</label>
                <input id="simulator-index-season-name-input" class="form-control" placeholder="@Localizer["Index_SeasonNamePlaceholder"]" @bind="newSeasonName" />
            </div>
            <div class="col-md-3">
                <label class="form-label">@Localizer["Index_StartsLabel"]</label>
                <input id="simulator-index-season-start-input" type="date" class="form-control" @bind="seasonStart" />
            </div>
            <div class="col-md-3">
                <label class="form-label">@Localizer["Index_EndsLabel"]</label>
                <input id="simulator-index-season-end-input" type="date" class="form-control" @bind="seasonEnd" />
            </div>
            <div class="col-md-2 mb-1">
                <div class="form-check">
                    <input id="simulator-index-season-current-input" type="checkbox" class="form-check-input" @bind="seasonIsCurrent" />
                    <label class="form-check-label">@Localizer["Index_SetCurrentCheckbox"]</label>
                </div>
            </div>
            <div class="col-md-1">
                <button id="simulator-index-season-create-btn" class="btn btn-primary w-100" @onclick="CreateSeasonAsync" disabled="@(busy || !connectionOk || string.IsNullOrWhiteSpace(newSeasonName) || seasonEnd <= seasonStart)">
                    <i class="bi bi-broadcast"></i> @Localizer["Index_CreateButton"]
                </button>
            </div>
        </div>

        @if (seasons.Count == 0)
        {
            <p id="simulator-index-season-empty" class="text-muted mb-0">@Localizer["Index_NoSeasonsYet"]</p>
        }
        else
        {
            <table id="simulator-index-season-table" class="table table-sm mb-0 align-middle">
                <thead class="table-light">
                    <tr><th>@Localizer["Index_SeasonColumn"]</th><th>@Localizer["Index_WindowColumn"]</th><th class="text-center">@Localizer["Index_CurrentColumn"]</th><th class="text-end">@Localizer["Index_EventsColumn"]</th><th class="text-end">@Localizer["Index_PassesColumn"]</th><th class="text-end">@Localizer["Index_ActionColumn"]</th></tr>
                </thead>
                <tbody>
                    @foreach (var se in seasons)
                    {
                        <tr id="simulator-index-season-row-@se.SeasonId" class="@(se.ExternalSeasonId == selectedSeasonExternalId ? "table-primary" : "")">
                            <td><strong>@se.Name</strong> <span class="text-muted small">#@se.SeasonId · <code>@se.ExternalSeasonId</code></span></td>
                            <td class="text-nowrap small">@se.StartDate.ToLocalTime().ToString("yyyy-MM-dd") → @se.EndDate.ToLocalTime().ToString("yyyy-MM-dd")</td>
                            <td class="text-center">@if (se.IsCurrent) { <span class="badge bg-success">@Localizer["Index_CurrentBadge"]</span> }</td>
                            <td class="text-end">@se.EventCount</td>
                            <td class="text-end">@se.SeasonTicketCount</td>
                            <td class="text-end">
                                @if (se.ExternalSeasonId == selectedSeasonExternalId)
                                {
                                    <span class="badge bg-primary">@Localizer["Index_SelectedBadge"]</span>
                                }
                                else
                                {
                                    <button id="simulator-index-season-select-btn-@se.SeasonId" class="btn btn-sm btn-outline-primary" @onclick="() => SelectSeason(se)" disabled="@busy">@Localizer["Index_SelectButton"]</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (selectedSeasonExternalId != null)
            {
                <div id="simulator-index-season-ticket-panel" class="border rounded p-2 mt-3 bg-light">
                    <div class="d-flex align-items-end gap-2 flex-wrap">
                        <div>
                            <label class="form-label mb-0 small">@Localizer["Index_SeasonTicketSectorLabel"]</label>
                            <select id="simulator-index-season-ticket-sector-select" class="form-select form-select-sm" @bind="seasonTicketSector" style="min-width:170px">
                                @foreach (var s in sections)
                                {
                                    <option value="@s.SectionCode">@s.SectionCode · @s.SectionName</option>
                                }
                            </select>
                        </div>
                        <button id="simulator-index-season-ticket-sell-btn" class="btn btn-sm btn-success" @onclick="SellSeasonTicketAsync" disabled="@(busy || string.IsNullOrEmpty(seasonTicketSector))">
                            <i class="bi bi-person-badge"></i> @Localizer["Index_Sell1Button"]
                        </button>
                        <button id="simulator-index-season-ticket-refund-btn" class="btn btn-sm btn-outline-danger" @onclick="RefundSeasonTicketAsync" disabled="@(busy || seasonTicketIds.Count == 0)">
                            <i class="bi bi-arrow-return-left"></i> @Localizer["Index_RefundLastButton"]
                        </button>

                        <div class="vr mx-1"></div>
                        <div>
                            <label class="form-label mb-0 small">@Localizer["Index_BulkLabel"]</label>
                            <div class="input-group input-group-sm" style="width:auto">
                                <input id="simulator-index-season-ticket-batch-input" type="number" min="1" max="1000" class="form-control form-control-sm" style="width:80px" @bind="seasonTicketBatch" />
                                <button id="simulator-index-season-ticket-batch-btn" class="btn btn-sm btn-primary" @onclick="() => SellSeasonTicketBatchAsync(seasonTicketBatch)" disabled="@(busy || sections.Count == 0)">
                                    <i class="bi bi-people-fill"></i> @Localizer["Index_CreatePassesButton", seasonTicketBatch]
                                </button>
                            </div>
                            <div class="btn-group btn-group-sm mt-1" role="group">
                                <button id="simulator-index-season-ticket-preset-20" class="btn btn-outline-primary" @onclick="() => SellSeasonTicketBatchAsync(20)" disabled="@(busy || sections.Count == 0)">@Localizer["Index_Plus20Button"]</button>
                                <button id="simulator-index-season-ticket-preset-40" class="btn btn-outline-primary" @onclick="() => SellSeasonTicketBatchAsync(40)" disabled="@(busy || sections.Count == 0)">@Localizer["Index_Plus40Button"]</button>
                                <button id="simulator-index-season-ticket-preset-100" class="btn btn-outline-primary" @onclick="() => SellSeasonTicketBatchAsync(100)" disabled="@(busy || sections.Count == 0)">@Localizer["Index_Plus100Button"]</button>
                            </div>
                        </div>

                        <span class="ms-auto small text-muted">@Localizer["Index_SoldThisSession"]: <strong>@seasonTicketIds.Count</strong> @Localizer["Index_PassesFor"] <strong>@selectedSeasonName</strong></span>
                    </div>
                    <div class="small text-muted mt-1">@Localizer["Index_SeasonPassInfo"]</div>
                </div>
            }
        }
    </div>
</div>

@* ---------- Step 1: create event ---------- *@
<div id="simulator-index-event-card" class="card mb-3">
    <div id="simulator-index-event-header" class="card-header fw-bold"><i class="bi bi-calendar-plus"></i> @Localizer["Index_EventHeader"]</div>
    <div id="simulator-index-event-body" class="card-body">
        @if (externalEventId == null)
        {
            <div id="simulator-index-event-form-row" class="row g-2 align-items-end">
                <div id="simulator-index-event-name-col" class="col-md-3">
                    <label class="form-label">@Localizer["Index_EventNameLabel"]</label>
                    <input id="simulator-index-event-name-input" class="form-control" @bind="eventName" />
                </div>
                <div id="simulator-index-event-date-col" class="col-md-2">
                    <label class="form-label">@Localizer["Index_StartLabel"]</label>
                    <input id="simulator-index-event-date-input" type="datetime-local" class="form-control" @bind="eventDate" />
                </div>
                <div id="simulator-index-event-enddate-col" class="col-md-2">
                    <label class="form-label">@Localizer["Index_EndLabel"]</label>
                    <input id="simulator-index-event-enddate-input" type="datetime-local" class="form-control" @bind="eventEndDate" />
                </div>
                <div id="simulator-index-event-season-col" class="col-md-2">
                    <label class="form-label">@Localizer["Index_SeasonLabel"]</label>
                    <select id="simulator-index-event-season-select" class="form-select" @bind="linkSeasonExternalId">
                        <option value="">@Localizer["Index_NoSeasonOption"]</option>
                        @foreach (var se in seasons)
                        {
                            <option value="@se.ExternalSeasonId">@se.Name</option>
                        }
                    </select>
                </div>
                <div id="simulator-index-event-buttons-col" class="col-md-2">
                    <button id="simulator-index-event-create-btn" class="btn btn-primary w-100" @onclick="CreateEventAsync" disabled="@(busy || !connectionOk || !EndAfterStart)">
                        <i class="bi bi-broadcast"></i> @Localizer["Index_CreateSyncButton"]
                    </button>
                </div>
            </div>
            @if (!EndAfterStart)
            {
                <div id="simulator-index-event-validation-msg" class="text-danger small mt-1"><i class="bi bi-exclamation-triangle"></i> @Localizer["Index_EndTimeValidationError"]</div>
            }
        }
        else
        {
            <div id="simulator-index-event-summary" class="d-flex flex-wrap gap-3 align-items-center">
                <div><span class="text-muted">@Localizer["Index_EventLabel"]</span> <strong>@eventName</strong></div>
                <div><span class="text-muted">@Localizer["Index_WindowLabel"]</span> <strong>@eventDate.ToString("yyyy-MM-dd HH:mm")</strong> → <strong>@eventEndDate.ToString("HH:mm")</strong></div>
                <div><span class="text-muted">@Localizer["Index_ExternalIdLabel"]</span> <code>@externalEventId</code></div>
                <div><span class="text-muted">@Localizer["Index_StadiumEventIdLabel"]</span> <strong>@(internalEventId?.ToString() ?? "?")</strong></div>
                <div>
                    <span class="text-muted">@Localizer["Index_StatusLabel"]</span> <strong>@eventStatusName</strong>
                    @if (eventLive) { <span id="simulator-index-event-live-badge" class="badge bg-danger ms-1">@Localizer["Index_LiveBadge"]</span> }
                    else if (!eventCanSell) { <span class="badge bg-secondary ms-1">@Localizer["Index_SalesClosedBadge"]</span> }
                </div>
                <div><span class="text-muted">@Localizer["Index_TotalOccupiedLabel"]</span> <strong>@TotalOccupied</strong> / @TotalCapacity@if (TotalSeasonSold > 0) { <span class="text-info small"> @Localizer["Index_IncludingSeasonText", TotalSeasonSold]</span> }</div>
                <button id="simulator-index-event-golive-btn" class="btn btn-sm btn-danger ms-auto" title="@Localizer["Index_MakeLiveNowTooltip"]" @onclick="MakeEventLiveAsync" disabled="@(busy || !connectionOk || eventLive)">
                    <i class="bi bi-broadcast-pin"></i> @Localizer["Index_MakeLiveNowButton"]
                </button>
                <button id="simulator-index-event-back-btn" class="btn btn-sm btn-outline-secondary" @onclick="ResetEvent">
                    <i class="bi bi-arrow-left"></i> @Localizer["Index_BackToEventsButton"]
                </button>
                <button id="simulator-index-event-reset-btn" class="btn btn-sm btn-outline-danger" @onclick="ResetEvent">@Localizer["Index_NewEventButton"]</button>
            </div>
        }
    </div>
</div>

@* ---------- Existing events (pick one to resume) ---------- *@
@if (externalEventId == null)
{
    <div id="simulator-index-existing-events-card" class="card mb-3">
        <div id="simulator-index-existing-header" class="card-header fw-bold d-flex align-items-center">
            <span><i class="bi bi-collection"></i> @Localizer["Index_ExistingEventsHeader"]</span>
            @if (existingEvents.Count > 0) { <span class="badge bg-secondary ms-2">@existingEvents.Count</span> }
            <button id="simulator-index-existing-refresh-btn" class="btn btn-sm btn-outline-secondary ms-auto" @onclick="LoadEventsAsync" disabled="@busy">@Localizer["Index_RefreshButton"]</button>
        </div>
        <div id="simulator-index-existing-body" class="card-body p-0">
            @if (existingEvents.Count == 0)
            {
                <p class="text-muted m-3 mb-3">@Localizer["Index_NoEventsYet"]</p>
            }
            else
            {
                <table id="simulator-index-existing-table" class="table table-sm mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>@Localizer["Index_EventColumn"]</th><th>@Localizer["Index_StartColumn"]</th><th>@Localizer["Index_EndColumn"]</th><th>@Localizer["Index_SourceColumn"]</th>
                            <th class="text-end">@Localizer["Index_SoldCapacityColumn"]</th><th class="text-end">@Localizer["Index_ActionColumn"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in existingEvents)
                        {
                            <tr id="simulator-index-existing-row-@e.EventId">
                                <td>
                                    <strong>@e.EventName</strong>
                                    <span class="text-muted small">#@e.EventId · <code>@e.ExternalEventId</code></span>
                                </td>
                                <td class="text-nowrap small">@e.EventDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="text-nowrap small">@(e.EventEndDate is DateTime end ? end.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "—")</td>
                                <td class="small text-muted">@e.SourceSystem</td>
                                <td class="text-end">@e.TotalSold / @e.TotalSeats</td>
                                <td class="text-end text-nowrap">
                                    <button id="simulator-index-existing-select-btn-@e.EventId" class="btn btn-sm btn-outline-primary" @onclick="() => SelectEventAsync(e)" disabled="@(busy || !connectionOk)">
                                        <i class="bi bi-box-arrow-in-right"></i> @Localizer["Index_SelectButton"]
                                    </button>
                                    <button id="simulator-index-existing-delete-btn-@e.EventId" class="btn btn-sm btn-outline-danger ms-1" title="@Localizer["Index_DeleteEventTooltip"]" @onclick="() => DeleteEventAsync(e)" disabled="@(busy || !connectionOk)">
                                        <i class="bi bi-trash"></i> @Localizer["Index_DeleteButton"]
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@if (externalEventId != null)
{
    @* ---------- Step 2: sales ---------- *@
    <div id="simulator-index-sales-card" class="card mb-3">
        <div id="simulator-index-sales-header" class="card-header fw-bold d-flex align-items-center">
            <span><i class="bi bi-cash-coin"></i> @Localizer["Index_SalesHeader"]</span>
            <div id="simulator-index-sales-controls" class="ms-auto d-flex align-items-center gap-2">
                <span class="small text-muted">@Localizer["Index_RateLabel"]</span>
                <input id="simulator-index-sales-rate-input" type="number" min="1" max="50" class="form-control form-control-sm" style="width:70px" @bind="autoRate" />
                <span class="small text-muted">@Localizer["Index_PerLabel"]</span>
                <input id="simulator-index-sales-interval-input" type="number" min="200" step="100" class="form-control form-control-sm" style="width:90px" @bind="autoIntervalMs" />
                <span class="small text-muted">@Localizer["Index_MsLabel"]</span>
                <button id="simulator-index-sales-autosell-toggle-btn" class="btn btn-sm @(autoSelling ? "btn-danger" : "btn-success")" @onclick="ToggleAutoSell" disabled="@(!autoSelling && !eventCanSell)">
                    <i class="bi @(autoSelling ? "bi-stop-fill" : "bi-play-fill")"></i>
                    @(autoSelling ? Localizer["Index_StopAutoSellButton"] : Localizer["Index_StartAutoSellButton"])
                </button>
                <button id="simulator-index-sales-random-batch-btn" class="btn btn-sm btn-outline-primary" @onclick="() => SellRandomBatchAsync(20)" disabled="@(busy || !eventCanSell)">@Localizer["Index_SellRandom20Button"]</button>
            </div>
        </div>
        <div id="simulator-index-sales-body" class="card-body p-0">
            @if (!eventCanSell)
            {
                <div id="simulator-index-sales-closed-banner" class="alert alert-warning m-2 mb-0 py-2">
                    <i class="bi bi-lock-fill"></i> @Localizer["Index_SalesClosedBannerPrefix"] <strong>@eventStatusName</strong>@(eventLive ? " (live)" : "")@Localizer["Index_SalesClosedBannerSuffix"]
                    @if (eventLive) { <span>@Localizer["Index_SimulateDrinkOrdersText"]</span> }
                </div>
            }
            <table id="simulator-index-sales-table" class="table table-sm mb-0 align-middle">
                <thead class="table-light">
                    <tr><th>@Localizer["Index_SectorColumn"]</th><th style="width:45%">@Localizer["Index_OccupancyColumn"]</th><th class="text-end">@Localizer["Index_OccupiedCapacityColumn"]</th><th class="text-end">@Localizer["Index_ActionsColumn"]</th></tr>
                </thead>
                <tbody>
                    @foreach (var s in sections)
                    {
                        var single = SoldCount(s.SectionCode);
                        var season = SeasonSoldCount(s.SectionCode);
                        var occupied = single + season;
                        var pct = s.Capacity > 0 ? (double)occupied / s.Capacity * 100 : 0;
                        var singlePct = s.Capacity > 0 ? (double)single / s.Capacity * 100 : 0;
                        var seasonPct = s.Capacity > 0 ? (double)season / s.Capacity * 100 : 0;
                        <tr id="simulator-index-sales-row-@s.SectionCode">
                            <td><strong>@s.SectionCode</strong> <span class="text-muted small">@s.SectionName</span></td>
                            <td>
                                <div id="simulator-index-sales-progress-@s.SectionCode" class="progress" style="height:14px" title="@single single-match + @season season pass = @occupied / @s.Capacity">
                                    <div class="progress-bar @BarClass(pct)" style="width:@singlePct.ToString("0.##")%"></div>
                                    @if (season > 0)
                                    {
                                        <div class="progress-bar bg-info" style="width:@seasonPct.ToString("0.##")%"></div>
                                    }
                                </div>
                            </td>
                            <td class="text-end">
                                @occupied / @s.Capacity
                                @if (season > 0)
                                {
                                    <span class="text-info small" title="@season season-pass seat(s) held in this sector">(@season <i class="bi bi-person-badge"></i>)</span>
                                }
                            </td>
                            <td class="text-end text-nowrap">
                                <button id="simulator-index-sales-sell1-btn-@s.SectionCode" class="btn btn-outline-success btn-sm" @onclick="() => SellAsync(s, 1)" disabled="@(busy || !eventCanSell || occupied >= s.Capacity)">@Localizer["Index_Plus1Button"]</button>
                                <button id="simulator-index-sales-sell5-btn-@s.SectionCode" class="btn btn-outline-success btn-sm" @onclick="() => SellAsync(s, 5)" disabled="@(busy || !eventCanSell || occupied >= s.Capacity)">@Localizer["Index_Plus5Button"]</button>
                                <button id="simulator-index-sales-refund-btn-@s.SectionCode" class="btn btn-outline-danger btn-sm" @onclick="() => RefundAsync(s)" disabled="@(busy || single == 0)" title="@Localizer["Index_RefundTooltip"]">@Localizer["Index_Minus1Button"]</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* ---------- Step 2b: live drink orders ---------- *@
    <div id="simulator-index-drinks-card" class="card mb-3 @(eventLive ? "border-danger" : "")">
        <div id="simulator-index-drinks-header" class="card-header fw-bold d-flex align-items-center">
            <span><i class="bi bi-cup-straw"></i> @Localizer["Index_DrinksHeader"]</span>
            @if (eventLive) { <span class="badge bg-danger ms-2">@Localizer["Index_LiveBadge"]</span> }
            <span class="ms-auto small text-muted">@Localizer["Index_PlacedThisSession"]: <strong>@drinkOrdersPlaced</strong></span>
        </div>
        <div id="simulator-index-drinks-body" class="card-body">
            @if (!eventLive)
            {
                <p id="simulator-index-drinks-locked" class="text-muted mb-0">
                    <i class="bi bi-lock"></i> @Localizer["Index_DrinksLockedMessage"]
                </p>
            }
            else
            {
                <div class="d-flex align-items-end gap-2 flex-wrap">
                    <button id="simulator-index-drinks-order1-btn" class="btn btn-success" @onclick="() => SimulateDrinkOrdersAsync(1)" disabled="@busy">
                        <i class="bi bi-cup-hot"></i> @Localizer["Index_Place1OrderButton"]
                    </button>
                    <button id="simulator-index-drinks-order5-btn" class="btn btn-outline-success" @onclick="() => SimulateDrinkOrdersAsync(5)" disabled="@busy">
                        @Localizer["Index_Place5OrdersButton"]
                    </button>

                    <div class="vr mx-1"></div>

                    <span class="small text-muted">@Localizer["Index_RateLabel"]</span>
                    <input id="simulator-index-drinks-rate-input" type="number" min="1" max="20" class="form-control form-control-sm" style="width:70px" @bind="autoOrderRate" />
                    <span class="small text-muted">@Localizer["Index_PerLabel"]</span>
                    <input id="simulator-index-drinks-interval-input" type="number" min="300" step="100" class="form-control form-control-sm" style="width:90px" @bind="autoOrderIntervalMs" />
                    <span class="small text-muted">@Localizer["Index_MsLabel"]</span>
                    <button id="simulator-index-drinks-auto-toggle-btn" class="btn btn-sm @(autoOrdering ? "btn-danger" : "btn-success")" @onclick="ToggleAutoOrder">
                        <i class="bi @(autoOrdering ? "bi-stop-fill" : "bi-play-fill")"></i>
                        @(autoOrdering ? Localizer["Index_StopAutoOrdersButton"] : Localizer["Index_StartAutoOrdersButton"])
                    </button>
                </div>
                <div class="small text-muted mt-2">
                    @Localizer["Index_DrinkOrdersInfo"]
                </div>
            }
        </div>
    </div>

    @* ---------- Step 3: reconciliation ---------- *@
    <div id="simulator-index-reconciliation-card" class="card mb-3">
        <div id="simulator-index-reconciliation-header" class="card-header fw-bold">
            <i class="bi bi-arrow-repeat"></i> @Localizer["Index_ReconciliationHeader"]
            <button id="simulator-index-reconciliation-verify-btn" class="btn btn-sm btn-outline-secondary ms-2" @onclick="VerifySyncAsync" disabled="@busy">@Localizer["Index_VerifySyncButton"]</button>
            <button id="simulator-index-reconciliation-replay-btn" class="btn btn-sm btn-outline-warning ms-1" @onclick="ReplayAsync" disabled="@busy">@Localizer["Index_ReplayAllSalesButton"]</button>
            <span class="small text-muted ms-2">@Localizer["Index_ReplayInfo"]</span>
        </div>
        @if (snapshot != null)
        {
            <div id="simulator-index-reconciliation-body" class="card-body">
                <p class="mb-2">@Localizer["Index_ApiReportsPrefix"] <strong>@snapshot.TotalSold</strong> @Localizer["Index_SoldIncludingPrefix"] <strong>@snapshot.TotalSeasonSold</strong> @Localizer["Index_SeasonSimulatorHoldsText"] <strong>@TotalOccupied</strong>.
                    <span class="@(snapshot.TotalSold == TotalOccupied ? "text-success" : "text-danger")">
                        @(snapshot.TotalSold == TotalOccupied ? Localizer["Index_InSyncText"] : $"{Localizer["Index_DriftText"]}: {TotalOccupied - snapshot.TotalSold}")
                    </span>
                </p>
                <table id="simulator-index-reconciliation-table" class="table table-sm">
                    <thead><tr><th>@Localizer["Index_SectorColumn"]</th><th class="text-end">@Localizer["Index_ApiSoldColumn"]</th><th class="text-end">@Localizer["Index_SimulatorOccupiedColumn"]</th></tr></thead>
                    <tbody>
                        @foreach (var sec in snapshot.Sectors)
                        {
                            var local = OccupiedCount(sec.SectionCode);
                            <tr id="simulator-index-reconciliation-row-@sec.SectionCode" class="@(sec.Sold == local ? "" : "table-warning")">
                                <td>@sec.SectionCode</td>
                                <td class="text-end">@sec.Sold</td>
                                <td class="text-end">@local</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@* ---------- Activity log ---------- *@
<div id="simulator-index-log-card" class="card">
    <div id="simulator-index-log-header" class="card-header fw-bold"><i class="bi bi-terminal"></i> @Localizer["Index_ActivityLogHeader"]</div>
    <div id="simulator-index-log-body" class="card-body" style="max-height:220px; overflow:auto; font-family:monospace; font-size:0.82rem;">
        @if (log.Count == 0)
        {
            <span class="text-muted">@Localizer["Index_NoActivityYet"]</span>
        }
        else
        {
            @foreach (var line in log)
            {
                <div>@line</div>
            }
        }
    </div>
</div>

@code {
    private List<StadiumSectionInfoDto> sections = new();
    private List<ExternalEventSummaryDto> existingEvents = new();
    private List<ExternalSeasonSummaryDto> seasons = new();
    private bool connectionOk;
    private string? connectionError;

    // Season state
    private string? selectedSeasonExternalId;
    private string? selectedSeasonName;
    private string newSeasonName = "2026/2027";
    private DateTime seasonStart = new DateTime(DateTime.Today.Year, 8, 1);
    private DateTime seasonEnd = new DateTime(DateTime.Today.Year + 1, 5, 31);
    private bool seasonIsCurrent = true;
    private string? linkSeasonExternalId; // event → season link on create
    private string seasonTicketSector = string.Empty;
    private int seasonTicketBatch = 20; // bulk-create quantity
    private readonly List<string> seasonTicketIds = new(); // passes sold this session (for "refund last")

    private string? externalEventId;
    private int? internalEventId;
    private string eventName = "Simulated Match";
    private DateTime eventDate = DateTime.Today.AddDays(7).AddHours(18);
    private DateTime eventEndDate = DateTime.Today.AddDays(7).AddHours(20);
    private const decimal basePrice = 45m;

    // Lifecycle of the loaded event (from the API). Ticket sales are only allowed while the event
    // is on sale; once it's live, selling stops and drink-order simulation opens up.
    private bool eventCanSell = true;
    private bool eventLive;
    private string eventStatusName = "";

    // Live drink-order simulation state
    private bool autoOrdering;
    private int autoOrderRate = 3;
    private int autoOrderIntervalMs = 1500;
    private CancellationTokenSource? autoOrderCts;
    private int drinkOrdersPlaced;

    // The event is only "live" between start and end, so the end must come after the start.
    private bool EndAfterStart => eventEndDate > eventDate;

    // Fixed-key structures created at event creation (safe for concurrent read/write of existing keys).
    private readonly Dictionary<string, int> soldCount = new();
    private readonly Dictionary<string, List<string>> soldIds = new();

    // Per-sector season-pass occupancy for the loaded event. Season passes hold a seat across every
    // event linked to their season, but their per-match access tickets carry no external id, so they
    // never appear in GetEventTickets/soldCount — we source this from the authoritative API snapshot.
    private readonly Dictionary<string, int> seasonCount = new();
    private readonly object _lock = new();

    private bool busy;
    private bool autoSelling;
    private int autoRate = 5;
    private int autoIntervalMs = 800;
    private CancellationTokenSource? autoCts;

    private EventSalesSnapshotDto? snapshot;
    private readonly List<string> log = new();
    private readonly Random _rng = new();

    private static readonly string[] Names =
        { "Ivan Horvat", "Marko Kovač", "Ana Babić", "Petra Novak", "Luka Marić", "Sara Jurić", "Tomislav Knežević", "Maja Vuković" };

    private int TotalCapacity => sections.Sum(s => s.Capacity);
    private int TotalSold => sections.Sum(s => SoldCount(s.SectionCode));
    private int SoldCount(string code) => soldCount.TryGetValue(code, out var c) ? c : 0;

    // Season passes occupy seats too, so occupancy/availability must count both single-match sales
    // and season holders.
    private int SeasonSoldCount(string code) => seasonCount.TryGetValue(code, out var c) ? c : 0;
    private int OccupiedCount(string code) => SoldCount(code) + SeasonSoldCount(code);
    private int TotalSeasonSold => sections.Sum(s => SeasonSoldCount(s.SectionCode));
    private int TotalOccupied => TotalSold + TotalSeasonSold;

    protected override async Task OnInitializedAsync()
    {
        await LoadSectionsAsync();
        await LoadEventsAsync();
        await LoadSeasonsAsync();
    }

    private async Task LoadSeasonsAsync()
    {
        try
        {
            seasons = await Api.GetSeasonsAsync();
            // Keep the selected-season name label in sync if the season still exists.
            var sel = seasons.FirstOrDefault(s => s.ExternalSeasonId == selectedSeasonExternalId);
            selectedSeasonName = sel?.Name;
            if (sel == null) selectedSeasonExternalId = null;
        }
        catch (Exception ex)
        {
            Log($"Failed to load seasons: {ex.Message}");
        }
    }

    private void SelectSeason(ExternalSeasonSummaryDto se)
    {
        selectedSeasonExternalId = se.ExternalSeasonId;
        selectedSeasonName = se.Name;
        linkSeasonExternalId = se.ExternalSeasonId;
        seasonTicketIds.Clear();
        Log($"🎫 Selected season '{se.Name}' for linking events and selling season tickets");
    }

    private async Task CreateSeasonAsync()
    {
        if (busy) return;
        if (string.IsNullOrWhiteSpace(newSeasonName) || seasonEnd <= seasonStart)
        {
            Log("❌ Season needs a name and an end date after the start.");
            return;
        }
        busy = true;
        try
        {
            var extId = "SEASON-" + Guid.NewGuid().ToString("N")[..8].ToUpperInvariant();
            var envelope = new TicketingWebhookEnvelope
            {
                EventType = TicketingEventTypes.SeasonCreated,
                IdempotencyKey = Guid.NewGuid().ToString(),
                OccurredAt = DateTime.UtcNow,
                SourceSystem = Api.SourceSystem,
                Season = new ExternalSeasonDto
                {
                    ExternalSeasonId = extId,
                    Name = newSeasonName,
                    StartDate = DateTime.SpecifyKind(seasonStart, DateTimeKind.Utc),
                    EndDate = DateTime.SpecifyKind(seasonEnd, DateTimeKind.Utc),
                    IsCurrent = seasonIsCurrent
                }
            };
            var result = await Api.SendAsync(envelope);
            if (result.Accepted)
            {
                Log($"✅ Season '{newSeasonName}' created — external {extId} → stadium season #{result.SeasonId}");
                await LoadSeasonsAsync();
                selectedSeasonExternalId = extId;
                selectedSeasonName = newSeasonName;
                linkSeasonExternalId = extId;
            }
            else
            {
                Log($"❌ Season create rejected: {result.Message}");
            }
        }
        catch (Exception ex)
        {
            Log($"❌ Season create error: {ex.Message}");
        }
        finally
        {
            busy = false;
        }
    }

    private async Task SellSeasonTicketAsync()
    {
        if (busy || selectedSeasonExternalId == null || string.IsNullOrEmpty(seasonTicketSector)) return;
        busy = true;
        try
        {
            var result = await SellOneSeasonTicketAsync(seasonTicketSector);
            if (result != null)
            {
                Log($"🎟 Season ticket sold in {seasonTicketSector} — {result.DerivedTicketsAffected} match ticket(s) generated (pass #{result.SeasonTicketId})");
                await LoadSeasonsAsync();
                await RefreshSeasonOccupancyAsync();
            }
        }
        finally
        {
            busy = false;
        }
    }

    // Bulk-create N season passes spread across all sectors (weighted by capacity), so you can
    // quickly seed the stadium with a chosen number of season holders. Returns nothing; logs a summary.
    private async Task SellSeasonTicketBatchAsync(int count)
    {
        if (busy || selectedSeasonExternalId == null || sections.Count == 0 || count <= 0) return;
        busy = true;
        try
        {
            int made = 0, failed = 0;
            for (var i = 0; i < count; i++)
            {
                var sector = PickWeightedSector();
                var result = await SellOneSeasonTicketAsync(sector.SectionCode);
                if (result != null) made++; else failed++;
                if (i % 10 == 0) await InvokeAsync(StateHasChanged); // periodic progress refresh
            }
            Log($"🎟 Bulk season passes: {made} sold across sectors" + (failed > 0 ? $", {failed} failed (sector full?)" : ""));
            await LoadSeasonsAsync();
            await RefreshSeasonOccupancyAsync();
        }
        finally
        {
            busy = false;
        }
    }

    /// <summary>Sells one season pass into a sector; returns the result on success, null on reject/duplicate/error.</summary>
    private async Task<TicketingWebhookResult?> SellOneSeasonTicketAsync(string sectorCode)
    {
        var extId = "STK-" + Guid.NewGuid().ToString("N")[..12].ToUpperInvariant();
        var envelope = new TicketingWebhookEnvelope
        {
            EventType = TicketingEventTypes.SeasonTicketSold,
            IdempotencyKey = Guid.NewGuid().ToString(),
            OccurredAt = DateTime.UtcNow,
            SourceSystem = Api.SourceSystem,
            SeasonTicket = new ExternalSeasonTicketDto
            {
                ExternalSeasonTicketId = extId,
                ExternalSeasonId = selectedSeasonExternalId!,
                SectionCode = sectorCode,
                Price = 0m, // price isn't relevant to the simulator — we only care which seats a pass occupies
                HolderName = Names[_rng.Next(Names.Length)],
                SoldAt = DateTime.UtcNow
            }
        };
        try
        {
            var result = await Api.SendAsync(envelope);
            if (result.Accepted && !result.Duplicate)
            {
                seasonTicketIds.Add(extId);
                return result;
            }
            if (!result.Accepted)
                Log($"⚠ Season ticket {sectorCode} rejected: {result.Message}");
            return null;
        }
        catch (Exception ex)
        {
            Log($"⚠ Season ticket error: {ex.Message}");
            return null;
        }
    }

    /// <summary>Picks a sector at random, weighted by capacity, so bulk passes spread realistically.</summary>
    private StadiumSectionInfoDto PickWeightedSector()
    {
        var total = sections.Sum(s => s.Capacity);
        if (total <= 0) return sections[_rng.Next(sections.Count)];
        var pick = _rng.Next(total);
        var acc = 0;
        foreach (var s in sections)
        {
            acc += s.Capacity;
            if (pick < acc) return s;
        }
        return sections[^1];
    }

    /// <summary>
    /// Refreshes the loaded event's per-sector season-pass occupancy from the API snapshot. Season
    /// passes materialise a per-match access ticket with no external id, so they never show up in
    /// GetEventTickets — this is the only way the simulator learns how many seats they hold.
    /// </summary>
    private async Task RefreshSeasonOccupancyAsync()
    {
        if (externalEventId == null) return;
        try
        {
            var snap = await Api.GetSnapshotAsync(externalEventId);
            if (snap == null) return;
            lock (_lock)
            {
                seasonCount.Clear();
                foreach (var sec in snap.Sectors)
                    if (sec.SeasonSold > 0) seasonCount[sec.SectionCode] = sec.SeasonSold;
            }
        }
        catch (Exception ex)
        {
            Log($"⚠ Could not refresh season occupancy: {ex.Message}");
        }
    }

    private async Task RefundSeasonTicketAsync()
    {
        if (busy || seasonTicketIds.Count == 0) return;
        busy = true;
        try
        {
            var extId = seasonTicketIds[^1];
            var envelope = new TicketingWebhookEnvelope
            {
                EventType = TicketingEventTypes.SeasonTicketRefunded,
                IdempotencyKey = Guid.NewGuid().ToString(),
                OccurredAt = DateTime.UtcNow,
                SourceSystem = Api.SourceSystem,
                SeasonTicket = new ExternalSeasonTicketDto
                {
                    ExternalSeasonTicketId = extId,
                    ExternalSeasonId = selectedSeasonExternalId ?? string.Empty
                }
            };
            var result = await Api.SendAsync(envelope);
            if (result.Accepted)
            {
                seasonTicketIds.Remove(extId);
                Log($"↩ Season ticket refunded — {result.DerivedTicketsAffected} match ticket(s) cancelled");
                await LoadSeasonsAsync();
                await RefreshSeasonOccupancyAsync();
            }
            else
            {
                Log($"⚠ Season ticket refund failed: {result.Message}");
            }
        }
        catch (Exception ex)
        {
            Log($"⚠ Season ticket refund error: {ex.Message}");
        }
        finally
        {
            busy = false;
        }
    }

    private async Task LoadEventsAsync()
    {
        try
        {
            existingEvents = await Api.GetEventsAsync();
        }
        catch (Exception ex)
        {
            Log($"Failed to load events: {ex.Message}");
        }
    }

    private async Task SelectEventAsync(ExternalEventSummaryDto summary)
    {
        if (busy) return;
        busy = true;
        try
        {
            var refs = await Api.GetEventTicketsAsync(summary.ExternalEventId);
            lock (_lock)
            {
                soldCount.Clear();
                soldIds.Clear();
                foreach (var s in sections)
                {
                    soldIds[s.SectionCode] = new List<string>();
                    soldCount[s.SectionCode] = 0;
                }
                foreach (var r in refs)
                {
                    if (!soldIds.TryGetValue(r.SectionCode, out var list))
                    {
                        list = new List<string>();
                        soldIds[r.SectionCode] = list;
                    }
                    list.Add(r.ExternalTicketId);
                    soldCount[r.SectionCode] = list.Count;
                }
            }

            externalEventId = summary.ExternalEventId;
            internalEventId = summary.EventId;
            eventName = summary.EventName;
            eventDate = summary.EventDate.ToLocalTime();
            if (summary.EventEndDate is DateTime end) eventEndDate = end.ToLocalTime();
            ApplyEventState(summary);
            snapshot = null;
            Log($"📂 Loaded '{summary.EventName}' (external {summary.ExternalEventId} → stadium #{summary.EventId}) — {refs.Count} sold ticket(s) restored");
            await RefreshSeasonOccupancyAsync();
        }
        catch (Exception ex)
        {
            Log($"❌ Failed to load event: {ex.Message}");
        }
        finally
        {
            busy = false;
        }
    }

    // Deletes an existing event (and its tickets) after a confirm. Derived season-pass tickets go
    // with it; the season passes themselves survive. If the deleted event was the loaded one, clear it.
    private async Task DeleteEventAsync(ExternalEventSummaryDto summary)
    {
        if (busy) return;

        var confirmed = await JSRuntime.InvokeAsync<bool>(
            "confirm", Localizer["Index_DeleteConfirm", summary.EventName].Value);
        if (!confirmed) return;

        busy = true;
        try
        {
            var (ok, message) = await Api.DeleteEventAsync(summary.ExternalEventId);
            if (ok)
            {
                Log($"🗑 Deleted '{summary.EventName}' (external {summary.ExternalEventId} → stadium #{summary.EventId})");
                if (externalEventId == summary.ExternalEventId)
                {
                    await ResetEvent(); // clears loaded event + reloads the list
                }
                else
                {
                    await LoadEventsAsync();
                    await LoadSeasonsAsync(); // season EventCount may have changed
                }
            }
            else
            {
                Log($"❌ Delete failed for '{summary.EventName}': {message}");
            }
        }
        catch (Exception ex)
        {
            Log($"❌ Delete error: {ex.Message}");
        }
        finally
        {
            busy = false;
        }
    }

    private async Task LoadSectionsAsync()
    {
        try
        {
            sections = await Api.GetSectionsAsync();
            connectionOk = true;
            connectionError = null;
            if (string.IsNullOrEmpty(seasonTicketSector) && sections.Count > 0)
                seasonTicketSector = sections[0].SectionCode;
        }
        catch (Exception ex)
        {
            connectionOk = false;
            connectionError = ex.Message;
            Log($"Failed to load sections: {ex.Message}");
        }
    }

    private async Task CreateEventAsync()
    {
        if (busy) return;
        if (!EndAfterStart)
        {
            Log("❌ End time must be after the start time.");
            return;
        }
        busy = true;
        try
        {
            var extId = "SIM-" + Guid.NewGuid().ToString("N")[..8].ToUpperInvariant();
            var envelope = new TicketingWebhookEnvelope
            {
                EventType = TicketingEventTypes.EventCreated,
                IdempotencyKey = Guid.NewGuid().ToString(),
                OccurredAt = DateTime.UtcNow,
                SourceSystem = Api.SourceSystem,
                Event = new ExternalEventDto
                {
                    ExternalEventId = extId,
                    EventName = eventName,
                    EventType = "Football",
                    EventDate = DateTime.SpecifyKind(eventDate, DateTimeKind.Utc),
                    EventEndDate = DateTime.SpecifyKind(eventEndDate, DateTimeKind.Utc),
                    TotalSeats = TotalCapacity,
                    BaseTicketPrice = basePrice,
                    Description = "Simulated event",
                    ExternalSeasonId = string.IsNullOrWhiteSpace(linkSeasonExternalId) ? null : linkSeasonExternalId
                }
            };

            var result = await Api.SendAsync(envelope);
            if (result.Accepted)
            {
                externalEventId = extId;
                internalEventId = result.EventId;
                lock (_lock)
                {
                    soldCount.Clear();
                    soldIds.Clear();
                    seasonCount.Clear();
                    foreach (var s in sections)
                    {
                        soldCount[s.SectionCode] = 0;
                        soldIds[s.SectionCode] = new List<string>();
                    }
                }
                var seasonNote = result.SeasonId != null
                    ? $" · linked to season #{result.SeasonId}" + (result.DerivedTicketsAffected > 0 ? $", {result.DerivedTicketsAffected} season pass ticket(s) generated" : "")
                    : "";
                Log($"✅ Event created — external {extId} → stadium event #{result.EventId}{seasonNote}");
                await LoadEventsAsync();
                ApplyEventState(existingEvents.FirstOrDefault(e => e.ExternalEventId == externalEventId));
                await LoadSeasonsAsync();
                await RefreshSeasonOccupancyAsync();
            }
            else
            {
                Log($"❌ Event create rejected: {result.Message}");
            }
        }
        catch (Exception ex)
        {
            Log($"❌ Event create error: {ex.Message}");
        }
        finally
        {
            busy = false;
        }
    }

    // Slides the selected event's start to "now" and flips its lifecycle to Active on the API,
    // so features gated on the event being live (drink ordering, live ticket sessions) can be tested.
    private async Task MakeEventLiveAsync()
    {
        if (busy || externalEventId == null) return;
        busy = true;
        try
        {
            var envelope = new TicketingWebhookEnvelope
            {
                EventType = TicketingEventTypes.EventWentLive,
                IdempotencyKey = Guid.NewGuid().ToString(),
                OccurredAt = DateTime.UtcNow,
                SourceSystem = Api.SourceSystem,
                Event = new ExternalEventDto
                {
                    ExternalEventId = externalEventId!,
                    EventName = eventName
                }
            };

            var result = await Api.SendAsync(envelope);
            if (result.Accepted)
            {
                // Mirror the new "now" window locally, preserving the event's original duration.
                var window = eventEndDate - eventDate;
                if (window <= TimeSpan.Zero) window = TimeSpan.FromHours(2);
                eventDate = DateTime.Now;
                eventEndDate = eventDate.Add(window);

                // Selling is closed once live — stop any running auto-sell.
                if (autoSelling) { autoSelling = false; autoCts?.Cancel(); }

                Log($"🔴 Event is now LIVE — window moved to now, {result.Message}");
                await LoadEventsAsync();
                ApplyEventState(existingEvents.FirstOrDefault(e => e.ExternalEventId == externalEventId));
            }
            else
            {
                Log($"❌ Could not make event live: {result.Message}");
            }
        }
        catch (Exception ex)
        {
            Log($"❌ Make-live failed: {ex.Message}");
        }
        finally
        {
            busy = false;
        }
    }

    private async Task SellAsync(StadiumSectionInfoDto s, int count)
    {
        busy = true;
        try
        {
            var made = 0;
            for (var i = 0; i < count; i++)
            {
                if (OccupiedCount(s.SectionCode) >= s.Capacity) break;
                if (await SellOneAsync(s)) made++;
                else break;
            }
            if (made > 0) Log($"Sold {made} in {s.SectionCode} (now {OccupiedCount(s.SectionCode)}/{s.Capacity})");
        }
        finally
        {
            busy = false;
        }
    }

    private async Task<bool> SellOneAsync(StadiumSectionInfoDto s)
    {
        var extTicket = "TCK-" + Guid.NewGuid().ToString("N")[..12].ToUpperInvariant();
        var envelope = new TicketingWebhookEnvelope
        {
            EventType = TicketingEventTypes.TicketSold,
            IdempotencyKey = Guid.NewGuid().ToString(),
            OccurredAt = DateTime.UtcNow,
            SourceSystem = Api.SourceSystem,
            Ticket = new ExternalTicketDto
            {
                ExternalTicketId = extTicket,
                ExternalEventId = externalEventId!,
                SectionCode = s.SectionCode,
                Price = basePrice,
                CustomerName = Names[_rng.Next(Names.Length)],
                SoldAt = DateTime.UtcNow
            }
        };

        try
        {
            var result = await Api.SendAsync(envelope);
            if (result.Accepted && !result.Duplicate)
            {
                lock (_lock)
                {
                    soldIds[s.SectionCode].Add(extTicket);
                    soldCount[s.SectionCode] = soldIds[s.SectionCode].Count;
                }
                return true;
            }
            if (!result.Accepted)
            {
                Log($"⚠ Sell {s.SectionCode} rejected: {result.Message}");
                return false;
            }
            return true; // duplicate — treat as no-op success
        }
        catch (Exception ex)
        {
            Log($"⚠ Sell {s.SectionCode} error: {ex.Message}");
            return false;
        }
    }

    private async Task RefundAsync(StadiumSectionInfoDto s)
    {
        busy = true;
        try
        {
            string? extTicket;
            lock (_lock)
            {
                var list = soldIds[s.SectionCode];
                extTicket = list.Count > 0 ? list[^1] : null;
            }
            if (extTicket == null) return;

            var envelope = new TicketingWebhookEnvelope
            {
                EventType = TicketingEventTypes.TicketRefunded,
                IdempotencyKey = Guid.NewGuid().ToString(),
                OccurredAt = DateTime.UtcNow,
                SourceSystem = Api.SourceSystem,
                Ticket = new ExternalTicketDto { ExternalTicketId = extTicket, ExternalEventId = externalEventId! }
            };

            var result = await Api.SendAsync(envelope);
            if (result.Accepted)
            {
                lock (_lock)
                {
                    soldIds[s.SectionCode].Remove(extTicket);
                    soldCount[s.SectionCode] = soldIds[s.SectionCode].Count;
                }
                Log($"↩ Refunded 1 in {s.SectionCode} (now {OccupiedCount(s.SectionCode)}/{s.Capacity})");
            }
            else
            {
                Log($"⚠ Refund {s.SectionCode} failed: {result.Message}");
            }
        }
        finally
        {
            busy = false;
        }
    }

    private async Task SellRandomBatchAsync(int count)
    {
        busy = true;
        try
        {
            var made = await SellRandomInternalAsync(count, CancellationToken.None);
            Log($"Sold {made} random tickets (total {TotalOccupied}/{TotalCapacity})");
        }
        finally
        {
            busy = false;
        }
    }

    private async Task<int> SellRandomInternalAsync(int count, CancellationToken ct)
    {
        var made = 0;
        for (var i = 0; i < count && !ct.IsCancellationRequested; i++)
        {
            var available = sections.Where(s => OccupiedCount(s.SectionCode) < s.Capacity).ToList();
            if (available.Count == 0) break;
            // Weight by remaining capacity so fuller sectors fill more slowly.
            var totalRemaining = available.Sum(s => s.Capacity - OccupiedCount(s.SectionCode));
            var pick = _rng.Next(totalRemaining);
            StadiumSectionInfoDto chosen = available[0];
            var acc = 0;
            foreach (var s in available)
            {
                acc += s.Capacity - OccupiedCount(s.SectionCode);
                if (pick < acc) { chosen = s; break; }
            }
            if (await SellOneAsync(chosen)) made++;
        }
        return made;
    }

    private async Task ToggleAutoSell()
    {
        if (autoSelling)
        {
            autoSelling = false;
            autoCts?.Cancel();
            Log("⏹ Auto-sell stopped");
            return;
        }

        if (!eventCanSell)
        {
            Log($"⚠ Ticket sales are closed — event is {eventStatusName}.");
            return;
        }

        autoSelling = true;
        autoCts = new CancellationTokenSource();
        var token = autoCts.Token;
        Log($"▶ Auto-sell started ({autoRate} / {autoIntervalMs}ms)");

        _ = Task.Run(async () =>
        {
            try
            {
                while (!token.IsCancellationRequested && autoSelling)
                {
                    var made = await SellRandomInternalAsync(autoRate, token);
                    await InvokeAsync(StateHasChanged);
                    if (made == 0)
                    {
                        autoSelling = false;
                        Log("⏹ Auto-sell stopped — stadium is full");
                        await InvokeAsync(StateHasChanged);
                        break;
                    }
                    await Task.Delay(autoIntervalMs, token);
                }
            }
            catch (OperationCanceledException) { /* expected on stop */ }
            catch (Exception ex)
            {
                Log($"Auto-sell error: {ex.Message}");
                await InvokeAsync(StateHasChanged);
            }
        });
    }

    private async Task VerifySyncAsync()
    {
        busy = true;
        try
        {
            snapshot = await Api.GetSnapshotAsync(externalEventId!);
            if (snapshot == null) Log("⚠ No snapshot returned by API");
            else Log($"🔍 Verify: API {snapshot.TotalSold} (incl. {snapshot.TotalSeasonSold} season) vs simulator {TotalOccupied}");
        }
        catch (Exception ex)
        {
            Log($"⚠ Verify error: {ex.Message}");
        }
        finally
        {
            busy = false;
        }
    }

    private async Task ReplayAsync()
    {
        busy = true;
        try
        {
            List<(string section, string ext)> all;
            lock (_lock)
            {
                all = soldIds.SelectMany(kv => kv.Value.Select(id => (kv.Key, id))).ToList();
            }

            var healed = 0;
            foreach (var (section, ext) in all)
            {
                var envelope = new TicketingWebhookEnvelope
                {
                    EventType = TicketingEventTypes.TicketSold,
                    IdempotencyKey = Guid.NewGuid().ToString(),
                    OccurredAt = DateTime.UtcNow,
                    SourceSystem = Api.SourceSystem,
                    Ticket = new ExternalTicketDto
                    {
                        ExternalTicketId = ext,
                        ExternalEventId = externalEventId!,
                        SectionCode = section,
                        Price = basePrice,
                        SoldAt = DateTime.UtcNow
                    }
                };
                var result = await Api.SendAsync(envelope);
                if (result.Accepted && !result.Duplicate) healed++;
            }
            Log($"🔁 Replay complete — {healed} missing sale(s) re-applied, {all.Count - healed} already present");
            await VerifySyncAsync();
        }
        finally
        {
            busy = false;
        }
    }

    // Mirrors the loaded event's lifecycle flags from the API summary so the UI can gate ticket
    // selling (only while on sale) and drink ordering (only while live).
    private void ApplyEventState(ExternalEventSummaryDto? s)
    {
        eventCanSell = s?.CanSellTickets ?? true;
        eventLive = s?.CanOrderDrinks ?? false;
        eventStatusName = s?.StatusName ?? "";
    }

    // Places N simulated live drink orders (server picks a random occupied seat + random drinks).
    private async Task SimulateDrinkOrdersAsync(int count)
    {
        if (busy || externalEventId == null || !eventLive) return;
        busy = true;
        try
        {
            for (var i = 0; i < count; i++)
            {
                var r = await Api.SimulateDrinkOrderAsync(externalEventId);
                if (r.Accepted)
                {
                    drinkOrdersPlaced++;
                    Log($"🍺 Drink order #{r.OrderId} @ seat {r.SeatNumber}: {r.OrderSummary} (€{r.TotalAmount:0.00})");
                }
                else
                {
                    Log($"⚠ Drink order rejected: {r.Message}");
                    break; // stop the batch on the first rejection (no seats / no longer live)
                }
            }
        }
        finally
        {
            busy = false;
        }
    }

    private async Task ToggleAutoOrder()
    {
        if (autoOrdering)
        {
            autoOrdering = false;
            autoOrderCts?.Cancel();
            Log("⏹ Auto drink-orders stopped");
            return;
        }

        if (!eventLive || externalEventId == null)
        {
            Log("⚠ Drink ordering is only available while the event is live.");
            return;
        }

        autoOrdering = true;
        autoOrderCts = new CancellationTokenSource();
        var token = autoOrderCts.Token;
        Log($"▶ Auto drink-orders started ({autoOrderRate} / {autoOrderIntervalMs}ms)");

        _ = Task.Run(async () =>
        {
            try
            {
                while (!token.IsCancellationRequested && autoOrdering)
                {
                    for (var i = 0; i < autoOrderRate && !token.IsCancellationRequested; i++)
                    {
                        var r = await Api.SimulateDrinkOrderAsync(externalEventId!);
                        if (r.Accepted)
                        {
                            drinkOrdersPlaced++;
                        }
                        else
                        {
                            autoOrdering = false;
                            Log($"⏹ Auto drink-orders stopped — {r.Message}");
                            break;
                        }
                    }
                    await InvokeAsync(StateHasChanged);
                    if (!autoOrdering) break;
                    await Task.Delay(autoOrderIntervalMs, token);
                }
            }
            catch (OperationCanceledException) { /* expected on stop */ }
            catch (Exception ex)
            {
                Log($"Auto drink-order error: {ex.Message}");
            }
            await InvokeAsync(StateHasChanged);
        });
    }

    private async Task ResetEvent()
    {
        autoSelling = false;
        autoCts?.Cancel();
        autoOrdering = false;
        autoOrderCts?.Cancel();
        externalEventId = null;
        internalEventId = null;
        snapshot = null;
        eventCanSell = true;
        eventLive = false;
        eventStatusName = "";
        lock (_lock) { soldCount.Clear(); soldIds.Clear(); seasonCount.Clear(); }
        Log("↩ Back to events list — cleared active event");
        await LoadEventsAsync();
    }

    private static string BarClass(double pct) => pct switch
    {
        >= 90 => "bg-danger",
        >= 50 => "bg-warning",
        _ => "bg-success"
    };

    private void Log(string message)
    {
        var stamp = DateTime.Now.ToString("HH:mm:ss");
        log.Insert(0, $"[{stamp}] {message}");
        if (log.Count > 40) log.RemoveAt(log.Count - 1);
    }

    public void Dispose()
    {
        autoSelling = false;
        autoCts?.Cancel();
        autoCts?.Dispose();
        autoOrdering = false;
        autoOrderCts?.Cancel();
        autoOrderCts?.Dispose();
    }
}
