@page "/login"
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Admin.Services
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Login_PageTitle"]</PageTitle>

<ConsoleLoginCard IdPrefix="admin"
                  Eyebrow="@L["Login_StadiumAdmin"]"
                  Title="@L["SignIn"]"
                  Subtitle="@L["Login_OperationsConsoleAccess"]"
                  EmailLabel="@L["Email"]"
                  PasswordLabel="@L["Password"]"
                  SubmitText="@L["Login"]"
                  LoadingText="@L["Login_LoggingIn"]"
                  ShowPasswordLabel="@L["Login_ShowPassword"]"
                  HidePasswordLabel="@L["Login_HidePassword"]"
                  FooterText="@L["Login_DemoCredentialsHint"]"
                  ErrorMessage="@errorMessage"
                  IsLoading="isLoading"
                  @bind-Email="email"
                  @bind-Password="password"
                  OnSubmit="HandleLogin" />
