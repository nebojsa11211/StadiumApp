@page "/events"
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Shared.Pricing
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Events_PageTitle"]</PageTitle>

<div class="console" id="admin-events-main-container">
    <!-- Page Header -->
    <header class="console-head" id="admin-events-header">
        <div class="console-head__title">
            <span class="eyebrow">@L["Events_Eyebrow"]</span>
            <h1 id="admin-events-title">@L["Events_Title"]</h1>
            <p>@L["Events_Subtitle"]</p>
        </div>
        <div class="console-head__actions">
            <button class="pill-btn pill-btn--primary" @onclick="ShowCreateEventModal" id="admin-events-create-btn">
                <i class="bi bi-plus-circle"></i><span>@L["Events_CreateButton"]</span>
            </button>
        </div>
    </header>

    @if (events == null)
    {
        <div class="loading-state" id="admin-events-loading">
            <span class="loading-spinner" id="admin-events-loading-spinner"></span>
            <p id="admin-events-loading-text">@L["Events_Loading"]</p>
        </div>
    }
    else if (loadingFailed)
    {
        <div class="console-alert console-alert--danger" role="alert" id="admin-events-error">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div id="admin-events-error-actions">
                <strong id="admin-events-error-title">@L["Events_ErrorTitle"]</strong>
                <p class="mb-0" id="admin-events-error-message">@loadingError</p>
                <hr id="admin-events-error-divider">
                <button class="pill-btn" @onclick="async () => await LoadEvents()" id="admin-events-retry-btn">
                    <i class="bi bi-arrow-clockwise"></i><span>@L["Events_RetryButton"]</span>
                </button>
            </div>
        </div>
    }
    else if (!events.Any())
    {
        <div class="empty" id="admin-events-empty">
            <i class="bi bi-calendar-event" id="admin-events-empty-icon"></i>
            <p id="admin-events-empty-title">@L["Events_NoEventsFound"]</p>
            <span id="admin-events-empty-message">@L["Events_EmptyMessage"]</span>
            <div class="mt-3" id="admin-events-empty-actions">
                <button class="pill-btn pill-btn--primary" @onclick="ShowCreateEventModal" id="admin-events-first-event-btn">
                    <i class="bi bi-plus-circle"></i><span>@L["Events_CreateFirstButton"]</span>
                </button>
            </div>
        </div>
    }
    else
    {
        <!-- Key Metrics Cards -->
        <section class="metrics metrics--3" id="admin-events-metrics">
            <article class="metric" id="admin-events-metric-total">
                <div class="metric__head" id="admin-events-metric-total-head">
                    <span class="metric__label" id="admin-events-metric-total-label">@L["Events_TotalEventsLabel"]</span>
                    <i class="bi bi-calendar-event metric__icon" id="admin-events-metric-total-icon"></i>
                </div>
                <div class="metric__value mono" id="admin-events-metric-total-value">@events.Count</div>
                <div class="metric__foot" id="admin-events-metric-total-foot">
                    <span class="metric__hint" id="admin-events-metric-total-hint">@L["Events_TotalEventsHint"]</span>
                </div>
            </article>

            <article class="metric metric--accent" id="admin-events-metric-active">
                <div class="metric__head" id="admin-events-metric-active-head">
                    <span class="metric__label" id="admin-events-metric-active-label">@L["Events_OnSaleLabel"]</span>
                    <i class="bi bi-broadcast metric__icon is-ok" id="admin-events-metric-active-icon"></i>
                </div>
                <div class="metric__value mono" id="admin-events-metric-active-value">@events.Count(e => e.CanSellTickets)</div>
                <div class="metric__foot" id="admin-events-metric-active-foot">
                    <span class="metric__hint" id="admin-events-metric-active-hint">@L["Events_OnSaleHint"]</span>
                </div>
            </article>

            <article class="metric" id="admin-events-metric-capacity">
                <div class="metric__head" id="admin-events-metric-capacity-head">
                    <span class="metric__label" id="admin-events-metric-capacity-label">@L["Events_TotalCapacityLabel"]</span>
                    <i class="bi bi-people metric__icon" id="admin-events-metric-capacity-icon"></i>
                </div>
                <div class="metric__value mono" id="admin-events-metric-capacity-value">@((events.Any() ? events.Max(e => e.Capacity) : 0).ToString("N0"))</div>
                <div class="metric__foot" id="admin-events-metric-capacity-foot">
                    <span class="metric__hint" id="admin-events-metric-capacity-hint">@L["Events_TotalCapacityHint"]</span>
                </div>
            </article>
        </section>

        <!-- Events Grid -->
        <div class="panel" id="admin-events-panel">
            <div class="panel__head" id="admin-events-panel-head">
                <h2 class="panel__title" id="admin-events-panel-title">@L["Events_PanelTitle"] <span class="panel__count mono" id="admin-events-panel-count">@FilteredEvents.Count()</span></h2>
                @if (seasons != null && seasons.Any())
                {
                    <div class="ms-auto d-flex align-items-center gap-2" id="admin-events-season-filter-container">
                        <label class="form-label mb-0 small text-muted" for="admin-events-season-filter" id="admin-events-season-filter-label">Season</label>
                        <select id="admin-events-season-filter" class="form-select form-select-sm" style="width:auto" @bind="seasonFilterValue">
                            <option value="">All seasons</option>
                            <option value="none">No season</option>
                            @foreach (var s in seasons.OrderByDescending(x => x.StartDate))
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>
                }
            </div>
            <div class="panel__body" id="admin-events-panel-body">
                <div class="row" id="admin-events-list">
                    @foreach (var evt in FilteredEvents.OrderBy(e => e.Date ?? DateTime.MaxValue))
                    {
                        <div class="col-md-6 col-lg-4 mb-4" id="admin-event-col-@evt.Id">
                            <div class="panel event-card" id="admin-event-card-@evt.Id">
                                <div class="panel__head" id="admin-event-header-@evt.Id">
                                    <h3 class="panel__title" id="admin-event-header-content-@evt.Id">
                                        <span id="admin-event-name-@evt.Id">@evt.Name</span>
                                    </h3>
                                    <span class="status @StatusBadgeClass(evt.Status)" id="admin-event-status-badge-@evt.Id" title="Phase: @evt.Phase">
                                        <span class="status__dot"></span>@StatusDisplay(evt.Status)
                                    </span>
                                </div>
                                <div class="panel__body" id="admin-event-body-@evt.Id">
                                    <dl class="event-meta" id="admin-event-details-@evt.Id">
                                        <dt><i class="bi bi-tag"></i> @L["Events_TypeLabel"]</dt>
                                        <dd id="admin-event-type-@evt.Id">@evt.EventType</dd>
                                        @if (!string.IsNullOrWhiteSpace(evt.HomeTeam) && !string.IsNullOrWhiteSpace(evt.AwayTeam))
                                        {
                                            <dt><i class="bi bi-shield-fill"></i> @L["Events_MatchupLabel"]</dt>
                                            <dd id="admin-event-teams-@evt.Id">@evt.HomeTeam <span class="text-muted">@L["Events_VersusSeparator"]</span> @evt.AwayTeam</dd>
                                        }
                                        <dt><i class="bi bi-calendar3"></i> @L["Events_DateLabel"]</dt>
                                        <dd class="mono" id="admin-event-date-@evt.Id">@evt.Date?.ToString("MMM dd, yyyy HH:mm")</dd>
                                        <dt><i class="bi bi-person-fill"></i> @L["Events_CapacityLabel"]</dt>
                                        <dd class="mono" id="admin-event-capacity-@evt.Id">@evt.Capacity.ToString("N0") @L["Events_SeatsLabel"]</dd>
                                        <dt><i class="bi bi-cash"></i> @L["Events_BasePriceLabel"]</dt>
                                        <dd class="mono" id="admin-event-price-@evt.Id">$@evt.BasePrice.ToString("F2")</dd>
                                        <dt><i class="bi bi-calendar-range"></i> Season</dt>
                                        <dd id="admin-event-season-@evt.Id">
                                            @if (!string.IsNullOrEmpty(evt.SeasonName))
                                            {
                                                <span class="status is-active"><span class="status__dot"></span>@evt.SeasonName</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </dd>
                                        <dt><i class="bi bi-diagram-3"></i> @L["Events_PhaseLabel"]</dt>
                                        <dd id="admin-event-phase-@evt.Id">
                                            @evt.Phase
                                            @if (evt.CanSellTickets)
                                            {
                                                <span class="status is-accepted ms-2" id="admin-event-selling-@evt.Id"><span class="status__dot"></span>@L["Events_SellingStatus"]</span>
                                            }
                                            @if (evt.CanOrderDrinks)
                                            {
                                                <span class="status is-active ms-2" id="admin-event-ordering-@evt.Id"><span class="status__dot"></span>@L["Events_OrdersStatus"]</span>
                                            }
                                        </dd>
                                    </dl>
                                    @if (!string.IsNullOrEmpty(evt.Description))
                                    {
                                        <p class="event-card__desc" id="admin-event-description-@evt.Id">@evt.Description</p>
                                    }
                                </div>
                                <div class="event-card__foot" id="admin-event-footer-@evt.Id">
                                    <div class="event-card__actions" id="admin-event-buttons-@evt.Id">
                                        <button class="pill-btn" @onclick="() => ShowEditEventModal(evt)"
                                                disabled="@(!EventLifecycle.CanEdit(evt.Status))"
                                                title="@(EventLifecycle.CanEdit(evt.Status) ? null : L["Events_EditLockedTooltip"].Value)"
                                                id="admin-event-edit-btn-@evt.Id">
                                            <i class="bi bi-pencil"></i><span>@L["Events_EditButton"]</span>
                                        </button>
                                        <a class="pill-btn" href="admin/stadium-overview?eventId=@evt.Id" id="admin-event-occupancy-btn-@evt.Id">
                                            <i class="bi bi-graph-up-arrow"></i><span>@L["Events_LiveOccupancyButton"]</span>
                                        </a>
                                        @if (evt.Status == EventStatus.Completed)
                                        {
                                            <a class="pill-btn pill-btn--primary" href="admin/event-statistics/@evt.Id" id="admin-event-statistics-btn-@evt.Id">
                                                <i class="bi bi-bar-chart-line"></i><span>@L["Events_StatisticsButton"]</span>
                                            </a>
                                        }
                                        @foreach (var target in EventLifecycle.AllowedNextStatuses(evt.Status))
                                        {
                                            var meta = TransitionMeta(target);
                                            <button class="@TransitionButtonClass(target)" @onclick="() => TransitionStatus(evt, target)" id="admin-event-transition-@(target.ToString().ToLowerInvariant())-btn-@evt.Id">
                                                <i class="bi @meta.Icon"></i><span>@meta.Label</span>
                                            </button>
                                        }
                                        <button class="pill-btn pill-btn--danger" @onclick="() => DeleteEvent(evt.Id)" id="admin-event-delete-btn-@evt.Id">
                                            <i class="bi bi-trash"></i><span>@L["Events_DeleteButton"]</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- Create/Edit Event Modal -->
@if (showEventModal)
{
    <div id="admin-event-modal" class="modal-backdrop-wrapper">
        <div class="modal-dialog" id="admin-event-modal-dialog">
            <div class="modal-content" id="admin-event-modal-content">
                <div class="modal-header" id="admin-event-modal-header" role="heading">
                    <h5 class="modal-title" id="admin-event-modal-title">@(editingEvent == null ? @L["Events_CreateModalTitle"] : @L["Events_EditModalTitle"])</h5>
                    <button type="button" class="btn-close" @onclick="HideEventModal" id="admin-event-modal-close"></button>
                </div>
                <div class="modal-body" id="admin-event-modal-body">
                    <div class="row" id="admin-event-form-name-row">
                        <div class="col-12" id="admin-event-form-name-col">
                            <div class="mb-3" id="admin-event-form-name-group">
                                <label class="form-label" for="admin-event-form-name">@L["Events_EventNameLabel"]</label>
                                <input type="text" class="form-control" @bind="eventForm.Name" required id="admin-event-form-name">
                            </div>
                        </div>
                    </div>

                    <div class="row" id="admin-event-form-type-row">
                        <div class="col-md-6" id="admin-event-form-type-col">
                            <div class="mb-3" id="admin-event-form-type-group">
                                <label class="form-label" for="admin-event-form-type">@L["Events_TypeFieldLabel"]</label>
                                <select class="form-control" @bind="eventForm.EventType" id="admin-event-form-type">
                                    <option value="Match">@L["Events_Type_Match"]</option>
                                    <option value="Concert">@L["Events_Type_Concert"]</option>
                                    <option value="Other">@L["Events_Type_Other"]</option>
                                </select>
                            </div>
                        </div>
                        @if (eventForm.EventType == "Other")
                        {
                            <div class="col-md-6" id="admin-event-form-type-custom-col">
                                <div class="mb-3" id="admin-event-form-type-custom-group">
                                    <label class="form-label" for="admin-event-form-type-custom">@L["Events_TypeCustomLabel"]</label>
                                    <input type="text" class="form-control" @bind="eventForm.EventTypeCustom"
                                           placeholder="@L["Events_TypeCustomPlaceholder"]" id="admin-event-form-type-custom">
                                </div>
                            </div>
                        }
                    </div>

                    @if (eventForm.EventType == "Match")
                    {
                        <div class="row" id="admin-event-form-teams-row">
                            <div class="col-md-6" id="admin-event-form-home-col">
                                <div class="mb-3" id="admin-event-form-home-group">
                                    <label class="form-label" for="admin-event-form-home">@L["Events_HomeTeamLabel"]</label>
                                    @if (venueClubs == null)
                                    {
                                        <div class="text-muted small" id="admin-event-form-home-loading">
                                            <span class="spinner-border spinner-border-sm me-2"></span>@L["Events_Loading"]
                                        </div>
                                    }
                                    else if (venueClubs.Count == 0)
                                    {
                                        <div class="alert alert-warning py-2 mb-0" id="admin-event-form-home-noclubs">
                                            <i class="bi bi-exclamation-triangle me-1"></i>@L["Events_NoClubsWarning"]
                                            <a href="/admin/venue-settings" id="admin-event-form-home-venue-link">@L["Events_NoClubsLink"]</a>
                                        </div>
                                    }
                                    else
                                    {
                                        <select class="form-control" @bind="eventForm.HomeTeam" id="admin-event-form-home">
                                            <option value="">@L["Events_SelectHomeTeam"]</option>
                                            @foreach (var club in venueClubs)
                                            {
                                                <option value="@club.Name">@club.Name @(club.IsPrimary ? "★" : "")</option>
                                            }
                                            @* Keep an out-of-list stored value selectable (e.g. a club later removed). *@
                                            @if (!string.IsNullOrWhiteSpace(eventForm.HomeTeam) && !venueClubs.Any(c => c.Name == eventForm.HomeTeam))
                                            {
                                                <option value="@eventForm.HomeTeam">@eventForm.HomeTeam</option>
                                            }
                                        </select>
                                    }
                                </div>
                            </div>
                            <div class="col-md-6" id="admin-event-form-away-col">
                                <div class="mb-3" id="admin-event-form-away-group">
                                    <label class="form-label" for="admin-event-form-away">@L["Events_AwayTeamLabel"]</label>
                                    <input type="text" class="form-control" @bind="eventForm.AwayTeam"
                                           placeholder="@L["Events_AwayTeamPlaceholder"]" id="admin-event-form-away">
                                </div>
                            </div>
                        </div>
                    }

                    <div class="mb-3" id="admin-event-form-description-group">
                        <label class="form-label" for="admin-event-form-description">@L["Events_DescriptionFieldLabel"]</label>
                        <textarea class="form-control" rows="3" @bind="eventForm.Description" id="admin-event-form-description"></textarea>
                    </div>

                    <div class="row" id="admin-event-form-datetime-row">
                        <div class="col-md-6" id="admin-event-form-date-col">
                            <div class="mb-3" id="admin-event-form-date-group">
                                <label class="form-label" for="admin-event-form-date">@L["Events_StartDateTimeLabel"]</label>
                                <input type="datetime-local" class="form-control" @bind="eventForm.Date" required id="admin-event-form-date">
                            </div>
                        </div>
                        <div class="col-md-6" id="admin-event-form-end-date-col">
                            <div class="mb-3" id="admin-event-form-end-date-group">
                                <label class="form-label" for="admin-event-form-end-date">@L["Events_EndDateTimeLabel"]</label>
                                <input type="datetime-local" class="form-control" @bind="eventForm.EndDate" required id="admin-event-form-end-date">
                                @if (eventForm.EndDate <= eventForm.Date)
                                {
                                    <div class="text-danger small mt-1" id="admin-event-form-end-date-error">@L["Events_EndAfterStartValidation"]</div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="row" id="admin-event-form-sales-window-row">
                        <div class="col-md-6" id="admin-event-form-sales-start-col">
                            <div class="mb-3" id="admin-event-form-sales-start-group">
                                <label class="form-label" for="admin-event-form-sales-start">@L["Events_SalesStartDateTimeLabel"]</label>
                                <input type="datetime-local" class="form-control" @bind="eventForm.TicketSalesStartDate" id="admin-event-form-sales-start">
                            </div>
                        </div>
                        <div class="col-md-6" id="admin-event-form-sales-end-col">
                            <div class="mb-3" id="admin-event-form-sales-end-group">
                                <label class="form-label" for="admin-event-form-sales-end">@L["Events_SalesEndDateTimeLabel"]</label>
                                <input type="datetime-local" class="form-control" @bind="eventForm.TicketSalesEndDate" id="admin-event-form-sales-end">
                                @if (eventForm.TicketSalesStartDate.HasValue && eventForm.TicketSalesEndDate.HasValue &&
                                     eventForm.TicketSalesEndDate.Value <= eventForm.TicketSalesStartDate.Value)
                                {
                                    <div class="text-danger small mt-1" id="admin-event-form-sales-end-error">@L["Events_SalesEndAfterStartValidation"]</div>
                                }
                            </div>
                        </div>
                        <div class="col-12" id="admin-event-form-sales-window-hint-col">
                            <div class="form-text mb-3" id="admin-event-form-sales-window-hint">@L["Events_SalesWindowHint"]</div>
                        </div>
                    </div>

                    <div class="row" id="admin-event-form-capacity-price-row">
                        <div class="col-md-6" id="admin-event-form-capacity-col">
                            <div class="mb-3" id="admin-event-form-capacity-group">
                                <label class="form-label" for="admin-event-form-capacity">@L["Events_CapacityFieldLabel"]</label>
                                <div class="input-group" id="admin-event-form-capacity-input-group">
                                    <input type="text" class="form-control" readonly tabindex="-1"
                                           value="@eventForm.Capacity.ToString("N0")" id="admin-event-form-capacity">
                                    <span class="input-group-text" id="admin-event-form-capacity-suffix">@L["Events_CapacitySeatsSuffix"]</span>
                                </div>
                                <div class="form-text" id="admin-event-form-capacity-hint">@L["Events_CapacityAutoHint"]</div>
                            </div>
                        </div>
                        <div class="col-md-6" id="admin-event-form-price-col">
                            <div class="mb-3" id="admin-event-form-price-group">
                                <label class="form-label" for="admin-event-form-price">@L["Events_BasePriceFieldLabel"]</label>
                                <div class="input-group" id="admin-event-form-price-input-group">
                                    <span class="input-group-text" id="admin-event-form-price-symbol">$</span>
                                    <input type="number" class="form-control" @bind="eventForm.BasePrice"
                                           step="0.01" min="0" required id="admin-event-form-price">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row" id="admin-event-form-status-season-row">
                        <div class="col-md-6" id="admin-event-form-active-col">
                            <div class="mb-3" id="admin-event-form-active-group">
                                <label class="form-label">@L["Events_StatusFieldLabel"]</label>
                                <div class="form-check form-switch" id="admin-event-form-active-switch">
                                    <input class="form-check-input" type="checkbox" @bind="eventForm.IsActive" id="admin-event-form-active">
                                    <label class="form-check-label" for="admin-event-form-active">
                                        @L["Events_ActiveLabel"]
                                    </label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6" id="admin-event-form-season-col">
                            <div class="mb-3" id="admin-event-form-season-group">
                                <label class="form-label" for="admin-event-form-season"><i class="bi bi-calendar-range"></i> Season</label>
                                <select class="form-control" @bind="eventForm.SeasonId" id="admin-event-form-season">
                                    <option value="">(no season)</option>
                                    @if (seasons != null)
                                    {
                                        @foreach (var s in seasons.OrderByDescending(x => x.StartDate))
                                        {
                                            <option value="@s.Id">@s.Name @(s.IsCurrent ? "(current)" : "")</option>
                                        }
                                    }
                                </select>
                                <div class="form-text" id="admin-event-form-season-hint">Linking backfills this season's passes with a match ticket.</div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3" id="admin-event-form-sector-prices-group">
                        <label class="form-label"><i class="bi bi-cash-stack"></i> @L["Events_SectorPricesLabel"]</label>
                        <div class="form-text mb-2" id="admin-event-form-sector-prices-hint">@L["Events_SectorPricesHint"]</div>
                        @if (sectorPrices == null)
                        {
                            <div class="text-muted small" id="admin-event-form-sector-prices-loading">
                                <span class="spinner-border spinner-border-sm me-2"></span>@L["Events_Loading"]
                            </div>
                        }
                        else if (!sectorPrices.Any())
                        {
                            <div class="text-muted small" id="admin-event-form-sector-prices-empty">@L["Events_SectorPricesEmpty"]</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0" id="admin-event-form-sector-prices-table">
                                    <thead>
                                        <tr>
                                            <th>@L["Events_SectorColumn"]</th>
                                            <th>@L["Events_SectorTypeColumn"]</th>
                                            <th class="text-end">@L["Events_SectorDefaultColumn"]</th>
                                            <th style="width: 12rem;">@L["Events_SectorPriceColumn"]</th>
                                            <th class="text-center" style="width: 7rem;">@L["Events_SectorDisabledColumn"]</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in sectorPrices)
                                        {
                                            <tr id="admin-event-form-sector-row-@row.SectorOverlayId" class="@(row.IsDisabled ? "table-secondary" : null)">
                                                <td>
                                                    <span class="fw-medium">@row.SectorName</span>
                                                    <span class="text-muted small ms-1">@row.SectorCode</span>
                                                </td>
                                                <td><span class="text-capitalize">@row.Type</span></td>
                                                <td class="text-end mono">$@EffectiveDefault(row).ToString("F2")</td>
                                                <td>
                                                    <div class="input-group input-group-sm">
                                                        <span class="input-group-text">$</span>
                                                        <input type="number" step="0.01" min="0" class="form-control"
                                                               placeholder="@EffectiveDefault(row).ToString("F2")"
                                                               @bind="row.EventPrice"
                                                               disabled="@row.IsDisabled"
                                                               id="admin-event-form-sector-price-@row.SectorOverlayId">
                                                        @if (row.EventPrice.HasValue && !row.IsDisabled)
                                                        {
                                                            <button type="button" class="btn btn-outline-secondary"
                                                                    title="@L["Events_SectorPriceClear"]"
                                                                    @onclick="() => row.EventPrice = null"
                                                                    id="admin-event-form-sector-clear-@row.SectorOverlayId">
                                                                <i class="bi bi-x"></i>
                                                            </button>
                                                        }
                                                    </div>
                                                </td>
                                                <td class="text-center">
                                                    <div class="form-check d-inline-block">
                                                        <input type="checkbox" class="form-check-input"
                                                               title="@L["Events_SectorDisabledTitle"]"
                                                               @bind="row.IsDisabled"
                                                               id="admin-event-form-sector-disabled-@row.SectorOverlayId">
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer" id="admin-event-modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HideEventModal" id="admin-event-modal-cancel-btn">
                        @L["Events_CancelButton"]
                    </button>
                    <button type="button" class="btn btn-primary" @onclick="SaveEvent" disabled="@isSaving" id="admin-event-modal-save-btn">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        @(editingEvent == null ? @L["Events_CreateEventButton"] : @L["Events_SaveChangesButton"])
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(alertMessage))
{
    <div class="position-fixed top-0 end-0 p-3" style="z-index: 1055;" id="admin-event-alert-container">
        <div class="console-alert @(alertType == "success" ? "console-alert--success" : "console-alert--danger")" id="admin-event-alert">
            <i class="bi @(alertType == "success" ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
            <span>@alertMessage</span>
            <button type="button" class="icon-btn" @onclick="ClearAlert" id="admin-event-alert-close" style="margin-left: auto;">
                <i class="bi bi-x"></i>
            </button>
        </div>
    </div>
}