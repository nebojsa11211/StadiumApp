@page "/orders"
@layout MobileShell
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Customer.Components
@inject IApiService ApiService
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["Orders_PageTitle"]</PageTitle>

<ScreenHeader Title="@Localizer["Orders_ScreenHeader_Title"]" Subtitle="@Localizer["Orders_ScreenHeader_Subtitle"]" ShowBack="false" />

<AuthenticationGuard>
    <div id="customer-orders-container" class="ord-body no-scrollbar">

        @if (orders == null)
        {
            <div id="customer-orders-loading" class="ord-state"><span class="spinner"></span> @Localizer["Orders_Loading"]</div>
        }
        else if (!orders.Any())
        {
            <div id="customer-orders-empty" class="ord-state ord-empty">
                <div class="ord-emoji">🛒</div>
                <h2>@Localizer["Orders_Empty_Title"]</h2>
                <p>@Localizer["Orders_Empty_Message"]</p>
                <a id="customer-browse-menu-btn" href="/menu" class="btn btn-primary">@Localizer["Orders_OpenMenu"]</a>
            </div>
        }
        else
        {
            <div id="customer-orders-list" class="ord-list">
                @foreach (var order in orders.OrderByDescending(o => o.CreatedAt))
                {
                    <div id="customer-order-@order.Id" class="ord-card">
                        <div id="customer-order-header-@order.Id" class="ord-card-head">
                            <span id="customer-order-number-@order.Id" class="ord-num">@Localizer["Orders_OrderNumber", order.Id]</span>
                            <span id="customer-order-status-@order.Id" class="ord-status @StatusClass(order.Status)">@StatusText(order.Status)</span>
                        </div>

                        <div id="customer-order-info-@order.Id" class="ord-meta">
                            <span id="customer-order-date-@order.Id">@Localizer["Orders_OrderDate", order.CreatedAt.ToString("dd.MM.yyyy · HH:mm")]</span>
                            @if (!string.IsNullOrEmpty(order.SeatNumber))
                            {
                                <span id="customer-order-seat-@order.Id">@Localizer["Orders_OrderSeat", order.SeatNumber]</span>
                            }
                        </div>

                        <div id="customer-order-items-@order.Id" class="ord-items">
                            @foreach (var item in order.OrderItems)
                            {
                                <div id="customer-order-item-@item.Id-@order.Id" class="ord-item">
                                    <span id="customer-order-item-name-@item.Id-@order.Id">@item.Quantity × @item.DrinkName</span>
                                    <span id="customer-order-item-total-@item.Id-@order.Id" class="tnum">€@item.TotalPrice.ToString("F2")</span>
                                </div>
                            }
                        </div>

                        <div id="customer-order-total-@order.Id" class="ord-card-foot">
                            <span id="customer-order-total-amount-@order.Id" class="ord-total tnum">€@order.TotalAmount.ToString("F2")</span>
                            <div id="customer-order-actions-@order.Id" class="ord-actions">
                                <button id="customer-order-details-btn-@order.Id" class="btn btn-ghost btn-sm" @onclick="() => ShowOrderDetails(order)">@Localizer["Orders_DetailsButton"]</button>
                                @if (order.Status == OrderStatus.Pending || order.Status == OrderStatus.Accepted)
                                {
                                    <button id="customer-order-cancel-btn-@order.Id" class="btn btn-sm ord-cancel" @onclick="() => CancelOrder(order.Id)" disabled="@isCancelling">
                                        @if (isCancelling)
                                        {
                                            <span class="spinner"></span>
                                        }
                                        else
                                        {
                                            <span>@Localizer["Orders_CancelButton"]</span>
                                        }
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @if (selectedOrder != null)
    {
        <div id="customer-order-scrim" class="ord-scrim show" @onclick="() => selectedOrder = null"></div>
        <div id="customer-order-modal" class="ord-sheet show">
            <div class="grab"></div>
            <div id="customer-order-sheet-head" class="ord-sheet-head">
                <div>
                    <div id="customer-order-modal-title" class="ord-sheet-title">@Localizer["Orders_ModalTitle", selectedOrder.Id]</div>
                    <div class="ord-sheet-sub">@selectedOrder.CreatedAt.ToString("dd.MM.yyyy · HH:mm")</div>
                </div>
                <button id="customer-order-modal-close-btn" class="iconbtn" @onclick="() => selectedOrder = null" aria-label="@Localizer["Orders_CloseButton_Aria"]">✕</button>
            </div>

            <div class="ord-sheet-body no-scrollbar">
                <div class="ord-detail-meta">
                    <div class="ord-meta-row"><span>@Localizer["Orders_StatusLabel"]</span><span class="ord-status @StatusClass(selectedOrder.Status)">@StatusText(selectedOrder.Status)</span></div>
                    @if (!string.IsNullOrEmpty(selectedOrder.TicketNumber))
                    {
                        <div class="ord-meta-row"><span>@Localizer["Orders_TicketLabel"]</span><span class="v">@selectedOrder.TicketNumber</span></div>
                    }
                    @if (!string.IsNullOrEmpty(selectedOrder.SeatNumber))
                    {
                        <div class="ord-meta-row"><span>@Localizer["Orders_SeatLabel"]</span><span class="v">@selectedOrder.SeatNumber</span></div>
                    }
                    <div class="ord-meta-row"><span>@Localizer["Orders_TotalLabel"]</span><span class="v tnum">€@selectedOrder.TotalAmount.ToString("F2")</span></div>
                </div>

                <span class="label">@Localizer["Orders_Items"]</span>
                <div class="ord-detail-items">
                    @foreach (var item in selectedOrder.OrderItems)
                    {
                        <div class="ord-detail-item">
                            <div class="ord-di-l">
                                <span class="ord-di-name">@item.Quantity × @item.DrinkName</span>
                                @if (!string.IsNullOrEmpty(item.SpecialInstructions))
                                {
                                    <span class="ord-di-note">💬 @item.SpecialInstructions</span>
                                }
                            </div>
                            <span class="tnum">€@item.TotalPrice.ToString("F2")</span>
                        </div>
                    }
                </div>

                @{
                    var steps = Timeline(selectedOrder);
                }
                @if (steps.Any())
                {
                    <span class="label">@Localizer["Orders_Timeline"]</span>
                    <div class="ord-timeline">
                        @foreach (var s in steps)
                        {
                            <div class="ord-tl-item">
                                <span class="ord-tl-dot"></span>
                                <div class="ord-tl-content"><strong>@s.Label</strong><span>@s.When</span></div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(alertMessage))
    {
        <div id="customer-alert-container" class="ord-toast @(alertType == "success" ? "ok" : "bad")">
            <span>@alertMessage</span>
            <button id="customer-orders-alert-close-btn" class="ord-toast-x" @onclick="ClearAlert" aria-label="@Localizer["Orders_CloseButton_Aria"]">✕</button>
        </div>
    }
</AuthenticationGuard>

@code {
    private List<OrderDto>? orders;
    private OrderDto? selectedOrder;
    private bool isCancelling = false;
    private string alertMessage = "";
    private string alertType = "";

    protected override async Task OnInitializedAsync() => await LoadOrders();

    private async Task LoadOrders() => orders = await ApiService.GetMyOrdersAsync();

    private void ShowOrderDetails(OrderDto order) => selectedOrder = order;

    private async Task CancelOrder(int orderId)
    {
        if (isCancelling) return;
        isCancelling = true;
        try
        {
            var success = await ApiService.CancelOrderAsync(orderId);
            if (success)
            {
                ShowAlert(Localizer["Orders_CancelledSuccess"], "success");
                await LoadOrders();
            }
            else
            {
                ShowAlert(Localizer["Orders_CancelFailed"], "danger");
            }
        }
        catch (Exception ex)
        {
            ShowAlert(Localizer["Orders_CancelError", ex.Message], "danger");
        }
        finally
        {
            isCancelling = false;
        }
    }

    private record TimelineStep(string Label, string When);

    private List<TimelineStep> Timeline(OrderDto o)
    {
        var steps = new List<TimelineStep> { new(Localizer["Orders_Status_Ordered"], o.CreatedAt.ToString("dd.MM · HH:mm")) };
        if (o.AcceptedAt.HasValue) steps.Add(new(Localizer["Orders_Status_Accepted"], o.AcceptedAt.Value.ToString("dd.MM · HH:mm")));
        if (o.PreparedAt.HasValue) steps.Add(new(Localizer["Orders_Status_Prepared"], o.PreparedAt.Value.ToString("dd.MM · HH:mm")));
        if (o.DeliveredAt.HasValue) steps.Add(new(Localizer["Orders_Status_Delivered"], o.DeliveredAt.Value.ToString("dd.MM · HH:mm")));
        return steps;
    }

    private static string StatusClass(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "is-pending",
        OrderStatus.Accepted => "is-accepted",
        OrderStatus.InPreparation => "is-prep",
        OrderStatus.Ready => "is-ready",
        OrderStatus.Delivered => "is-done",
        OrderStatus.Cancelled => "is-cancelled",
        _ => ""
    };

    private string StatusText(OrderStatus status) => status switch
    {
        OrderStatus.Pending => Localizer["Orders_Status_Pending"],
        OrderStatus.Accepted => Localizer["Orders_Status_Accepted_Text"],
        OrderStatus.InPreparation => Localizer["Orders_Status_InPreparation"],
        OrderStatus.Ready => Localizer["Orders_Status_Ready"],
        OrderStatus.Delivered => Localizer["Orders_Status_Delivered_Text"],
        OrderStatus.Cancelled => Localizer["Orders_Status_Cancelled"],
        _ => status.ToString()
    };

    private void ShowAlert(string message, string type)
    {
        alertMessage = message;
        alertType = type;
        StateHasChanged();
        _ = Task.Delay(5000).ContinueWith(_ =>
        {
            alertMessage = "";
            InvokeAsync(StateHasChanged);
        });
    }

    private void ClearAlert() => alertMessage = "";
}
