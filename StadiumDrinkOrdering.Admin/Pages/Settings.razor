@code {
    private string activeTab = "ticketing";

    private bool isLoading = true;
    private bool loadError;
    private bool isSaving;
    private AppSettingsDto? settings;

    private EmailSettingsDto? email;
    private bool isSavingEmail;
    private bool isTestingEmail;
    private string testRecipient = string.Empty;

    private string? alertMessage;
    private string alertClass = "alert-success";

    // Image generation (external API test tab)
    private string imageGenPrompt = string.Empty;
    private int imageGenWidth = 1024;
    private int imageGenHeight = 1024;
    private bool isGenerating;
    private ImageGenerationResult? imageResult;
    private bool imageIsPlaceholder;
    private string? imageGenError;

    private bool showPurgeModal;
    private bool isPurging;
    private string purgeConfirmText = string.Empty;
    private bool IsPurgeConfirmed =>
        string.Equals(purgeConfirmText.Trim(), "DELETE", StringComparison.Ordinal);

    // Factory reset (scoped) state
    private bool resetOperational;
    private bool resetStadium;
    private bool resetUsers;
    private bool resetCatalog;
    private bool resetDirectories;
    private bool resetFirstRun;
    private bool showResetModal;
    private bool isResetting;
    private string resetConfirmText = string.Empty;

    // Any deeper area forces the operational layer along with it (tickets/orders reference the data
    // those areas remove), so the operational checkbox is auto-ticked and locked while one is selected.
    private bool ResetOperationalLocked => resetStadium || resetUsers || resetCatalog || resetDirectories;
    private bool AnyResetAreaSelected => resetOperational || ResetOperationalLocked || resetFirstRun;
    private bool IsResetConfirmed =>
        string.Equals(resetConfirmText.Trim(), "RESET EVERYTHING", StringComparison.Ordinal);

    // Backup & restore state
    private const long MaxBackupBytes = 512L * 1024 * 1024; // matches the API upload limit
    private static readonly string[] BackupGroupOrder = { "Domain", "UsersWallets", "Security", "Logs" };

    private List<BackupTableInfoDto>? backupTables;
    private readonly HashSet<string> backupSelected = new(StringComparer.OrdinalIgnoreCase);
    private bool isBackingUp;

    private byte[]? restoreFileBytes;
    private string? restoreFileName;
    private BackupPreviewDto? restorePreview;
    private readonly HashSet<string> restoreSelected = new(StringComparer.OrdinalIgnoreCase);
    private bool isPreviewing;
    private bool isRestoring;
    private bool showRestoreModal;
    private string restoreConfirmText = string.Empty;
    private bool IsRestoreConfirmed =>
        string.Equals(restoreConfirmText.Trim(), "RESTORE", StringComparison.Ordinal);

    private string GroupLabel(string group) => group switch
    {
        "Domain" => L["Settings_BackupGroupDomain"],
        "UsersWallets" => L["Settings_BackupGroupUsers"],
        "Security" => L["Settings_BackupGroupSecurity"],
        "Logs" => L["Settings_BackupGroupLogs"],
        _ => group
    };

    // The shared "AuthenticatedClient" injects the JWT via AuthenticationHandler, but that handler
    // runs in a different DI scope than the Blazor circuit, so its scoped token store is empty and
    // every authorized (write) call comes back 401. Match the VenueSettings pattern: read the
    // circuit-scoped token and attach it ourselves before each request.
    private HttpClient Api
    {
        get
        {
            var client = HttpClientFactory.CreateClient("AuthenticatedClient");
            var token = TokenStorage.Token;
            if (!string.IsNullOrEmpty(token))
                client.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            return client;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        await LoadBackupTablesAsync();
    }

    private async Task LoadBackupTablesAsync()
    {
        try
        {
            backupTables = await Api.GetFromJsonAsync<List<BackupTableInfoDto>>("api/admin/backup/tables");
            backupSelected.Clear();
            foreach (var t in backupTables!.Where(t => t.DefaultSelected))
                backupSelected.Add(t.Key);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load backup tables");
        }
        finally
        {
            StateHasChanged();
        }
    }

    private void ToggleBackupTable(string key, bool selected)
    {
        if (selected) backupSelected.Add(key);
        else backupSelected.Remove(key);
    }

    private void ToggleBackupGroup(string group, bool selected)
    {
        if (backupTables is null) return;
        foreach (var t in backupTables.Where(t => t.Group == group))
        {
            if (selected) backupSelected.Add(t.Key);
            else backupSelected.Remove(t.Key);
        }
    }

    private async Task DownloadBackupAsync()
    {
        if (backupSelected.Count == 0) return;
        isBackingUp = true;
        try
        {
            var resp = await Api.PostAsJsonAsync("api/admin/backup/export", backupSelected.ToList());
            if (!resp.IsSuccessStatusCode)
            {
                ShowAlert(L["Settings_BackupFailed"], false);
                return;
            }

            var bytes = await resp.Content.ReadAsByteArrayAsync();
            var fileName = resp.Content.Headers.ContentDisposition?.FileNameStar
                ?? resp.Content.Headers.ContentDisposition?.FileName
                ?? $"stadium-backup-{DateTime.Now:yyyyMMdd-HHmmss}.json";
            fileName = fileName.Trim('"');

            using var ms = new MemoryStream(bytes);
            using var streamRef = new DotNetStreamReference(ms);
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);

            ShowAlert(L["Settings_BackupSuccess", bytes.Length / 1024], true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to export backup");
            ShowAlert(L["Settings_BackupFailed"], false);
        }
        finally
        {
            isBackingUp = false;
        }
    }

    private async Task OnRestoreFileSelected(InputFileChangeEventArgs e)
    {
        restorePreview = null;
        restoreSelected.Clear();
        restoreFileBytes = null;
        restoreFileName = e.File.Name;
        isPreviewing = true;
        StateHasChanged();
        try
        {
            using var ms = new MemoryStream();
            await using (var stream = e.File.OpenReadStream(MaxBackupBytes))
                await stream.CopyToAsync(ms);
            restoreFileBytes = ms.ToArray();

            using var content = BuildFileContent();
            var resp = await Api.PostAsync("api/admin/backup/import/preview", content);
            if (resp.IsSuccessStatusCode)
            {
                restorePreview = await resp.Content.ReadFromJsonAsync<BackupPreviewDto>();
                foreach (var t in restorePreview!.Tables)
                    restoreSelected.Add(t.Key);
            }
            else
            {
                restoreFileBytes = null;
                ShowAlert(L["Settings_RestoreInvalidFile"], false);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to preview backup file");
            restoreFileBytes = null;
            ShowAlert(L["Settings_RestoreInvalidFile"], false);
        }
        finally
        {
            isPreviewing = false;
            StateHasChanged();
        }
    }

    private MultipartFormDataContent BuildFileContent()
    {
        var content = new MultipartFormDataContent();
        var fileContent = new ByteArrayContent(restoreFileBytes!);
        fileContent.Headers.ContentType = new MediaTypeHeaderValue("application/json");
        content.Add(fileContent, "file", restoreFileName ?? "backup.json");
        return content;
    }

    private void ToggleRestoreTable(string key, bool selected)
    {
        if (selected) restoreSelected.Add(key);
        else restoreSelected.Remove(key);
    }

    private void OpenRestoreModal()
    {
        if (restoreSelected.Count == 0) return;
        restoreConfirmText = string.Empty;
        showRestoreModal = true;
    }

    private void CloseRestoreModal()
    {
        if (isRestoring) return;
        showRestoreModal = false;
    }

    private async Task RestoreAsync()
    {
        if (!IsRestoreConfirmed || restoreFileBytes is null || restoreSelected.Count == 0) return;
        isRestoring = true;
        try
        {
            using var content = BuildFileContent();
            content.Add(new StringContent(JsonSerializer.Serialize(restoreSelected.ToList())), "selectedKeys");

            var resp = await Api.PostAsync("api/admin/backup/import", content);
            var result = await resp.Content.ReadFromJsonAsync<RestoreResultDto>();

            if (resp.IsSuccessStatusCode && result?.Success == true)
            {
                showRestoreModal = false;
                ShowAlert(L["Settings_RestoreSuccess", result.TotalRowsInserted, result.Tables.Count], true);
                // Reset the restore panel and refresh live counts.
                restorePreview = null;
                restoreFileBytes = null;
                restoreFileName = null;
                restoreSelected.Clear();
                await LoadBackupTablesAsync();
            }
            else
            {
                ShowAlert(L["Settings_RestoreFailed", result?.Error ?? "unknown error"], false);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to restore backup");
            ShowAlert(L["Settings_RestoreFailed", ex.Message], false);
        }
        finally
        {
            isRestoring = false;
        }
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();
        try
        {
            settings = await Api.GetFromJsonAsync<AppSettingsDto>("api/venue/settings");
            email = await Api.GetFromJsonAsync<EmailSettingsDto>("api/venue/email-settings");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load app settings");
            loadError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SaveEmailAsync()
    {
        if (email is null) return;
        isSavingEmail = true;
        try
        {
            var resp = await Api.PutAsJsonAsync("api/venue/email-settings", email);
            if (resp.IsSuccessStatusCode)
            {
                email = await resp.Content.ReadFromJsonAsync<EmailSettingsDto>();
                ShowAlert(L["Settings_EmailSaved"], true);
            }
            else
            {
                ShowAlert(L["Settings_EmailSaveFailed"], false);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save email settings");
            ShowAlert(L["Settings_EmailSaveFailed"], false);
        }
        finally
        {
            isSavingEmail = false;
        }
    }

    private async Task SendTestEmailAsync()
    {
        if (email is null || string.IsNullOrWhiteSpace(testRecipient)) return;
        isTestingEmail = true;
        try
        {
            var request = new SendTestEmailDto { Settings = email, ToEmail = testRecipient.Trim() };
            var resp = await Api.PostAsJsonAsync("api/venue/email-settings/test", request);
            var result = resp.IsSuccessStatusCode
                ? await resp.Content.ReadFromJsonAsync<SendTestEmailResultDto>()
                : null;

            if (result?.Success == true)
                ShowAlert(L["Settings_EmailTestSuccess"], true);
            else
                ShowAlert(L["Settings_EmailTestFailed", result?.Error ?? "unknown error"], false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to send test email");
            ShowAlert(L["Settings_EmailTestFailed", ex.Message], false);
        }
        finally
        {
            isTestingEmail = false;
        }
    }

    private void OnTicketSalesToggled(ChangeEventArgs e)
    {
        if (settings is not null)
            settings.TicketSalesEnabled = e.Value is bool b && b;
    }

    /// <summary>Toggles one accepted payment method. Saving with none enabled is blocked in the UI
    /// (and refused by the API) — fans would have no way to check out.</summary>
    private void OnPaymentToggled(string method, ChangeEventArgs e)
    {
        if (settings is null) return;
        var on = e.Value is bool b && b;
        switch (method)
        {
            case "wallet": settings.WalletPaymentEnabled = on; break;
            case "card": settings.CardPaymentEnabled = on; break;
            case "cash": settings.CashPaymentEnabled = on; break;
        }
    }

    private async Task SaveAsync()
    {
        if (settings is null) return;
        isSaving = true;
        try
        {
            var resp = await Api.PutAsJsonAsync("api/venue/settings", settings);
            if (resp.IsSuccessStatusCode)
            {
                settings = await resp.Content.ReadFromJsonAsync<AppSettingsDto>();
                ShowAlert(L["Settings_Saved"], true);
            }
            else
            {
                ShowAlert(L["Settings_SaveFailed"], false);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save app settings");
            ShowAlert(L["Settings_SaveFailed"], false);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void OpenPurgeModal()
    {
        purgeConfirmText = string.Empty;
        showPurgeModal = true;
    }

    private void ClosePurgeModal()
    {
        if (isPurging) return;
        showPurgeModal = false;
    }

    private async Task PurgeAsync()
    {
        if (!IsPurgeConfirmed) return;
        isPurging = true;
        try
        {
            var resp = await Api.PostAsync("api/admin/maintenance/purge-transactional-data", content: null);
            if (resp.IsSuccessStatusCode)
            {
                var summary = await resp.Content.ReadFromJsonAsync<PurgeDataResultDto>();
                showPurgeModal = false;
                ShowAlert(L["Settings_PurgeSuccess", summary?.TotalRowsDeleted ?? 0], true);
            }
            else
            {
                ShowAlert(L["Settings_PurgeFailed"], false);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to purge transactional data");
            ShowAlert(L["Settings_PurgeFailed"], false);
        }
        finally
        {
            isPurging = false;
        }
    }

    private void OpenResetModal()
    {
        if (!AnyResetAreaSelected) return;
        resetConfirmText = string.Empty;
        showResetModal = true;
    }

    private void CloseResetModal()
    {
        if (isResetting) return;
        showResetModal = false;
    }

    private async Task FactoryResetAsync()
    {
        if (!IsResetConfirmed || !AnyResetAreaSelected) return;
        isResetting = true;
        try
        {
            var request = new FactoryResetRequestDto
            {
                Operational = resetOperational,
                StadiumStructure = resetStadium,
                Users = resetUsers,
                Catalog = resetCatalog,
                Directories = resetDirectories,
                ResetToFirstRun = resetFirstRun
            };

            var resp = await Api.PostAsJsonAsync("api/admin/maintenance/factory-reset", request);
            if (resp.IsSuccessStatusCode)
            {
                var summary = await resp.Content.ReadFromJsonAsync<FactoryResetResultDto>();
                showResetModal = false;

                if (resetUsers)
                {
                    // Clearing accounts also invalidated our own refresh token — re-authenticate cleanly.
                    Navigation.NavigateTo("/login", forceLoad: true);
                    return;
                }

                ShowAlert(L["Settings_ResetSuccess", summary?.TotalRowsDeleted ?? 0], true);
                resetOperational = resetStadium = resetUsers = resetCatalog = resetDirectories = resetFirstRun = false;
                // Row counts shown in the backup panel are now stale.
                await LoadBackupTablesAsync();
            }
            else
            {
                ShowAlert(L["Settings_ResetFailed"], false);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to run factory reset");
            ShowAlert(L["Settings_ResetFailed"], false);
        }
        finally
        {
            isResetting = false;
        }
    }

    private void ShowAlert(string message, bool success)
    {
        alertMessage = message;
        alertClass = success ? "alert-success" : "alert-danger";
    }

    private async Task GenerateImageAsync()
    {
        if (string.IsNullOrWhiteSpace(imageGenPrompt)) return;
        isGenerating = true;
        imageGenError = null;
        imageResult = null;
        imageIsPlaceholder = false;
        try
        {
            var result = await ImageGen.GenerateAsync(imageGenPrompt.Trim(), imageGenWidth, imageGenHeight);
            if (result is null)
            {
                imageGenError = L["Settings_ImageGenFailed"];
                return;
            }

            imageResult = result;
            // The API never throws on generation failure - it returns a 1x1 placeholder PNG. Detect
            // it so we can warn the admin instead of showing a blank speck.
            imageIsPlaceholder = ImageGen.IsPlaceholder(result);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Image generation failed for prompt '{Prompt}'", imageGenPrompt);
            imageGenError = L["Settings_ImageGenFailed"];
        }
        finally
        {
            isGenerating = false;
        }
    }

    private async Task DownloadImageAsync()
    {
        if (imageResult is null || imageIsPlaceholder) return;
        try
        {
            var bytes = ImageGen.GetPngBytes(imageResult);
            var fileName = string.IsNullOrWhiteSpace(imageResult.FileName) ? "generated-image.png" : imageResult.FileName;
            using var ms = new MemoryStream(bytes);
            using var streamRef = new DotNetStreamReference(ms);
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to download generated image");
            imageGenError = L["Settings_ImageGenFailed"];
        }
    }
}
