@page "/fetchdata"
@using Microsoft.Extensions.Localization
@using StadiumDrinkOrdering.Admin
@using StadiumDrinkOrdering.Admin.Data
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["FetchData_PageTitle"]</PageTitle>

<h1>@L["FetchData_Title"]</h1>

<p>@L["FetchData_Description"]</p>

@if (forecasts == null)
{
    <p><em>@L["Loading"]</em></p>
}
else
{
    <table class="table" id="admin-fetchdata-table">
        <thead id="admin-fetchdata-thead">
            <tr id="admin-fetchdata-header-row">
                <th id="admin-fetchdata-header-date">@L["FetchData_Date"]</th>
                <th id="admin-fetchdata-header-tempc">@L["FetchData_TempC"]</th>
                <th id="admin-fetchdata-header-tempf">@L["FetchData_TempF"]</th>
                <th id="admin-fetchdata-header-summary">@L["FetchData_Summary"]</th>
            </tr>
        </thead>
        <tbody id="admin-fetchdata-tbody">
            @foreach (var forecast in forecasts)
            {
                <tr id="@($"admin-fetchdata-row-{Array.IndexOf(forecasts, forecast)}")">
                    <td>@forecast.Date.ToShortDateString()</td>
                    <td>@forecast.TemperatureC</td>
                    <td>@forecast.TemperatureF</td>
                    <td>@forecast.Summary</td>
                </tr>
            }
        </tbody>
    </table>
}

