@page "/logs"
@layout MobileShell
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Customer.Components
@inject IApiService ApiService
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["Logs_PageTitle"]</PageTitle>

<ScreenHeader Title="@Localizer["Logs_Title"]" Subtitle="@Localizer["Logs_Subtitle"]" ShowBack="false" />

<AuthenticationGuard>
    <div id="customer-logs-container" class="act-body no-scrollbar">

        <div id="customer-logs-info-alert" class="act-note">
            ℹ️ @Localizer["Logs_InfoAlert"]
        </div>

        <div id="customer-logs-cards" class="act-cards">
            <div id="customer-logs-order-card" class="act-card">
                <div class="act-card-icon">🍺</div>
                <div class="act-card-body">
                    <span class="act-card-title">@Localizer["Logs_OrdersTitle"]</span>
                    <span class="act-card-desc">@Localizer["Logs_OrdersDesc"]</span>
                </div>
                <button id="customer-log-order-activity-btn" class="btn btn-ghost btn-sm" @onclick="@(() => LogSampleActivity("PlaceOrder", "UserAction", "Viewed order activity information"))">@Localizer["Logs_LogExample"]</button>
            </div>

            <div id="customer-logs-qr-card" class="act-card">
                <div class="act-card-icon">🎫</div>
                <div class="act-card-body">
                    <span class="act-card-title">@Localizer["Logs_QRTitle"]</span>
                    <span class="act-card-desc">@Localizer["Logs_QRDesc"]</span>
                </div>
                <button id="customer-log-qr-activity-btn" class="btn btn-ghost btn-sm" @onclick="@(() => LogSampleActivity("ScanQRCode", "UserAction", "Viewed QR code activity information"))">@Localizer["Logs_LogExample"]</button>
            </div>

            <div id="customer-logs-auth-card" class="act-card">
                <div class="act-card-icon">🔐</div>
                <div class="act-card-body">
                    <span class="act-card-title">@Localizer["Logs_AuthTitle"]</span>
                    <span class="act-card-desc">@Localizer["Logs_AuthDesc"]</span>
                </div>
                <button id="customer-log-auth-activity-btn" class="btn btn-ghost btn-sm" @onclick="@(() => LogSampleActivity("Login", "Authentication", "Viewed authentication activity information"))">@Localizer["Logs_LogExample"]</button>
            </div>
        </div>

        <div id="customer-logs-info-section-card" class="act-info">
            <span class="act-info-title">@Localizer["Logs_WhyTitle"]</span>
            <ul class="act-list">
                <li><strong>@Localizer["Logs_History"]</strong> — @Localizer["Logs_HistoryDesc"]</li>
                <li><strong>@Localizer["Logs_Support"]</strong> — @Localizer["Logs_SupportDesc"]</li>
                <li><strong>@Localizer["Logs_Security"]</strong> — @Localizer["Logs_SecurityDesc"]</li>
                <li><strong>@Localizer["Logs_Improvements"]</strong> — @Localizer["Logs_ImprovementsDesc"]</li>
            </ul>

            <div id="customer-logs-privacy-alert" class="act-privacy">
                🛡️ <strong>@Localizer["Logs_PrivacyLabel"]</strong> @Localizer["Logs_PrivacyDesc"]
            </div>

            <span class="act-info-title">@Localizer["Logs_RecentTitle"]</span>
            <ul class="act-checks">
                <li>@Localizer["Logs_RecentActivity1"]</li>
                <li>@Localizer["Logs_RecentActivity2"]</li>
                <li>@Localizer["Logs_RecentActivity3"]</li>
                <li>@Localizer["Logs_RecentActivity4"]</li>
                <li>@Localizer["Logs_RecentActivity5"]</li>
                <li>@Localizer["Logs_RecentActivity6"]</li>
            </ul>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div id="customer-logs-status-alert" class="act-toast @(isSuccessMessage ? "ok" : "bad")">
            <span>@statusMessage</span>
            <button id="customer-log-alert-close-btn" class="act-toast-x" @onclick="() => statusMessage = null" aria-label="@Localizer["Logs_Close"]">✕</button>
        </div>
    }
</AuthenticationGuard>

@code {
    private string? statusMessage;
    private bool isSuccessMessage = false;

    protected override async Task OnInitializedAsync()
    {
        await ApiService.LogUserActionAsync("ViewActivityPage", "UserAction", "Customer viewed their activity page");
    }

    private async Task LogSampleActivity(string action, string category, string details)
    {
        try
        {
            var success = await ApiService.LogUserActionAsync(action, category, details);
            if (success)
            {
                statusMessage = string.Format(Localizer["Logs_ActivityLogged"], action);
                isSuccessMessage = true;
            }
            else
            {
                statusMessage = Localizer["Logs_ActivityFailed"];
                isSuccessMessage = false;
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"{Localizer["Logs_LoggingError"]} {ex.Message}";
            isSuccessMessage = false;
        }

        StateHasChanged();
        await Task.Delay(5000);
        statusMessage = null;
        StateHasChanged();
    }
}
