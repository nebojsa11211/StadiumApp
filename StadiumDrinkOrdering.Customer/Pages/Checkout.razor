@page "/checkout"
@layout MobileShell
@using CustomerServices = StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Shared.DTOs
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Localization
@inject CustomerServices.IApiService ApiService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["Checkout_PageTitle"]</PageTitle>

<ScreenHeader Title="@Localizer["Checkout_ScreenHeaderTitle"]" Subtitle="@Localizer["Checkout_ScreenHeaderSubtitle"]" OnBack="GoBack" />

@if (cart == null || !cart.Items.Any())
{
    <div id="customer-checkout-empty" class="co-empty">
        <div id="customer-checkout-emoji" class="co-emoji">🛒</div>
        <h2>@Localizer["Checkout_CartEmptyTitle"]</h2>
        <p>@Localizer["Checkout_CartEmptyMessage"]</p>
        <button id="customer-checkout-empty-browse-btn" class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/events"))">@Localizer["Checkout_BrowseEventsButton"]</button>
    </div>
}
else
{
    <EditForm Model="@checkoutForm" OnValidSubmit="@ProcessCheckout">
        <DataAnnotationsValidator />

        <div id="customer-checkout-body" class="co-body no-scrollbar">
            <!-- Order summary -->
            <div id="customer-checkout-card" class="co-card">
                <div id="customer-checkout-card-head" class="co-card-head">
                    <span class="label">@Localizer["Checkout_SummaryLabel"]</span>
                    <span class="co-event">@(cart.Items.FirstOrDefault()?.EventName ?? Localizer["Checkout_DefaultEventName"])</span>
                </div>

                <div id="customer-checkout-seats" class="co-seats">
                    @foreach (var item in cart.Items)
                    {
                        var _itemIndex = System.Array.IndexOf(cart.Items.ToArray(), item);
                        <div id="customer-checkout-seat-@_itemIndex" class="co-seat">
                            <div id="customer-checkout-seat-left-@_itemIndex" class="co-seat-l">
                                <span class="co-seat-code">@SeatLabel(item)</span>
                                <span class="co-seat-sec">@(string.IsNullOrWhiteSpace(item.SectionName) ? (Localizer["Checkout_SectorPrefix"].Value + item.SectorId) : item.SectionName)</span>
                            </div>
                            <span class="co-seat-price tnum">€@item.Price.ToString("F2")</span>
                        </div>
                    }
                </div>

                <div id="customer-checkout-lines" class="co-lines">
                    <div id="customer-checkout-line-subtotal" class="co-line"><span>@Localizer["Checkout_SubtotalLine", cart.Items.Count]</span><span class="tnum">€@subtotal.ToString("F2")</span></div>
                    <div id="customer-checkout-line-service" class="co-line"><span>@Localizer["Checkout_ServiceFeeLine"]</span><span class="tnum">€@serviceFee.ToString("F2")</span></div>
                    <div id="customer-checkout-line-processing" class="co-line"><span>@Localizer["Checkout_ProcessingFeeLine"]</span><span class="tnum">€@processingFee.ToString("F2")</span></div>
                    <div id="customer-checkout-line-total" class="co-line co-line-total"><span>@Localizer["Checkout_TotalLine"]</span><span class="tnum">€@total.ToString("F2")</span></div>
                </div>
            </div>

            <!-- Customer info -->
            <div id="customer-checkout-customer-info" class="co-section">
                <span class="label">@Localizer["Checkout_CustomerInfoSection"]</span>
                <div id="customer-checkout-grid-name" class="co-grid2">
                    <div id="customer-checkout-field-firstname" class="field">
                        <label>@Localizer["Checkout_FirstNameLabel"]</label>
                        <InputText class="co-input" @bind-Value="checkoutForm.FirstName" placeholder="@Localizer["Checkout_FirstNamePlaceholder"]" />
                        <ValidationMessage For="@(() => checkoutForm.FirstName)" class="co-err" />
                    </div>
                    <div id="customer-checkout-field-lastname" class="field">
                        <label>@Localizer["Checkout_LastNameLabel"]</label>
                        <InputText class="co-input" @bind-Value="checkoutForm.LastName" placeholder="@Localizer["Checkout_LastNamePlaceholder"]" />
                        <ValidationMessage For="@(() => checkoutForm.LastName)" class="co-err" />
                    </div>
                </div>
                <div id="customer-checkout-field-email" class="field">
                    <label>@Localizer["Checkout_EmailLabel"]</label>
                    <InputText type="email" class="co-input" @bind-Value="checkoutForm.Email" placeholder="@Localizer["Checkout_EmailPlaceholder"]" />
                    <ValidationMessage For="@(() => checkoutForm.Email)" class="co-err" />
                </div>
                <div id="customer-checkout-field-phone" class="field">
                    <label>@Localizer["Checkout_PhoneLabel"]</label>
                    <InputText class="co-input" @bind-Value="checkoutForm.Phone" placeholder="@Localizer["Checkout_PhonePlaceholder"]" />
                    <ValidationMessage For="@(() => checkoutForm.Phone)" class="co-err" />
                </div>

                <label id="customer-checkout-foreigner-label" class="co-terms">
                    <InputCheckbox id="customer-checkout-foreigner-input" @bind-Value="checkoutForm.IsForeigner" />
                    <span>@Localizer["Checkout_ForeignerLabel"]</span>
                </label>

                @if (!checkoutForm.IsForeigner)
                {
                    <div id="customer-checkout-field-oib" class="field">
                        <label>@Localizer["Checkout_OIBLabel"]</label>
                        <InputText class="co-input" @bind-Value="checkoutForm.Oib" placeholder="12345678901" maxlength="11" inputmode="numeric" />
                        <ValidationMessage For="@(() => checkoutForm.Oib)" class="co-err" />
                    </div>
                }
                else
                {
                    <div id="customer-checkout-field-document" class="field">
                        <label>@Localizer["Checkout_DocumentLabel"]</label>
                        <InputText class="co-input" @bind-Value="checkoutForm.DocumentNumber" placeholder="HR1234567" maxlength="50" />
                        <ValidationMessage For="@(() => checkoutForm.DocumentNumber)" class="co-err" />
                    </div>
                }

                @if (!string.IsNullOrEmpty(identityError))
                {
                    <div id="customer-checkout-identity-error" class="co-err">@identityError</div>
                }
            </div>

            <!-- Payment -->
            <div id="customer-checkout-payment-section" class="co-section">
                <div id="customer-checkout-payment-head" class="co-section-head">
                    <span class="label">@Localizer["Checkout_PaymentSection"]</span>
                    <button id="customer-checkout-sample-data-btn" type="button" class="btn btn-ghost btn-sm" @onclick="FillSamplePaymentData">@Localizer["Checkout_SampleDataButton"]</button>
                </div>
                <div id="customer-checkout-field-cardnumber" class="field">
                    <label>@Localizer["Checkout_CardNumberLabel"]</label>
                    <InputText class="co-input" @bind-Value="checkoutForm.CardNumber" placeholder="1234 5678 9012 3456" maxlength="19" />
                    <ValidationMessage For="@(() => checkoutForm.CardNumber)" class="co-err" />
                </div>
                <div id="customer-checkout-grid-carddetails" class="co-grid2">
                    <div id="customer-checkout-field-expiry" class="field">
                        <label>@Localizer["Checkout_ExpiryLabel"]</label>
                        <InputText class="co-input" @bind-Value="checkoutForm.ExpiryDate" placeholder="@Localizer["Checkout_ExpiryPlaceholder"]" maxlength="5" />
                        <ValidationMessage For="@(() => checkoutForm.ExpiryDate)" class="co-err" />
                    </div>
                    <div id="customer-checkout-field-cvv" class="field">
                        <label>@Localizer["Checkout_CVVLabel"]</label>
                        <InputText class="co-input" @bind-Value="checkoutForm.CVV" placeholder="123" maxlength="4" />
                        <ValidationMessage For="@(() => checkoutForm.CVV)" class="co-err" />
                    </div>
                </div>
                <div id="customer-checkout-field-cardholder" class="field">
                    <label>@Localizer["Checkout_CardholderLabel"]</label>
                    <InputText class="co-input" @bind-Value="checkoutForm.CardholderName" placeholder="@Localizer["Checkout_CardholderPlaceholder"]" />
                    <ValidationMessage For="@(() => checkoutForm.CardholderName)" class="co-err" />
                </div>
            </div>

            <!-- Terms -->
            <label id="customer-checkout-terms-label" class="co-terms">
                <InputCheckbox id="customer-checkout-terms-input" @bind-Value="checkoutForm.AgreeToTerms" />
                <span>@Localizer["Checkout_TermsAccept"] <a href="/terms" target="_blank">@Localizer["Checkout_TermsLinkText"]</a> @Localizer["Checkout_TermsAnd"] <a href="/privacy" target="_blank">@Localizer["Checkout_PrivacyLinkText"]</a>@Localizer["Checkout_TermsDot"]</span>
            </label>
            <ValidationMessage For="@(() => checkoutForm.AgreeToTerms)" class="co-err" />
        </div>

        <div id="customer-checkout-paybar" class="co-paybar">
            <button id="customer-checkout-submit-btn" type="submit" class="btn btn-primary" disabled="@isProcessing">
                @if (isProcessing)
                {
                    <span class="spinner"></span> <span>@Localizer["Checkout_ProcessingText"]</span>
                }
                else
                {
                    <span>@Localizer["Checkout_PayButton", total.ToString("F2")]</span>
                }
            </button>
        </div>
    </EditForm>
}

@if (showProcessingModal)
{
    <div id="customer-checkout-overlay" class="co-overlay">
        <div id="customer-checkout-overlay-box" class="co-overlay-box">
            <span class="spinner co-big-spin"></span>
            <h3>@Localizer["Checkout_ProcessingPaymentTitle"]</h3>
            <p>@Localizer["Checkout_WaitMessage"]</p>
        </div>
    </div>
}

@code {
    private CheckoutFormDto checkoutForm = new();
    private CustomerServices.ShoppingCartDto? cart;
    private bool isProcessing = false;
    private bool showProcessingModal = false;
    private string? identityError;

    private decimal subtotal => cart?.Items?.Sum(i => i.Price) ?? 0;
    private decimal serviceFee => subtotal * 0.10m; // 10% service fee
    private decimal processingFee => 2.50m;         // Fixed processing fee
    private decimal total => subtotal + serviceFee + processingFee;

    protected override async Task OnInitializedAsync()
    {
        await LoadCart();
        await LoadSavedFormData();
    }

    private async Task LoadCart()
    {
        try
        {
            var sessionId = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "ticketingSessionId");
            if (string.IsNullOrEmpty(sessionId))
            {
                sessionId = Guid.NewGuid().ToString();
                await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "ticketingSessionId", sessionId);
            }

            cart = await ApiService.GetCartAsync(sessionId);
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading cart: " + ex.Message);
        }
    }

    private async Task LoadSavedFormData()
    {
        try
        {
            var savedEmail = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "checkout_email");
            var savedFirstName = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "checkout_firstName");
            var savedLastName = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "checkout_lastName");
            var savedPhone = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "checkout_phone");

            if (!string.IsNullOrEmpty(savedEmail)) checkoutForm.Email = savedEmail;
            if (!string.IsNullOrEmpty(savedFirstName)) checkoutForm.FirstName = savedFirstName;
            if (!string.IsNullOrEmpty(savedLastName)) checkoutForm.LastName = savedLastName;
            if (!string.IsNullOrEmpty(savedPhone)) checkoutForm.Phone = savedPhone;
        }
        catch { /* Ignore localStorage errors */ }
    }

    private async Task ProcessCheckout()
    {
        if (cart == null || !cart.Items.Any())
        {
            await JSRuntime.InvokeVoidAsync("alert", Localizer["Checkout_EmptyCartAlert"].Value);
            return;
        }

        // Identity is mandatory: a domestic buyer must give an 11-digit OIB, a foreigner a document
        // number. The [RegularExpression] on Oib treats empty as valid, so the "required" rule is
        // enforced here (client) as well as in the API.
        identityError = TicketIdentity.Validate(checkoutForm.IsForeigner, checkoutForm.Oib, checkoutForm.DocumentNumber)
            .FirstOrDefault()?.ErrorMessage;
        if (identityError != null)
        {
            StateHasChanged();
            return;
        }

        try
        {
            isProcessing = true;
            showProcessingModal = true;
            StateHasChanged();

            await SaveFormData();

            var orderRequest = new CreateTicketOrderRequest
            {
                CustomerInfo = new CustomerInfoDto
                {
                    FirstName = checkoutForm.FirstName,
                    LastName = checkoutForm.LastName,
                    Email = checkoutForm.Email,
                    Phone = checkoutForm.Phone,
                    IsForeigner = checkoutForm.IsForeigner,
                    Oib = checkoutForm.IsForeigner ? null : checkoutForm.Oib?.Trim(),
                    DocumentNumber = checkoutForm.IsForeigner ? checkoutForm.DocumentNumber?.Trim() : null
                },
                PaymentInfo = new PaymentInfoDto
                {
                    CardNumber = checkoutForm.CardNumber,
                    ExpiryDate = checkoutForm.ExpiryDate,
                    CVV = checkoutForm.CVV,
                    CardholderName = checkoutForm.CardholderName
                },
                SessionId = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "ticketingSessionId"),
                Items = cart.Items.Select(i => new TicketOrderItemDto
                {
                    EventId = i.EventId,
                    SectorId = i.SectorId,
                    RowNumber = i.RowNumber,
                    SeatNumber = i.SeatNumber,
                    Price = i.Price,
                    SeatCode = i.SeatCode,
                    SectionName = string.IsNullOrWhiteSpace(i.SectionName) ? ("Sektor " + i.SectorId) : i.SectionName
                }).ToList(),
                TotalAmount = total
            };

            var orderResult = await ApiService.ProcessTicketOrderAsync(orderRequest);

            if (orderResult != null && orderResult.Success)
            {
                await JSRuntime.InvokeVoidAsync("sessionStorage.removeItem", "ticketingSessionId");
                Navigation.NavigateTo("/order-confirmation/" + orderResult.OrderId);
            }
            else
            {
                var errorMsg = orderResult?.ErrorMessage ?? Localizer["Checkout_UnknownError"].Value;
                await JSRuntime.InvokeVoidAsync("alert", Localizer["Checkout_PaymentFailedAlert", errorMsg].Value);
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", Localizer["Checkout_ErrorAlert", ex.Message].Value);
        }
        finally
        {
            isProcessing = false;
            showProcessingModal = false;
            StateHasChanged();
        }
    }

    private async Task SaveFormData()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "checkout_email", checkoutForm.Email);
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "checkout_firstName", checkoutForm.FirstName);
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "checkout_lastName", checkoutForm.LastName);
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "checkout_phone", checkoutForm.Phone);
        }
        catch { /* Ignore localStorage errors */ }
    }

    private void FillSamplePaymentData()
    {
        checkoutForm.CardNumber = "4111 1111 1111 1111"; // Visa test card
        checkoutForm.ExpiryDate = "12/25";
        checkoutForm.CVV = "123";
        checkoutForm.CardholderName = !string.IsNullOrEmpty(checkoutForm.FirstName) && !string.IsNullOrEmpty(checkoutForm.LastName)
            ? (checkoutForm.FirstName + " " + checkoutForm.LastName)
            : "Ivan Horvat";

        if (string.IsNullOrEmpty(checkoutForm.FirstName)) checkoutForm.FirstName = "Ivan";
        if (string.IsNullOrEmpty(checkoutForm.LastName)) checkoutForm.LastName = "Horvat";
        if (string.IsNullOrEmpty(checkoutForm.Email)) checkoutForm.Email = "ivan.horvat@email.hr";
        if (string.IsNullOrEmpty(checkoutForm.Phone)) checkoutForm.Phone = "+385 91 234 5678";

        checkoutForm.AgreeToTerms = true;
        StateHasChanged();
    }

    private async Task GoBack() => await JSRuntime.InvokeVoidAsync("history.back");

    private static string SeatLabel(CustomerServices.CartItemDto item) =>
        string.IsNullOrWhiteSpace(item.SeatCode) ? ("R" + item.RowNumber + " · " + item.SeatNumber) : item.SeatCode;
}
