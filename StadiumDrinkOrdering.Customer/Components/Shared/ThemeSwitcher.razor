@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResources> Localizer

<div id="customer-theme-switcher" class="theme-switcher" title="@GetThemeTooltip()">
    <button type="button"
            id="customer-theme-switcher-btn"
            class="theme-switcher-btn"
            @onclick="ToggleTheme"
            aria-label="@GetAriaLabel()">
        @if (isDarkMode)
        {
            <!-- Sun Icon for Light Mode -->
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" class="theme-icon">
                <path d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6zm0 1a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0zm0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13zm8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5zM3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8zm10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0zm-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0zm9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707zM4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708z"/>
            </svg>
        }
        else
        {
            <!-- Moon Icon for Dark Mode -->
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16" class="theme-icon">
                <path d="M6 .278a.768.768 0 0 1 .08.858 7.208 7.208 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277.527 0 1.04-.055 1.533-.16a.787.787 0 0 1 .81.316.733.733 0 0 1-.031.893A8.349 8.349 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.752.752 0 0 1 6 .278zM4.858 1.311A7.269 7.269 0 0 0 1.025 7.71c0 4.02 3.279 7.276 7.319 7.276a7.316 7.316 0 0 0 5.205-2.162c-.337.042-.68.063-1.029.063-4.61 0-8.343-3.714-8.343-8.29 0-1.167.242-2.278.681-3.286z"/>
            </svg>
        }
    </button>
</div>

@code {
    private bool isDarkMode = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Get initial theme state
                isDarkMode = await JSRuntime.InvokeAsync<bool>("eval", "window.ThemeManager.isDarkMode()");
                StateHasChanged();

                // Listen for theme changes from other sources
                await JSRuntime.InvokeVoidAsync("eval", @"
                    window.addEventListener('themechange', function(e) {
                        DotNet.invokeMethodAsync('StadiumDrinkOrdering.Customer', 'OnThemeChanged', e.detail.theme);
                    });
                ");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Theme initialization error: {ex.Message}");
            }
        }
    }

    private async Task ToggleTheme()
    {
        try
        {
            // Toggle theme via JavaScript
            var newTheme = await JSRuntime.InvokeAsync<string>("eval", "window.ThemeManager.toggle()");
            isDarkMode = newTheme == "dark";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Theme toggle error: {ex.Message}");
        }
    }

    private string GetThemeTooltip()
    {
        return isDarkMode ? Localizer["ThemeSwitcher_ToLightMode"] : Localizer["ThemeSwitcher_ToDarkMode"];
    }

    private string GetAriaLabel()
    {
        return isDarkMode ? Localizer["ThemeSwitcher_ToLightMode"] : Localizer["ThemeSwitcher_ToDarkMode"];
    }

    [JSInvokable]
    public static void OnThemeChanged(string theme)
    {
        // This method can be called from JavaScript when theme changes externally
        Console.WriteLine($"Theme changed to: {theme}");
    }
}

<style>
    .theme-switcher {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-left: 0.5rem;
    }

    .theme-switcher-btn {
        background: transparent;
        border: 2px solid rgba(0, 0, 0, 0.1);
        border-radius: 50%;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        padding: 0;
        color: #333;
    }

    .theme-switcher-btn:hover {
        background: rgba(0, 0, 0, 0.05);
        border-color: rgba(0, 0, 0, 0.2);
        transform: scale(1.1);
    }

    .theme-switcher-btn:active {
        transform: scale(0.95);
    }

    .theme-icon {
        transition: transform 0.3s ease;
    }

    .theme-switcher-btn:hover .theme-icon {
        transform: rotate(20deg);
    }

    /* Dark mode styles */
    [data-theme="dark"] .theme-switcher-btn {
        border-color: rgba(255, 255, 255, 0.2);
        color: #f1f5f9;
    }

    [data-theme="dark"] .theme-switcher-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.3);
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .theme-switcher {
            margin-left: 0.25rem;
        }

        .theme-switcher-btn {
            width: 36px;
            height: 36px;
        }
    }

    /* Focus styles for accessibility */
    .theme-switcher-btn:focus-visible {
        outline: 2px solid #10b981;
        outline-offset: 2px;
    }

    [data-theme="dark"] .theme-switcher-btn:focus-visible {
        outline-color: #10b981;
    }

    /* Animation for theme transition */
    @@keyframes rotate-in {
        from {
            transform: rotate(-180deg) scale(0.8);
            opacity: 0;
        }
        to {
            transform: rotate(0deg) scale(1);
            opacity: 1;
        }
    }

    .theme-icon {
        animation: rotate-in 0.3s ease;
    }

    /* Reduced motion support */
    @@media (prefers-reduced-motion: reduce) {
        .theme-switcher-btn,
        .theme-icon {
            transition: none;
            animation: none;
        }

        .theme-switcher-btn:hover {
            transform: none;
        }

        .theme-switcher-btn:hover .theme-icon {
            transform: none;
        }
    }
</style>
