@using StadiumDrinkOrdering.Shared.DTOs
@* Bottom sheet for a drink: quantity + special instructions, then add. Visible whenever Drink != null. *@

<div id="customer-drink-sheet-scrim" class="scrim @(Drink != null ? "show" : "")" @onclick="OnClose"></div>
<div id="customer-drink-sheet-container" class="sheet @(Drink != null ? "show" : "")">
    @if (Drink != null)
    {
        <div id="customer-drink-sheet-grab" class="grab"></div>
        <div id="customer-drink-sheet-thumb" class="big-thumb @DrinkVisuals.Thumb(Drink.CategoryName)">@DrinkVisuals.Emoji(Drink.CategoryIcon)</div>
        <h3>@Drink.Name</h3>
        <div id="customer-drink-sheet-description" class="desc">@(string.IsNullOrWhiteSpace(Drink.Description) ? "Poslužuje se hladno i donosi na tvoje mjesto." : Drink.Description)</div>

        <div id="customer-drink-sheet-stepper" class="stepper">
            <span class="lab">Količina</span>
            <div id="customer-drink-sheet-control" class="ctrl">
                <button id="customer-drink-sheet-dec-btn" @onclick="Dec" aria-label="Manje">−</button>
                <span class="q tnum">@_qty</span>
                <button id="customer-drink-sheet-inc-btn" @onclick="Inc" aria-label="Više">+</button>
            </div>
        </div>

        <textarea id="customer-drink-sheet-note-input" class="note-in" rows="2" @bind="_note" placeholder="Posebne napomene (npr. bez leda, dodatna čaša)"></textarea>

        <button id="customer-drink-sheet-submit-btn" class="btn btn-primary" @onclick="Submit">Dodaj u košaricu · €@((Drink.Price * _qty).ToString("F2"))</button>
    }
</div>

@code {
    [Parameter] public DrinkDto? Drink { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<DrinkOrderRequest> OnAdd { get; set; }

    private int _qty = 1;
    private string? _note;
    private int? _lastId;

    protected override void OnParametersSet()
    {
        // Reset when a different drink opens; forget when closed.
        if (Drink != null && Drink.Id != _lastId)
        {
            _qty = 1;
            _note = null;
            _lastId = Drink.Id;
        }
        else if (Drink == null)
        {
            _lastId = null;
        }
    }

    private void Inc() => _qty = Math.Min(20, _qty + 1);
    private void Dec() => _qty = Math.Max(1, _qty - 1);

    private async Task Submit()
    {
        if (Drink != null)
            await OnAdd.InvokeAsync(new DrinkOrderRequest(Drink.Id, _qty, _note));
    }
}
