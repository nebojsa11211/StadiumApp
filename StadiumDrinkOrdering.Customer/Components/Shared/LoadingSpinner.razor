@if (IsLoading)
{
    <div class="loading-overlay @(Fullscreen ? "loading-fullscreen" : "")" id="@ComponentId">
        <div class="loading-spinner-wrapper">
            <div class="stadium-loader">
                <div class="stadium-loader-inner">
                    <div class="stadium-ball">⚽</div>
                </div>
                <div class="stadium-loader-track"></div>
            </div>
            @if (!string.IsNullOrEmpty(Message))
            {
                <p class="loading-message">@Message</p>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsLoading { get; set; } = false;

    [Parameter]
    public string Message { get; set; } = "Loading...";

    [Parameter]
    public bool Fullscreen { get; set; } = false;

    [Parameter]
    public string ComponentId { get; set; } = $"loading-spinner-{Guid.NewGuid():N}";
}
