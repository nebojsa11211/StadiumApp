@using StadiumDrinkOrdering.Shared.Authentication.Interfaces
@using StadiumDrinkOrdering.Shared.Authentication.Models
@inject IAuthenticationStateService AuthState
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResources> Localizer
@implements IDisposable

@if (isChecking || !AuthState.IsAuthenticated)
{
    @* Unauthenticated users are redirected to /login (see RedirectToLogin); this spinner is
       what they see for the instant between the auth check failing and the navigation. *@
    <div id="bar-authroute-checking-container" class="d-flex justify-content-center align-items-center" style="height: 100vh;">
        <div id="bar-authroute-checking-center" class="text-center">
            <div id="bar-authroute-spinner" class="spinner-border text-primary mb-3" role="status">
                <span class="visually-hidden">@Localizer["AuthRoute_CheckingAuthentication"]</span>
            </div>
            <p class="text-muted">@Localizer["AuthRoute_VerifyingAuthentication"]</p>
        </div>
    </div>
}
else if (!AuthState.HasAnyRole(AllowedRoles))
{
    <div id="bar-authroute-restricted-container" class="d-flex justify-content-center align-items-center" style="height: 100vh;">
        <div id="bar-authroute-restricted-center" class="text-center">
            <div id="bar-authroute-restricted-card" class="card border-warning">
                <div id="bar-authroute-restricted-body" class="card-body">
                    <h5 class="card-title">⛔ @Localizer["AuthRoute_AccessRestricted"]</h5>
                    <p class="card-text">
                        @string.Format(Localizer["AuthRoute_BarStationForBartenders"].Value, AuthState.UserRole ?? Localizer["AuthRoute_Unknown"].Value)
                    </p>
                    <button class="btn btn-outline-secondary" @onclick="Logout" id="bar-authroute-logout-btn">
                        @Localizer["AuthRoute_SignInAsDifferentUser"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    @ChildContent
}

@code {
    [Parameter] public RenderFragment ChildContent { get; set; } = default!;

    // The Bar (prep station) is a Bartender workstation; Admins may also supervise it.
    // Waiters use the separate Runner app; Customers have no access.
    private static readonly string[] AllowedRoles = { "Bartender", "Admin" };

    private bool isChecking = true;
    private bool hasRedirected;

    protected override async Task OnInitializedAsync()
    {
        // Brief delay so the auth state (restored from storage in App.razor) settles before we decide.
        await Task.Delay(100);
        isChecking = false;
        StateHasChanged();

        AuthState.OnAuthenticationStateChanged += OnAuthChanged;

        RedirectToLoginIfUnauthenticated();
    }

    private void OnAuthChanged(StadiumDrinkOrdering.Shared.Authentication.Models.AuthenticationState _)
        => InvokeAsync(() =>
        {
            StateHasChanged();
            // Covers losing auth mid-session (token expiry, logout in another tab).
            RedirectToLoginIfUnauthenticated();
        });

    private void RedirectToLoginIfUnauthenticated()
    {
        if (isChecking || AuthState.IsAuthenticated || hasRedirected)
            return;

        hasRedirected = true;
        RedirectToLogin();
    }

    private void RedirectToLogin()
    {
        // Pass a relative return path (e.g. /order-queue) so login can send the user back to the
        // page they actually requested instead of the home page.
        var relativePath = "/" + NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var returnUrl = Uri.EscapeDataString(relativePath);
        NavigationManager.NavigateTo($"/login?returnUrl={returnUrl}");
    }

    private async Task Logout()
    {
        await AuthState.LogoutAsync();
        NavigationManager.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        AuthState.OnAuthenticationStateChanged -= OnAuthChanged;
    }
}
