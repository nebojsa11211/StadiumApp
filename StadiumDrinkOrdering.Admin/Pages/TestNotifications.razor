@page "/test-notifications"
@using Microsoft.Extensions.Localization
@using StadiumDrinkOrdering.Admin
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["TestNotif_PageTitle"]</PageTitle>

<h3 id="admin-testnotif-title">🧪 @L["TestNotif_Title"]</h3>

<div class="row" id="admin-testnotif-row">
    <div class="col-md-12" id="admin-testnotif-col">
        <div class="card" id="admin-testnotif-card">
            <div class="card-header" id="admin-testnotif-header">
                <h5 id="admin-testnotif-card-title">@L["TestNotif_CardTitle"]</h5>
            </div>
            <div class="card-body" id="admin-testnotif-body">
                <div class="d-grid gap-2" id="admin-testnotif-buttons">
                    <button class="btn btn-danger" @onclick="TestErrorNotification" id="admin-test-notifications-error-btn">
                        🚨 @L["TestNotif_TestErrorNotif"]
                    </button>

                    <button class="btn btn-warning" @onclick="TestTimeoutNotification" id="admin-test-notifications-timeout-btn">
                        ⏱️ @L["TestNotif_TestTimeoutNotif"]
                    </button>

                    <button class="btn btn-info" @onclick="TestApiErrorNotification" id="admin-test-notifications-api-error-btn">
                        🌐 @L["TestNotif_TestApiError"]
                    </button>

                    <button class="btn btn-secondary" @onclick="TestJavaScriptDirect" id="admin-test-notifications-js-direct-btn">
                        📱 @L["TestNotif_TestJsDirect"]
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

