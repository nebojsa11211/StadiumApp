@page "/wallet"
@layout MobileShell
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Customer.Components
@using Microsoft.Extensions.Localization
@inject IApiService ApiService
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> Localizer
@implements IAsyncDisposable

<PageTitle>@Localizer["Wallet_PageTitle"]</PageTitle>

<ScreenHeader Title="@Localizer["Wallet_ScreenHeader_Title"]" Subtitle="@Localizer["Wallet_ScreenHeader_Subtitle"]" ShowBack="false" />

<AuthenticationGuard>
    <div id="customer-wallet-container" class="wal-body no-scrollbar">

        @if (summary == null)
        {
            <div id="customer-wallet-loading" class="wal-state"><span class="spinner"></span> @Localizer["Wallet_Loading"]</div>
        }
        else if (!summary.Exists && !summary.IsEligible)
        {
            <div id="customer-wallet-not-eligible" class="wal-state wal-empty">
                <div class="wal-emoji">🎟️</div>
                <h2>@Localizer["Wallet_NotEligible_Title"]</h2>
                <p id="customer-wallet-not-eligible-message">@Localizer["Wallet_NotEligible_Message"]</p>
            </div>
        }
        else
        {
            <div id="customer-wallet-balance-card" class="wal-balance">
                <span class="wal-balance-label">@Localizer["Wallet_Balance_Label"]</span>
                <span id="customer-wallet-balance-amount" class="wal-balance-amount tnum">@FormatMoney(summary.Balance)</span>
                @if (summary.Status == WalletStatus.Frozen)
                {
                    <span id="customer-wallet-frozen-badge" class="wal-frozen">@Localizer["Wallet_FrozenBadge"]</span>
                }
            </div>

            <div id="customer-wallet-deposit-card" class="wal-card">
                <span class="label">@Localizer["Wallet_AddFunds"]</span>
                <div class="field">
                    <label for="customer-wallet-deposit-amount">@Localizer["Wallet_AmountLabel", @summary.Currency]</label>
                    <input id="customer-wallet-deposit-amount" type="number" min="0.01" step="0.01" @bind="depositAmount" />
                </div>
                @if (summary.RequiresCardEntry)
                {
                    <div class="field">
                        <label>@Localizer["Wallet_CardDataLabel"]</label>
                        <div id="customer-wallet-card-element" class="wal-card-input"></div>
                        <div id="customer-wallet-card-errors" class="wal-card-errors" role="alert"></div>
                    </div>
                }
                else
                {
                    <div class="field">
                        <label for="customer-wallet-deposit-method">@Localizer["Wallet_MethodLabel"]</label>
                        <select id="customer-wallet-deposit-method" class="wal-select" @bind="depositMethod">
                            <option value="CreditCard">@Localizer["Wallet_CreditCard"]</option>
                            <option value="PayPal">@Localizer["Wallet_PayPal"]</option>
                        </select>
                    </div>
                }
                <button id="customer-wallet-deposit-btn" class="btn btn-primary" @onclick="Deposit" disabled="@(isDepositing || depositAmount <= 0 || summary.Status == WalletStatus.Frozen)">
                    @if (isDepositing)
                    {
                        <span class="spinner"></span> <span>@depositBusyText</span>
                    }
                    else
                    {
                        <span>@Localizer["Wallet_DepositButton"]</span>
                    }
                </button>
            </div>

            <div id="customer-wallet-transactions-card" class="wal-card">
                <span class="label">@Localizer["Wallet_Transactions_Label"]</span>
                @if (transactions == null || transactions.Transactions.Count == 0)
                {
                    <p id="customer-wallet-transactions-empty" class="wal-tx-empty">@Localizer["Wallet_NoTransactions"]</p>
                }
                else
                {
                    <div class="wal-tx-list">
                        @foreach (var t in transactions.Transactions)
                        {
                            <div id="customer-wallet-txn-@t.Id" class="wal-tx">
                                <div class="wal-tx-l">
                                    <span id="customer-wallet-txn-type-@t.Id" class="wal-tx-type">@t.Type</span>
                                    <span id="customer-wallet-txn-date-@t.Id" class="wal-tx-date">@t.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy · HH:mm")</span>
                                </div>
                                <span id="customer-wallet-txn-amount-@t.Id" class="wal-tx-amount tnum @(t.Amount < 0 ? "neg" : "pos")">
                                    @(t.Amount < 0 ? "−" : "+")@FormatMoney(t.Amount)
                                </span>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(alertMessage))
    {
        <div id="customer-wallet-alert-container" class="wal-toast @(alertType == "success" ? "ok" : alertType == "info" ? "info" : "bad")">
            <span>@alertMessage</span>
            <button id="customer-wallet-alert-close" class="wal-toast-x" @onclick="() => alertMessage = string.Empty" aria-label="@Localizer["Wallet_AlertCloseButton"]">✕</button>
        </div>
    }
</AuthenticationGuard>

@code {
    private WalletSummaryDto? summary;
    private WalletTransactionListDto? transactions;
    private decimal depositAmount = 20m;
    private string depositMethod = "CreditCard";
    private bool isDepositing;
    private string depositBusyText = string.Empty;
    private string alertMessage = string.Empty;
    private string alertType = string.Empty;

    // Stripe (async gateway) card-entry state.
    private bool stripeInitStarted;
    private bool stripeReady;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        summary = await ApiService.GetWalletSummaryAsync();
        if (summary is { Exists: true })
            transactions = await ApiService.GetWalletTransactionsAsync(1, 25);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Mount the Stripe Card Element once, the first time the deposit card is on screen in async-gateway
        // mode. Guarded so a failed attempt (or later re-renders) doesn't retry in a loop.
        if (!stripeInitStarted && summary is { RequiresCardEntry: true, PublishableKey: not null })
        {
            stripeInitStarted = true;
            try
            {
                await JS.InvokeAsync<bool>("stripeWallet.init",
                    summary.PublishableKey, "customer-wallet-card-element", "customer-wallet-card-errors");
                stripeReady = true;
            }
            catch (Exception ex)
            {
                ShowAlert(Localizer["Wallet_CardUnavailable"], "danger");
                Console.WriteLine($"Stripe init failed: {ex.Message}");
            }
        }
    }

    private async Task Deposit()
    {
        if (isDepositing || depositAmount <= 0) return;
        isDepositing = true;
        depositBusyText = Localizer["Wallet_Processing"];
        try
        {
            var dto = new InitiateDepositDto
            {
                Amount = depositAmount,
                Method = summary?.RequiresCardEntry == true ? "CreditCard" : depositMethod,
                IdempotencyKey = Guid.NewGuid().ToString("N")
            };
            var result = await ApiService.DepositToWalletAsync(dto);

            if (result is { RequiresAction: true, ClientSecret: not null })
            {
                // Async gateway (Stripe): confirm the card in the browser, then wait for the webhook to credit.
                if (!stripeReady)
                {
                    ShowAlert(Localizer["Wallet_CardNotReady"], "danger");
                    return;
                }

                depositBusyText = Localizer["Wallet_ConfirmingCard"];
                StateHasChanged();
                var confirm = await JS.InvokeAsync<StripeConfirmResult>("stripeWallet.confirm", result.ClientSecret);
                if (confirm is not { Success: true })
                {
                    ShowAlert(confirm?.Error ?? "Plaćanje nije uspjelo.", "danger");
                    return;
                }

                // Card charged. Our wallet is credited by the signed webhook — poll the intent's settlement
                // status (an exact ledger check, not a balance guess) until it lands.
                depositBusyText = Localizer["Wallet_BookingDeposit"];
                StateHasChanged();
                var settled = await WaitForSettlementAsync(result.ProviderIntentId);
                if (settled is { Settled: true })
                {
                    // The status response already carries the credited balance — apply it straight to the
                    // hero and only refresh the ledger, skipping a redundant summary fetch.
                    if (summary != null)
                        summary.Balance = settled.NewBalance;
                    transactions = await ApiService.GetWalletTransactionsAsync(1, 25);
                    ShowAlert(Localizer["Wallet_DepositSuccess"], "success");
                }
                else
                {
                    // Delayed webhook — reload fully; funds will appear shortly.
                    await Load();
                    ShowAlert(Localizer["Wallet_PaymentReceived"], "info");
                }
            }
            else if (result is { Success: true })
            {
                // Synchronous gateway (mock): already credited.
                ShowAlert(Localizer["Wallet_DepositSuccess"], "success");
                await Load();
            }
            else
            {
                ShowAlert(TranslateFailure(result?.FailureReason), "danger");
            }
        }
        catch (Exception ex)
        {
            ShowAlert(ex.Message, "danger");
        }
        finally
        {
            isDepositing = false;
        }
    }

    // Webhook settlement is asynchronous; poll the intent's status for a short window until the wallet is
    // credited. A returned (settled) status is definitive (the ledger has the credit) and carries the new
    // balance; null means it hadn't landed within the window.
    private async Task<DepositStatusDto?> WaitForSettlementAsync(string? intentId)
    {
        if (string.IsNullOrEmpty(intentId))
            return null;
        for (var attempt = 0; attempt < 10; attempt++)
        {
            await Task.Delay(1500);
            var status = await ApiService.GetDepositStatusAsync(intentId);
            if (status is { Settled: true })
                return status;
        }
        return null;
    }

    private string TranslateFailure(string? reason) => reason switch
    {
        "WalletFrozen" => Localizer["Wallet_FrozenError"],
        "GatewayDeclined" => Localizer["Wallet_DeclinedError"],
        "NotEligible" => Localizer["Wallet_NotAvailableError"],
        _ => Localizer["Wallet_DepositFailed"]
    };

    private sealed class StripeConfirmResult
    {
        public bool Success { get; set; }
        public string? Error { get; set; }
        public string? Status { get; set; }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("stripeWallet.destroy"); }
        catch { /* circuit already gone during teardown */ }
    }

    private string FormatMoney(decimal amount)
    {
        var currency = summary?.Currency ?? "EUR";
        var symbol = currency == "EUR" ? "€" : currency + " ";
        return $"{symbol}{Math.Abs(amount).ToString("N2")}";
    }

    private void ShowAlert(string message, string type)
    {
        alertMessage = message;
        alertType = type;
        StateHasChanged();
        _ = Task.Delay(5000).ContinueWith(_ =>
        {
            alertMessage = string.Empty;
            InvokeAsync(StateHasChanged);
        });
    }
}
