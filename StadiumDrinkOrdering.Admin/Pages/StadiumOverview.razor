@page "/admin/stadium-overview"
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Shared.DTOs
@using System.Globalization
@using System.Text.Json
@using StadiumDrinkOrdering.Admin.Components.Stadium

<PageTitle>Stadium Operations Center - Admin</PageTitle>

<div class="stadium-overview-wrapper" role="main" aria-labelledby="stadium-overview-title">
    <header class="stadium-overview-header">
        <div class="header-content">
            <div class="header-icon">
                <i class="bi bi-building" aria-hidden="true"></i>
            </div>
            <div class="header-info">
                <h1 id="stadium-overview-title" class="overview-title">Stadium Operations Center</h1>
                <p class="overview-subtitle">Real-time stadium management dashboard</p>
            </div>
            <div class="header-status">
                <div class="status-indicator @(isLoading ? "loading" : "online")">
                    <div class="status-dot" aria-hidden="true"></div>
                    <span class="status-text">@(isLoading ? "Loading..." : "System Online")</span>
                </div>
            </div>
        </div>
    </header>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            @errorMessage
        </div>
    }

    @* Event Selection *@
    @if (events != null && events.Any())
    {
        <div id="admin-stadium-overview-event-selector" class="card mb-4">
            <div id="admin-stadium-overview-event-card-body" class="card-body">
                <label for="admin-stadium-overview-event-select" class="form-label fw-bold">Select Event:</label>
                <select id="admin-stadium-overview-event-select" class="form-select" @bind="selectedEventId" @bind:after="OnEventChanged">
                    <option value="0">-- No Event Selected --</option>
                    @foreach (var evt in events)
                    {
                        <option value="@evt.Id">@evt.EventName (@evt.EventDate.ToString("dd MMM yyyy"))</option>
                    }
                </select>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div id="admin-stadium-overview-loading" class="stadium-loading">
            <div id="admin-stadium-overview-loading-spinner" class="loading-spinner"></div>
            <p id="admin-stadium-overview-loading-text">Loading stadium layout...</p>
        </div>
    }
    else
    {
        @* Stadium Image with SVG Overlays - ALWAYS RENDER *@
        <div id="admin-stadium-overview-image-container" class="stadium-image-container">
            <img id="admin-stadium-overview-blueprint-img"
                 src="/images/stadium-blueprint.png"
                 alt="Stadium Layout"
                 class="stadium-blueprint-img" />

            @* SVG Sector Overlays - CONDITIONALLY RENDER *@
            @if (sectorOverlays != null && sectorOverlays.Any())
            {
                <svg id="admin-stadium-overview-svg-overlay"
                     class="sector-overlays-svg"
                     width="1170"
                     height="898"
                     viewBox="0 0 1170 898"
                     preserveAspectRatio="xMidYMid meet"
                     xmlns="http://www.w3.org/2000/svg"
                     role="img"
                     aria-label="Stadium sector overlay map">

                    @* Define filter effects for hover/focus *@
                    <defs>
                        <filter id="sector-glow" x="-50%" y="-50%" width="200%" height="200%">
                            <feGaussianBlur in="SourceAlpha" stdDeviation="4"/>
                            <feOffset dx="0" dy="0" result="offsetblur"/>
                            <feComponentTransfer>
                                <feFuncA type="linear" slope="0.8"/>
                            </feComponentTransfer>
                            <feMerge>
                                <feMergeNode/>
                                <feMergeNode in="SourceGraphic"/>
                            </feMerge>
                        </filter>
                    </defs>

                    @* Render each sector as SVG path *@
                    @foreach (var overlay in sectorOverlays)
                    {
                        var occupancyClass = GetSectorOccupancyClass(overlay.SectorCode);
                        var sectorType = overlay.Type?.ToLower() ?? "standard";
                        var svgPath = GenerateSvgPath(overlay);
                        var labelCenter = CalculateLabelCenter(overlay);

                        @if (!string.IsNullOrEmpty(svgPath))
                        {
                            <g id="admin-stadium-overview-sector-group-@overlay.SectorCode"
                               class="sector-group @occupancyClass @sectorType"
                               role="button"
                               tabindex="0"
                               aria-label="@overlay.Name - Click to view sector details"
                               @onclick="() => OpenSectorModal(overlay.SectorCode)"
                               @onkeydown="(e) => HandleSectorKeyDown(e, overlay.SectorCode)">

                                @* Sector shape path *@
                                <path id="admin-stadium-overview-sector-path-@overlay.SectorCode"
                                      class="sector-path @occupancyClass @sectorType"
                                      d="@svgPath"
                                      vector-effect="non-scaling-stroke" />

                                @* Sector label text *@
                                <text id="admin-stadium-overview-sector-label-@overlay.SectorCode"
                                      class="sector-label-text"
                                      x="@labelCenter.X"
                                      y="@labelCenter.Y"
                                      text-anchor="middle"
                                      dominant-baseline="middle"
                                      pointer-events="none">
                                    @overlay.SectorCode
                                </text>
                            </g>
                        }
                    }
                </svg>
            }
            else
            {
                @* No Sectors Message - Positioned on Image *@
                <div id="admin-stadium-overview-no-sectors-overlay" class="no-sectors-overlay">
                    <div class="no-sectors-content">
                        <i class="bi bi-info-circle-fill fs-1 mb-3"></i>
                        <h4>No Sector Overlays Configured</h4>
                        <p class="text-muted">Use the Stadium Drawing Tool to create sector overlays</p>
                        <a href="/admin/stadium-drawing-tool" class="btn btn-primary mt-3">
                            <i class="bi bi-pencil-square"></i> Open Drawing Tool
                        </a>
                    </div>
                </div>
            }
        </div>

        @* Legend - ALWAYS SHOW *@
        <div id="admin-stadium-overview-legend" class="card mt-4">
            <div id="admin-stadium-overview-legend-body" class="card-body">
                <h5 id="admin-stadium-overview-legend-title" class="card-title">Occupancy Legend</h5>
                <div id="admin-stadium-overview-legend-items" class="d-flex gap-4 flex-wrap">
                    <div id="admin-stadium-overview-legend-available" class="d-flex align-items-center gap-2">
                        <div style="width: 24px; height: 24px; background: rgba(34, 197, 94, 0.3); border: 2px solid #22c55e; border-radius: 4px;"></div>
                        <span>Available (0-49%)</span>
                    </div>
                    <div id="admin-stadium-overview-legend-partial" class="d-flex align-items-center gap-2">
                        <div style="width: 24px; height: 24px; background: rgba(245, 158, 11, 0.3); border: 2px solid #f59e0b; border-radius: 4px;"></div>
                        <span>Partial (50-89%)</span>
                    </div>
                    <div id="admin-stadium-overview-legend-full" class="d-flex align-items-center gap-2">
                        <div style="width: 24px; height: 24px; background: rgba(239, 68, 68, 0.3); border: 2px solid #ef4444; border-radius: 4px;"></div>
                        <span>Full (90-100%)</span>
                    </div>
                    <div id="admin-stadium-overview-legend-vip" class="d-flex align-items-center gap-2">
                        <div style="width: 24px; height: 24px; background: rgba(139, 92, 246, 0.3); border: 2px solid #8b5cf6; border-radius: 4px;"></div>
                        <span>VIP Section</span>
                    </div>
                </div>
            </div>
        </div>
    }

    @* Sector Detail Modal *@
    @if (showSectorModal && selectedSectorSeats != null)
    {
        <SectorDetailModal
            SectorCode="@selectedSectorCode"
            SectorName="@selectedSectorName"
            Seats="@selectedSectorSeats"
            OnClose="CloseSectorModal" />
    }
</div>
