@page "/events"
@layout MobileShell
@using StadiumDrinkOrdering.Customer.Services
@using StadiumDrinkOrdering.Shared.DTOs
@using Microsoft.Extensions.Localization
@inject IApiService ApiService
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> Localizer

<PageTitle>@Localizer["Events_PageTitle"]</PageTitle>

<ScreenHeader Title="@Localizer["Events_ScreenHeader_Title"]" Subtitle="@Localizer["Events_ScreenHeader_Subtitle"]" ShowBack="true" BackHref="/" />

<div id="customer-events-page" class="evl-body no-scrollbar">

    @if (!salesEnabled)
    {
        <div id="customer-events-sales-disabled" class="evl-state evl-empty">
            @Localizer["Events_SalesDisabled"]
        </div>
    }

    <!-- Filter bar -->
    <div id="customer-events-filterbar" class="evl-filterbar">
        <button id="customer-events-filter-toggle" class="evl-chip @(showFilters ? "on" : "")" @onclick="() => showFilters = !showFilters">
            @Localizer["Events_FiltersToggle"]@(activeFilterCount > 0 ? $" · {activeFilterCount}" : "")
        </button>
        @if (activeFilterCount > 0)
        {
            <button id="customer-events-clear-filters-btn" class="evl-chip evl-chip-ghost" @onclick="ClearFilters">@Localizer["Events_ClearFilters"]</button>
        }
    </div>

    @if (showFilters)
    {
        <div id="customer-events-filters" class="evl-filters">
            <div class="evl-field">
                <label>@Localizer["Events_EventTypeLabel"]</label>
                <select id="customer-events-filter-type-select" class="evl-input" @bind="filterEventType">
                    <option value="">@Localizer["Events_AllTypes"]</option>
                    <option value="Match">@Localizer["Events_Match"]</option>
                    <option value="Concert">@Localizer["Events_Concert"]</option>
                    <option value="Other">@Localizer["Events_Other"]</option>
                </select>
            </div>
            <div class="evl-grid2">
                <div class="evl-field">
                    <label>@Localizer["Events_FromDateLabel"]</label>
                    <input id="customer-events-filter-datefrom-input" type="date" class="evl-input" @bind="filterDateFrom" />
                </div>
                <div class="evl-field">
                    <label>@Localizer["Events_ToDateLabel"]</label>
                    <input id="customer-events-filter-dateto-input" type="date" class="evl-input" @bind="filterDateTo" />
                </div>
            </div>
            <div class="evl-grid2">
                <div class="evl-field">
                    <label>@Localizer["Events_MinPriceLabel"]</label>
                    <input id="customer-events-filter-minprice-input" type="number" class="evl-input" placeholder="0" @bind="filterMinPrice" step="10" />
                </div>
                <div class="evl-field">
                    <label>@Localizer["Events_MaxPriceLabel"]</label>
                    <input id="customer-events-filter-maxprice-input" type="number" class="evl-input" placeholder="500" @bind="filterMaxPrice" step="10" />
                </div>
            </div>
            <button id="customer-events-apply-filters-btn" class="btn btn-primary" @onclick="ApplyFilters" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner"></span> <span>@Localizer["Events_Searching"]</span>
                }
                else
                {
                    <span>@Localizer["Events_ApplyFilters"]</span>
                }
            </button>
        </div>
    }

    @if (isLoading && events == null)
    {
        <div id="customer-events-loading" class="evl-state"><span class="spinner"></span> @Localizer["Events_Loading"]</div>
    }
    else if (events == null || !events.Any())
    {
        <div id="customer-events-empty" class="evl-state evl-empty">
            <div class="evl-emoji">🎭</div>
            <h2>@Localizer["Events_Empty_Title"]</h2>
            <p>@Localizer["Events_Empty_Message"]</p>
            <button id="customer-events-empty-clear-btn" class="btn btn-primary" @onclick="ClearFilters">@Localizer["Events_ClearFiltersButton"]</button>
        </div>
    }
    else
    {
        <div id="customer-events-list" class="evl-list">
            @foreach (var evt in events)
            {
                var avail = evt.AvailableSeats;
                var isSoldOut = avail <= 0;
                var isSellingFast = avail > 0 && avail <= 50;
                <button id="customer-events-card-@evt.Id" class="evl-card @(isSoldOut ? "sold" : "")"
                        @onclick="() => ViewEventDetails(evt.Id)" disabled="@isSoldOut">
                    <div id="customer-events-card-date-@evt.Id" class="evl-date">
                        <span class="d">@evt.EventDate.ToString("dd")</span>
                        <span class="m">@MonthHr(evt.EventDate)</span>
                    </div>
                    <div id="customer-events-card-main-@evt.Id" class="evl-main">
                        <span id="customer-events-card-name-@evt.Id" class="evl-name">@evt.EventName</span>
                        <span id="customer-events-card-when-@evt.Id" class="evl-when">@evt.EventDate.ToString("dd.MM.yyyy · HH:mm")</span>
                        <div class="evl-tags">
                            <span class="evl-tag">@evt.EventType</span>
                            @if (isSoldOut)
                            {
                                <span class="evl-tag is-none">@Localizer["Events_SoldOut"]</span>
                            }
                            else if (isSellingFast)
                            {
                                <span class="evl-tag is-low">@Localizer["Events_SellingFast", avail]</span>
                            }
                            else
                            {
                                <span class="evl-tag is-ok">@Localizer["Events_Available", avail]</span>
                            }
                        </div>
                    </div>
                    <div id="customer-events-card-right-@evt.Id" class="evl-right">
                        <span class="evl-price tnum">€@evt.BaseTicketPrice.ToString("F0")</span>
                        <span class="evl-chev">›</span>
                    </div>
                </button>
            }
        </div>
    }
</div>

@code {
    private List<CustomerEventDto>? events;
    private bool isLoading = false;
    private bool showFilters = false;
    private bool salesEnabled = true;

    private string filterEventType = "";
    private DateTime? filterDateFrom;
    private DateTime? filterDateTo;
    private decimal? filterMinPrice;
    private decimal? filterMaxPrice;

    private static readonly string[] MonthsHr =
        { "sij", "velj", "ožu", "tra", "svi", "lip", "srp", "kol", "ruj", "lis", "stu", "pro" };
    private static string MonthHr(DateTime d) => MonthsHr[d.Month - 1];

    private int activeFilterCount =>
        (string.IsNullOrEmpty(filterEventType) ? 0 : 1)
        + (filterDateFrom.HasValue ? 1 : 0)
        + (filterDateTo.HasValue ? 1 : 0)
        + (filterMinPrice.HasValue ? 1 : 0)
        + (filterMaxPrice.HasValue ? 1 : 0);

    protected override async Task OnInitializedAsync()
    {
        salesEnabled = await ApiService.GetTicketSalesEnabledAsync();
        await LoadEvents();
    }

    private async Task LoadEvents()
    {
        isLoading = true;
        try
        {
            var filter = new CustomerEventFilterDto
            {
                EventType = string.IsNullOrEmpty(filterEventType) ? null : filterEventType,
                DateFrom = filterDateFrom,
                DateTo = filterDateTo,
                MinPrice = filterMinPrice,
                MaxPrice = filterMaxPrice
            };

            events = await ApiService.GetAvailableEventsAsync(filter);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading events: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApplyFilters()
    {
        showFilters = false;
        await LoadEvents();
    }

    private async Task ClearFilters()
    {
        filterEventType = "";
        filterDateFrom = null;
        filterDateTo = null;
        filterMinPrice = null;
        filterMaxPrice = null;
        await LoadEvents();
    }

    private void ViewEventDetails(int eventId) => Navigation.NavigateTo($"/events/{eventId}");
}
