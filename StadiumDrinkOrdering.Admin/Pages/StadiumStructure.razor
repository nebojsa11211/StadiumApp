@page "/admin/stadium-structure"
@using StadiumDrinkOrdering.Shared.DTOs
@using StadiumDrinkOrdering.Shared.Models
@using StadiumDrinkOrdering.Admin.Services
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Structure_PageTitle"]</PageTitle>

<div class="console" id="admin-stadium-structure-main-container">
    <!-- Page Header -->
    <header class="console-head">
        <div class="console-head__title">
            <span class="eyebrow">@L["Structure_Eyebrow"]</span>
            <h1>@L["Structure_Heading"]</h1>
            <p>@L["Structure_Subtitle"]</p>
        </div>
        <div class="console-head__actions">
            <a href="/admin/structure-help" class="pill-btn">
                <i class="fas fa-question-circle"></i><span>@L["Structure_HelpLink"]</span>
            </a>
        </div>
    </header>

    <!-- Import Structure -->
    <div class="panel">
        <div class="panel__head">
            <h2 class="panel__title">@L["Structure_ImportTitle"]</h2>
        </div>
        <div class="panel__body">
            <div class="console-alert console-alert--info">
                <div>
                    <strong>@L["Structure_QuickStart"]</strong>
                    <ul class="mb-0 small mt-1">
                        <li>@L["Structure_QsJsonFile"]</li>
                        <li>@L["Structure_QsTribuneCode"]</li>
                        <li>@L["Structure_QsSectorNeeds"]</li>
                    </ul>
                    <a href="/admin/structure-help" class="link-btn mt-2">
                        <i class="fas fa-external-link-alt"></i> @L["Structure_ViewGuide"]
                    </a>
                </div>
            </div>

            <div class="field" style="margin-bottom:1.25rem;">
                <label class="field__label">@L["Structure_SelectFile"]</label>
                <InputFile OnChange="@HandleFileSelected"
                           accept=".json"
                           class="field__input" />
                @if (selectedFileName != null)
                {
                    <div class="form-text text-success">@L["Structure_SelectedPrefix"] @selectedFileName</div>
                }
            </div>

            @if (!string.IsNullOrEmpty(importError))
            {
                <div class="console-alert console-alert--danger">
                    <span><strong>@L["Structure_ImportErrorPrefix"]</strong> @importError</span>
                </div>
            }

            <div class="console-alert console-alert--info">
                <span><strong>@L["Structure_ImportWarning"]</strong></span>
            </div>

            <button type="button"
                    class="pill-btn pill-btn--primary"
                    disabled="@(selectedFile == null || isImporting)"
                    @onclick="ImportStructure"
                    id="admin-stadium-import-btn">
                @if (isImporting)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    <text>@L["Structure_Importing"]</text>
                }
                else
                {
                    <i class="fas fa-upload"></i>
                    <text>@L["Structure_ImportButton"]</text>
                }
            </button>
        </div>
    </div>

    <!-- Current Structure -->
    <div class="panel">
        <div class="panel__head">
            <h2 class="panel__title">@L["Structure_CurrentStructure"]</h2>
        </div>
        <div class="panel__body">
            @if (summary != null)
            {
                <section class="metrics metrics--3">
                    <article class="metric">
                        <div class="metric__head">
                            <span class="metric__label">@L["Structure_MetricTribunes"]</span>
                            <i class="fas fa-layer-group metric__icon"></i>
                        </div>
                        <div class="metric__value mono">@summary.TotalTribunes</div>
                    </article>
                    <article class="metric">
                        <div class="metric__head">
                            <span class="metric__label">@L["Structure_MetricRings"]</span>
                            <i class="fas fa-circle-notch metric__icon"></i>
                        </div>
                        <div class="metric__value mono">@summary.TotalRings</div>
                    </article>
                    <article class="metric">
                        <div class="metric__head">
                            <span class="metric__label">@L["Structure_MetricSectors"]</span>
                            <i class="fas fa-th metric__icon"></i>
                        </div>
                        <div class="metric__value mono">@summary.TotalSectors</div>
                    </article>
                    <article class="metric">
                        <div class="metric__head">
                            <span class="metric__label">@L["Structure_MetricTotalSeats"]</span>
                            <i class="fas fa-chair metric__icon"></i>
                        </div>
                        <div class="metric__value mono">@summary.TotalSeats</div>
                    </article>
                    <article class="metric metric--accent">
                        <div class="metric__head">
                            <span class="metric__label">@L["Structure_MetricAvailable"]</span>
                            <i class="fas fa-check metric__icon is-ok"></i>
                        </div>
                        <div class="metric__value mono">@summary.AvailableSeats</div>
                    </article>
                    <article class="metric">
                        <div class="metric__head">
                            <span class="metric__label">@L["Structure_MetricOccupied"]</span>
                            <i class="fas fa-user metric__icon"></i>
                        </div>
                        <div class="metric__value mono">@summary.OccupiedSeats</div>
                    </article>
                </section>
            }
            else if (isLoadingSummary)
            {
                <div class="loading-state">
                    <span class="loading-spinner"></span>
                    <p>@L["Structure_Loading"]</p>
                </div>
            }
            else
            {
                <div class="empty">
                    <i class="fas fa-stadium"></i>
                    <p>@L["Structure_NoData"]</p>
                    <span>@L["Structure_EmptyStateText"]</span>
                </div>
            }

            <div class="console-head__actions" style="margin-top:1.5rem; flex-wrap:wrap;">
                <button class="pill-btn pill-btn--danger"
                        @onclick="ShowClearConfirmation"
                        disabled="@(summary == null || summary.TotalSeats == 0)"
                        id="admin-stadium-clear-btn">
                    <i class="fas fa-trash"></i><span>@L["Structure_ClearButton"]</span>
                </button>

                <button class="pill-btn"
                        @onclick="ExportStructure"
                        disabled="@(summary == null || summary.TotalSeats == 0 || isExporting)"
                        id="admin-stadium-export-btn">
                    @if (isExporting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <text>@L["Structure_Exporting"]</text>
                    }
                    else
                    {
                        <i class="fas fa-download"></i><text>@L["Structure_ExportButton"]</text>
                    }
                </button>

                <button class="pill-btn"
                        @onclick="RefreshCache"
                        disabled="@isRefreshingCache"
                        id="admin-stadium-refresh-cache-btn"
                        title="@L["Structure_RefreshTooltip"]">
                    @if (isRefreshingCache)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <text>@L["Structure_Refreshing"]</text>
                    }
                    else
                    {
                        <i class="fas fa-sync-alt"></i><text>@L["Structure_RefreshButton"]</text>
                    }
                </button>
            </div>
        </div>
    </div>

    @if (importSuccess)
    {
        <div class="console-alert console-alert--success">
            <i class="fas fa-check-circle"></i>
            <div>
                <strong>@L["Structure_ImportSuccessHeading"]</strong>
                <span> @L["Structure_ImportSuccessText"] @importMessage</span>
            </div>
            <button type="button" class="icon-btn" style="margin-left:auto;" @onclick="() => importSuccess = false" id="admin-stadium-success-close-btn">
                <i class="fas fa-times"></i>
            </button>
        </div>
    }
</div>

<!-- Clear Confirmation Modal -->
@if (showClearModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@L["Structure_ConfirmDeleteTitle"]</h5>
                    <button type="button" class="btn-close" @onclick="HideClearConfirmation" id="admin-stadium-clear-modal-close-btn"></button>
                </div>
                <div class="modal-body">
                    <p>@L["Structure_ConfirmDeleteText"]</p>
                    <p class="text-danger"><strong>@L["Structure_ConfirmCannotUndo"]</strong></p>
                    @if (summary != null)
                    {
                        <div class="console-alert console-alert--info">
                            <span>
                                @L["Structure_ConfirmRemovePrefix"] <strong>@summary.TotalSeats @L["Structure_SeatsLabel"]</strong> @L["Structure_ConfirmRemoveMiddle"]
                                <strong>@summary.TotalSectors @L["Structure_SectorsLabel"]</strong> @L["Structure_ConfirmRemoveEnd"]
                                <strong>@summary.TotalTribunes @L["Structure_TribunesLabel"]</strong>.
                            </span>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="pill-btn" @onclick="HideClearConfirmation" id="admin-stadium-clear-cancel-btn">
                        <span>@L["Structure_CancelButton"]</span>
                    </button>
                    <button type="button" class="pill-btn pill-btn--danger" @onclick="ClearStructure" disabled="@isClearing" id="admin-stadium-clear-confirm-btn">
                        @if (isClearing)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <text>@L["Structure_Deleting"]</text>
                        }
                        else
                        {
                            <i class="fas fa-trash"></i><text>@L["Structure_DeleteButton"]</text>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}
