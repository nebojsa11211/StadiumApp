<div class="alert alert-secondary mt-4" id="staff-survey-prompt">
    <span class="oi oi-pencil me-2" aria-hidden="true" id="staff-survey-prompt-icon"></span>
    <strong id="staff-survey-prompt-title">@Title</strong>

    <span class="text-nowrap" id="staff-survey-prompt-text">
        Please take our
        <a target="_blank" class="font-weight-bold link-dark" id="staff-survey-prompt-link" href="https://go.microsoft.com/fwlink/?linkid=2186158">brief survey</a>
    </span>
    and tell us what you think.
</div>

@code {
    // Demonstrates how a parent component can supply parameters
    [Parameter]
    public string? Title { get; set; }
}
