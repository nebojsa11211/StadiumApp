@using StadiumDrinkOrdering.Shared.Models
@inject IStringLocalizer<SharedResources> L

<div class="sector-modal-overlay"
     id="sector-detail-modal-overlay"
     @onclick="HandleOverlayClick"
     @onkeydown="HandleModalKeyDown"
     tabindex="-1">
    <div class="sector-modal"
         id="sector-detail-modal"
         @onclick:stopPropagation
         @ref="modalElement"
         role="dialog"
         aria-modal="true"
         aria-labelledby="sector-modal-title">
        <div class="sector-modal-header" id="sector-detail-modal-header">
            <h3 id="sector-modal-title" class="sector-modal-title">@SectorName</h3>
            <button class="sector-modal-close"
                    id="sector-detail-modal-close-btn"
                    @onclick="OnClose"
                    @ref="closeButtonElement"
                    aria-label="Close modal">
                ×
            </button>
        </div>

        <div class="sector-modal-body" id="sector-detail-modal-body">
            @if (isLoading)
            {
                <div class="stadium-loading" id="sector-detail-modal-loading">
                    <div class="loading-spinner" id="sector-detail-modal-spinner"></div>
                    <p>@L["SectorDetail_Loading"]</p>
                </div>
            }
            else if (Seats != null && Seats.Any())
            {
                <div class="sector-info" id="sector-detail-modal-info">
                    <p><strong>@L["SectorDetail_TotalSeatsLabel"]:</strong> @Seats.Count()</p>
                    <p><strong>@L["SectorDetail_ActiveLabel"]:</strong> <span style="color: #22c55e;">@Seats.Count(s => s.IsActive)</span></p>
                    <p><strong>@L["SectorDetail_InactiveLabel"]:</strong> <span style="color: #ef4444;">@Seats.Count(s => !s.IsActive)</span></p>
                </div>

                <div class="seat-grid" id="sector-detail-modal-grid">
                    @foreach (var seat in Seats.OrderBy(s => s.RowNumber).ThenBy(s => s.SeatNumber))
                    {
                        <div class="seat @GetSeatClass(seat)"
                             id="@($"sector-detail-modal-seat-{seat.Id}")"
                             title="@L["SectorDetail_SeatTooltip", seat.RowNumber, seat.SeatNumber]"
                             @onclick="() => HandleSeatClick(seat)">
                            @seat.SeatNumber
                        </div>
                    }
                </div>
            }
            else
            {
                <p>@L["SectorDetail_NoSeats"]</p>
            }
        </div>
    </div>
</div>

@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime

@code {
    [Parameter]
    public string SectorCode { get; set; } = string.Empty;

    [Parameter]
    public string SectorName { get; set; } = string.Empty;

    [Parameter]
    public List<StadiumSeat>? Seats { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback<StadiumSeat> OnSeatClick { get; set; }

    private bool isLoading = false;
    private ElementReference modalElement;
    private ElementReference closeButtonElement;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Set focus to close button when modal opens (focus trap entry point)
            try
            {
                await closeButtonElement.FocusAsync();
            }
            catch
            {
                // Ignore focus errors during prerendering
            }
        }
    }

    private async Task HandleModalKeyDown(KeyboardEventArgs e)
    {
        // Handle Escape key to close modal
        if (e.Key == "Escape")
        {
            await OnClose.InvokeAsync();
        }

        // Handle Tab key for focus trap (basic implementation)
        if (e.Key == "Tab")
        {
            // Focus trap implementation would go here
            // For now, the browser handles tab focus within modal
        }
    }

    private string GetSeatClass(StadiumSeat seat)
    {
        if (!seat.IsActive)
            return "occupied";

        // Add selected class if seat is selected (future enhancement)
        return "available";
    }

    private async Task HandleSeatClick(StadiumSeat seat)
    {
        if (seat.IsActive)
        {
            await OnSeatClick.InvokeAsync(seat);
        }
    }

    private async Task HandleOverlayClick()
    {
        await OnClose.InvokeAsync();
    }
}
